---
import ProtoLayout from '../../layouts/ProtoLayout.astro';

const exchange = {
  name: 'Bybit',
  slug: 'bybit',
  logo: '/logos/bybit.png',
  promoCode: 'CRYPTOBONUSW',
  affiliateUrl: 'https://partner.bybit.com/b/CRYPTOBONUSW',
  bonusMax: 30000,
  bonusTypicalMin: 200,
  bonusTypicalMax: 600,
  currency: 'USDT',
  minDeposit: 100,
  founded: 2018,
  users: '30M+',
  headquarters: 'Dubai, UAE',
  licence: 'Dubai VARA',
  kycRequired: true,
  depositRequired: true,
  spotFee: 0.1,
  futuresMakerFee: 0.01,
  futuresTakerFee: 0.06,
  lastVerified: '2026-06-11',
  excludedCountries: ['US', 'UK', 'Canada'],
};

const alternatives = [
  { name: 'MEXC', slug: 'mexc', logo: '/logos/mexc.png', bonus: '8,000 USDT', code: 'mexc-CryptoBonus', url: 'https://www.mexc.com/acquisition/custom-sign-up?shareCode=mexc-CryptoBonus', tag: 'No KYC option' },
  { name: 'Bitget', slug: 'bitget', logo: '/logos/bitget.png', bonus: '6,200 USDT', code: 'CryptoBonW', url: 'https://partner.bitget.com/bg/CryptoBonW', tag: 'Copy trading' },
  { name: 'BingX', slug: 'bingx', logo: '/logos/bingx.png', bonus: '5,125 USDT', code: 'CRYPTOBONUSWORLD', url: 'https://bingxdao.com/partner/CRYPTOBONUSWORLD/', tag: 'Social trading' },
];

// Ordered proof flow: referral → registration → bonus → KYC → deposit
const proofScreenshots = [
  {
    slot: 'bonus_referral_landing',
    title: 'Referral Landing Page',
    path: '/screenshots/bybit/bonus_referral_landing/global-desktop-2026-06.webp',
    status: 'available',
    caption: 'Confirms code CRYPTOBONUSW is accepted. Page states "Unlock up to $30,020 in exclusive rewards."',
    verified: '2026-06-11',
  },
  {
    slot: 'registration',
    title: 'Sign-Up Form — Code Accepted',
    path: '/screenshots/bybit/registration/global-desktop-2026-06.webp',
    status: 'available',
    caption: 'Registration panel showing CRYPTOBONUSW pre-filled and confirmed (✓) in the Referral Code field.',
    verified: '2026-06-11',
  },
  {
    slot: 'bonus',
    title: 'Reward Tiers Chart',
    path: '/screenshots/bybit/bonus/global-desktop-2026-06.webp',
    status: 'available',
    caption: 'Full deposit-tier bonus chart: $50 → $100 → $800 → $8,800 → $30,000 tiers based on deposit + trading volume.',
    verified: '2026-06',
  },
  {
    slot: 'kyc',
    title: 'KYC Verification',
    path: '/screenshots/bybit/kyc/global-desktop-2026-06.webp',
    status: 'available',
    caption: 'KYC identity verification screen — required before any bonus can be claimed.',
    verified: '2026-06',
  },
  {
    slot: 'deposit',
    title: 'Deposit / Funding',
    path: '/screenshots/bybit/deposit/global-desktop-2026-06.webp',
    status: 'available',
    caption: 'Assets and deposit screen — funding the account to unlock deposit-tier rewards.',
    verified: '2026-06',
  },
  {
    slot: 'fees',
    title: 'Fee Schedule',
    path: null,
    status: 'needs_manual_capture',
    caption: 'Fee schedule page — pending manual screenshot capture.',
    verified: null,
  },
];

const pendingProof = proofScreenshots.filter(s => s.status === 'needs_manual_capture');

// ─── Brand Hero Token Object ─────────────────────────────────────
// Swap these values per exchange to retheme the hero section.
// bgFrom / bgTo  → gradient (dark on dark works best)
// accent         → exchange brand highlight (Bybit = yellow #f7a600)
// codeBg/Border  → code field treatment
// Future:  Binance accent=#F0B90B  |  MEXC accent=#20B26C bg=#1A2332
//          Phemex accent=#00B4A0   |  OKX accent=#0A74F5 bg=#0A0C12
const brandHeroTokens = {
  'bh-bgFrom':     '#0d1117',
  'bh-bgTo':       '#1a1f2e',
  'bh-text':       '#ffffff',
  'bh-text2':      'rgba(255,255,255,0.65)',
  'bh-accent':     '#f7a600',
  'bh-codeBg':     'rgba(247,166,0,0.10)',
  'bh-codeBorder': 'rgba(247,166,0,0.40)',
  'bh-note':       'rgba(255,255,255,0.38)',
};
const bhStyle = Object.entries(brandHeroTokens).map(([k,v]) => `--${k}:${v}`).join(';');
---

<ProtoLayout
  title="Bybit Referral Code 2026: CRYPTOBONUSW — Up to 30,000 USDT"
  description="Bybit referral code CRYPTOBONUSW — up to 30,000 USDT welcome bonus. Verified June 2026."
  noindex={true}
  ogImage="/media/exchanges/bybit/share/bybit-og-1200x630.png"
  ogTitle="Bybit Referral Code 2026: CRYPTOBONUSW"
  ogDescription="Use CRYPTOBONUSW to claim Bybit new user rewards. Source checked June 2026."
  ogUrl="https://cryptobonusworld.com/prototype/bybit-light/"
>

<style>
  /* ─── Reset + base ─────────────────────────────────────────── */
  html, body { background: #F7F8F4 !important; color: #111827 !important; color-scheme: light !important; }

  /* ─── Layout ───────────────────────────────────────────────── */
  .container { max-width: 760px; margin: 0 auto; padding: 0 20px; }
  .section { padding: 40px 0; background: var(--proto-bg); }
  .section + .section { border-top: 1px solid var(--proto-border); }

  /* ─── Title bar (light, centered, above dark hero) ───────── */
  /* padding arithmetic: 13+h1(25)+13+border(1) = 52px desktop; 14+h1(22)+14+1 = 51px mobile */
  .title-bar {
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    border-bottom: 1px solid var(--proto-border);
    text-align: center; padding: 13px 20px;
    color-scheme: light; forced-color-adjust: none;
  }
  .title-bar h1 {
    font-size: 20px; font-weight: 700; color: var(--proto-text);
    margin: 0; line-height: 1.25;
  }
  @media (max-width: 479px) {
    .title-bar { padding: 14px 20px; }
    .title-bar h1 { font-size: 18px; }
  }

  /* ─── Brand Hero ─────────────────────────────────────────────
     Tokens: --bh-bgFrom  --bh-bgTo  --bh-text  --bh-text2
             --bh-accent  --bh-codeBg  --bh-codeBorder  --bh-note
     Swap tokens per exchange to retheme.
  ──────────────────────────────────────────────────────────── */
  .brand-hero {
    background: linear-gradient(160deg, var(--bh-bgFrom) 0%, var(--bh-bgTo) 100%);
    padding: 26px 0 11px;
    color: var(--bh-text);
  }
  @media (min-width: 640px) { .brand-hero { padding: 31px 0 8px; } }
  /* ─── Unified top column — 540px shared across hero / table / cta ── */
  .bh-inner { max-width: 540px; margin: 0 auto; padding: 0 20px; text-align: center; }

  /* Wordmark — competitor-matched proportions */
  .bh-wordmark { display: block; width: 165px; height: auto; margin: 0 auto 10px; filter: none; opacity: 1; }
  @media (min-width: 640px) { .bh-wordmark { width: 210px; } }
  @media (max-width: 359px) { .bh-wordmark { width: 140px; } }

  /* Promo-code label */
  .bh-promo-label {
    display: block;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 16px; font-weight: 700; text-transform: uppercase;
    font-stretch: condensed;
    letter-spacing: 0.09em; color: var(--bh-text);
    line-height: 1.1;
    margin-top: 16px; margin-bottom: 24px;
  }
  @media (min-width: 640px) { .bh-promo-label { font-size: 18px; letter-spacing: 0.10em; margin-top: 18px; margin-bottom: 26px; } }

  /* ── Promo module: code field 272px, CTA 312px ── */
  .bh-promo-row {
    width: 100%;
    max-width: 272px;
    margin-left: auto;
    margin-right: auto;
  }
  .bh-cta-btn {
    width: 100%;
    max-width: 312px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Promo code field — white default, green only on copy success */
  .bh-promo-row {
    display: flex; align-items: stretch;
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    border: 1px solid #D1D5DB;
    border-radius: 8px; overflow: hidden;
    height: 56px; margin-bottom: 14px;
    transition: border-color .18s, background .18s;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-promo-row.copy-success {
    border-color: #22c55e !important;
    background: #dcfce7 !important;
  }
  .bh-promo-code {
    flex: 1; display: flex; align-items: center; padding: 0 14px;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 20px; font-weight: 800; letter-spacing: 0.01em;
    font-stretch: condensed;
    text-transform: uppercase;
    color: #111827; -webkit-text-fill-color: #111827;
    min-width: 0; overflow: hidden;
    white-space: nowrap; text-overflow: ellipsis;
    transition: color .18s;
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .bh-promo-code { font-size: 22px; letter-spacing: 0.015em; } }
  .bh-promo-code.copy-success { color: #166534 !important; -webkit-text-fill-color: #166534 !important; }
  /* Fixed width prevents layout jump between "Copy" and "Copied ✓" */
  .bh-copy-btn {
    flex-shrink: 0; width: 68px;
    display: flex; align-items: center; justify-content: center;
    border: none; border-left: 1px solid #e5e7eb;
    font-size: 12px; font-weight: 700; color: #16a34a; -webkit-text-fill-color: #16a34a;
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap; letter-spacing: .03em;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-copy-btn:hover { background: #f0fdf4; }
  .bh-copy-btn.copy-success {
    background: #dcfce7 !important;
    border-color: #22c55e !important;
    color: #166534 !important;
  }

  /* CTA — competitor-scale: large text, slightly wider than code field */
  .bh-cta-btn {
    display: flex; align-items: center; justify-content: center;
    background: #16a34a; color: #fff;
    font-size: 24px; font-weight: 700; border-radius: 6px;
    height: 62px; margin-bottom: 12px;
    transition: background .15s, transform .1s; letter-spacing: 0;
  }
  @media (min-width: 640px) { .bh-cta-btn { font-size: 28px; } }
  .bh-cta-btn:hover { background: #15803d; transform: translateY(-1px); }

  /* Under-CTA 2-line info block */
  .bh-source {
    font-size: 14px; color: var(--bh-note); line-height: 1.65;
    margin: 8px 0 0; text-align: center;
  }
  @media (min-width: 640px) { .bh-source { font-size: 15px; } }
  .bh-source a {
    color: var(--bh-note); text-decoration: underline;
    text-underline-offset: 2px; text-decoration-color: rgba(255,255,255,0.35);
  }
  .bh-source a:hover { text-decoration-color: var(--bh-note); }

  /* ─── Compact facts table (light, right below hero) ─────── */
  .compact-facts {
    background: #ffffff !important; border-bottom: 1px solid #E5E7EB;
    padding: 20px 16px; color-scheme: light; forced-color-adjust: none;
  }
  .cf-inner {
    max-width: 100%;
    margin: 0 auto; padding: 0;
    background: #ffffff;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    overflow: hidden;
  }
  @media (min-width: 720px) { .cf-inner { max-width: 720px; } }
  /* table-layout:fixed + word-wrap = clean 2-col on all screens, no overflow */
  .cf-table { width: 100%; border-collapse: collapse; font-size: 14px; background: #ffffff; table-layout: fixed; }
  .cf-table tr { border-bottom: 1px solid #E5E7EB; background: #ffffff !important; }
  .cf-table tr:last-child { border-bottom: none; }
  .cf-table td { padding: 11px 16px; vertical-align: middle; background: #ffffff; color: #111827; word-wrap: break-word; overflow-wrap: break-word; }
  /* mobile: 43% label / 57% value — labels stay readable, long values wrap */
  .cf-table td:first-child { color: #9CA3AF !important; font-size: 13px; width: 43%; }
  .cf-table td:last-child { font-weight: 600; color: #111827 !important; }
  @media (max-width: 479px) {
    .cf-table td { padding: 10px 12px; font-size: 13px; }
    .cf-table td:first-child { font-size: 12px; }
  }
  .cf-code { font-family: 'Courier New', monospace; letter-spacing: .04em; color: #c47f00 !important; -webkit-text-fill-color: #c47f00 !important; }
  .cf-good { color: #16a34a !important; -webkit-text-fill-color: #16a34a !important; }
  .cf-warn { color: #b45309 !important; -webkit-text-fill-color: #b45309 !important; font-weight: 500 !important; }

  /* ─── Post-table CTA block ───────────────────────────────── */
  /* Desktop: large top pad forces button below the fold (one-CTA rule) */
  .post-table-cta {
    background: var(--proto-surface-2); border-bottom: 1px solid var(--proto-border);
    padding: 24px 0;
  }
  @media (min-width: 640px) { .post-table-cta { padding-top: 180px; } }
  .ptc-inner { max-width: 540px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .ptc-intro { font-size: 13.5px; color: var(--proto-text-2); line-height: 1.6; margin-bottom: 14px; }
  .ptc-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: #16a34a; color: #fff;
    font-size: 15px; font-weight: 700; border-radius: 10px;
    padding: 0 28px; height: 48px;
    width: 100%; max-width: 310px;
    transition: background .15s, transform .1s; letter-spacing: .01em;
  }
  .ptc-btn:hover { background: #15803d; transform: translateY(-1px); }

  /* ─── Shared buttons (final-cta and any light-section use) ── */
  .btn-primary {
    display: flex; align-items: center; justify-content: center;
    background: var(--proto-cta); color: #fff;
    font-size: 16px; font-weight: 700; border-radius: 12px;
    padding: 0 24px; height: 46px; width: 100%;
    transition: background .15s, transform .1s; letter-spacing: .01em; text-align: center;
  }
  .btn-primary:hover { background: var(--proto-cta-hover); transform: translateY(-1px); }
  @media (max-width: 479px) { .btn-primary { height: 48px; } }
  @media (min-width: 960px) { .btn-primary { width: auto; min-width: 200px; max-width: 260px; } }

  /* ─── Section headings ─────────────────────────────────────── */
  h2.section-title { font-size: 20px; font-weight: 700; color: var(--proto-text); margin-bottom: 16px; line-height: 1.3; }

  /* ─── Card ─────────────────────────────────────────────────── */
  .card { background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius); padding: 20px; box-shadow: var(--proto-shadow); }

  /* .fact-yes / .fact-warn used in lower sections */
  .fact-yes { color: var(--proto-verified); }
  .fact-warn { color: var(--proto-warning); }

  /* ─── Steps ─────────────────────────────────────────────────── */
  .steps { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .step { display: flex; gap: 14px; align-items: flex-start; }
  .step-num { flex-shrink: 0; width: 28px; height: 28px; background: var(--proto-accent); color: #1a1a18; font-size: 13px; font-weight: 700; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
  .step-text { font-size: 14px; line-height: 1.55; color: var(--proto-text); }
  .step-text strong { font-weight: 600; }

  /* ─── Conditions table ────────────────────────────────────── */
  .conditions-wrap { overflow-x: auto; }
  .conditions-table { width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 440px; }
  .conditions-table thead { background: var(--proto-surface-2); }
  .conditions-table th { padding: 9px 12px; text-align: left; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; color: var(--proto-text-3); border-bottom: 1px solid var(--proto-border); }
  .conditions-table td { padding: 10px 12px; border-bottom: 1px solid var(--proto-border); color: var(--proto-text); line-height: 1.4; background: var(--proto-surface); }
  .conditions-table tr:last-child td { border-bottom: none; }
  .cond-required { color: var(--proto-warning); font-weight: 500; }
  .cond-ok { color: var(--proto-verified); font-weight: 500; }
  .cond-note { font-size: 12px; color: var(--proto-text-3); margin-top: 3px; }

  /* ─── Realistic value ────────────────────────────────────── */
  .value-grid { display: grid; gap: 12px; }
  @media (min-width: 480px) { .value-grid { grid-template-columns: 1fr 1fr; } }
  .value-card { border: 1px solid var(--proto-border); border-radius: var(--proto-radius); padding: 16px; background: var(--proto-surface); }
  .value-card.highlight { border-color: var(--proto-verified); background: var(--proto-verified-light); }
  .value-card-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--proto-text-3); margin-bottom: 6px; }
  .value-card-amount { font-size: 22px; font-weight: 700; color: var(--proto-text); margin-bottom: 4px; }
  .value-card-amount.green { color: var(--proto-verified); }
  .value-card-desc { font-size: 13px; color: var(--proto-text-2); line-height: 1.45; }

  /* ─── Availability ───────────────────────────────────────── */
  .availability-box { background: var(--proto-warning-light); border: 1px solid #fcd34d; border-radius: var(--proto-radius); padding: 16px 20px; font-size: 14px; color: var(--proto-text); line-height: 1.55; }
  .availability-box strong { display: block; margin-bottom: 6px; color: var(--proto-warning); font-size: 13px; text-transform: uppercase; letter-spacing: .04em; }
  .excluded-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .excluded-chip { background: #fff; border: 1px solid #fcd34d; border-radius: 6px; padding: 3px 10px; font-size: 12px; font-weight: 500; color: var(--proto-warning); }

  /* ─── Verdict ────────────────────────────────────────────── */
  .verdict-grid { display: grid; gap: 12px; }
  @media (min-width: 500px) { .verdict-grid { grid-template-columns: 1fr 1fr; } }
  .verdict-card { border-radius: var(--proto-radius); padding: 16px 18px; font-size: 14px; line-height: 1.55; }
  .verdict-card.worth-it { background: var(--proto-verified-light); border: 1px solid #86efac; }
  .verdict-card.not-ideal { background: #fff7f7; border: 1px solid #fca5a5; }
  .verdict-card-head { font-weight: 600; font-size: 13px; margin-bottom: 8px; }
  .verdict-card.worth-it .verdict-card-head { color: var(--proto-verified); }
  .verdict-card.not-ideal .verdict-card-head { color: var(--proto-danger); }
  .verdict-card ul { padding-left: 16px; }
  .verdict-card li { margin-bottom: 5px; }

  /* ─── Mini review ────────────────────────────────────────── */
  .mini-review { font-size: 14px; line-height: 1.7; color: var(--proto-text); }
  .mini-review p { margin-bottom: 12px; }
  .mini-review p:last-child { margin-bottom: 0; }

  /* ─── Alternatives ───────────────────────────────────────── */
  .alt-grid { display: flex; flex-direction: column; gap: 10px; }
  .alt-card { display: flex; align-items: center; gap: 14px; background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius); padding: 14px 16px; transition: border-color .15s; }
  .alt-card:hover { border-color: var(--proto-border-strong); }
  .alt-logo { width: 36px; height: 36px; border-radius: 8px; object-fit: contain; border: 1px solid var(--proto-border); padding: 4px; flex-shrink: 0; background: #fff; }
  .alt-info { flex: 1; min-width: 0; }
  .alt-name { font-weight: 600; font-size: 14px; color: var(--proto-text); }
  .alt-bonus { font-size: 13px; color: var(--proto-text-2); }
  .alt-tag { font-size: 11px; color: var(--proto-text-3); margin-top: 2px; }
  .alt-btn { flex-shrink: 0; background: var(--proto-surface-2); border: 1px solid var(--proto-border); border-radius: 8px; padding: 7px 14px; font-size: 13px; font-weight: 500; color: var(--proto-text); transition: background .15s; }
  .alt-btn:hover { background: var(--proto-border); }

  /* ─── FAQ ────────────────────────────────────────────────── */
  details.faq-item { border: 1px solid var(--proto-border); border-radius: var(--proto-radius); margin-bottom: 8px; background: var(--proto-surface); overflow: hidden; }
  details.faq-item[open] { border-color: var(--proto-border-strong); }
  summary.faq-q { padding: 14px 16px; font-size: 14px; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: var(--proto-text); user-select: none; }
  summary.faq-q::-webkit-details-marker { display: none; }
  summary.faq-q::after { content: '+'; font-size: 18px; font-weight: 400; color: var(--proto-text-3); flex-shrink: 0; margin-left: 12px; }
  details[open] summary.faq-q::after { content: '−'; }
  .faq-a { padding: 12px 16px 14px; font-size: 13.5px; color: var(--proto-text-2); line-height: 1.6; border-top: 1px solid var(--proto-border); }

  /* ─── Final CTA ──────────────────────────────────────────── */
  .final-cta { background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius-lg); padding: 28px 24px; text-align: center; box-shadow: var(--proto-shadow-md); }
  .final-cta-logo { width: 44px; height: 44px; border-radius: 10px; border: 1px solid var(--proto-border); padding: 5px; margin: 0 auto 12px; object-fit: contain; background: #fff; }
  .final-cta-amount { font-size: 28px; font-weight: 700; color: var(--proto-text); margin-bottom: 4px; }
  .final-cta-typical { font-size: 13px; color: var(--proto-text-3); margin-bottom: 20px; }
  .final-cta-disclaimer { font-size: 12px; color: var(--proto-text-3); margin-top: 14px; line-height: 1.5; }

  /* ─── In-article banner CTA ─────────────────────────────── */
  .article-banner {
    display: block; border-radius: var(--proto-radius); overflow: hidden;
    margin: 28px 0 0;
    box-shadow: var(--proto-shadow-md);
    transition: transform .15s, box-shadow .15s;
  }
  .article-banner:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
  .article-banner-img { width: 100%; height: auto; display: block; }
  .article-banner-cap {
    font-size: 12px; color: var(--proto-text-3); text-align: center;
    margin: 8px 0 28px; line-height: 1.4;
  }
  .article-banner-cap strong { color: var(--proto-text-2); }

  /* ─── Disclosure ─────────────────────────────────────────── */
