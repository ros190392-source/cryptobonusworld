---
import CleanLayout from '../layouts/CleanLayout.astro';
import ExchangeCard from '../components/home/ExchangeCard.astro';
import HomepageGeoBonusFinder from '../components/home/HomepageGeoBonusFinder.astro';
import { getFeaturedExchanges } from '../data/exchanges';
import { getOffer } from '../data/offers';

const exchanges = getFeaturedExchanges();
const exchangesWithOffers = exchanges.map(ex => ({
  exchange: ex,
  offer: getOffer(ex.slug),
}));

const guideBlocks = [
  {
    h3: 'What is a crypto referral code?',
    p: 'A crypto referral code (also called a promo code or invite code) is a short identifier you enter during sign-up at a crypto exchange. It links your new account to a partner, which can unlock a welcome bonus, fee discount, or other new-user reward that is not available to accounts created without a code.',
  },
  {
    h3: 'How to claim a crypto sign-up bonus',
    p: 'Open the exchange’s official offer page through a verified link, create a new account, and apply the code if it is not already pre-filled. Most exchanges also require identity verification (KYC) and a qualifying deposit before any reward becomes available — complete these steps before making further deposits so you do not miss a bonus tier.',
  },
  {
    h3: 'Why bonus amounts are not guaranteed',
    p: 'Advertised bonus figures are maximum amounts, not typical results. Reaching the full advertised amount usually requires completing several tasks — a deposit above a set threshold, a minimum trading volume, and finishing KYC — within a limited time window, often 30 days. Most users receive a partial reward rather than the headline figure.',
  },
  {
    h3: 'Common bonus requirements',
    p: 'Bonus programs vary by exchange, but frequently include identity verification (KYC), a minimum first deposit, a trading volume milestone, and a deadline to complete all tasks. Some rewards are issued as trading fee vouchers rather than withdrawable cash. Always read the current terms on the exchange’s official page before depositing.',
  },
  {
    h3: 'Referral link vs promo code',
    p: 'A referral link and a promo code often unlock the same offer, but work differently. A referral link usually applies the code automatically when you register through it. A promo code must be entered manually during sign-up, typically in a dedicated field. We list both where available — use the link where possible, and keep the code visible as a backup.',
  },
  {
    h3: 'How CryptoBonusWorld checks exchange codes',
    p: 'We check each listed code and bonus offer directly against the exchange’s own promotions page, not third-party forums or expired affiliate databases. Each exchange page on this site shows the date it was last verified. Promotions change frequently — if something looks outdated, check the individual exchange page for the latest information.',
  },
];

const faqs = [
  {
    q: 'What is a crypto referral code?',
    a: 'It’s a code entered at sign-up that links your account to a partner offer. Applying it can unlock a welcome bonus or fee discount that is not available otherwise. See the guide above for more detail on how these work.',
  },
  {
    q: 'Do I need to enter the code manually?',
    a: 'It depends on the exchange. Some auto-apply the code when you use our link — you just complete registration. Others require you to paste the code into a field during signup. Copy the code before clicking, just in case.',
  },
  {
    q: 'Are crypto exchange bonuses guaranteed?',
    a: 'No. Welcome bonuses are not guaranteed for every user. Advertised amounts are maximums — reaching them typically requires completing multiple tasks such as a deposit, a trading volume milestone, and KYC within a set window. Many users receive a partial bonus. Always read the full terms on the exchange’s official website before depositing.',
  },
  {
    q: 'Why do offers differ by country?',
    a: 'Bonus programs are subject to local regulations, exchange licensing, and KYC requirements. An offer available in one country may be restricted or unavailable in another. Always check the exchange’s terms for your region before signing up.',
  },
  {
    q: 'Are these affiliate links?',
    a: 'Yes. Links marked "Claim Bonus" are affiliate referral links. If you register through one, CryptoBonusWorld may earn a commission from the exchange. This does not cost you anything extra and does not change your bonus. See our affiliate disclosure for details.',
  },
  {
    q: 'Which exchange bonus is best?',
    a: 'There is no single "best" bonus for everyone — it depends on your priorities, such as whether you want to avoid KYC, your region, and how much you plan to deposit. Compare the verified details on each exchange’s page before deciding.',
  },
  {
    q: 'How often are codes checked?',
    a: 'We check each exchange’s promo codes regularly, with the date of the last check shown on each exchange page. Promotions change frequently — if a code looks outdated, check the most recent version on the official exchange website.',
  },
  {
    q: 'Can a code expire?',
    a: 'Yes. Exchanges can change or discontinue a promo code or referral offer at any time, without notice. We recheck listed codes regularly and update or remove them if they stop working. If a code on this site appears expired, check the individual exchange page for the latest version.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<CleanLayout
  title="Crypto Exchange Referral & Bonus Codes 2026 | CryptoBonusWorld"
  description="Verified crypto exchange referral codes and bonus links for Bybit, MEXC, OKX, Bitget, KuCoin, and BingX. Bonus terms, KYC, region, and trading requirements may vary — checked directly against official exchange pages."
  ogImage="/og-default.png"
>

  <!-- 0. Homepage GEO Bonus Finder (above the fold) -->
  <HomepageGeoBonusFinder />

  <!-- 1. Compact intro -->
  <section class="hp-intro">
    <div class="hp-text-wrap">
      <div class="hp-intro-label">Verified · Updated July 2026</div>
      <h2 class="hp-intro-h1">Crypto Sign-Up Bonuses &amp; Referral Codes</h2>
      <p class="hp-intro-sub">
        CryptoBonusWorld tracks verified crypto exchange referral codes and bonus links,
        checked directly against each exchange's official promotions page.
      </p>
      <p class="hp-intro-caveat">
        Bonus availability, KYC, region, deposit, and trading requirements may vary by exchange and account.
      </p>
    </div>
  </section>

  <!-- 2. Trust strip -->
  <div class="trust-bar">
    <div class="hp-text-wrap">
      <div class="trust-bar-inner">
        <span class="tb-item">✓ Codes checked against official exchange pages</span>
        <span class="tb-sep" aria-hidden="true">·</span>
        <span class="tb-item">ⓘ Bonus terms may vary by country and account</span>
        <span class="tb-sep" aria-hidden="true">·</span>
        <span class="tb-item">Affiliate links — <a href="/affiliate-disclosure/" class="tb-link">we may earn a commission</a></span>
      </div>
    </div>
  </div>

  <!-- 3. Featured exchange grid -->
  <section class="section bg-white section-exchange" id="exchanges">
    <div class="hp-directory-wrap">
      <div class="section-label">Featured Exchanges</div>
      <h2 class="section-title">Top Crypto Referral Codes</h2>
      <p class="section-sub">
        Each listing includes the verified promo code, realistic bonus estimate,
        and a direct link to the official offer page.
      </p>
      <div class="exchange-grid">
        {exchangesWithOffers.map(({ exchange, offer }) => (
          <ExchangeCard exchange={exchange} offer={offer} />
        ))}
      </div>
      <p class="grid-coming-soon">More verified exchange codes are being checked.</p>
      <div class="grid-footer">
        <a href="/exchanges/" class="btn-secondary">View All Exchanges →</a>
      </div>
    </div>
  </section>

  <!-- 4. Guide -->
  <section class="section bg-gray" id="guide">
    <div class="hp-text-wrap">
      <div class="section-label">Guide</div>
      <h2 class="section-title">Crypto Exchange Bonuses Guide</h2>
      <div class="guide-list">
        {guideBlocks.map(block => (
          <div class="guide-block">
            <h3 class="guide-h3">{block.h3}</h3>
            <p class="guide-p">{block.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="section bg-white" id="faq">
    <div class="hp-text-wrap">
      <div class="section-label">Common Questions</div>
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(item => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Disclaimer -->
  <div class="disclaimer-bar">
    <div class="hp-text-wrap">
      <p class="disclaimer-text">
        <strong>Disclosure:</strong> CryptoBonusWorld may earn a commission when you register via links on this site.
        This does not affect our editorial assessments or the codes we list.
        Bonus amounts shown are advertised maximums — individual results vary and depend on meeting all exchange requirements.
        Bonus availability and terms can change at any time; verify current conditions on the official exchange website before registering or depositing.
        Cryptocurrency trading carries significant risk. Nothing on this site constitutes financial or investment advice.
      </p>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</CleanLayout>

<style>
  /* ── Width utilities ─────────────────────────────────────────── */
  .hp-text-wrap      { max-width: 800px; margin: 0 auto; padding: 0 20px; box-sizing: border-box; }
  .hp-directory-wrap  { max-width: 960px; margin: 0 auto; padding: 0 20px; box-sizing: border-box; }
  @media (min-width: 820px) {
    .hp-text-wrap, .hp-directory-wrap { padding: 0 32px; }
  }

  .bg-white { background: #fff; }
  .bg-gray  { background: #F7F8F4; }

  /* ── 1. Compact intro ────────────────────────────────────────── */
  .hp-intro { background: #fff; padding: 40px 0 28px; text-align: center; }
  @media (min-width: 820px) { .hp-intro { padding: 56px 0 36px; } }
  .hp-intro-label {
    display: inline-block; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em; color: #F7931A;
    background: rgba(247,147,26,.08); border: 1px solid rgba(247,147,26,.22);
    padding: 4px 12px; border-radius: 20px; margin-bottom: 14px;
  }
  .hp-intro-h1 {
    font-size: clamp(26px, 4.2vw, 38px); font-weight: 800; line-height: 1.15;
    letter-spacing: -.02em; color: #111827; margin-bottom: 12px;
  }
  .hp-intro-sub { font-size: 15px; line-height: 1.65; color: #4B5563; margin-bottom: 8px; }
  .hp-intro-caveat { font-size: 13px; line-height: 1.6; color: #9CA3AF; }

  /* ── 2. Trust strip ──────────────────────────────────────────── */
  .trust-bar { background: #F0FDF4; border-top: 1px solid #D1FAE5; border-bottom: 1px solid #D1FAE5; padding: 10px 0; }
  .trust-bar-inner {
    display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap;
    font-size: 12px; color: #374151; text-align: center;
  }
  .tb-item { display: flex; align-items: center; gap: 4px; white-space: nowrap; }
  .tb-sep { color: #9CA3AF; }
  .tb-link { color: #15803D; font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .tb-link:hover { color: #166534; }

  /* ── 3. Featured exchange grid ───────────────────────────────── */
  .section-exchange { padding: 32px 0 48px; }
  .section-exchange .section-sub { max-width: none; margin-bottom: 20px; }

  .exchange-grid {
    display: grid; gap: 16px;
    grid-template-columns: 1fr;
    margin-bottom: 20px;
  }
  @media (min-width: 640px)  { .exchange-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px)  { .exchange-grid { grid-template-columns: repeat(3, 1fr); } }

  .grid-coming-soon { text-align: center; font-size: 13px; color: #9CA3AF; margin: 8px 0 20px; }
  .grid-footer { text-align: center; }

  /* ── 4. Guide ─────────────────────────────────────────────────── */
  .guide-list { display: flex; flex-direction: column; gap: 26px; margin-top: 8px; }
  .guide-block { }
  .guide-h3 { font-size: 17px; font-weight: 700; color: #111827; margin-bottom: 8px; letter-spacing: -.01em; }
  .guide-p  { font-size: 14.5px; line-height: 1.75; color: #4B5563; }

  /* ── 5. FAQ ───────────────────────────────────────────────────── */
  .faq-list { display: flex; flex-direction: column; gap: 8px; margin-top: 8px; }
  .faq-item { background: #fff; border: 1px solid #E5E7EB; border-radius: 10px; overflow: hidden; }
  .faq-q {
    padding: 16px 20px; font-size: 15px; font-weight: 600; color: #111827;
    cursor: pointer; list-style: none;
    display: flex; align-items: center; justify-content: space-between; user-select: none;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after { content: '+'; font-size: 18px; color: #9CA3AF; }
  details[open] .faq-q::after { content: '−'; }
  .faq-a { padding: 0 20px 16px; font-size: 14px; color: #4B5563; line-height: 1.7; }

  /* ── 6. Disclaimer ────────────────────────────────────────────── */
  .disclaimer-bar {
    background: #F9FAFB; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;
    padding: 20px 0;
  }
  .disclaimer-text { font-size: 12px; color: #6B7280; line-height: 1.7; }
  .disclaimer-text strong { color: #374151; }

  /* ── Shared section header sizing within text-width sections ──── */
  #guide .section-sub, #faq .section-sub { max-width: none; }
</style>
