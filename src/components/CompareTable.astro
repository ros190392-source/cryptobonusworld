---
import CTAButton from './CTAButton.astro';
import KycBadge from './KycBadge.astro';

interface Exchange {
  name: string;
  slug: string;
  rating: number;
  bonusTitle: string;
  bonusAmount: number;
  bonusCurrency: string;
  bonusTypes: string[];
  kycRequired: boolean;
  depositRequired: boolean;
  futuresRequired: boolean;
  paymentMethods: string[];
  affiliateUrl: string;
  shortDescription: string;
}

interface Props {
  exchanges: [Exchange, Exchange];
}

const { exchanges: [a, b] } = Astro.props;

const rows: { label: string; keyA: string; keyB: string }[] = [
  { label: 'Max Bonus', keyA: `${a.bonusAmount.toLocaleString()} ${a.bonusCurrency}`, keyB: `${b.bonusAmount.toLocaleString()} ${b.bonusCurrency}` },
  { label: 'Bonus Type', keyA: a.bonusTypes.join(', '), keyB: b.bonusTypes.join(', ') },
  { label: 'KYC Required', keyA: a.kycRequired ? 'Yes' : 'No', keyB: b.kycRequired ? 'Yes' : 'No' },
  { label: 'Deposit Required', keyA: a.depositRequired ? 'Yes' : 'No', keyB: b.depositRequired ? 'Yes' : 'No' },
  { label: 'Futures Required', keyA: a.futuresRequired ? 'Yes' : 'No', keyB: b.futuresRequired ? 'Yes' : 'No' },
  { label: 'Payment Methods', keyA: a.paymentMethods.join(', '), keyB: b.paymentMethods.join(', ') },
  { label: 'Rating', keyA: `★ ${a.rating}`, keyB: `★ ${b.rating}` },
];
---

<div class="compare-table-wrap">
  <table class="compare-table">
    <thead>
      <tr>
        <th scope="col" class="compare-label-col"></th>
        <th scope="col" class="compare-exchange-col">
          <a href={`/exchanges/${a.slug}/`}>{a.name}</a>
        </th>
        <th scope="col" class="compare-exchange-col">
          <a href={`/exchanges/${b.slug}/`}>{b.name}</a>
        </th>
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr>
          <td class="compare-label">{row.label}</td>
          <td class="compare-value">{row.keyA}</td>
          <td class="compare-value">{row.keyB}</td>
        </tr>
      ))}
      <tr class="compare-cta-row">
        <td class="compare-label">Action</td>
        <td><CTAButton href={a.affiliateUrl} exchange={a.name} size="sm" fullWidth /></td>
        <td><CTAButton href={b.affiliateUrl} exchange={b.name} size="sm" fullWidth /></td>
      </tr>
    </tbody>
  </table>
</div>

<style>
  .compare-table-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 500px;
  }
  .compare-table thead tr {
    background: var(--color-bg-tertiary);
  }
  .compare-table th {
    padding: 1rem;
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
    border-bottom: 1px solid var(--color-border);
  }
  .compare-label-col { width: 30%; text-align: left; }
  .compare-table th a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .compare-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    vertical-align: middle;
  }
  .compare-table tbody tr:last-child td { border-bottom: none; }
  .compare-table tbody tr:hover { background: var(--color-bg-tertiary); }
  .compare-label {
    text-align: left !important;
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.8rem !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .compare-value { font-weight: 500; }
  .compare-cta-row td { padding: 1rem; }
</style>
