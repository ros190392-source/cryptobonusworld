{
  "name": "cryptobonusworld",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "audit": "node scripts/audit-exchanges.mjs",
    "audit:json": "node scripts/audit-exchanges.mjs --json",
    "audit:content": "node scripts/audit-content.mjs",
    "audit:content:json": "node scripts/audit-content.mjs --json",
    "content:draft": "node scripts/content-draft.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:links:json": "node scripts/audit-links.mjs --json",
    "audit:links:strict": "node scripts/audit-links.mjs --fail-on-missing",
    "validate": "node scripts/validate-bonuses.cjs",
    "validate:strict": "node scripts/validate-bonuses.cjs || exit 2",
    "deploy": "node scripts/deploy.mjs",
    "media-update": "node scripts/media-update.mjs",
    "evidence:audit": "node scripts/evidence-audit.mjs",
    "evidence:audit:json": "node scripts/evidence-audit.mjs --json",
    "evidence:queue": "node scripts/evidence-update-queue.mjs",
    "evidence:queue:p1": "node scripts/evidence-update-queue.mjs --priority P1",
    "evidence:queue:bybit": "node scripts/evidence-update-queue.mjs --exchange bybit",
    "evidence:queue:stale": "node scripts/evidence-update-queue.mjs --stale-only",
    "evidence:queue:md": "node scripts/evidence-update-queue.mjs --format markdown --out reports/evidence-update-queue.md",
    "screenshot:checklist": "node scripts/screenshot-checklist.mjs",
    "screenshot:checklist:missing": "node scripts/screenshot-checklist.mjs --missing-only",
    "screenshot:checklist:json": "node scripts/screenshot-checklist.mjs --json",
    "screenshot:checklist:bybit": "node scripts/screenshot-checklist.mjs --exchange bybit",
    "seo:intake": "node scripts/seo-issue-intake.mjs",
    "seo:intake:gsc": "node scripts/seo-issue-intake.mjs --source google-search-console",
    "seo:intake:critical": "node scripts/seo-issue-intake.mjs --severity critical",
    "seo:intake:open": "node scripts/seo-issue-intake.mjs --status new,classified,needs_manual_review",
    "seo:intake:inbox": "node scripts/seo-issue-intake.mjs --status new",
    "seo:intake:json": "node scripts/seo-issue-intake.mjs --format json",
    "indexnow": "node scripts/indexnow.mjs",
    "indexnow:dry": "node scripts/indexnow.mjs --dry-run",
    "affiliate:audit": "node scripts/audit-affiliate-links.mjs",
    "affiliate:audit:json": "node scripts/audit-affiliate-links.mjs --json",
    "affiliate:audit:strict": "node scripts/audit-affiliate-links.mjs --fail-on-issues",
    "affiliate:inventory": "node scripts/affiliate-link-inventory.mjs",
    "affiliate:inventory:write": "node scripts/affiliate-link-inventory.mjs --md --write && node scripts/affiliate-link-inventory.mjs --json --write",
    "affiliate:report": "node scripts/affiliate-link-inventory.mjs --md --write && node scripts/affiliate-link-inventory.mjs --json --write && node scripts/audit-affiliate-links.mjs",
    "affiliate:check": "node scripts/audit-affiliate-links.mjs --fail-on-issues && node scripts/affiliate-link-inventory.mjs",
    "seo:titles": "node scripts/audit-seo-titles.mjs --write",
    "seo:titles:json": "node scripts/audit-seo-titles.mjs --json",
    "seo:check": "node scripts/audit-seo-titles.mjs --fail-on-ci",
    "seo:check:strict": "node scripts/audit-seo-titles.mjs --fail-on-error",
    "screenshots:audit": "node scripts/audit-exchange-screenshots.mjs --verbose",
    "screenshots:report": "node scripts/audit-exchange-screenshots.mjs --write --verbose",
    "screenshots:check": "node scripts/audit-exchange-screenshots.mjs --fail-on-errors",
    "screenshots:report:json": "node scripts/audit-exchange-screenshots.mjs --json",
    "schema:audit": "node scripts/audit-schema.mjs --verbose",
    "schema:audit:json": "node scripts/audit-schema.mjs --json",
    "schema:audit:write": "node scripts/audit-schema.mjs --write --verbose",
    "schema:check": "node scripts/audit-schema.mjs --fail-on-errors",
    "freshness:audit": "node scripts/audit-freshness.mjs",
    "freshness:audit:json": "node scripts/audit-freshness.mjs --json",
    "freshness:audit:write": "node scripts/audit-freshness.mjs --write",
    "freshness:audit:strict": "node scripts/audit-freshness.mjs --fail-on-issues",
    "links:audit": "node scripts/audit-internal-links.mjs",
    "links:audit:json": "node scripts/audit-internal-links.mjs --json",
    "links:audit:write": "node scripts/audit-internal-links.mjs --write",
    "links:audit:verbose": "node scripts/audit-internal-links.mjs --verbose"
  },
  "dependencies": {
    "astro": "^4.15.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.1.6",
    "typescript": "^5.5.0"
  }
}
