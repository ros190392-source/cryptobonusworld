---
interface Props {
  countries: string[];
  excludedCountries: string[];
}

const { countries, excludedCountries } = Astro.props;

const countryLabels: Record<string, string> = {
  global: '🌍 Global',
  turkey: '🇹🇷 Turkey',
  india: '🇮🇳 India',
  indonesia: '🇮🇩 Indonesia',
  nigeria: '🇳🇬 Nigeria',
  brazil: '🇧🇷 Brazil',
  vietnam: '🇻🇳 Vietnam',
  philippines: '🇵🇭 Philippines',
  us: '🇺🇸 United States',
  uk: '🇬🇧 United Kingdom',
  canada: '🇨🇦 Canada',
};
---

<div class="country-availability">
  {countries.length > 0 && (
    <div class="ca-section">
      <h4 class="ca-label ca-label--available">Available in</h4>
      <div class="ca-tags">
        {countries.map(c => (
          <span class="ca-tag ca-tag--available">
            {countryLabels[c] ?? c}
          </span>
        ))}
      </div>
    </div>
  )}

  {excludedCountries.length > 0 && (
    <div class="ca-section">
      <h4 class="ca-label ca-label--excluded">Not available in</h4>
      <div class="ca-tags">
        {excludedCountries.map(c => (
          <span class="ca-tag ca-tag--excluded">
            {countryLabels[c] ?? c}
          </span>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .country-availability {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
  }
  .ca-section { display: flex; flex-direction: column; gap: 0.5rem; }
  .ca-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }
  .ca-label--available { color: #4ade80; }
  .ca-label--excluded { color: #f87171; }
  .ca-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .ca-tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    font-weight: 500;
  }
  .ca-tag--available {
    background: #1a3a2a;
    color: #4ade80;
    border: 1px solid #1a3a2a;
  }
  .ca-tag--excluded {
    background: #3a1a1a;
    color: #f87171;
    border: 1px solid #3a1a1a;
  }
</style>
