---
import SeoHead from '../components/SeoHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const { title, description, canonical, schema, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      schema={schema}
      noindex={noindex}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    /* ── Core palette ── */
    --color-bg:           #0a0a0a;
    --color-bg-secondary: #111111;
    --color-bg-tertiary:  #1a1a1a;
    --color-border:       #252525;
    --color-border-subtle:#1c1c1c;

    /* ── Accent / gold ── */
    --color-accent:       #f5c542;
    --color-accent-warm:  #fbbf24;
    --color-accent-deep:  #d97706;
    --color-accent-dim:   rgba(245, 197, 66, 0.15);
    --color-accent-glow:  rgba(245, 197, 66, 0.22);
    --color-accent-muted: rgba(245, 197, 66, 0.08);

    /* ── Surfaces ── */
    --surface-base:      #0a0a0a;
    --surface-raised:    #111111;
    --surface-elevated:  #151515;
    --surface-overlay:   #1a1a1a;
    --surface-featured:  #16160a;

    /* ── Text ── */
    --color-text-primary:   #f0f0f0;
    --color-text-secondary: #aaaaaa;
    --color-text-muted:     #606060;

    /* ── Typography scale ── */
    --text-xs:   0.75rem;    /* 12px */
    --text-sm:   0.875rem;   /* 14px */
    --text-base: 1rem;       /* 16px */
    --text-lg:   1.125rem;   /* 18px */
    --text-xl:   1.25rem;    /* 20px */
    --text-2xl:  1.5rem;     /* 24px */
    --text-3xl:  2rem;       /* 32px */
    --text-4xl:  2.5rem;     /* 40px */

    /* ── Border radius ── */
    --radius-xs:   4px;
    --radius-sm:   6px;
    --radius-md:   10px;
    --radius-lg:   14px;
    --radius-xl:   20px;
    --radius-2xl:  28px;
    --radius-pill: 100px;

    /* ── Shadow system (elevation) ── */
    --shadow-xs: 0 1px 3px rgba(0,0,0,0.45);
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.5);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.5), 0 1px 4px rgba(0,0,0,0.3);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.6), 0 2px 8px rgba(0,0,0,0.4);
    --shadow-xl: 0 16px 48px rgba(0,0,0,0.7), 0 4px 12px rgba(0,0,0,0.5);

    /* ── Glow system ── */
    --glow-gold-sm: 0 0 12px rgba(245,197,66,0.2);
    --glow-gold-md: 0 0 24px rgba(245,197,66,0.25), 0 0 8px rgba(245,197,66,0.12);
    --glow-gold-lg: 0 0 40px rgba(245,197,66,0.3),  0 0 16px rgba(245,197,66,0.18);
    --glow-card:    0 4px 24px rgba(245,197,66,0.12), 0 1px 6px rgba(245,197,66,0.08);
    --glow-cta:     0 4px 20px rgba(245,197,66,0.35), 0 1px 8px rgba(245,197,66,0.2);

    /* ── Gradient system ── */
    --gradient-gold:         linear-gradient(135deg, #fbbf24 0%, #f5c542 45%, #d97706 100%);
    --gradient-gold-text:    linear-gradient(135deg, #fbbf24 0%, #f5c542 50%, #f59e0b 100%);
    --gradient-gold-subtle:  linear-gradient(135deg, rgba(245,197,66,0.1) 0%, rgba(245,197,66,0.03) 100%);
    --gradient-surface:      linear-gradient(180deg, #151515 0%, #111111 100%);
    --gradient-featured:     linear-gradient(135deg, #1a1a08 0%, #111111 100%);
    --gradient-hero-glow:    radial-gradient(ellipse at 30% 40%, rgba(245,197,66,0.1) 0%, transparent 65%);

    /* ── Animation system ── */
    --ease-standard: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-spring:   cubic-bezier(0.34, 1.56, 0.64, 1);
    --ease-out:      cubic-bezier(0, 0, 0.2, 1);
    --ease-in:       cubic-bezier(0.4, 0, 1, 1);
    --duration-fast: 120ms;
    --duration-base: 200ms;
    --duration-slow: 320ms;

    /* ── Layout ── */
    --font-sans:     'Inter', system-ui, -apple-system, sans-serif;
    --container-max: 1200px;
    --container-pad: 1.5rem;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    scroll-padding-top: 64px;
  }

  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }

  h1, h2, h3, h4, h5, h6 {
    line-height: 1.2;
    color: var(--color-text-primary);
  }

  a { color: inherit; }

  /* Global focus ring — keyboard nav only */
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  img { max-width: 100%; height: auto; }

  p { margin: 0 0 1rem; color: var(--color-text-secondary); }

  /* Reusable section heading with gold accent */
  .section-heading {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
    position: relative;
    padding-left: 0.875rem;
  }
  .section-heading::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15em;
    bottom: 0.15em;
    width: 3px;
    background: var(--gradient-gold);
    border-radius: var(--radius-pill);
  }

  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .page-header .lead {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
    :root { --container-pad: 1rem; }
    .page-header { padding: 1.5rem 0 1rem; }
    .page-header h1 { font-size: clamp(1.4rem, 5.5vw, 2rem); }
  }

  @media (max-width: 520px) {
    .grid-2,
    .grid-3,
    .grid-4 { grid-template-columns: 1fr; }
  }

  @media (max-width: 375px) {
    :root { --container-pad: 0.875rem; }
  }

  /* Prose */
  .prose h2 { font-size: 1.3rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose h3 { font-size: 1.1rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .prose p { color: var(--color-text-secondary); line-height: 1.75; margin-bottom: 1rem; }
  .prose ul, .prose ol { color: var(--color-text-secondary); padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose li { margin-bottom: 0.375rem; line-height: 1.6; }
  .prose a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose strong { color: var(--color-text-primary); }
</style>
