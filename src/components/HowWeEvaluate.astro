---
/**
 * HowWeEvaluate — inline E-E-A-T methodology block.
 *
 * Explains the scoring process to users and signals editorial expertise
 * to search engines. Lightweight alternative to the full /methodology/ page.
 *
 * Usage:
 *  - Bonus comparison pages (below table)
 *  - Category pages (once per page)
 *  - Use-case pages (once per page)
 *
 * Variants:
 *  - default: full criteria list with descriptions
 *  - compact: single-line reference to methodology page
 *  - inline: small text note (for table footers)
 */

interface EvalCriterion {
  icon: string;
  label: string;
  description: string;
}

interface Props {
  variant?: 'default' | 'compact' | 'inline';
  heading?: string;
  /** Override default criteria for a specific page type */
  criteria?: EvalCriterion[];
}

const { variant = 'default', heading, criteria } = Astro.props;

const defaultCriteria: EvalCriterion[] = [
  {
    icon: '💰',
    label: 'Bonus Value',
    description: 'Maximum advertised bonus amount, weighted by realistic achievability for average users — not just the headline number.',
  },
  {
    icon: '📋',
    label: 'Condition Clarity',
    description: 'How clearly the exchange explains KYC, deposit, and trading volume requirements. Buried or vague conditions are penalised.',
  },
  {
    icon: '🪪',
    label: 'KYC Requirement',
    description: 'Whether identity verification is mandatory. No-KYC options score higher for accessibility.',
  },
  {
    icon: '🌍',
    label: 'Country Availability',
    description: 'Geographic reach and local payment method support. Global availability without country restrictions scores highest.',
  },
  {
    icon: '🛡️',
    label: 'Platform Reputation',
    description: 'Exchange age, regulatory standing, user base size, and track record for security and withdrawal reliability.',
  },
  {
    icon: '⚡',
    label: 'Claiming Ease',
    description: 'Number of steps required to claim the bonus, mobile accessibility, and process clarity.',
  },
];

const activeCriteria = criteria ?? defaultCriteria;
---

{variant === 'inline' && (
  <p class="hwe-inline">
    Rated by bonus value, conditions, KYC, availability and reputation.
    <a href="/methodology/" class="hwe-inline-link">See full methodology</a>
  </p>
)}

{variant === 'compact' && (
  <div class="hwe-compact">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <span>
      Rankings based on bonus value, conditions clarity, KYC requirement and platform reputation.
      <a href="/methodology/" class="hwe-compact-link">Our full methodology →</a>
    </span>
  </div>
)}

{variant === 'default' && (
  <div class="hwe" role="region" aria-label="How we evaluate exchanges">
    <div class="hwe-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      <h3 class="hwe-heading">{heading ?? 'How We Evaluate & Rank Exchanges'}</h3>
    </div>

    <p class="hwe-intro">
      Every exchange on this page has been manually evaluated by our editorial team against the following criteria.
      Bonus amounts are verified against official exchange promotion pages.
    </p>

    <div class="hwe-criteria">
      {activeCriteria.map(c => (
        <div class="hwe-criterion">
          <span class="hwe-criterion-icon" aria-hidden="true">{c.icon}</span>
          <div class="hwe-criterion-content">
            <span class="hwe-criterion-label">{c.label}</span>
            <span class="hwe-criterion-desc">{c.description}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="hwe-footer">
      <a href="/methodology/" class="hwe-method-link">
        Read our full exchange evaluation methodology →
      </a>
    </div>
  </div>
)}

<style>
  /* ── Inline ── */
  .hwe-inline {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0;
    line-height: 1.5;
  }
  .hwe-inline-link {
    color: var(--color-accent);
    text-decoration: none;
    margin-left: 0.25rem;
  }
  .hwe-inline-link:hover { text-decoration: underline; }

  /* ── Compact ── */
  .hwe-compact {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    padding: 0.625rem 0.875rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .hwe-compact svg { color: var(--color-accent); flex-shrink: 0; margin-top: 0.1rem; }
  .hwe-compact-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    margin-left: 0.25rem;
  }
  .hwe-compact-link:hover { text-decoration: underline; }

  /* ── Full ── */
  .hwe {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }

  .hwe-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
  }
  .hwe-header svg { color: var(--color-accent); flex-shrink: 0; }

  .hwe-heading {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .hwe-intro {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .hwe-criteria {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.625rem;
    margin-bottom: 1rem;
  }

  .hwe-criterion {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 8px;
  }

  .hwe-criterion-icon {
    font-size: 0.875rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .hwe-criterion-content {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .hwe-criterion-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .hwe-criterion-desc {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .hwe-footer {
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .hwe-method-link {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.15s;
  }
  .hwe-method-link:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .hwe-criteria { grid-template-columns: 1fr; }
  }
</style>
