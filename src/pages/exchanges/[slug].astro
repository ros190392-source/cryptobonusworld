      <section class="compare-vs-section">
        <h2 class="section-heading">Compare {ex.name} vs Alternatives</h2>
        <div class="compare-vs-grid">
          {myComparePairs.map(p => {
            const otherSlug = p.a === ex.slug ? p.b : p.a;
            const other = exMap[otherSlug] as any;
            if (!other) return null;
            return (
              <a href={`/compare/${p.pair}/`} class="compare-vs-card">
                <div class="compare-vs-logos">
                  <ExchangeLogo slug={ex.slug} name={ex.name} size={44} variant="square" lazy={false} />
                  <span class="compare-vs-divider">vs</span>
                  <ExchangeLogo slug={otherSlug} name={other.name} size={44} variant="square" lazy={false} />
                </div>
                <span class="compare-vs-label">{ex.name} vs {other.name}</span>
                <span class="compare-vs-arrow">→</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <RiskDisclaimer />
  </div>
