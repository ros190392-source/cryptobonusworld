---
import BonusBadge from './BonusBadge.astro';
import KycBadge from './KycBadge.astro';
import RatingBadge from './RatingBadge.astro';
import CTAButton from './CTAButton.astro';
import LastUpdated from './LastUpdated.astro';
import ExchangeLogo from './ExchangeLogo.astro';

interface Props {
  name: string;
  slug: string;
  rating: number;
  bonusTitle: string;
  bonusAmount: number;
  bonusCurrency: string;
  bonusTypes: string[];
  kycRequired: boolean;
  depositRequired?: boolean;
  affiliateUrl: string;
  shortDescription: string;
  updatedAt: string;
  bestFor?: string[];
  topChoice?: boolean;
  users?: string;
}

import { getCtaLabel } from '../utils/affiliateUtils';
const props = Astro.props;
const showUsers = props.users && parseInt(props.users.replace(/[^0-9]/g, ''), 10) >= 10;
---

<article class="exchange-card">
  <div class="exchange-card-header">
    <div class="exchange-card-identity">
      <ExchangeLogo slug={props.slug} name={props.name} size={80} variant="square" />
      <div>
        <h3 class="exchange-card-name">
          <a href={`/exchanges/${props.slug}/`}>{props.name}</a>
        </h3>
        <div class="card-rating-row">
          <RatingBadge rating={props.rating} />
          {showUsers && (
            <span class="card-users">{props.users} users</span>
          )}
        </div>
      </div>
    </div>
    <div class="exchange-card-bonus">
      <span class="exchange-bonus-amount">
        Up to {props.bonusAmount.toLocaleString()} {props.bonusCurrency}
      </span>
    </div>
  </div>

  <p class="exchange-card-desc">{props.shortDescription}</p>

  {props.bestFor && props.bestFor.length > 0 && (
    <div class="exchange-card-bestfor">
      <span class="bestfor-label">Best for:</span>
      {props.bestFor.slice(0, 2).map(b => (
        <span class="bestfor-chip">{b}</span>
      ))}
    </div>
  )}

  <div class="exchange-card-badges">
    {props.bonusTypes.map(t => <BonusBadge type={t} />)}
    <KycBadge required={props.kycRequired} />
  </div>

  <div class="exchange-card-footer">
    <LastUpdated date={props.updatedAt} />
    <div class="exchange-card-actions">
      <a href={`/exchanges/${props.slug}/`} class="details-link">View Details</a>
      <CTAButton
        href={props.affiliateUrl}
        label={!props.kycRequired ? 'No KYC' : 'Claim'}
        exchange={props.name}
        size="sm"
        trackPlacement="card"
        trackBonus={props.bonusAmount}
      />
    </div>
  </div>
</article>

<style>
  .exchange-card {
    background: var(--surface-raised, #111111);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 14px);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition:
      border-color var(--duration-base, 200ms) var(--ease-standard, ease),
      box-shadow   var(--duration-base, 200ms) var(--ease-standard, ease),
      transform    var(--duration-base, 200ms) var(--ease-standard, ease);
  }
  .exchange-card:hover {
    border-color: var(--color-accent-dim, rgba(245,197,66,0.15));
    box-shadow: var(--glow-card, 0 4px 24px rgba(245,197,66,0.12));
    transform: translateY(-2px);
  }
  .exchange-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .exchange-card-identity { display: flex; align-items: center; gap: 1rem; }
  .exchange-card-name {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.2rem;
  }
  .exchange-card-name a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .exchange-card-name a:hover { color: var(--color-accent); }

  .card-rating-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .card-users {
    font-size: 0.68rem;
    font-weight: 600;
    color: #60a5fa;
    background: rgba(96,165,250,0.08);
    border: 1px solid rgba(96,165,250,0.15);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    white-space: nowrap;
  }
  .exchange-bonus-amount {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent);
    text-align: right;
    display: block;
  }
  .exchange-card-desc {
    font-size: 0.825rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  /* Best-for chips */
  .exchange-card-bestfor {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: -0.25rem;
  }
  .bestfor-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .bestfor-chip {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-muted, rgba(245,197,66,0.08));
    border: 1px solid rgba(245,197,66,0.15);
    border-radius: var(--radius-pill, 100px);
    padding: 0.1rem 0.5rem;
  }

  .exchange-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .exchange-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
  }
  .exchange-card-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .details-link {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .details-link:hover { color: var(--color-text-primary); }
</style>
