---
import Layout from '../../layouts/Layout.astro';
import ExchangeHero from '../../components/ExchangeHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BonusBadge from '../../components/BonusBadge.astro';
import ProsConsBlock from '../../components/ProsConsBlock.astro';
import RequirementsBlock from '../../components/RequirementsBlock.astro';
import CountryAvailability from '../../components/CountryAvailability.astro';
import AlternativesBlock from '../../components/AlternativesBlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import CTAButton from '../../components/CTAButton.astro';
import ReviewerBlock from '../../components/ReviewerBlock.astro';
import EditorialNote from '../../components/EditorialNote.astro';
import HowWeEvaluate from '../../components/HowWeEvaluate.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import OfferRealism from '../../components/OfferRealism.astro';
import EditorialExperienceBar from '../../components/EditorialExperienceBar.astro';

import exchanges from '../../data/exchanges.json';
import categories from '../../data/categories.json';
import countries from '../../data/countries.json';
import comparePairs from '../../data/compare-pairs.json';
import allGuides from '../../data/guides.json';
import { USE_CASES } from '../../data/use-cases';

import RelatedCategoriesBlock from '../../components/RelatedCategoriesBlock.astro';
import CountryCrossLinksBlock from '../../components/CountryCrossLinksBlock.astro';
import EditorSummary from '../../components/EditorSummary.astro';
import GeoContentBlock from '../../components/GeoContentBlock.astro';
import RelatedGuidesBlock from '../../components/RelatedGuidesBlock.astro';
import WalkthroughFlow from '../../components/WalkthroughFlow.astro';
import WalkthroughStepImage from '../../components/WalkthroughStepImage.astro';
import FeeSnippetBlock from '../../components/FeeSnippetBlock.astro';
import RelatedNextReads from '../../components/RelatedNextReads.astro';

import {
  exchangePageTitle,
  exchangeMetaDesc,
  buildProductSchema,
  getRelatedCategories,
  getCountryCrossLinks,
} from '../../utils/seo';
import { getFlowsBySlug } from '../../data/exchange-walkthroughs';
import type { PageContext } from '../../utils/analytics';
import {
  generateExchangeFAQs,
  applyFAQOverrides,
  BONUS_TYPE_DEFS,
  type ContentExchange,
} from '../../utils/contentEngine';
import contentOverrides from '../../data/content-overrides.json';

export async function getStaticPaths() {
  return exchanges.map(ex => ({
    params: { slug: ex.slug },
    props: { exchange: ex },
  }));
}

const { exchange: ex } = Astro.props;

// SEO: dynamic title, meta description, cross-link data
const seoTitle = exchangePageTitle(ex as any);
const seoDesc = exchangeMetaDesc(ex as any);
const relatedCats = getRelatedCategories(ex.bonusTypes, ex.kycRequired, ex.depositRequired, categories as any);
const countryCrossLinks = getCountryCrossLinks(ex.countries, countries as any);

const pageTitle = `${ex.name} Bonus 2026: ${ex.bonusTitle}`;

// Bonus type definitions — centralised in contentEngine.ts
const bonusTypeDefs = BONUS_TYPE_DEFS;

// Use structured bonusTiers from data if available, else fall back to bonusTypeDefs
const activeBonusTiers = (ex as any).bonusTiers?.length
  ? (ex as any).bonusTiers
  : ex.bonusTypes.map(t => bonusTypeDefs[t]).filter(Boolean);
const hasBonusTierData = !!(ex as any).bonusTiers?.length;

// Conditions data for icon grid
const minDeposit = (ex as any).minDeposit;
const tradingVol = (ex as any).tradingVolumeRequired;
const bonusExpiry = (ex as any).bonusExpiry;

const conditions = [
  {
    icon: '💰',
    label: 'Max Bonus',
    value: `${ex.bonusAmount.toLocaleString()} ${ex.bonusCurrency}`,
    highlight: true,
  },
  {
    icon: '🪪',
    label: 'KYC Required',
    value: ex.kycRequired ? 'Yes — ID verification' : 'No KYC needed',
    ok: !ex.kycRequired,
  },
  {
    icon: '🏦',
    label: 'Min Deposit',
    value: minDeposit
      ? (minDeposit.amount > 0 ? `${minDeposit.amount.toLocaleString()} ${minDeposit.currency}` : 'No deposit needed')
      : (ex.depositRequired ? 'Deposit required' : 'No deposit needed'),
    ok: minDeposit ? minDeposit.amount === 0 : !ex.depositRequired,
  },
  {
    icon: '📈',
    label: 'Trading Volume',
    value: tradingVol && tradingVol.amount > 0
      ? `${tradingVol.amount.toLocaleString()} ${tradingVol.currency}`
      : 'None required',
    ok: !tradingVol || tradingVol.amount === 0,
  },
  {
    icon: '⏳',
    label: 'Bonus Expiry',
    value: bonusExpiry ? `${bonusExpiry.days} days after signup` : 'See official terms',
  },
  {
    icon: '💳',
    label: 'Payment Methods',
    value: ex.paymentMethods.join(', '),
  },
];

// FAQ — generated centrally, then editorial overrides applied
const _faqGenerated = generateExchangeFAQs(ex as unknown as ContentExchange);
const _faqOverride = (contentOverrides.exchanges as Record<string, any>)[ex.slug];
const faqItems = applyFAQOverrides(_faqGenerated, _faqOverride);

// Analytics context
const analyticsContext: PageContext = {
  pageType:        'exchange',
  exchangeSlug:    ex.slug,
  exchangeRating:  ex.rating,
  exchangeBonus:   ex.bonusAmount,
  exchangeKyc:     ex.kycRequired,
  exchangeDeposit: ex.depositRequired,
};

// Compare pairs for this exchange
const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));
const myComparePairs = comparePairs
  .filter(p => p.a === ex.slug || p.b === ex.slug)
  .slice(0, 6);

// SEO: use utility builder for richer, consistent Product schema
const schema = buildProductSchema(ex as any);

// Related guides — pick guides that reference this exchange
const relatedGuides = allGuides
  .filter(g => g.relatedExchanges?.includes(ex.slug))
  .slice(0, 4);

// Related use cases — use cases where this exchange is in the pool
const relatedUseCases = USE_CASES.filter(uc =>
  uc.exchangePool === 'all' ||
  (Array.isArray(uc.exchangePool) && uc.exchangePool.includes(ex.slug))
).slice(0, 6);

// Visual walkthroughs — only available for select exchanges (bybit, binance, mexc)
const walkthroughFlows = getFlowsBySlug(ex.slug);

// Related Next Reads — top compare pairs + related guides for internal distribution
const rnrItems = [
  ...myComparePairs.slice(0, 2).map(p => {
    const otherSlug = p.a === ex.slug ? p.b : p.a;
    const other = exMap[otherSlug] as any;
    return {
      type: 'compare' as const,
      label: `${ex.name} vs ${other?.name ?? otherSlug} — Fees, Bonuses & KYC`,
      href: `/compare/${p.pair}/`,
    };
  }),
  ...relatedGuides.slice(0, 2).map(g => ({
    type: 'guide' as const,
    label: g.title,
    href: `/guides/${g.slug}/`,
    meta: g.readTime + ' read',
  })),
];
---

<Layout
  title={seoTitle}
  description={seoDesc}
  canonical={`/exchanges/${ex.slug}/`}
  schema={schema}
  analyticsContext={analyticsContext}
  ogImage={`https://cryptobonusworld.com/og/exchange-${ex.slug}.png`}
>
  <div class="container ex-page">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Exchanges', href: '/exchanges/' },
      { label: ex.name },
    ]} />

    <AffiliateDisclosure compact />

    <AuthorCard
      compact
      verb="Reviewed by"
      reviewedAt={(ex as any).lastVerified ?? ex.updatedAt}
      profileUrl="/reviewers/editorial-team/"
    />

    <!-- Full-width hero with h1 -->
    <ExchangeHero
      name={ex.name}
      slug={ex.slug}
      rating={ex.rating}
      pageTitle={pageTitle}
      bonusTitle={ex.bonusTitle}
      bonusAmount={ex.bonusAmount}
      bonusCurrency={ex.bonusCurrency}
      bonusTypes={ex.bonusTypes}
      kycRequired={ex.kycRequired}
      depositRequired={ex.depositRequired}
      affiliateUrl={ex.affiliateUrl}
      promoCode={ex.promoCode}
      updatedAt={ex.updatedAt}
      countries={ex.countries}
      paymentMethods={ex.paymentMethods}
      licences={(ex as any).licences}
      founded={(ex as any).founded}
      users={(ex as any).users}
      bonusExpiry={(ex as any).bonusExpiry ?? null}
      geoHrefs={(ex as any).affiliateLinks?.geo ?? undefined}
      lastVerified={(ex as any).lastVerified}
      verificationStatus={(ex as any).verificationStatus}
      bonusNote={(ex as any).bonusNote ?? null}
      bonusSourceUrl={(ex as any).bonusSourceUrl ?? null}
      excludedCountries={(ex as any).excludedCountries ?? null}
      bonusDisplayMode={(ex as any).bonusDisplayMode ?? 'up-to'}
    />

    <!-- Editorial summary: verdict, best-for, feature badges (EEAT anchor) -->
    <EditorSummary
      name={ex.name}
      rating={ex.rating}
      shortDescription={ex.shortDescription}
      bestFor={(ex as any).bestFor ?? []}
      featureBadges={(ex as any).featureBadges ?? []}
      lastVerified={(ex as any).lastVerified ?? ex.updatedAt}
      topChoice={(ex as any).topChoice ?? false}
      founded={(ex as any).founded}
      users={(ex as any).users}
      editorNote={
        // Content override takes priority over exchange data field
        (_faqOverride?.editorNote?.length > 0 ? _faqOverride.editorNote : null) ??
        ((ex as any).editorNote?.length > 0 ? (ex as any).editorNote : undefined)
      }
    />

    <!-- E-E-A-T: Editorial reviewer block — emits Person schema JSON-LD -->
    <ReviewerBlock
      reviewedAt={(ex as any).lastVerified ?? ex.updatedAt}
      verb="Reviewed by"
    />

    <!-- Two-column layout: main content + sticky sidebar -->
    <div class="ex-layout">

      <!-- ── MAIN CONTENT ── -->
      <div class="ex-main">

        <!-- Editorial experience signals (E-E-A-T) -->
        <EditorialExperienceBar
          signals={[
            'editorial-reviewed',
            'bonus-checked',
            'fees-verified',
            ...(((ex as any).p2pAvailable) ? ['p2p-checked'] as const : []),
            ...(ex.kycRequired ? ['kyc-tested'] as const : []),
            'desktop-tested',
            'mobile-tested',
            'content-fresh',
          ]}
          verifiedAt={(ex as any).offerLastChecked ? (() => {
            const d = new Date((ex as any).offerLastChecked + 'T00:00:00');
            return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
          })() : 'May 2026'}
          compact
        />

        <!-- Offer transparency / realism block -->
        {((ex as any).offerConfidenceScore != null || (ex as any).realisticUserExpectation) && (
          <section class="ex-section">
            <OfferRealism
              exchangeName={ex.name}
              offerConfidenceScore={(ex as any).offerConfidenceScore ?? null}
              realisticUserExpectation={(ex as any).realisticUserExpectation ?? null}
              verificationLastChecked={(ex as any).verificationLastChecked ?? null}
              bonusConditionSummary={(ex as any).bonusConditionSummary ?? null}
              bonusDisplayMode={(ex as any).bonusDisplayMode ?? 'up-to'}
              termsUrl={ex.termsUrl ?? null}
            />
          </section>
        )}

        <!-- Bonus tiers breakdown -->
        {activeBonusTiers.length > 0 && (
          <section class="ex-section">
            <h2 class="ex-section-title">What's Included in This Bonus</h2>
            <div class="bonus-tiers">
              {hasBonusTierData
                ? activeBonusTiers.map((tier: any) => (
                    <div class="bonus-tier bonus-tier--data">
                      <div class="bonus-tier-icon">
                        {bonusTypeDefs[tier.type]?.icon ?? '🎁'}
                      </div>
                      <div class="bonus-tier-content">
                        <div class="bonus-tier-header">
                          <div class="bonus-tier-title">{tier.title}</div>
                          {tier.amount > 0 && (
                            <div class="bonus-tier-amount">
                              {tier.amount >= 1000
                                ? `${(tier.amount / 1000).toFixed(0)}K`
                                : tier.amount} {tier.currency}
                            </div>
                          )}
                        </div>
                        <div class="bonus-tier-desc">{tier.condition}</div>
                        {tier.note && (
                          <div class="bonus-tier-note">{tier.note}</div>
                        )}
                      </div>
                    </div>
                  ))
                : activeBonusTiers.map((tier: any) => (
                    <div class="bonus-tier">
                      <div class="bonus-tier-icon">{tier.icon}</div>
                      <div>
                        <div class="bonus-tier-title">{tier.title}</div>
                        <div class="bonus-tier-desc">{tier.desc}</div>
                      </div>
                    </div>
                  ))
              }
            </div>
          </section>
        )}

        <!-- Geo-aware payment method tip -->
        <GeoContentBlock
          geoContent={{
            tr: { body: "P2P trading with TRY is the most popular deposit method in Turkey. Most exchanges including Bybit and MEXC offer P2P desks with strong TRY liquidity." },
            in: { body: "UPI and P2P trading with INR are the standard on-ramps for Indian users. Note: OKX does not currently accept Indian users." },
            id: { body: "P2P trading with IDR (via BCA, Mandiri, BRI) is the primary funding method in Indonesia. Most major exchanges support this." },
            ng: { body: "P2P trading with NGN is essential in Nigeria due to banking restrictions on direct crypto transfers. MEXC and Bybit have the strongest NGN P2P desks." },
            br: { body: "PIX instant payments are the fastest BRL on-ramp in Brazil. Available via P2P counterparties on Bybit and several other exchanges." },
            vn: { body: "P2P trading with VND is the standard method for Vietnamese users. Bybit and MEXC have the most active VND P2P markets." },
            ph: { body: "P2P trading with PHP via BDO, BPI or GCash is the most popular method in the Philippines. Most major exchanges support this." },
          }}
          defaultContent="Check the exchange's supported payment methods and country availability before registering."
          type="tip"
        />

        <!-- Key conditions — icon grid -->
        <section class="ex-section">
          <h2 class="ex-section-title">Key Bonus Conditions</h2>
          <div class="conditions-grid">
            {conditions.map(c => (
              <div class:list={['cond-card', c.highlight && 'cond-card--highlight', c.ok === true && 'cond-card--ok', c.ok === false && 'cond-card--warn']}>
                <span class="cond-icon">{c.icon}</span>
                <div>
                  <div class="cond-label">{c.label}</div>
                  <div class="cond-value">{c.value}</div>
                </div>
              </div>
            ))}
          </div>

          {ex.bonusTypes.length > 0 && (
            <div class="cond-bonus-types">
              <span class="cond-types-label">Bonus types:</span>
              {ex.bonusTypes.map(t => <BonusBadge type={t} />)}
            </div>
          )}
        </section>

        <!-- Fee snippet block — featured snippet targeting for fee queries -->
        {((ex as any).spotMakerFee !== undefined || (ex as any).futuresMakerFee !== undefined) && (
          <FeeSnippetBlock
            exchangeName={ex.name}
            spotMakerFee={(ex as any).spotMakerFee}
            spotTakerFee={(ex as any).spotTakerFee}
            futuresMakerFee={(ex as any).futuresMakerFee}
            futuresTakerFee={(ex as any).futuresTakerFee}
            p2pFee={(ex as any).p2pAvailable ? '0%' : undefined}
            maxLeverage={(ex as any).maxFuturesLeverage}
            lastVerified={(ex as any).lastVerified ?? ex.updatedAt}
          />
        )}

        <!-- How to claim — timeline -->
        <RequirementsBlock
          requirements={ex.requirements}
          kycRequired={ex.kycRequired}
          depositRequired={ex.depositRequired}
          futuresRequired={ex.futuresRequired}
          exchangeName={ex.name}
          minDeposit={minDeposit}
          affiliateUrl={ex.affiliateUrl}
          bonusAmount={ex.bonusAmount}
          bonusCurrency={ex.bonusCurrency}
        />

        <!-- Visual walkthroughs — only rendered for exchanges with walkthrough data -->
        {walkthroughFlows.length > 0 && (
          <section class="ex-section" id="walkthroughs">
            <h2 class="ex-section-title">Step-by-Step Walkthroughs</h2>
            <p class="ex-prose" style="margin-bottom: 1.5rem">
              Our editorial team tested all flows below on the live {ex.name} platform. Screenshots reflect the interface as of the last verification date.
            </p>
            {walkthroughFlows.map((flow) => (
              <WalkthroughFlow
                id={flow.id}
                title={flow.title}
                description={flow.description}
                stepCount={flow.stepCount}
                lastVerified={flow.lastVerified}
                exchangeName={ex.name}
                exchangeSlug={ex.slug}
                affiliateUrl={ex.affiliateUrl}
                ctaLabel={flow.cta?.label}
                ctaBody={flow.cta?.body}
                showCTA={true}
              >
                {flow.steps.map((step, i) => (
                  <WalkthroughStepImage
                    step={i + 1}
                    title={step.title}
                    description={step.description}
                    src={step.src}
                    alt={step.alt}
                    caption={step.caption}
                    capturedAt={step.capturedAt ?? flow.lastVerified}
                    device={step.device ?? 'desktop'}
                    aspectRatio={step.aspectRatio ?? '16/9'}
                    width={step.width ?? (step.device === 'mobile' ? 390 : 1280)}
                    height={step.height ?? (step.device === 'mobile' ? 844 : 720)}
                    warning={step.warning}
                    tip={step.tip}
                    region={step.region}
                    whatHappensNext={step.whatHappensNext}
                    lightboxGroup={flow.id}
                    label={step.screenshotLabel}
                  />
                ))}
              </WalkthroughFlow>
            ))}
          </section>
        )}

        <!-- About exchange -->
        <section class="ex-section">
          <h2 class="ex-section-title">About {ex.name}</h2>
          <p class="ex-prose">{ex.longDescription}</p>
          {((ex as any).editorNote?.length > 30 || (_faqOverride?.editorNote?.length > 30)) && (
            <EditorialNote
              note={(_faqOverride?.editorNote?.length > 30 ? _faqOverride.editorNote : null) ?? (ex as any).editorNote}
              reviewedAt={(ex as any).lastVerified ?? ex.updatedAt}
            />
          )}
        </section>

        <!-- Pros & Cons -->
        <section class="ex-section">
          <h2 class="ex-section-title">Pros & Cons</h2>
          <ProsConsBlock pros={ex.pros} cons={ex.cons} />
        </section>

        <!-- Country availability + cross-links -->
        <section class="ex-section">
          <h2 class="ex-section-title">Country Availability</h2>
          <CountryAvailability countries={ex.countries} excludedCountries={ex.excludedCountries} />
          {countryCrossLinks.length > 0 && (
            <CountryCrossLinksBlock
              countries={countryCrossLinks as any}
              heading="Explore Country-Specific Bonus Guides"
            />
          )}
        </section>

        <!-- Related bonus categories (internal linking) -->
        {relatedCats.length > 0 && (
          <section class="ex-section">
            <h2 class="ex-section-title">Compare by Bonus Type</h2>
            <p class="ex-prose" style="margin-bottom: 0.75rem">
              {ex.name} qualifies across multiple bonus categories. Browse the full comparison for each type:
            </p>
            <RelatedCategoriesBlock
              categories={relatedCats as any}
              heading="Bonus Categories"
            />
          </section>
        )}

        <!-- Related Guides (internal linking) -->
        {relatedGuides.length > 0 && (
          <section class="ex-section">
            <RelatedGuidesBlock
              guides={relatedGuides}
              heading="Related Guides"
              variant="full"
            />
          </section>
        )}

        <!-- Use-case cross-links -->
        {relatedUseCases.length > 0 && (
          <section class="ex-section ex-use-case-links">
            <h3 class="ex-section-sub-title">{ex.name} is recommended for:</h3>
            <div class="ex-uc-chips">
              {relatedUseCases.map(uc => (
                <a href={`/use-cases/${uc.slug}/`} class="ex-uc-chip">
                  {uc.label}
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Related Next Reads — internal distribution, dead-end elimination -->
        {rnrItems.length > 0 && (
          <RelatedNextReads
            heading="Explore next"
            items={rnrItems}
            compact
          />
        )}

        <!-- Bonus landing page link -->
        <section class="ex-section">
          <div class="bonus-page-link-strip">
            <div>
              <div class="bonus-page-link-label">Step-by-step bonus guide</div>
              <div class="bonus-page-link-title">How to Claim the {ex.name} Bonus</div>
            </div>
            <a href={`/bonuses/${ex.slug}-bonus/`} class="bonus-page-link-cta">Claim Guide →</a>
          </div>
        </section>

        <!-- How we evaluate — compact E-E-A-T methodology reference -->
        <HowWeEvaluate variant="compact" />

        <!-- FAQ -->
        <FAQBlock items={faqItems} title={`${ex.name} Bonus — FAQ`} />

      </div>

      <!-- ── STICKY SIDEBAR ── -->
      <aside class="ex-sidebar">
        <div class="sidebar-card">
          <div class="sidebar-label">Bonus Summary</div>
          <div class="sidebar-amount">
            Up to {ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}
          </div>
          <div class="sidebar-title">{ex.bonusTitle}</div>

          <div class="sidebar-stats">
            <div class:list={['sidebar-stat', !ex.kycRequired && 'sidebar-stat--ok']}>
              <span class="sidebar-stat-icon">{ex.kycRequired ? '🪪' : '✓'}</span>
              <span>{ex.kycRequired ? 'KYC Required' : 'No KYC'}</span>
            </div>
            <div class:list={['sidebar-stat', !ex.depositRequired && 'sidebar-stat--ok']}>
              <span class="sidebar-stat-icon">{ex.depositRequired ? '💰' : '✓'}</span>
              <span>
                {minDeposit && minDeposit.amount > 0
                  ? `Min deposit: ${minDeposit.amount} ${minDeposit.currency}`
                  : ex.depositRequired ? 'Deposit Required' : 'No Deposit'}
              </span>
            </div>
            <div class="sidebar-stat">
              <span class="sidebar-stat-icon">⭐</span>
              <span>Rating: {ex.rating}/10</span>
            </div>
            {bonusExpiry && (
              <div class="sidebar-stat">
                <span class="sidebar-stat-icon">⏳</span>
                <span>Expires in {bonusExpiry.days} days</span>
              </div>
            )}
          </div>
          {((ex as any).founded || (ex as any).users || (ex as any).headquarters) && (
            <div class="sidebar-meta">
              {(ex as any).founded && (
                <div class="sidebar-meta-row">
                  <span class="sidebar-meta-label">Founded</span>
                  <span class="sidebar-meta-val">{(ex as any).founded}</span>
                </div>
              )}
              {(ex as any).users && (
                <div class="sidebar-meta-row">
                  <span class="sidebar-meta-label">Users</span>
                  <span class="sidebar-meta-val">{(ex as any).users}</span>
                </div>
              )}
              {(ex as any).headquarters && (
                <div class="sidebar-meta-row">
                  <span class="sidebar-meta-label">HQ</span>
                  <span class="sidebar-meta-val">{(ex as any).headquarters}</span>
                </div>
              )}
            </div>
          )}

          {ex.promoCode && (
            <div class="sidebar-promo">
              <div class="sidebar-promo-label">Promo code</div>
              <div class="sidebar-promo-val">{ex.promoCode}</div>
            </div>
          )}

          <div class="sidebar-cta">
            <CTAButton
              href={ex.affiliateUrl}
              label={!ex.kycRequired && !ex.depositRequired
                ? `Get ${ex.name} Bonus`
                : !ex.kycRequired
                  ? `Claim — No KYC`
                  : `Claim ${ex.name} Bonus`}
              exchange={ex.name}
              size="lg"
              fullWidth
              trackPlacement="sidebar"
              trackBonus={ex.bonusAmount}
              geoHrefs={(ex as any).affiliateLinks?.geo ?? undefined}
            />
          </div>

          {ex.termsUrl && (
            <a href={ex.termsUrl} target="_blank" rel="noopener noreferrer nofollow" class="sidebar-terms">
              View official terms ↗
            </a>
          )}

          <p class="sidebar-risk">{ex.riskNotes}</p>
        </div>

        <!-- Trust block -->
        <div class="sidebar-trust">
          {(ex as any).topChoice && (
            <div class="sidebar-top-choice">⭐ Editor's Top Pick</div>
          )}
          <div class="sidebar-trust-title">Why we list this exchange</div>
          <ul class="sidebar-trust-list">
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {(ex as any).founded
                ? `Established ${(ex as any).founded} — ${new Date().getFullYear() - (ex as any).founded}+ years operating`
                : 'Established platform with track record'}
            </li>
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {(ex as any).users ? `${(ex as any).users} registered users` : 'Cold storage asset protection'}
