---
/**
 * PromoCodeCopy — canonical promo-code field + Copy button.
 *
 * Cloned from the approved review-page hero promo row
 * (`.bh-promo-row` in ExchangePromoPage.astro / bybit / mexc inline copies):
 * same shape, colors, typography, hover and copied-state behavior.
 * The review pages keep their own inline implementation (they are the
 * design source of truth and are not touched); every other surface
 * (homepage cards, /exchanges/ cards, /promo-codes/ table, GEO finder)
 * renders this component.
 *
 * The code value must always come from the existing offer/exchange data —
 * never hardcode codes here or at call sites.
 */
interface Props {
  code: string;
  /** Exchange name for the accessible button label. */
  exchange?: string;
}
const { code, exchange } = Astro.props;
const aria = exchange ? `Copy promo code ${code} for ${exchange}` : `Copy promo code ${code}`;
---

<div class="pcc-row">
  <span class="pcc-code">{code}</span>
  <button class="pcc-copy" data-code={code} type="button" aria-label={aria}>Copy</button>
</div>

<script>
  // Delegated once per page (Astro dedupes this module across instances).
  // Behavior mirrors the review-page hero copy button exactly:
  // 'Copied ✓' + green success state on row/code/button for 1800 ms.
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.pcc-copy');
    if (!btn) return;
    const code = btn.dataset.code ?? '';
    try {
      await navigator.clipboard.writeText(code);
    } catch {
      const ta = document.createElement('textarea');
      ta.value = code;
      ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
    const row = btn.closest('.pcc-row');
    const codeSpan = row?.querySelector('.pcc-code');
    btn.textContent = 'Copied ✓';
    btn.classList.add('copy-success');
    row?.classList.add('copy-success');
    codeSpan?.classList.add('copy-success');
    setTimeout(() => {
      btn.textContent = 'Copy';
      btn.classList.remove('copy-success');
      row?.classList.remove('copy-success');
      codeSpan?.classList.remove('copy-success');
    }, 1800);
  });
</script>

<style>
  /* Byte-for-byte visual clone of .bh-promo-row / .bh-promo-code / .bh-copy-btn */
  .pcc-row {
    width: 100%; max-width: 298px;
    display: flex; align-items: stretch;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    border: 1px solid #D1D5DB; border-radius: 8px; overflow: hidden;
    height: 56px;
    transition: border-color .18s, background .18s;
    color-scheme: light; forced-color-adjust: none;
  }
  .pcc-row.copy-success { border-color: #22c55e !important; background: #dcfce7 !important; }

  .pcc-code {
    flex: 1; display: flex; align-items: center; padding: 0 14px;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 20px; font-weight: 800; letter-spacing: 0.01em; font-stretch: condensed;
    text-transform: uppercase; color: #111827; -webkit-text-fill-color: #111827;
    min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
    transition: color .18s;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .pcc-code { font-size: 22px; letter-spacing: 0.015em; } }
  .pcc-code.copy-success { color: #166534 !important; -webkit-text-fill-color: #166534 !important; }

  .pcc-copy {
    flex-shrink: 0; width: 68px;
    display: flex; align-items: center; justify-content: center;
    border: none; border-left: 1px solid #e5e7eb;
    font-size: 12px; font-weight: 700; color: #16a34a; -webkit-text-fill-color: #16a34a;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    cursor: pointer; transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap; letter-spacing: .03em;
    color-scheme: light; forced-color-adjust: none;
  }
  .pcc-copy:hover { background: #f0fdf4; }
  .pcc-copy:focus-visible { outline: 2px solid #16A34A; outline-offset: 2px; }
  .pcc-copy.copy-success { background: #dcfce7 !important; border-color: #22c55e !important; color: #166534 !important; }
</style>
