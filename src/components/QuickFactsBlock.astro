---
/**
 * QuickFactsBlock — machine-readable quick-facts panel.
 *
 * Optimised for:
 *  - Google AI Overviews (short definitive answers)
 *  - ChatGPT/Perplexity citations (structured fact list)
 *  - Bing Copilot (concise table-like format)
 *  - Featured snippets (definition + quick facts pattern)
 *
 * Renders a compact definition-list-style block with key:value pairs.
 * Uses schema.org Table microdata for additional structure.
 */

interface Props {
  heading?: string;
  facts: { label: string; value: string }[];
  compact?: boolean;
}

const { heading, facts, compact = false } = Astro.props;
---

<div class:list={['qfb', compact && 'qfb--compact']}
  itemscope itemtype="https://schema.org/Table"
  role="region"
  aria-label={heading ?? 'Quick facts'}
>
  {heading && <h3 class="qfb-heading" itemprop="name">{heading}</h3>}
  <dl class="qfb-list">
    {facts.map(f => (
      <div class="qfb-row">
        <dt class="qfb-label">{f.label}</dt>
        <dd class="qfb-value">{f.value}</dd>
      </div>
    ))}
  </dl>
</div>

<style>
  .qfb {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .qfb--compact {
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
  }

  .qfb-heading {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .qfb-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .qfb-row {
    display: grid;
    grid-template-columns: minmax(120px, 40%) 1fr;
    gap: 0.5rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: baseline;
  }
  .qfb-row:last-child { border-bottom: none; }

  .qfb-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .qfb-value {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
  }

  @media (max-width: 480px) {
    .qfb-row {
      grid-template-columns: 1fr;
      gap: 0.05rem;
      padding: 0.5rem 0;
    }
    .qfb-label { font-size: 0.72rem; }
    .qfb-value { font-size: 0.85rem; }
  }
</style>
