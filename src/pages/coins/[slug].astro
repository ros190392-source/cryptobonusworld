---
/**
 * /coins/[slug]/ — Coin-specific exchange comparison pages.
 *
 * Architecture:
 *  - Static paths from COINS data (src/data/coins.ts)
 *  - Filters exchanges.json to those supporting the coin
 *  - Renders: AI summary, ranked table, no-KYC highlight, network info, FAQs
 *  - Full structured data: ItemList + FAQPage
 *
 * Target intents:
 *  "best exchange to buy [coin]"
 *  "buy [coin] without KYC"
 *  "best [coin] bonus"
 *  "[coin] deposit network"
 */

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AiSummaryBlock from '../../components/AiSummaryBlock.astro';
import QuickFactsBlock from '../../components/QuickFactsBlock.astro';
import BonusTable from '../../components/BonusTable.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import RelatedGuidesBlock from '../../components/RelatedGuidesBlock.astro';
import ExchangeLogo from '../../components/ExchangeLogo.astro';
import CTAButton from '../../components/CTAButton.astro';

import { COINS, getCoinBySlug } from '../../data/coins';
import exchanges from '../../data/exchanges.json';
import guides from '../../data/guides.json';

import { buildItemListSchema, SITE_URL, YEAR } from '../../utils/seo';
import type { PageContext } from '../../utils/analytics';

export async function getStaticPaths() {
  return COINS.map(coin => ({
    params: { slug: coin.slug },
    props: { coin },
  }));
}

const { coin } = Astro.props;

// ── Filter exchanges that support this coin ──────────────────────────────────
const supported: typeof exchanges =
  coin.supportedBy === 'all'
    ? [...exchanges]
    : exchanges.filter(ex => (coin.supportedBy as string[]).includes(ex.slug));

const ranked = [...supported].sort((a, b) => b.rating - a.rating);
const noKycExchanges = ranked.filter(ex => !ex.kycRequired);
const topPick = ranked[0];

// ── Related guides ───────────────────────────────────────────────────────────
const relatedGuides = guides.filter(g =>
  g.slug === coin.relatedGuideSlug || g.tags?.includes('buying') || g.tags?.includes('bonus')
).slice(0, 3);

// ── AI Summary items ─────────────────────────────────────────────────────────
const aiItems = ranked.slice(0, 5).map(ex => ({
  label: ex.name,
  value: `Up to ${ex.bonusAmount.toLocaleString('en-US')} ${ex.bonusCurrency} — ${ex.shortDescription.split('.')[0]}`,
  note: `${ex.kycRequired ? 'KYC required' : 'No KYC'} · ${ex.depositRequired ? `Min deposit $${(ex.minDeposit as any)?.amount ?? '—'}` : 'No min deposit'}`,
}));

// ── Structured data ──────────────────────────────────────────────────────────
const itemListSchema = buildItemListSchema(
  ranked.map(ex => ({
    name: `${ex.name} — Buy ${coin.symbol} With Bonus`,
    url: `/exchanges/${ex.slug}/`,
    description: ex.shortDescription,
  })),
  `Best Exchanges to Buy ${coin.label} (${coin.symbol}) ${YEAR}`
);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: coin.faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const analyticsContext: PageContext = { pageType: 'category' };
---

<Layout
  title={coin.seoTitle}
  description={coin.metaDesc}
  canonical={`/coins/${coin.slug}/`}
  schema={[itemListSchema, faqSchema]}
  analyticsContext={analyticsContext}
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Coins', href: '/coins/' },
      { label: coin.label },
    ]} />

    <div class="page-header">
      <div class="coin-header">
        <span class="coin-symbol-badge">{coin.symbol}</span>
        <div>
          <h1>Best Exchanges to Buy {coin.label} ({coin.symbol}) in {YEAR}</h1>
          <p class="lead">
            {ranked.length} exchange{ranked.length !== 1 ? 's' : ''} support {coin.symbol}.
            {noKycExchanges.length > 0 && `${noKycExchanges.length} available without KYC.`}
          </p>
        </div>
      </div>
    </div>

    <AffiliateDisclosure compact />

    <AiSummaryBlock
      title={`Best Exchanges to Buy ${coin.label} — Quick Summary`}
      intro={`These exchanges support ${coin.symbol} trading and offer new-user bonuses. Rankings are based on bonus value, fees, and ease of use. All verified May ${YEAR}.`}
      updatedDate={`May ${YEAR}`}
      items={aiItems}
    />

    <QuickFactsBlock
      heading={`${coin.label} (${coin.symbol}) — Key Facts`}
      facts={coin.quickFacts}
    />

    <!-- Exchange table -->
    <section class="section">
      <h2 class="section-title">All Exchanges That Support {coin.symbol}</h2>
      <BonusTable exchanges={ranked} suppressSchema={true} />
    </section>

    <!-- No-KYC section -->
    {noKycExchanges.length > 0 && (
      <section class="section nokyc-section" aria-label={`No-KYC exchanges for ${coin.symbol}`}>
        <div class="nokyc-header">
          <span class="nokyc-badge">🔓 No KYC Required</span>
          <h2 class="section-title">Buy {coin.symbol} Without Identity Verification</h2>
          <p class="section-sub">
            These exchanges allow you to buy {coin.label} without submitting personal documents.
            Withdrawal limits may apply to unverified accounts.
          </p>
        </div>
        <div class="nokyc-grid">
          {noKycExchanges.slice(0, 4).map(ex => (
            <a href={`/exchanges/${ex.slug}/`} class="nokyc-card">
              <ExchangeLogo slug={ex.slug} name={ex.name} size={64} variant="square" />
              <div class="nokyc-card-info">
                <span class="nokyc-card-name">{ex.name}</span>
                <span class="nokyc-card-bonus">Up to {ex.bonusAmount.toLocaleString('en-US')} {ex.bonusCurrency}</span>
              </div>
              <span class="nokyc-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Network support table -->
    {coin.networks.length > 0 && (
      <section class="section">
        <h2 class="section-title">{coin.symbol} Deposit Networks Explained</h2>
        <p class="section-sub">
          Always select the correct network when depositing {coin.symbol} to an exchange.
          Sending to the wrong network results in permanent loss of funds.
        </p>
        <div class="networks-table" role="table" aria-label={`${coin.symbol} deposit networks`}>
          <div class="networks-head" role="row">
            <span role="columnheader">Network</span>
            <span role="columnheader">Notes</span>
          </div>
          {coin.networks.map(net => (
            <div class={`networks-row${coin.recommendedNetwork === net.name ? ' networks-row--recommended' : ''}`} role="row">
              <span role="cell" class="networks-name">
                {net.name}
                {coin.recommendedNetwork === net.name && <span class="networks-tag">Recommended</span>}
              </span>
              <span role="cell" class="networks-note">{net.note ?? '—'}</span>
            </div>
          ))}
        </div>
        {coin.minBuyNote && (
          <p class="networks-footnote">💡 {coin.minBuyNote}</p>
        )}
      </section>
    )}

    <!-- Beginner explanation -->
    <section class="section intro-section">
      <h2 class="section-title">About {coin.label} ({coin.symbol})</h2>
      <div class="intro-prose">
        <p>{coin.intro}</p>
        <p><strong>Primary use case:</strong> {coin.useCase}</p>
        {coin.geoNote && (
          <p class="intro-geo-note">🌍 <strong>Regional note:</strong> {coin.geoNote}</p>
        )}
      </div>
    </section>

    <!-- Top pick CTA -->
    {topPick && (
      <div class="top-pick-cta">
        <div class="top-pick-inner">
          <ExchangeLogo slug={topPick.slug} name={topPick.name} size={80} variant="square" />
          <div class="top-pick-text">
            <span class="top-pick-label">Editor's Top Pick for {coin.symbol}</span>
            <span class="top-pick-name">{topPick.name} — Up to {topPick.bonusAmount.toLocaleString('en-US')} {topPick.bonusCurrency}</span>
          </div>
          <CTAButton
            href={`/exchanges/${topPick.slug}/`}
            label={`Claim ${topPick.name} Bonus →`}
            variant="primary"
            size="sm"
          />
        </div>
      </div>
    )}

    <!-- FAQ -->
    <FAQBlock items={coin.faq} suppressSchema={true} />

    <!-- Related guides -->
    {relatedGuides.length > 0 && (
      <RelatedGuidesBlock guides={relatedGuides} heading={`Guides: Buying ${coin.label}`} />
    )}

    <!-- Hub cross-links: bonuses + compare -->
    <section class="coin-hub-links" aria-label="Explore bonus offers and comparisons">
      <h2 class="coin-hub-links__title">Compare Bonuses &amp; Find the Best Offer</h2>
      <div class="coin-hub-links__grid">
        <a href="/bonuses/" class="coin-hub-links__card">
          <span class="coin-hub-links__icon">🎁</span>
          <div>
            <strong>All Exchange Bonuses</strong>
            <p>Filter and compare bonuses across all {ranked.length} exchanges that support {coin.symbol} — by type, KYC status and country.</p>
          </div>
          <span class="coin-hub-links__arrow">→</span>
        </a>
        <a href="/compare/" class="coin-hub-links__card">
          <span class="coin-hub-links__icon">⚖️</span>
          <div>
            <strong>Side-by-Side Exchange Comparisons</strong>
            <p>Not sure which exchange to use for {coin.symbol}? Compare any two exchanges head-to-head on bonuses, fees and KYC.</p>
          </div>
          <span class="coin-hub-links__arrow">→</span>
        </a>
      </div>
    </section>

    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }

  .coin-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .coin-symbol-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    height: 52px;
    background: rgba(245,197,66,0.12);
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 800;
    border-radius: 12px;
    border: 1px solid rgba(245,197,66,0.2);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .section { margin: 2rem 0; }
  .section-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .section-sub {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  /* No-KYC section */
  .nokyc-section {
    padding: 1.25rem;
    background: rgba(74,222,128,0.03);
    border: 1px solid rgba(74,222,128,0.12);
    border-radius: 14px;
  }
  .nokyc-header { margin-bottom: 1rem; }
  .nokyc-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #4ade80;
    background: rgba(74,222,128,0.1);
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
    margin-bottom: 0.5rem;
  }
  .nokyc-header .section-title { margin-bottom: 0.35rem; }
  .nokyc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.625rem;
  }
  .nokyc-card {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .nokyc-card:hover {
    border-color: rgba(74,222,128,0.3);
    background: rgba(74,222,128,0.04);
  }
  .nokyc-card-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }
  .nokyc-card-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .nokyc-card-bonus {
    font-size: 0.72rem;
    color: var(--color-accent);
    font-weight: 600;
  }
  .nokyc-arrow {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    transition: transform 0.15s;
  }
  .nokyc-card:hover .nokyc-arrow { transform: translateX(2px); }

  /* Networks table */
  .networks-table {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    font-size: 0.875rem;
  }
  .networks-head {
    display: grid;
    grid-template-columns: 1fr 2fr;
    padding: 0.625rem 1rem;
    background: rgba(255,255,255,0.03);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
  }
  .networks-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border);
    align-items: center;
  }
  .networks-row:last-child { border-bottom: none; }
  .networks-row--recommended { background: rgba(245,197,66,0.04); }
  .networks-name {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .networks-tag {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: rgba(245,197,66,0.12);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
  }
  .networks-note { color: var(--color-text-secondary); }
  .networks-footnote {
    margin-top: 0.625rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* Intro prose */
  .intro-prose {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .intro-prose strong { color: var(--color-text-primary); }
  .intro-geo-note {
    padding: 0.625rem 0.875rem;
    background: rgba(255,255,255,0.03);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
  }

  /* Top pick CTA */
  .top-pick-cta {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(90deg, rgba(245,197,66,0.07) 0%, rgba(245,197,66,0.02) 100%);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: 14px;
  }
  .top-pick-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .top-pick-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .top-pick-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }
  .top-pick-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  @media (max-width: 640px) {
    .coin-header { flex-direction: row; align-items: flex-start; }
    .networks-head, .networks-row { grid-template-columns: 1fr; gap: 0.1rem; }
    .networks-head span:last-child, .networks-row span:last-child { color: var(--color-text-muted); font-size: 0.8rem; }
    .top-pick-inner { flex-direction: column; align-items: flex-start; }
    .coin-hub-links__grid { grid-template-columns: 1fr; }
  }

  /* ── Hub cross-links ── */
  .coin-hub-links { margin: 2.5rem 0; }
  .coin-hub-links__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 1.25rem;
    color: var(--color-text-primary);
  }
  .coin-hub-links__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }
  .coin-hub-links__card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.125rem 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 14px);
    text-decoration: none;
    color: var(--color-text-primary);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .coin-hub-links__card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent, #f5c542) inset;
  }
  .coin-hub-links__icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 0.1rem; }
  .coin-hub-links__card div { flex: 1; min-width: 0; }
  .coin-hub-links__card strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--color-text-primary);
  }
  .coin-hub-links__card p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .coin-hub-links__arrow { font-size: 0.9rem; color: var(--color-accent); flex-shrink: 0; margin-top: 0.1rem; }
</style>
