---
/**
 * AnswerBox — machine-readable concise answer block.
 *
 * Optimised for:
 *  - Google featured snippets (direct answer format)
 *  - Google AI Overviews (short definitive paragraph)
 *  - ChatGPT / Perplexity citations (clean answer + source label)
 *  - Bing Copilot (structured Q&A format)
 *
 * Uses FAQPage schema when embedded in a FAQ context, or standalone
 * as a standalone answer paragraph with clear question label.
 *
 * Keep `answer` between 40–100 words for optimal snippet capture.
 */

interface Props {
  question: string;
  answer: string;
  updatedDate?: string;
  compact?: boolean;
}

const { question, answer, updatedDate, compact = false } = Astro.props;
---

<div
  class:list={['ab', compact && 'ab--compact']}
  itemscope
  itemtype="https://schema.org/Question"
  role="note"
  aria-label="Quick answer"
>
  <div class="ab-q-row">
    <span class="ab-icon" aria-hidden="true">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
      </svg>
    </span>
    <span class="ab-question" itemprop="name">{question}</span>
    {updatedDate && <span class="ab-date">Updated {updatedDate}</span>}
  </div>
  <div
    class="ab-answer"
    itemprop="acceptedAnswer"
    itemscope
    itemtype="https://schema.org/Answer"
  >
    <p itemprop="text">{answer}</p>
  </div>
</div>

<style>
  .ab {
    background: rgba(245,197,66,0.04);
    border: 1px solid rgba(245,197,66,0.18);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 10px 10px 0;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .ab--compact {
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
  }

  .ab-q-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .ab-icon { color: var(--color-accent); flex-shrink: 0; }

  .ab-question {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-accent);
    flex: 1;
  }

  .ab-date {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ab-answer p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .ab-answer strong {
    color: var(--color-text-primary);
  }
</style>
