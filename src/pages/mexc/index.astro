---
/*
 * EXCHANGE PAGE TEMPLATE — CLONE CHECKLIST
 * To clone for a new exchange, update the exchange object fields:
 *   name, slug, affiliateUrl, officialDomain, supportUrl, feeUrl,
 *   bonusMax, currency, founded, users, headquarters,
 *   wordmarkImg, articleImg, logoImg, ogImage,
 *   fees.spot / fees.futures,
 *   rewardsAreaName ('Rewards Hub' for Bybit, 'Reward Center' for OKX)
 * Update brandHeroTokens for exchange brand colors.
 * Update relatedExchanges (exclude self).
 * canonical + ogImage in CleanLayout auto-derive from exchange object.
 * Manual per-clone: restrictedCountries prose, evidence image paths,
 *   fee table status notes, verification table date notes.
 */
import CleanLayout from '../../layouts/CleanLayout.astro';
import { getOffer } from '../../data/offers';

const offer = getOffer('mexc')!;

// Static exchange data — volatile fields come from offer
const exchange = {
  name:           'MEXC',
  slug:           'mexc',
  affiliateUrl:   '/go/mexc/',
  officialDomain: 'mexc.com',
  supportUrl:     'https://www.mexc.com/support',
  feeUrl:         'https://www.mexc.com/fee',
  bonusMax:       10000,
  currency:       'USDT',
  minDeposit:     0,
  founded:        2018,
  users:          '10M+',
  headquarters:   'Seychelles',
  wordmarkImg:    '/logos/mexc-wordmark-light.svg',
  articleImg:     '/media/exchanges/mexc/final/mexc-article-final-v1-1200x675.jpg',
  logoImg:        '/logos/mexc.png',
  ogImage:        '/media/exchanges/mexc/final/mexc-og-final-v1-1200x630.jpg',
  rewardsAreaName:'Activity Center',
  fees: {
    spot:    { maker: '0%',    taker: '0.05%' },
    futures: { maker: '0%',    taker: '0.01%' },
  },
};

const relatedExchanges = [
  { slug: 'bybit',  name: 'Bybit',  logo: '/logos/bybit.png',  bonus: 'Up to 30,000 USDT', tag: 'Derivatives leader', tileBg: '#F7F8FA' },
  { slug: 'bitget', name: 'Bitget', logo: '/logos/bitget.png', bonus: 'Up to 6,200 USDT',  tag: 'Copy trading',     tileBg: '#ECFDF5' },
  { slug: 'bingx',  name: 'BingX',  logo: '/logos/bingx.png',  bonus: 'Up to 5,125 USDT',  tag: 'Social trading',   tileBg: '#EFF6FF' },
  { slug: 'okx',    name: 'OKX',    logo: '/logos/okx.png',    bonus: 'Up to 10,000 USDT', tag: 'CEX + Web3',       tileBg: '#F3F4F6' },
];

const brandHeroTokens = {
  'bh-bgFrom':     '#060E1A',
  'bh-bgTo':       '#0A2038',
  'bh-text':       '#ffffff',
  'bh-text2':      'rgba(255,255,255,0.65)',
  'bh-accent':     '#0BCDFF',
  'bh-codeBg':     'rgba(11,205,255,0.10)',
  'bh-codeBorder': 'rgba(11,205,255,0.40)',
  'bh-note':       'rgba(255,255,255,0.38)',
};
const bhStyle = Object.entries(brandHeroTokens).map(([k,v]) => `--${k}:${v}`).join(';');

const pageCanonical = `https://cryptobonusworld.com/${exchange.slug}/`;

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",                           "item": "https://cryptobonusworld.com/" },
        { "@type": "ListItem", "position": 2, "name": `${exchange.name} Referral Code`, "item": pageCanonical }
      ]
    },
    {
      "@type": "WebPage",
      "@id": pageCanonical,
      "url": pageCanonical,
      "name": `${exchange.name} Referral Code 2026: ${offer.promoCode} — Up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency} Bonus`,
      "description": `${exchange.name} referral code ${offer.promoCode} — up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency} in new user rewards. No KYC required for base tiers. Verified ${offer.lastChecked}.`,
      "publisher": { "@type": "Organization", "name": "CryptoBonusWorld", "url": "https://cryptobonusworld.com/" },
      "inLanguage": "en"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Do I have to make a cryptocurrency deposit?",
          "acceptedAnswer": { "@type": "Answer", "text": `No deposit is required for the base signup reward. The initial ${exchange.name} welcome bonus can be claimed through email or phone registration alone — no identity verification or deposit is needed for the first reward tier. Larger deposit and trading bonuses do require you to fund your account, with rewards scaling by deposit and volume. Check the ${exchange.name} ${exchange.rewardsAreaName} after registering to see which tasks are active for your account and region.` }
        },
        {
          "@type": "Question",
          "name": `Can I get more than one ${exchange.name} bonus?`,
          "acceptedAnswer": { "@type": "Answer", "text": `Yes — the ${exchange.name} new user bonus is structured as a series of separate tasks, each with its own reward. You can earn multiple rewards by registering, completing a first deposit, placing futures trades, and reaching volume milestones. The welcome package itself is a one-time offer for new accounts and cannot be repeated on the same account.` }
        },
        {
          "@type": "Question",
          "name": `What are the ${exchange.name} fees?`,
          "acceptedAnswer": { "@type": "Answer", "text": `${exchange.name}'s standard spot trading fee is ${exchange.fees.spot.maker} for makers and ${exchange.fees.spot.taker} for takers. Perpetual futures fees are ${exchange.fees.futures.maker} for makers and ${exchange.fees.futures.taker} for takers. These rates were verified on the official ${exchange.name} fee page in ${offer.lastChecked}. Rates may vary by VIP level, trading pair, and current fee schedule — always check ${exchange.officialDomain}/fee before trading.` }
        },
        {
          "@type": "Question",
          "name": "Which currency are rewards paid in?",
          "acceptedAnswer": { "@type": "Answer", "text": `${exchange.name} new user rewards are typically issued as USDT vouchers or trading coupons. Specific reward formats, including any voucher conditions or volume requirements for conversion, are shown inside the ${exchange.name} ${exchange.rewardsAreaName} for each task after registration.` }
        },
        {
          "@type": "Question",
          "name": "Can existing users use the referral code?",
          "acceptedAnswer": { "@type": "Answer", "text": `No. The ${exchange.name} referral code ${offer.promoCode} is for new users only and must be entered during account creation. It cannot be added to an existing ${exchange.name} account after registration is complete. If you already have a ${exchange.name} account, check the ${exchange.rewardsAreaName} inside your account for any available ongoing promotions.` }
        },
        {
          "@type": "Question",
          "name": `Is the ${exchange.name} bonus available in every country?`,
          "acceptedAnswer": { "@type": "Answer", "text": `No. ${exchange.name} restricts service in a number of jurisdictions. Residents of North Korea, Cuba, Sudan, Iran, Mainland China, Singapore, the United States, the United Kingdom, Hong Kong, Russian-controlled regions of Ukraine, and Canada are not eligible. This list may change. Even in supported countries, specific bonus tasks or amounts may differ by region and current promotion terms.` }
        }
      ]
    }
  ]
};
---

<CleanLayout
  title={`${exchange.name} Referral Code 2026: ${offer.promoCode} — Up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency}`}
  description={`${exchange.name} referral code ${offer.promoCode} — up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency} in new user rewards. No KYC required for base tiers. Verified ${offer.lastChecked}. Enter code at registration.`}
  canonical={pageCanonical}
  ogImage={exchange.ogImage}
  ogTitle={`${exchange.name} Referral Code: ${offer.promoCode} — Claim Bonus`}
  ogDescription={`Use ${exchange.name} referral code ${offer.promoCode} to claim up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency} in new user rewards. No KYC required for base tier. Verified ${offer.lastChecked} by CryptoBonusWorld.`}
>

<style>
  /* ── Breadcrumb ──────────────────────────────────────────── */
  .breadcrumb-nav { background: #F3F4F6; border-bottom: 1px solid #E5E7EB; padding: 0; }
  .breadcrumb-inner { max-width: 760px; margin: 0 auto; padding: 6px 20px; }
  .breadcrumb-list { display: flex; align-items: center; flex-wrap: wrap; gap: 4px; list-style: none; margin: 0; padding: 0; }
  .breadcrumb-item { font-size: 13px; color: #6B7280; line-height: 1.4; }
  .breadcrumb-link { color: #6B7280; text-decoration: none; }
  .breadcrumb-link:hover { color: #374151; text-decoration: underline; }
  .breadcrumb-sep { font-size: 13px; color: #9CA3AF; }
  .breadcrumb-current { color: #374151; font-weight: 500; }

  /* ── Proto design tokens (replaces ProtoLayout :root vars) ─ */
  :root {
    --proto-bg:             #F7F8F4;
    --proto-surface:        #ffffff;
    --proto-surface-2:      #F3F4F6;
    --proto-border:         #E5E7EB;
    --proto-border-strong:  #D1D5DB;
    --proto-text:           #111827;
    --proto-text-2:         #4B5563;
    --proto-text-3:         #9CA3AF;
    --proto-accent:         #0BCDFF;
    --proto-accent-dark:    #0099cc;
    --proto-cta:            #16A34A;
    --proto-cta-hover:      #15803D;
    --proto-verified:       #16A34A;
    --proto-verified-light: #f0fdf4;
    --proto-warning:        #b45309;
    --proto-warning-light:  #fffbeb;
    --proto-danger:         #dc2626;
    --proto-radius:         10px;
    --proto-radius-lg:      16px;
    --proto-shadow:         0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --proto-shadow-md:      0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  }

  /* ── Narrow content wrapper (760px) ── */
  .bw-wrap { max-width: 760px; margin: 0 auto; padding: 0 20px; }

  /* ── Section base ─────────────────────────────────────────── */
  .mexc-section { padding: 40px 0; background: var(--proto-bg); }
  .mexc-section + .mexc-section { border-top: 1px solid var(--proto-border); }

  /* ── Title bar ────────────────────────────────────────────── */
  .title-bar {
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    border-bottom: 1px solid var(--proto-border);
    text-align: center; padding: 9px 20px;
    color-scheme: light; forced-color-adjust: none;
  }
  .title-bar h1 {
    font-size: 20px; font-weight: 700; color: var(--proto-text);
    margin: 0; line-height: 1.25;
  }
  @media (max-width: 479px) {
    .title-bar { padding: 9px 20px; }
    .title-bar h1 { font-size: 18px; }
  }

  /* ── Brand Hero ───────────────────────────────────────────── */
  .brand-hero {
    background: linear-gradient(160deg, var(--bh-bgFrom) 0%, var(--bh-bgTo) 100%);
    padding: 35px 0 54px;
    color: var(--bh-text);
  }
  @media (min-width: 640px) {
    .brand-hero { padding: 42px 0 46px; display: flex; flex-direction: column; justify-content: center; }
  }
  .bh-inner { width: 100%; max-width: 540px; margin: 0 auto; padding: 0 20px; text-align: center; box-sizing: border-box; }

  .bh-wordmark { display: block; width: 165px; height: auto; margin: 0 auto 10px; filter: none; opacity: 1; }
  @media (min-width: 640px) { .bh-wordmark { width: 210px; } }
  @media (max-width: 359px) { .bh-wordmark { width: 140px; } }

  .bh-promo-label {
    display: block;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 22px; font-weight: 700; text-transform: uppercase;
    font-stretch: condensed; letter-spacing: 0.09em; color: var(--bh-text);
    line-height: 1.1; margin-top: 16px; margin-bottom: 24px;
  }
  @media (min-width: 640px) { .bh-promo-label { font-size: 18px; letter-spacing: 0.10em; margin-top: 18px; margin-bottom: 26px; } }

  .bh-promo-row {
    width: 100%; max-width: 298px;
    margin-left: auto; margin-right: auto;
    display: flex; align-items: stretch;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    border: 1px solid #D1D5DB; border-radius: 8px; overflow: hidden;
    height: 56px; margin-bottom: 14px;
    transition: border-color .18s, background .18s;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-promo-row.copy-success { border-color: #22c55e !important; background: #dcfce7 !important; }

  .bh-promo-code {
    flex: 1; display: flex; align-items: center; padding: 0 14px;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 20px; font-weight: 800; letter-spacing: 0.01em; font-stretch: condensed;
    text-transform: uppercase; color: #111827; -webkit-text-fill-color: #111827;
    min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
    transition: color .18s;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .bh-promo-code { font-size: 22px; letter-spacing: 0.015em; } }
  .bh-promo-code.copy-success { color: #166534 !important; -webkit-text-fill-color: #166534 !important; }

  .bh-copy-btn {
    flex-shrink: 0; width: 68px;
    display: flex; align-items: center; justify-content: center;
    border: none; border-left: 1px solid #e5e7eb;
    font-size: 12px; font-weight: 700; color: #16a34a; -webkit-text-fill-color: #16a34a;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    cursor: pointer; transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap; letter-spacing: .03em;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-copy-btn:hover { background: #f0fdf4; }
  .bh-copy-btn.copy-success { background: #dcfce7 !important; border-color: #22c55e !important; color: #166534 !important; }

  .bh-cta-btn {
    display: flex; align-items: center; justify-content: center;
    width: 100%; max-width: 320px; margin-left: auto; margin-right: auto;
    background: #55C72F; color: #fff;
    font-size: 24px; font-weight: 700; border-radius: 6px;
    height: 68px; margin-bottom: 12px;
    transition: background .15s, transform .1s; letter-spacing: 0;
    text-decoration: none;
  }
  @media (min-width: 640px) { .bh-cta-btn { font-size: 28px; } }
  .bh-cta-btn:hover { background: #46b024; transform: translateY(-1px); }

  .bh-source {
    font-size: 14px; color: var(--bh-note); line-height: 1.65;
    margin: 8px 0 0; text-align: center;
  }
  @media (min-width: 640px) { .bh-source { font-size: 15px; } }
  .bh-source a { color: var(--bh-note); text-decoration: underline; text-underline-offset: 2px; text-decoration-color: rgba(255,255,255,0.35); }
  .bh-source a:hover { text-decoration-color: var(--bh-note); }

  /* ── Compact facts table ──────────────────────────────────── */
  .compact-facts {
    background: #ffffff !important;
    padding: 20px 16px 6px; color-scheme: light; forced-color-adjust: none;
  }
  .cf-inner {
    max-width: 720px; margin: 0 auto; padding: 0;
    background: #F3F4F6; border: 1px solid #D1D5DB;
    border-radius: 8px; overflow: hidden;
  }
  .cf-table { width: 100%; border-collapse: collapse; font-size: 14px; background: #F3F4F6; table-layout: fixed; }
  .cf-table tr { border-bottom: 1px solid #E5E7EB; }
  .cf-table tr:last-child { border-bottom: none; }
  .cf-table td { padding: 11px 16px; vertical-align: middle; background: #F3F4F6; color: #111827; word-wrap: break-word; overflow-wrap: break-word; }
  .cf-table td:first-child { color: #374151 !important; font-size: 14px; font-weight: 500; width: 50%; }
  .cf-table td:last-child { font-weight: 600; color: #111827 !important; }
  @media (max-width: 479px) {
    .cf-table td { padding: 10px 12px; font-size: 13px; }
    .cf-table td:first-child { font-size: 13px; }
  }
  .cf-code { font-family: 'Courier New', monospace; letter-spacing: .04em; color: #0099cc !important; -webkit-text-fill-color: #0099cc !important; }
  .cf-good { color: #16a34a !important; -webkit-text-fill-color: #16a34a !important; }
  .cf-warn { color: #b45309 !important; -webkit-text-fill-color: #b45309 !important; font-weight: 500 !important; }

  /* ── SEO intro block ─────────────────────────────────────── */
  .seo-intro-block {
    background: #ffffff; border-bottom: 1px solid #E5E7EB;
    padding: 8px 20px 20px;
  }
  .seo-intro-inner { max-width: 720px; margin: 0 auto; }
  .seo-phrase {
    font-size: 14px; font-weight: 400; color: #9CA3AF;
    margin: 0; padding-bottom: 10px; font-style: italic;
    border-bottom: 1px solid #E5E7EB;
  }
  .seo-intro-text {
    font-size: 15px; color: #4B5563; line-height: 1.65;
    margin: 12px 0 0;
  }
  @media (max-width: 479px) {
    .seo-phrase { font-size: 13px; }
    .seo-intro-text { font-size: 14px; }
  }

  /* ═══════════════════════════════════════════════════════════
     PART 2 — SEO SKELETON
  ═══════════════════════════════════════════════════════════ */

  .p2-section {
    background: #ffffff; border-bottom: 1px solid #E5E7EB;
    padding: 28px 0;
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-section-alt { background: #F9FAFB; }
  .p2-inner { max-width: 720px; margin: 0 auto; padding: 0 20px; }

  .p2-h2 { font-size: 20px; font-weight: 700; color: #111827; margin: 0 0 14px; line-height: 1.3; }
  @media (min-width: 640px) { .p2-h2 { font-size: 22px; } }
  .p2-h3 { font-size: 16px; font-weight: 700; color: #111827; margin: 20px 0 10px; line-height: 1.35; }
  @media (min-width: 640px) { .p2-h3 { font-size: 17px; } }

  .p2-placeholder {
    background: #F3F4F6; border: 1px dashed #D1D5DB; border-radius: 6px;
    padding: 12px 16px; font-size: 12px; color: #9CA3AF;
    font-family: 'Courier New', monospace; line-height: 1.5;
    color-scheme: light; forced-color-adjust: none;
  }

  .p2-cta-block { text-align: center; }
  .p2-cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: #55C72F; color: #fff;
    font-size: 16px; font-weight: 700; border-radius: 8px;
    padding: 0 28px; height: 52px;
    width: 100%; max-width: 340px;
    text-decoration: none; letter-spacing: .01em;
    transition: background .15s, transform .1s;
  }
  .p2-cta-btn:hover { background: #46b024; transform: translateY(-1px); }

  .p2-text {
    font-size: 14px; color: #374151; line-height: 1.7; margin: 0 0 12px;
  }
  .p2-text:last-child { margin-bottom: 0; }
  @media (min-width: 640px) { .p2-text { font-size: 15px; } }

  /* Full-width article CTA bar */
  .p2-cta-bar {
    display: flex; align-items: center; justify-content: center;
    background: #55C72F; color: #fff;
    font-size: 17px; font-weight: 700; border-radius: 8px;
    padding: 0 24px; height: 56px; width: 100%; box-sizing: border-box;
    text-decoration: none; letter-spacing: .01em;
    transition: background .18s ease, transform .15s ease, box-shadow .18s ease;
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-cta-bar:hover {
    background: #46b024;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(70,176,36,0.35);
  }

  .p2-steps {
    margin: 0 0 20px; padding: 0; list-style: none;
    counter-reset: p2-step-counter;
    display: flex; flex-direction: column; gap: 10px;
  }
  .p2-step {
    display: flex; align-items: flex-start; gap: 12px;
    counter-increment: p2-step-counter;
    font-size: 14px; color: #374151; line-height: 1.55;
  }
  .p2-step::before {
    content: counter(p2-step-counter);
    flex-shrink: 0; width: 26px; height: 26px;
    background: #111827; color: #fff; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; margin-top: 1px;
  }
  @media (min-width: 640px) { .p2-step { font-size: 15px; } }

  .p2-screenshot-placeholder {
    background: #F3F4F6; border: 1px solid #E5E7EB; border-radius: 8px;
    min-height: 160px; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px; padding: 24px 20px; text-align: center;
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .p2-screenshot-placeholder { min-height: 200px; } }
  .p2-screenshot-label {
    font-family: 'Courier New', monospace; font-size: 11px; color: #9CA3AF;
    letter-spacing: .04em; text-transform: uppercase; line-height: 1.5;
  }
  .p2-screenshot-desc { font-size: 12px; color: #D1D5DB; line-height: 1.4; margin-top: 4px; }

  .p2-evidence-figure { margin: 0; text-align: center; }
  .p2-evidence-img {
    max-width: 360px; width: 100%; height: auto;
    display: block; margin: 0 auto;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.10);
  }
  .p2-evidence-caption {
    font-size: 12px; color: #6B7280; line-height: 1.5;
    margin-top: 8px; text-align: center;
  }
  .p2-evidence-img--wide { max-width: 740px; }

  .p2-table-wrap {
    overflow-x: auto; border-radius: 8px; border: 1px solid #D1D5DB;
    margin-top: 10px; color-scheme: light; forced-color-adjust: none;
  }
  .p2-table {
    width: 100%; border-collapse: collapse; font-size: 13px;
    background: #F9FAFB; min-width: 320px;
  }
  .p2-table th {
    background: #F3F4F6; padding: 10px 14px; text-align: left;
    font-size: 12px; font-weight: 600; color: #6B7280;
    border-bottom: 1px solid #E5E7EB; white-space: nowrap;
  }
  .p2-table td { padding: 10px 14px; color: #374151; border-bottom: 1px solid #F3F4F6; }
  .p2-table tr:last-child td { border-bottom: none; }
  .p2-table-placeholder-row td {
    text-align: center; color: #9CA3AF;
    font-size: 12px; font-style: italic; padding: 18px 14px;
  }

  .p2-faq { display: flex; flex-direction: column; gap: 4px; }
  .p2-faq-item {
    border: 1px solid #E5E7EB; border-radius: 8px;
    overflow: hidden; background: #fff;
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-faq-q {
    padding: 13px 16px; font-size: 14px; font-weight: 600;
    color: #111827; cursor: pointer; list-style: none;
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px; transition: background .12s;
  }
