---
/**
 * ExchangeLogo.astro — Normalized exchange logo renderer
 *
 * Visual consistency system:
 *   - All logos render in a fixed-size square container
 *   - PNG loads first (official brand icons), SVG fallback second
 *   - Safe-area padding per exchange prevents optical size disparities
 *   - object-fit: contain — never crops logos
 *   - Letter avatar fallback when no image available
 *
 * Sizes used across the site:
 *   BonusTable desktop: 80px
 *   BonusTable mobile:  68px
 *   ExchangeHero:       64px
 *   RelatedGuides:      56px
 *   Navigation:         32px
 *   Inline chips:       24px
 */

interface Props {
  slug: string;
  name: string;
  /** Container size in px (width = height). Default 40. */
  size?: number;
  /** 'square' = rounded square, 'pill' = fully rounded, 'raw' = no container */
  variant?: 'square' | 'pill' | 'raw';
  /** Extra CSS classes on the wrapper */
  class?: string;
  /** Lazy load the image (default true) */
  lazy?: boolean;
}

const {
  slug,
  name,
  size = 40,
  variant = 'square',
  class: extraClass = '',
  lazy = true,
} = Astro.props;

import { getBrandColor } from '../utils/logoConfig';
const bgColor = getBrandColor(slug);
const initial   = name.charAt(0).toUpperCase();
const logoPath  = `/logos/${slug}.png`;
const radiusPx  = variant === 'pill' ? size / 2 : variant === 'square' ? Math.round(size * 0.22) : 0;
const fontSize  = Math.round(size * 0.44);

/**
 * Safe-area padding system — minimal breathing room only.
 * Target fill: ~90-94% of container (premium app-icon feel).
 * Values are % of container used as inner padding PER SIDE.
 *   3% → 94% fill   4% → 92% fill   5% → 90% fill
 * Keep values low — object-fit:contain + natural logo whitespace
 * already prevents hard-edge clipping.
 */
const LOGO_PADDING: Record<string, number> = {
  bybit:    3,
  binance:  2,
  okx:      3,
  mexc:     2,
  bitget:   2,
  bingx:    3,
  kucoin:   0,   // white bg matched in container — no gap to hide
  htx:      0,   // white bg matched in container — no gap to hide
  coinex:   0,   // white bg matched in container — no gap to hide
  phemex:   0,   // dark bg matched in container — no gap to hide
  bitunix:  0,   // dark bg matched in container — no gap to hide
  'gate-io':2,
  coinbase: 2,
  lbank:    0,   // yellow bg matched in container — no gap to hide
};
const padPct = LOGO_PADDING[slug] ?? 2;
const padPx = Math.round(size * padPct / 100);

/**
 * Container background matching — eliminates dark gap artefacts.
 *
 * Some PNG logos have a baked-in background shape (white circle for HTX,
 * white rounded square for CoinEx, yellow square for LBank, dark square
 * for Phemex/Bitunix). Transparent pixels outside that shape expose the
 * container's dark surface. Setting the container bg to match the logo's
 * own bg colour makes the seam invisible.
 *
 * Exchanges NOT in this map use the default dark surface (correct for
 * logos that already fill edge-to-edge or sit on a transparent field).
 */
const LOGO_CONTAINER_BG: Record<string, string> = {
  htx:     '#FFFFFF',   // white circle
  coinex:  '#FFFFFF',   // white/light rounded square
  lbank:   '#F5C100',   // yellow rounded square
  phemex:  '#0C0C0C',   // near-black rounded square
  bitunix: '#0C0C0C',   // dark bg with green leaf mark
  kucoin:  '#FFFFFF',   // white rounded square
};
const containerBg = variant !== 'raw'
  ? (LOGO_CONTAINER_BG[slug] ?? 'var(--surface-overlay, #1a1a1a)')
  : 'transparent';
---

<div
  class:list={['exlogo', `exlogo--${variant}`, extraClass]}
  style={`width:${size}px;height:${size}px;border-radius:${radiusPx}px;background:${containerBg};`}
  aria-label={name}
  role="img"
>
  <img
    src={logoPath}
    alt={name}
    width={size - padPx * 2}
    height={size - padPx * 2}
    loading={lazy ? 'lazy' : 'eager'}
    decoding="async"
    class="exlogo-img"
    style={`padding:${padPx}px;`}
    data-slug={slug}
    onerror="var s=this.dataset.slug;if(this.src.indexOf('.png')>-1){this.src='/logos/'+s+'.svg';}else{this.style.display='none';this.nextElementSibling.style.display='flex';}"
  />
  <span
    class="exlogo-fallback"
    style={`background:${bgColor};display:none;width:${size}px;height:${size}px;border-radius:${radiusPx}px;font-size:${fontSize}px;`}
    aria-hidden="true"
  >{initial}</span>
</div>

<style>
  .exlogo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--surface-overlay, #1a1a1a);
    position: relative;
  }
  .exlogo--raw {
    background: transparent;
    border: none;
  }
  .exlogo-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    border-radius: 0;
    image-rendering: auto;
    /* padding applied inline per-exchange for safe-area */
    box-sizing: border-box;
  }
  .exlogo-fallback {
    display: none;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    position: absolute;
    inset: 0;
  }
</style>
