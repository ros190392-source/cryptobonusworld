---
/**
 * /bonuses/[exchange]-bonus/ — Exchange-specific bonus landing pages
 *
 * Targets high-intent transactional queries:
 *   "bybit bonus code 2026", "mexc bonus how to claim", "okx referral bonus"
 *
 * Each page is a dedicated landing page for a single exchange's welcome offer.
 * Distinct from /exchanges/[slug]/ — more focused, more keyword-dense,
 * with full step-by-step claim guide and bonus-code callout.
 */
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AlternativesBlock from '../../components/AlternativesBlock.astro';
import PromoCodeBox from '../../components/PromoCodeBox.astro';
import BonusBadge from '../../components/BonusBadge.astro';
import KycBadge from '../../components/KycBadge.astro';
import BonusTrustLabel from '../../components/BonusTrustLabel.astro';
import TrustVerificationBlock from '../../components/TrustVerificationBlock.astro';
import ExchangeLogo from '../../components/ExchangeLogo.astro';

import exchanges from '../../data/exchanges.json';
import comparePairs from '../../data/compare-pairs.json';

import { buildProductSchema, buildBreadcrumbSchema, bonusPageTitle, SITE_URL, YEAR } from '../../utils/seo';
import { goRedirectUrl } from '../../utils/affiliateUtils';
import type { PageContext } from '../../utils/analytics';

// Generate one page per exchange: /bonuses/{slug}-bonus/
export async function getStaticPaths() {
  return exchanges.map(ex => ({
    params: { slug: `${ex.slug}-bonus` },
    props: { exchange: ex },
  }));
}

const { exchange: ex } = Astro.props;

// --- SEO ---
const bonusDisplayMode = (ex as any).bonusDisplayMode ?? 'up-to';
const bonusPrefix = bonusDisplayMode === 'fixed' ? '' : 'Up to ';
// Fixed-mode: use the bonusTitle directly (e.g. "$10 in Bitcoin") — more readable than "10 USD"
const bonusLabel  = bonusDisplayMode === 'fixed'
  ? ex.bonusTitle
  : `Up to ${ex.bonusAmount.toLocaleString()} ${ex.bonusCurrency}`;
// Use centralised title generator (targets 50-60 chars)
const pageTitle = bonusPageTitle(ex as any);
const kycNote = ex.kycRequired ? 'KYC required.' : 'No KYC needed.';
const metaDesc = `Claim the ${ex.name} bonus ${YEAR}: ${bonusLabel}. Step-by-step guide, promo code, requirements and verified conditions. ${kycNote}`.slice(0, 160);
const canonicalPath = `/bonuses/${ex.slug}-bonus/`;

// --- Bonus tiers ---
const bonusTiers = (ex as any).bonusTiers ?? [];
const hasTiers = bonusTiers.length > 0;

// --- Promo code ---
const promoCode = (ex as any).promoCode ?? '';

// --- Conditions ---
const minDeposit = (ex as any).minDeposit;
const tradingVol = (ex as any).tradingVolumeRequired;
const bonusExpiry = (ex as any).bonusExpiry;

// --- CTA URL ---
const affiliateUrl = ex.affiliateUrl;
const ctaUrl = affiliateUrl && affiliateUrl !== '#'
  ? goRedirectUrl(ex.slug, 'bonus-page-hero', 'bonus-page')
  : `/exchanges/${ex.slug}/`;

// --- Compare pairs featuring this exchange ---
const relatedCompare = comparePairs
  .filter(p => p.a === ex.slug || p.b === ex.slug)
  .slice(0, 3);

// --- Schema ---
const productSchema = buildProductSchema(ex as any, `${SITE_URL}${canonicalPath}`);
const faqItems = [
  {
    question: `What is the ${ex.name} welcome bonus in ${YEAR}?`,
    answer: `${ex.name} offers new users a welcome package of ${bonusLabel}. The bonus includes ${ex.bonusTypes.join(', ')} rewards that unlock progressively as you complete registration and trading milestones.`,
  },
  {
    question: `How do I claim the ${ex.name} bonus?`,
    answer: `Register through a referral link${promoCode ? ` or enter promo code ${promoCode}` : ''}, complete ${ex.kycRequired ? 'KYC identity verification, ' : ''}${(ex as any).depositRequired ? 'make a qualifying deposit, ' : ''}and complete the required trading tasks. Bonus is distributed in stages as each milestone is met.`,
  },
  {
    question: `Do I need KYC to get the ${ex.name} bonus?`,
    answer: ex.kycRequired
      ? `Yes. ${ex.name} requires identity verification (KYC) to access the full welcome bonus. KYC typically requires a government-issued ID and may include a selfie or proof of address.`
      : `No. ${ex.name} allows you to claim the initial bonus without full identity verification. However, non-KYC accounts have withdrawal limits. Full KYC unlocks higher withdrawal tiers.`,
  },
  {
    question: `How long does the ${ex.name} bonus last?`,
    answer: bonusExpiry
      ? `The ${ex.name} welcome bonus tasks must be completed within ${bonusExpiry.days} days of registration. ${bonusExpiry.note ?? ''} Uncompleted milestones will expire after this window.`
      : `${ex.name} welcome bonus conditions vary. Check the official promotion page for current expiry terms before registering.`,
  },
  {
    question: `What is the minimum deposit for the ${ex.name} bonus?`,
    answer: minDeposit && minDeposit.amount > 0
      ? `The minimum deposit to qualify for the ${ex.name} deposit bonus is ${minDeposit.amount} ${minDeposit.currency}. Lower deposits may still qualify for partial rewards depending on the bonus tier structure.`
      : `${ex.name} offers some bonus rewards without a minimum deposit requirement. Check the official terms for the current deposit threshold on each bonus tier.`,
  },
  {
    question: `Can I withdraw the ${ex.name} bonus?`,
    answer: `${ex.name} bonuses are typically issued as trading fee vouchers or conditional credits. They are generally not directly withdrawable — they must be used to offset trading fees or meet a minimum trading volume before any equivalent value can be withdrawn. Always read the official bonus terms.`,
  },
];

const schemaArray = [
  productSchema,
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map(f => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
  buildBreadcrumbSchema([
    { name: 'Home',       url: SITE_URL + '/' },
    { name: 'All Bonuses', url: SITE_URL + '/bonuses/' },
    { name: `${ex.name} Bonus`, url: SITE_URL + canonicalPath },
  ]),
];

const analyticsContext: PageContext = { pageType: 'bonus-page', exchange: ex.slug };
---

<Layout
  title={pageTitle}
  description={metaDesc}
  canonical={canonicalPath}
  schema={schemaArray}
  analyticsContext={analyticsContext}
  ogImage={`https://cryptobonusworld.com/og/exchange-${ex.slug}.png`}
  ogType="article"
  publishedTime={(ex as any).updatedAt}
  modifiedTime={(ex as any).lastVerified ?? (ex as any).updatedAt}
>
  <div class="container">

    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'All Bonuses', href: '/bonuses/' },
      { label: `${ex.name} Bonus` },
    ]} />

    <AffiliateDisclosure />

    <!-- Hero -->
    <section class="bp-hero">
      <div class="bp-hero-identity">
        <ExchangeLogo slug={ex.slug} name={ex.name} size={72} variant="square" />
        <div class="bp-hero-text">
          <div class="bp-freshness">
            <span class="bp-freshness-dot"></span>
            Verified {(ex as any).lastVerified ?? (ex as any).updatedAt ?? `May ${YEAR}`} · Reviewed by <a href="/reviewers/alexandr-shadurskyi/" class="bp-reviewer-link">Oleksandr Shadurskyi</a>
          </div>
          <h1 class="bp-h1">{ex.name} Bonus {YEAR}: {bonusLabel}</h1>
          <p class="bp-subtitle">{(ex as any).shortDescription}</p>
        </div>
      </div>

      <div class="bp-badges">
        {ex.bonusTypes.map(t => <BonusBadge type={t} />)}
        <KycBadge required={ex.kycRequired} />
        <BonusTrustLabel
          verificationStatus={(ex as any).verificationStatus ?? 'needs-review'}
          offerLastChecked={(ex as any).offerLastChecked ?? (ex as any).lastVerified}
          hasExpiry={!!(ex as any).bonusExpiry}
          isRegional={((ex as any).excludedCountries ?? []).length > 0}
          variant="chip"
        />
      </div>

      <div class="bp-hero-cta">
        <CTAButton
          href={ctaUrl}
          exchange={ex.name}
          label={`Claim ${ex.name} Bonus →`}
          size="lg"
          trackPlacement="bonus-page-hero"
          trackBonus={ex.bonusAmount}
        />
        {promoCode && (
          <div class="bp-code-inline">
            Use code: <strong class="bp-code-val">{promoCode}</strong>
          </div>
        )}
        <p class="bp-cta-note">Opens official {ex.name} registration · No account needed to compare</p>
      </div>

      <!-- Trust + disclaimer block below CTA -->
      <TrustVerificationBlock
        verificationStatus={(ex as any).verificationStatus ?? 'needs-review'}
        verifiedAt={(ex as any).lastVerified}
        offerLastChecked={(ex as any).offerLastChecked ?? (ex as any).lastVerified}
        termsUrl={(ex as any).termsUrl ?? (ex as any).bonusSourceUrl}
        bonusNote={(ex as any).bonusNote}
        regionRestrictions={(ex as any).excludedCountries}
        compact={false}
      />
    </section>

    <!-- Promo code box -->
    {promoCode && (
      <PromoCodeBox
        code={promoCode}
        exchange={ex.name}
        affiliateUrl={ctaUrl}
      />
    )}

    <!-- Bonus breakdown -->
    <section class="bp-section">
      <h2 class="bp-section-title">Bonus Breakdown</h2>
      {hasTiers ? (
        <div class="bp-tiers">
          {bonusTiers.map((tier: any) => (
            <div class="bp-tier">
              <div class="bp-tier-header">
                <span class="bp-tier-type">{tier.type.replace('-', ' ')}</span>
                <span class="bp-tier-amount">+{tier.amount.toLocaleString()} {tier.currency}</span>
              </div>
              <p class="bp-tier-title">{tier.title}</p>
              <p class="bp-tier-condition">{tier.condition}</p>
              {tier.note && <p class="bp-tier-note">{tier.note}</p>}
            </div>
          ))}
        </div>
      ) : (
        <p class="bp-fallback">Up to <strong>{ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</strong> total welcome package. See the <a href={`/exchanges/${ex.slug}/`}>{ex.name} exchange page</a> for full tier breakdown.</p>
      )}
    </section>

    <!-- How to claim -->
    <section class="bp-section">
      <h2 class="bp-section-title">How to Claim the {ex.name} Bonus</h2>
      <ol class="bp-steps">
        <li class="bp-step">
          <div class="bp-step-num">1</div>
          <div class="bp-step-body">
            <strong>Register via referral link{promoCode ? ` or enter code ${promoCode}` : ''}</strong>
            <p>Click the claim button above to open the official {ex.name} registration page. Using a referral link or promo code is required to activate the welcome bonus.</p>
          </div>
        </li>
        {ex.kycRequired && (
          <li class="bp-step">
            <div class="bp-step-num">2</div>
            <div class="bp-step-body">
              <strong>Complete identity verification (KYC)</strong>
              <p>Upload a government-issued ID and complete the identity check. KYC is required to unlock the full bonus package and withdraw funds.</p>
            </div>
          </li>
        )}
        {(ex as any).depositRequired && (
          <li class="bp-step">
            <div class="bp-step-num">{ex.kycRequired ? '3' : '2'}</div>
            <div class="bp-step-body">
              <strong>Make a qualifying deposit{minDeposit && minDeposit.amount > 0 ? ` (min. ${minDeposit.amount} ${minDeposit.currency})` : ''}</strong>
              <p>Fund your account to activate deposit-tier bonus rewards. Higher deposits unlock higher bonus tiers. Transfer crypto or use a card or P2P to deposit.</p>
            </div>
          </li>
        )}
        <li class="bp-step">
          <div class="bp-step-num">{ex.kycRequired && (ex as any).depositRequired ? '4' : ex.kycRequired || (ex as any).depositRequired ? '3' : '2'}</div>
          <div class="bp-step-body">
            <strong>Complete trading tasks{bonusExpiry ? ` within ${bonusExpiry.days} days` : ''}</strong>
            <p>Complete the required trading volume milestones in the bonus task centre. Rewards are distributed progressively as each milestone is reached.</p>
          </div>
        </li>
      </ol>

      <div class="bp-claim-cta">
        <CTAButton
          href={ctaUrl}
          exchange={ex.name}
          label={`Start Claiming — ${ex.name} Bonus`}
          size="lg"
          trackPlacement="bonus-page-steps"
          trackBonus={ex.bonusAmount}
        />
      </div>
    </section>

    <!-- Conditions at a glance -->
    <section class="bp-section">
      <h2 class="bp-section-title">Conditions at a Glance</h2>
      <div class="bp-conditions">
        <div class="bp-cond">
          <span class="bp-cond-icon">💰</span>
          <div>
            <div class="bp-cond-label">{bonusDisplayMode === 'fixed' ? 'Bonus Amount' : 'Max Bonus'}</div>
            <div class="bp-cond-val">{bonusLabel}</div>
          </div>
        </div>
        <div class="bp-cond">
          <span class="bp-cond-icon">🪪</span>
          <div>
            <div class="bp-cond-label">KYC</div>
            <div class="bp-cond-val">{ex.kycRequired ? 'Required' : 'Not required'}</div>
          </div>
        </div>
        <div class="bp-cond">
          <span class="bp-cond-icon">💳</span>
          <div>
            <div class="bp-cond-label">Min. Deposit</div>
            <div class="bp-cond-val">{minDeposit && minDeposit.amount > 0 ? `${minDeposit.amount} ${minDeposit.currency}` : 'None required'}</div>
          </div>
        </div>
        <div class="bp-cond">
          <span class="bp-cond-icon">📅</span>
          <div>
            <div class="bp-cond-label">Validity</div>
            <div class="bp-cond-val">{bonusExpiry ? `${bonusExpiry.days} days` : 'Check terms'}</div>
          </div>
        </div>
        <div class="bp-cond">
          <span class="bp-cond-icon">📈</span>
          <div>
            <div class="bp-cond-label">Volume Required</div>
            <div class="bp-cond-val">{tradingVol && tradingVol.amount > 0 ? `${tradingVol.amount.toLocaleString()} ${tradingVol.currency}` : 'None for initial tier'}</div>
          </div>
        </div>
        <div class="bp-cond">
          <span class="bp-cond-icon">⭐</span>
          <div>
            <div class="bp-cond-label">Our Rating</div>
            <div class="bp-cond-val">{ex.rating}/10</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Editor's take -->
    <section class="bp-section bp-editor-section">
      <div class="bp-editor-card">
        <div class="bp-editor-header">
          <span class="bp-editor-icon">✍️</span>
          <div>
            <div class="bp-editor-label">CryptoBonusWorld Editorial Review</div>
            <div class="bp-editor-date">Last verified: {(ex as any).lastVerified ?? (ex as any).updatedAt}</div>
          </div>
        </div>
        <p class="bp-editor-text">{(ex as any).editorNote ?? `${ex.name} offers competitive welcome rewards for new users. As with all exchange bonuses, conditions apply — always read the official promotion terms before registering.`}</p>
        <a href="/methodology/" class="bp-editor-method-link">How we review exchange bonuses →</a>
      </div>
    </section>

    <!-- Compare with alternatives -->
    {relatedCompare.length > 0 && (
      <section class="bp-section">
        <h2 class="bp-section-title">Compare {ex.name} With Others</h2>
        <div class="bp-compare-links">
          {relatedCompare.map(pair => {
            const other = pair.a === ex.slug ? pair.b : pair.a;
            const otherEx = exchanges.find(e => e.slug === other);
            return otherEx ? (
              <a href={`/compare/${pair.pair}/`} class="bp-compare-link">
                <span>{ex.name} vs {otherEx.name}</span>
                <span class="bp-compare-link-arrow">→</span>
              </a>
            ) : null;
          })}
          <a href="/compare/" class="bp-compare-link bp-compare-link--all">
            <span>View all comparisons</span>
            <span class="bp-compare-link-arrow">→</span>
          </a>
        </div>
      </section>
    )}

    <!-- FAQ -->
    <section class="bp-section">
      <h2 class="bp-section-title">Frequently Asked Questions</h2>
      <FAQBlock items={faqItems} />
    </section>

    <!-- Alternatives -->
    <section class="bp-section">
      <h2 class="bp-section-title">Compare Other Bonuses</h2>
      <AlternativesBlock currentSlug={ex.slug} exchanges={exchanges as any} count={3} />
    </section>

    <RiskDisclaimer />

  </div>
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .bp-hero {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border, #1a1a1a);
    margin-bottom: 2rem;
  }
  .bp-hero-identity {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }
  .bp-logo-avatar {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
    background: var(--surface-elevated, #1a1a1a);
    border: 1px solid var(--color-border);
  }
  .bp-freshness {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .bp-reviewer-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }
  .bp-reviewer-link:hover { text-decoration: underline; }
  .bp-freshness-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success, #22c55e);
    flex-shrink: 0;
  }
  .bp-h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .bp-subtitle {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
    margin: 0;
  }
  .bp-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0;
  }
  .bp-hero-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.625rem;
    margin-top: 1.25rem;
  }
  .bp-code-inline {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }
  .bp-code-val {
    font-family: monospace;
    color: var(--color-accent);
    background: rgba(245,197,66,0.08);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }
  .bp-cta-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .bp-section {
    margin-bottom: 2.5rem;
  }
  .bp-section-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-border);
    letter-spacing: -0.01em;
  }

  /* ── Bonus tiers ─────────────────────────────────────────────────────────── */
  .bp-tiers {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .bp-tier {
    background: var(--surface-overlay, #111);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem;
  }
  .bp-tier-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .bp-tier-type {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .bp-tier-amount {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-accent);
  }
  .bp-tier-title { font-size: 0.875rem; font-weight: 600; color: var(--color-text-primary); margin: 0 0 0.25rem; }
  .bp-tier-condition { font-size: 0.8rem; color: var(--color-text-secondary); margin: 0 0 0.25rem; }
  .bp-tier-note { font-size: 0.75rem; color: var(--color-text-muted); margin: 0; font-style: italic; }
  .bp-fallback { color: var(--color-text-secondary); }

  /* ── Steps ───────────────────────────────────────────────────────────────── */
  .bp-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .bp-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .bp-step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--gradient-gold, var(--color-accent));
    color: #000;
    font-weight: 800;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  .bp-step-body strong { display: block; font-weight: 700; color: var(--color-text-primary); margin-bottom: 0.25rem; }
  .bp-step-body p { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0; line-height: 1.5; }
  .bp-claim-cta { margin-top: 1.5rem; }

  /* ── Conditions grid ─────────────────────────────────────────────────────── */
  .bp-conditions {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }
  .bp-cond {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: var(--surface-overlay, #111);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.875rem;
  }
  .bp-cond-icon { font-size: 1.25rem; flex-shrink: 0; }
  .bp-cond-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); font-weight: 600; margin-bottom: 0.2rem; }
  .bp-cond-val { font-size: 0.9rem; font-weight: 700; color: var(--color-text-primary); }

  /* ── Editor card ─────────────────────────────────────────────────────────── */
  .bp-editor-card {
    background: var(--surface-overlay, #111);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
  }
  .bp-editor-header {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }
  .bp-editor-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 0.125rem; }
  .bp-editor-label { font-size: 0.8rem; font-weight: 700; color: var(--color-text-primary); }
  .bp-editor-date { font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.125rem; }
  .bp-editor-text { font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.6; margin: 0 0 0.75rem; }
  .bp-editor-method-link { font-size: 0.8rem; color: var(--color-accent); text-decoration: none; }
  .bp-editor-method-link:hover { text-decoration: underline; }

  /* ── Compare links ───────────────────────────────────────────────────────── */
  .bp-compare-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .bp-compare-link {
