---
/**
 * PageHero — reusable dark hero band for NON-exchange pages
 * (homepage, /exchanges/, /promo-codes/, /methodology/).
 *
 * A full-bleed band whose 3:1 background artwork sits on the right (center-right)
 * with a strong left→right dark gradient overlay, so left-aligned HTML text stays
 * readable. No text is baked into the image — H1/subtitle/buttons remain real HTML
 * passed via the default slot.
 *
 * NOT for exchange review pages — those keep their own `.brand-hero` conversion
 * header (Bybit/MEXC/OKX/Bitget/KuCoin/BingX) and are intentionally excluded.
 *
 * Content authoring: put a `.ph-content` wrapper in the slot and use the provided
 * `.ph-eyebrow` / `.ph-title` / `.ph-sub` / `.ph-caveat` / `.ph-chips`/`.ph-chip`
 * / `.ph-actions` classes for consistent styling.
 *
 * Optional named slot `panel`: right-side functional panel (e.g. the homepage
 * GEO panel). When present, the inner layout becomes a two-column grid on
 * desktop and stacks on mobile.
 *
 * Unified site hero height standard (2026-07 site-level hero system):
 *   mobile <640px: 360px · tablet ≥640px: 384px · desktop ≥1024px: 432px
 * Both 'tall' and 'short' variants now resolve to the same standard so every
 * section page carries identical visual weight ('short' kept for API
 * compatibility with existing call sites).
 */
export interface Props {
  /** Background image path (prefer the .webp). */
  img: string;
  /** 'tall' (default) or 'short' — both use the unified standard height. */
  variant?: 'tall' | 'short';
  /** Extra class(es) on the band. */
  class?: string;
}
const { img, variant = 'tall', class: cls = '' } = Astro.props;
const hasPanel = Astro.slots.has('panel');
---

<section class:list={['page-hero', `page-hero--${variant}`, cls]} style={`--ph-img:url('${img}')`}>
  <div class:list={['page-hero__inner', { 'page-hero__inner--panel': hasPanel }]}>
    <div class="page-hero__main">
      <slot />
    </div>
    {hasPanel && (
      <div class="page-hero__panel">
        <slot name="panel" />
      </div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    display: flex;
    align-items: center;
    background-color: #13233E; /* header navy — matches SiteHeader */
    background-image: var(--ph-img);
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
    overflow: hidden;
  }
  /* Left→right dark gradient overlay for text legibility on the left. */
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      90deg,
      rgba(8, 12, 20, 0.97) 0%,
      rgba(8, 12, 20, 0.93) 32%,
      rgba(8, 12, 20, 0.60) 64%,
      rgba(8, 12, 20, 0.20) 100%
    );
  }
  @media (max-width: 767px) {
    .page-hero { background-position: center right -40px; }
    .page-hero::before {
      background: linear-gradient(
        90deg,
        rgba(8, 12, 20, 0.96) 0%,
        rgba(8, 12, 20, 0.90) 50%,
        rgba(8, 12, 20, 0.66) 100%
      );
    }
  }

  /* ── Heights — unified site standard, EXACT (360 / 384 / 432).
        Fixed height by contract: pages must keep hero content essential;
        secondary content belongs in a post-hero strip, not in hero growth. ── */
  .page-hero--tall,
  .page-hero--short { height: 360px; }
  @media (min-width: 641px)  { .page-hero--tall, .page-hero--short { height: 384px; } }
  @media (min-width: 1024px) { .page-hero--tall, .page-hero--short { height: 432px; } }

  /* ── Inner content wrapper ───────────────────────────────────── */
  .page-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--cbw-page-max, 1180px);
    margin: 0 auto;
    padding: 24px 20px;
    box-sizing: border-box;
  }
  @media (min-width: 640px) { .page-hero__inner { padding: 32px 24px; } }
  @media (min-width: 820px) { .page-hero__inner { padding: 40px 32px; } }

  /* ── Two-column layout when a right panel is provided ────────── */
  .page-hero__inner--panel {
    display: flex;
    align-items: center;
    gap: 36px;
  }
  .page-hero__inner--panel .page-hero__main { flex: 1 1 auto; min-width: 0; }
  .page-hero__panel { flex: 0 0 330px; box-sizing: border-box; }
  @media (max-width: 1023px) and (min-width: 640px) { .page-hero__panel { flex-basis: 300px; } }
  @media (max-width: 639px) {
    .page-hero__inner--panel { flex-direction: column; align-items: stretch; justify-content: center; gap: 14px; }
    .page-hero__panel { flex: none; width: 100%; }
  }

  /* ── Slotted content helpers (global — slot children aren't scoped) ── */
  .page-hero :global(.ph-content) { max-width: 600px; }

  .page-hero :global(.ph-eyebrow) {
    display: inline-block;
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
    color: #F7C24B;
    background: rgba(247, 166, 0, 0.12);
    border: 1px solid rgba(247, 166, 0, 0.30);
    padding: 4px 12px; border-radius: 20px; margin-bottom: 14px;
  }
  .page-hero :global(.ph-title) {
    font-size: clamp(26px, 4vw, 40px); font-weight: 800; line-height: 1.12;
    letter-spacing: -.02em; color: #ffffff; margin: 0 0 12px;
  }
  .page-hero :global(.ph-sub) {
    font-size: clamp(14px, 1.5vw, 17px); line-height: 1.6;
    color: rgba(255, 255, 255, 0.80); margin: 0 0 10px; max-width: 560px;
  }
  .page-hero :global(.ph-caveat) {
    font-size: 13px; line-height: 1.55; color: rgba(255, 255, 255, 0.55);
    margin: 6px 0 0; max-width: 560px;
  }
  .page-hero :global(.ph-content a) {
    color: #7CE0A0; text-decoration: underline; text-underline-offset: 2px;
  }
  .page-hero :global(.ph-content a:hover) { color: #A5EDBE; }

  .page-hero :global(.ph-updated) {
    font-size: 12px; color: rgba(255, 255, 255, 0.45); margin: 12px 0 0;
  }
  .page-hero :global(.ph-updated time) { color: rgba(255, 255, 255, 0.6); }

  .page-hero :global(.ph-chips) {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin: 16px 0 0; padding: 0; list-style: none;
  }
  .page-hero :global(.ph-chip) {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12.5px; font-weight: 600; color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 100px; padding: 6px 12px;
  }
  .page-hero :global(.ph-actions) {
    display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px;
  }
</style>
