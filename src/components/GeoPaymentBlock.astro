---
/**
 * GeoPaymentBlock.astro
 * =====================
 * Shows exchange-specific payment methods for the visitor's country.
 * Uses geo-overrides data: exact country → region → global exchange defaults.
 *
 * Falls back gracefully — if no geo detected or no override exists,
 * shows the global payment methods from the exchange object.
 *
 * Props:
 *   exchange      — Exchange data object
 *   title         — Section title (optional)
 *   alwaysShow    — Show even when no geo detected (uses global defaults)
 */

import type { GeoExchange } from '../utils/geoConfig';
import {
  serializeGeoConfigsForExchange,
  getPaymentMethodsForGeo,
  REGION_MAP,
} from '../utils/geoConfig';
import type { GeoPaymentMethod } from '../data/geo-overrides';

interface ExchangeProp {
  slug: string;
  name: string;
  affiliateUrl: string;
  paymentMethods?: string[];
  affiliateLinks?: { default?: string; geo?: Record<string, string> };
}

interface Props {
  exchange: ExchangeProp;
  title?: string;
  alwaysShow?: boolean;
}

const { exchange: ex, title = 'Payment Methods', alwaysShow = true } = Astro.props;

// Global default methods (shown before geo detection fires)
const globalMethods: GeoPaymentMethod[] = (ex.paymentMethods ?? []).map(m => ({
  method: m.charAt(0).toUpperCase() + m.slice(1),
  note: '',
}));

// Serialize geo configs for client-side use
const geoConfigs = serializeGeoConfigsForExchange(ex as GeoExchange);
const geoConfigsJson = JSON.stringify(geoConfigs);
const regionMapJson = JSON.stringify(REGION_MAP);
const globalMethodsJson = JSON.stringify(globalMethods);

const blockId = `geo-pay-${Math.random().toString(36).slice(2, 8)}`;
---

{(alwaysShow || Object.keys(geoConfigs).length > 0) && (
  <div class="geo-pay" id={blockId}>
    {title && <h4 class="geo-pay__title">{title}</h4>}
    <ul class="geo-pay__list" data-geo-pay-list>
      {globalMethods.map(m => (
        <li class="geo-pay__item" data-method={m.method.toLowerCase()}>
          <span class="geo-pay__method">{m.method}</span>
          {m.note && <span class="geo-pay__note">{m.note}</span>}
        </li>
      ))}
    </ul>
    <!-- Geo-specific P2P note (hidden by default) -->
    <p class="geo-pay__p2p-note" data-geo-pay-p2p style="display:none;"></p>
  </div>
)}

<script define:vars={{ blockId, geoConfigsJson, regionMapJson, globalMethodsJson }}>
  (function () {
    const wrapper = document.getElementById(blockId);
    if (!wrapper) return;

    const listEl = wrapper.querySelector('[data-geo-pay-list]');
    const p2pEl = wrapper.querySelector('[data-geo-pay-p2p]');

    const geoConfigs = JSON.parse(geoConfigsJson);
    const regionMap = JSON.parse(regionMapJson);
    const globalMethods = JSON.parse(globalMethodsJson);

    function resolveConfig(countryCode) {
      if (!countryCode) return null;
      var cc = countryCode.toLowerCase();
      if (geoConfigs[cc]) return geoConfigs[cc];
      var region = regionMap[cc];
      if (region && geoConfigs['region:' + region]) return geoConfigs['region:' + region];
      return null;
    }

    function renderMethods(methods) {
      if (!listEl || !methods || !methods.length) return;
      listEl.innerHTML = methods.map(function (m) {
        var noteHtml = m.note
          ? '<span class="geo-pay__note">' + m.note + '</span>'
          : '';
        var primaryBadge = m.isPrimary
          ? '<span class="geo-pay__badge">Recommended</span>'
          : '';
        var key = (m.method || '').toLowerCase();
        return '<li class="geo-pay__item" data-method="' + key + '">' +
          '<span class="geo-pay__method">' + m.method + '</span>' +
          primaryBadge + noteHtml + '</li>';
      }).join('');
    }

    function tryApply() {
      var geo = null;
      try { geo = localStorage.getItem('cbw_geo'); } catch (e) {}
      if (!geo) return;

      var config = resolveConfig(geo);
      if (!config) return;

      if (config.paymentMethods && config.paymentMethods.length) {
        renderMethods(config.paymentMethods);
      }

      if (p2pEl && config.p2pNote) {
        p2pEl.textContent = config.p2pNote;
        p2pEl.style.display = 'block';
      }
    }

    tryApply();
    window.addEventListener('cbw:geo', function () { tryApply(); });
  })();
</script>

<style>
  .geo-pay {
    padding: 1rem 1.125rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .geo-pay__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .geo-pay__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .geo-pay__item {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
    transition: border-color 0.15s;
  }

  .geo-pay__item::before {
    font-size: 0.85rem;
    line-height: 1;
    flex-shrink: 0;
  }

  /* per-method icons */
  .geo-pay__item[data-method="crypto"]::before   { content: "🔗"; }
  .geo-pay__item[data-method="card"]::before     { content: "💳"; }
  .geo-pay__item[data-method="p2p"]::before      { content: "🤝"; }
  .geo-pay__item[data-method="bank"]::before     { content: "🏦"; }
  .geo-pay__item[data-method="sepa"]::before     { content: "🏛️"; }
  .geo-pay__item[data-method="wire"]::before     { content: "🏛️"; }
  .geo-pay__item[data-method="paypal"]::before   { content: "🅿️"; }
  /* generic fallback */
  .geo-pay__item:not([data-method])::before,
  .geo-pay__item[data-method=""]::before         { content: "•"; }

  .geo-pay__method {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-transform: capitalize;
    letter-spacing: 0.01em;
  }

  .geo-pay__note {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .geo-pay__badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 1px 5px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
  }

  .geo-pay__p2p-note {
    margin: 0.75rem 0 0;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    padding: 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    border-left: 2px solid var(--color-accent-dim, rgba(245,197,66,0.4));
    border-radius: 0 4px 4px 0;
    line-height: 1.5;
    animation: fade-in 0.2s ease;
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
