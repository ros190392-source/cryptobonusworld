---
interface Props {
  name: string;
  slug: string;
  flag: string;
  description: string;
  exchangeCount?: number;
}

const { name, slug, flag, description, exchangeCount = 0 } = Astro.props;
---

<a href={`/countries/${slug}/`} class="country-card">
  <div class="country-card-flag" aria-hidden="true">{flag}</div>
  <div class="country-card-content">
    <h3 class="country-card-name">{name}</h3>
    <p class="country-card-desc">{description}</p>
    {exchangeCount > 0 && (
      <span class="country-card-count">{exchangeCount} exchanges available</span>
    )}
  </div>
  <svg class="country-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <polyline points="9 18 15 12 9 6"/>
  </svg>
</a>

<style>
  .country-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .country-card:hover {
    border-color: var(--color-accent-dim);
    box-shadow: 0 2px 12px rgba(245, 197, 66, 0.06);
  }
  .country-card-flag { font-size: 1.75rem; flex-shrink: 0; }
  .country-card-content { flex: 1; min-width: 0; }
  .country-card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.2rem;
  }
  .country-card-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .country-card-count {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-top: 0.3rem;
  }
  .country-card-arrow {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.15s;
  }
  .country-card:hover .country-card-arrow { transform: translateX(3px); }
</style>
