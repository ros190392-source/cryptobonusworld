---
import type { Exchange } from '../../data/exchanges';
import type { Offer } from '../../data/offers';
import PromoCodeCopy from '../promo/PromoCodeCopy.astro';

export interface Props {
  exchange: Exchange;
  offer?: Offer;
}

const { exchange: ex, offer } = Astro.props;
---

<div class="ec">
  <a href={ex.pageUrl ?? `/exchanges/${ex.slug}/`} class="ec-img-link" tabindex="-1" aria-label={`${ex.name} exchange page`}>
    <div class="ec-img-wrap">
      <img
        src={ex.cardImage}
        alt={`${ex.name} referral code — claim bonus`}
        class="ec-img"
        width="1200" height="800"
        loading="eager"
      />
    </div>
  </a>
  <div class="ec-body">
    <a href={ex.pageUrl ?? `/exchanges/${ex.slug}/`} class="ec-name">{ex.name}</a>
    {offer && (
      <div class="ec-bonus">{offer.bonusHeadline}</div>
    )}
    {offer && (
      <div class="ec-code-band">
        <div class="ec-code-meta">
          <span class="ec-code-label">Promo code</span>
          {offer.status === 'verified' && <span class="ec-verified">✓ verified</span>}
        </div>
        <PromoCodeCopy code={offer.promoCode} exchange={ex.name} />
      </div>
    )}
    <a href={ex.affiliateUrl} class="ec-cta">Claim Bonus →</a>
    <a href={ex.pageUrl ?? `/exchanges/${ex.slug}/`} class="ec-review-link">Read {ex.name} review</a>
  </div>
</div>

<style>
  .ec {
    display: flex; flex-direction: column;
    background: var(--cbw-card-bg, #fff);
    border: 1px solid var(--cbw-card-border, #E5E7EB);
    border-radius: var(--cbw-card-radius, 12px);
    overflow: hidden;
    box-shadow: var(--cbw-card-shadow, 0 2px 6px rgba(0,0,0,0.06));
    transition: box-shadow .2s, transform .15s, border-color .2s;
  }
  .ec:hover {
    box-shadow: var(--cbw-card-shadow-h, 0 6px 20px rgba(0,0,0,0.11));
    transform: translateY(-3px);
    border-color: var(--cbw-card-border-h, #C7D2FE);
  }

  .ec-img-link { display: block; text-decoration: none; }
  .ec-img-wrap {
    overflow: hidden;
    border-bottom: 1px solid var(--cbw-gray-100, #F3F4F6);
    aspect-ratio: 16/9;
  }
  .ec-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .35s; }
  .ec:hover .ec-img { transform: scale(1.025); }

  .ec-body { padding: 12px 14px 14px; display: flex; flex-direction: column; gap: 5px; }

  .ec-name {
    font-size: 15px; font-weight: 800; color: var(--cbw-gray-900, #111827);
    letter-spacing: -.01em; text-decoration: none; display: block;
  }
  .ec-name:hover { color: #1D4ED8; text-decoration: underline; }

  .ec-bonus { font-size: 13px; color: var(--cbw-gray-700, #374151); line-height: 1.45; }

  /* Promo code band — field itself is the shared canonical PromoCodeCopy */
  .ec-code-band { display: flex; flex-direction: column; gap: 4px; }
  .ec-code-meta { display: flex; align-items: center; gap: 7px; }
  .ec-code-label {
    font-size: 10px; text-transform: uppercase; letter-spacing: .07em;
    color: var(--cbw-coupon-label, #92400E); font-weight: 600; white-space: nowrap;
  }
  .ec-verified { font-size: 10px; color: var(--cbw-green, #16A34A); font-weight: 700; white-space: nowrap; }

  .ec-cta {
    margin-top: 4px;
    display: block; text-align: center; text-decoration: none;
    background: var(--cbw-green, #16A34A); color: #fff;
    font-size: 13px; font-weight: 700;
    padding: 8px 14px; border-radius: 8px;
    transition: background .15s;
  }
  .ec-cta:hover { background: var(--cbw-green-hover, #15803D); }

  .ec-review-link {
    display: block; text-align: center;
    font-size: 12px; font-weight: 600;
    color: var(--cbw-gray-500, #6B7280); text-decoration: none;
    padding: 2px 0;
  }
  .ec-review-link:hover { color: #1D4ED8; text-decoration: underline; text-underline-offset: 2px; }
</style>
