---
/**
 * SourceLink — Styled citation link to an official source
 *
 * Renders a small anchor styled as a footnote-style citation.
 * Used wherever a claim needs an inline source reference.
 *
 * Variants:
 *   inline  — fits inside running text
 *   block   — standalone line with label prefix
 *   chip    — badge/chip style
 */

interface Props {
  href: string;
  label?: string;
  /** Source type hint — affects icon and colour */
  type?: 'official' | 'secondary' | 'internal';
  variant?: 'inline' | 'block' | 'chip';
  /** Whether to show an external arrow */
  arrow?: boolean;
}

const {
  href,
  label = 'Source',
  type = 'official',
  variant = 'inline',
  arrow = true,
} = Astro.props;

const icon = type === 'official' ? '↗' : type === 'secondary' ? '→' : '✓';
---

<a
  href={href}
  class:list={['sl', `sl--${variant}`, `sl--${type}`]}
  target="_blank"
  rel="noopener noreferrer nofollow"
  aria-label={`Source: ${label}`}
>
  {variant === 'block' && <span class="sl__prefix">Source: </span>}
  <span class="sl__label">{label}</span>
  {arrow && <span class="sl__arrow" aria-hidden="true">{icon}</span>}
</a>

<style>
  .sl {
    text-decoration: none;
    transition: opacity 0.12s, color 0.12s;
  }

  /* Inline variant */
  .sl--inline {
    display: inline-flex;
    align-items: center;
    gap: 0.15em;
    font-size: 0.68rem;
    font-weight: 600;
    vertical-align: middle;
    opacity: 0.8;
  }
  .sl--inline:hover { opacity: 1; }

  /* Block variant */
  .sl--block {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.7rem;
    font-weight: 500;
    margin-top: 0.25rem;
    opacity: 0.8;
  }
  .sl--block:hover { opacity: 1; }
  .sl--block .sl__prefix {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  /* Chip variant */
  .sl--chip {
    display: inline-flex;
    align-items: center;
    gap: 0.2em;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    border: 1px solid;
  }

  /* Type colours */
  .sl--official {
    color: #4ade80;
  }
  .sl--official.sl--chip {
    border-color: rgba(74, 222, 128, 0.20);
    background: rgba(74, 222, 128, 0.06);
  }

  .sl--secondary {
    color: var(--color-text-secondary);
  }
  .sl--secondary.sl--chip {
    border-color: var(--color-border);
    background: rgba(255,255,255,0.03);
  }

  .sl--internal {
    color: var(--color-accent);
  }
  .sl--internal.sl--chip {
    border-color: rgba(245,197,66,0.20);
    background: rgba(245,197,66,0.06);
  }

  .sl__arrow {
    font-size: 0.8em;
    font-style: normal;
  }
</style>
