---
/**
 * TrustVerificationBlock.astro
 *
 * Displays honest trust signals for a bonus offer:
 *   - Verification status with date
 *   - Region restriction notice
 *   - "Terms apply" with link to official page
 *   - Accurate bonus wording (no overclaiming)
 *
 * Used on exchange hero and bonus landing pages.
 * All fields optional — renders nothing for missing data.
 */

interface Props {
  verificationStatus?: 'verified' | 'needs-review' | 'outdated' | 'unverified';
  verifiedAt?: string | null;
  offerLastChecked?: string | null;
  termsUrl?: string;
  bonusNote?: string | null;
  regionRestrictions?: string[] | null;   // excluded country codes
  /** Show compact inline variant (no card wrapper) */
  compact?: boolean;
}

const {
  verificationStatus = 'needs-review',
  verifiedAt,
  offerLastChecked,
  termsUrl,
  bonusNote,
  regionRestrictions,
  compact = false,
} = Astro.props;

// Human-readable date — ISO date string → "May 2026"
function fmtDate(iso: string | null | undefined): string {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
  } catch {
    return iso;
  }
}

// Days since last check
function daysSince(iso: string | null | undefined): number | null {
  if (!iso) return null;
  try {
    const ms = Date.now() - new Date(iso).getTime();
    return Math.max(0, Math.floor(ms / 86_400_000));
  } catch {
    return null;
  }
}

const checkDate  = offerLastChecked ?? verifiedAt;
const age        = daysSince(checkDate);
const ageLabel   = age === null
  ? null
  : age === 0  ? 'Today'
  : age === 1  ? '1 day ago'
  : age < 30   ? `${age} days ago`
  : age < 60   ? '~1 month ago'
  : `${Math.round(age / 30)} months ago`;

const isVerified  = verificationStatus === 'verified';
const isOutdated  = verificationStatus === 'outdated';
const needsReview = verificationStatus === 'needs-review';

// Summarise regions
const hasRegionRestrictions = regionRestrictions && regionRestrictions.length > 0;
const regionNote = hasRegionRestrictions
  ? `Not available in: ${regionRestrictions!.slice(0,4).join(', ').toUpperCase()}${regionRestrictions!.length > 4 ? ` +${regionRestrictions!.length - 4} more` : ''}`
  : null;
---

<div class:list={['tvb', compact && 'tvb--compact', isOutdated && 'tvb--outdated']}>

  {/* Verification badge row */}
  <div class="tvb-row">
    {isVerified && (
      <span class="tvb-badge tvb-badge--verified">
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M10 3L5 9 2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Verified offer
      </span>
    )}
    {needsReview && (
      <span class="tvb-badge tvb-badge--review">
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6 4v3M6 8.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Awaiting re-verification
      </span>
    )}
    {isOutdated && (
      <span class="tvb-badge tvb-badge--outdated">
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M6 2v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Offer may be outdated
      </span>
    )}

    {ageLabel && (
      <span class="tvb-age">Updated {ageLabel}</span>
    )}
  </div>

  {/* Bonus note (conditions summary) */}
  {bonusNote && (
    <p class="tvb-note">{bonusNote}</p>
  )}

  {/* Region restrictions */}
  {regionNote && (
    <p class="tvb-region">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
        <path d="M8 1c0 0-3 3-3 7s3 7 3 7M8 1c0 0 3 3 3 7s-3 7-3 7M1 8h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Region dependent · {regionNote}
    </p>
  )}

  {/* Terms link */}
  <p class="tvb-terms">
    Actual reward depends on trading volume, deposit size and region.
    {termsUrl && (
      <>
        {' '}
        <a href={termsUrl} target="_blank" rel="noopener noreferrer nofollow" class="tvb-terms-link">
          Check official terms →
        </a>
      </>
    )}
  </p>

</div>

<style>
  .tvb {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.625rem 0.875rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--color-border-subtle, #1c1c1c);
    border-radius: var(--radius-md, 10px);
    margin-top: 0.75rem;
  }
  .tvb--compact {
    background: transparent;
    border: none;
    padding: 0;
    margin-top: 0.25rem;
    border-radius: 0;
    gap: 0.25rem;
  }
  .tvb--outdated {
    border-color: rgba(251,146,60,0.25);
    background: rgba(251,146,60,0.04);
  }

  /* Badge row */
  .tvb-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .tvb-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill, 100px);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .tvb-badge--verified {
    background: rgba(74,222,128,0.1);
    color: #4ade80;
    border: 1px solid rgba(74,222,128,0.2);
  }
  .tvb-badge--review {
    background: rgba(250,204,21,0.08);
    color: #facc15;
    border: 1px solid rgba(250,204,21,0.18);
  }
  .tvb-badge--outdated {
    background: rgba(251,146,60,0.1);
    color: #fb923c;
    border: 1px solid rgba(251,146,60,0.2);
  }

  .tvb-age {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    opacity: 0.8;
  }

  /* Note */
  .tvb-note {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Region */
  .tvb-region {
    margin: 0;
    display: flex;
    align-items: flex-start;
    gap: 0.3rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  .tvb-region svg {
    flex-shrink: 0;
    margin-top: 0.1rem;
    opacity: 0.7;
  }

  /* Terms */
  .tvb-terms {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.5;
    opacity: 0.85;
  }
  .tvb-terms-link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .tvb-terms-link:hover {
    color: var(--color-text-secondary);
  }
</style>
