<script define:vars={{ promoCode: offer.promoCode, exchangeSlug: exchange.slug }}>
  (function () {
    var btn = document.getElementById('copy-btn-hero');
    if (btn) {
      btn.addEventListener('click', function () {
        navigator.clipboard.writeText(promoCode).then(function () {
          var row = btn.closest('.bh-promo-row');
          var codeSpan = row ? row.querySelector('.bh-promo-code') : null;
          btn.textContent = 'Copied ✓';
          btn.classList.add('copy-success');
          if (row) row.classList.add('copy-success');
          if (codeSpan) codeSpan.classList.add('copy-success');
          setTimeout(function () {
            btn.textContent = 'Copy';
            btn.classList.remove('copy-success');
            if (row) row.classList.remove('copy-success');
            if (codeSpan) codeSpan.classList.remove('copy-success');
          }, 1800);
        });
      });
    }
    // Deal Activated state for related exchange cards
    var DEAL_PREFIX = 'cbw_deal_activated_';
    document.querySelectorAll('.p2-rel-btn').forEach(function(relBtn) {
      var slug = relBtn.getAttribute('data-exchange');
      if (!slug) return;
      try {
        if (localStorage.getItem(DEAL_PREFIX + slug)) {
          relBtn.textContent = 'Deal Activated';
          relBtn.classList.add('is-activated');
        }
      } catch(e) {}
      relBtn.addEventListener('click', function() {
        try { localStorage.setItem(DEAL_PREFIX + slug, '1'); } catch(e) {}
        relBtn.textContent = 'Deal Activated';
        relBtn.classList.add('is-activated');
      });
    });

    // Voting block — localStorage only, no fake global counts
    var VOTE_KEY = 'cbw_vote_' + exchangeSlug + '_code';
    var voteUpBtn   = document.getElementById('vote-up');
    var voteDownBtn = document.getElementById('vote-down');
    var voteStatus  = document.getElementById('vote-status');
    function applyVoteState(vote) {
      if (!voteUpBtn || !voteDownBtn || !voteStatus) return;
      if (vote === 'up') {
        voteUpBtn.classList.add('is-selected-up');
        voteDownBtn.classList.remove('is-selected-down');
      } else if (vote === 'down') {
        voteDownBtn.classList.add('is-selected-down');
        voteUpBtn.classList.remove('is-selected-up');
      }
      voteUpBtn.disabled   = true;
      voteDownBtn.disabled = true;
      voteStatus.textContent = 'Thanks — your vote was recorded. Your vote is saved on this device.';
    }
    try { var savedVote = localStorage.getItem(VOTE_KEY); if (savedVote) applyVoteState(savedVote); } catch(e) {}
    if (voteUpBtn)   { voteUpBtn.addEventListener('click',   function() { try { localStorage.setItem(VOTE_KEY, 'up');   } catch(e) {} applyVoteState('up');   }); }
    if (voteDownBtn) { voteDownBtn.addEventListener('click', function() { try { localStorage.setItem(VOTE_KEY, 'down'); } catch(e) {} applyVoteState('down'); }); }

    var couponBtn = document.getElementById('copy-btn-coupon');
    if (couponBtn) {
      couponBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(promoCode).then(function () {
          var row = couponBtn.closest('.bh-promo-row');
          var codeSpan = row ? row.querySelector('.bh-promo-code') : null;
          couponBtn.textContent = 'Copied ✓';
          couponBtn.classList.add('copy-success');
          if (row) row.classList.add('copy-success');
          if (codeSpan) codeSpan.classList.add('copy-success');
          setTimeout(function () {
            couponBtn.textContent = 'Copy';
            couponBtn.classList.remove('copy-success');
            if (row) row.classList.remove('copy-success');
            if (codeSpan) codeSpan.classList.remove('copy-success');
          }, 1800);
        });
      });
    }
  })();
</script>

