---
/**
 * ScreenshotPlaceholder.astro
 * ============================================================
 * Shows a styled placeholder block where a real screenshot will go.
 *
 * Design goals:
 *  - Clearly communicates "screenshot coming soon" without looking broken
 *  - Provides semantic context about what the screenshot will show
 *  - Zero performance cost (pure CSS, no JS, no image requests)
 *  - Degrades: if `src` is provided, renders a real <img> instead
 *  - Supports all exchange media categories
 *
 * Usage (placeholder mode):
 *   <ScreenshotPlaceholder
 *     category="exchange-ui"
 *     label="Bybit Trading Interface"
 *     aspectRatio="16/9"
 *   />
 *
 * Usage (real image mode — src provided):
 *   <ScreenshotPlaceholder
 *     src="/media/exchanges/bybit/ui-2026-05.webp"
 *     alt="Bybit trading platform interface — May 2026"
 *     category="exchange-ui"
 *     label="Bybit Trading Interface"
 *     capturedAt="2026-05"
 *     width={1280}
 *     height={720}
 *   />
 */

type MediaCategory =
  | 'exchange-ui'
  | 'exchange-bonus'
  | 'exchange-app'
  | 'guide-step'
  | 'guide-hero'
  | 'compare-visual'
  | 'coin-chart'
  | 'team-photo'
  | 'video-thumbnail';

interface Props {
  /** If provided, renders a real <img> tag instead of placeholder */
  src?: string;
  /** Required when src is provided */
  alt?: string;
  /** Category controls aspect ratio, icon, and label defaults */
  category: MediaCategory;
  /** Human-readable label shown on the placeholder */
  label: string;
  /** Caption shown below image/placeholder */
  caption?: string;
  /** ISO month the screenshot was taken (YYYY-MM) */
  capturedAt?: string;
  /** Override aspect ratio (CSS value like "16/9" or "9/16") */
  aspectRatio?: string;
  /** Image width for real images */
  width?: number;
  /** Image height for real images */
  height?: number;
  /** Lazy load (default true) */
  lazy?: boolean;
  /** Extra CSS class on the wrapper */
  class?: string;
}

const {
  src,
  alt,
  category,
  label,
  caption,
  capturedAt,
  aspectRatio,
  width,
  height,
  lazy = true,
  class: extraClass,
} = Astro.props;

// ── Defaults per category ───────────────────────────────────────────────────

const CATEGORY_CONFIG: Record<MediaCategory, {
  defaultRatio: string;
  icon: string;
  hint: string;
  bgClass: string;
}> = {
  'exchange-ui':     { defaultRatio: '16/9',  icon: '🖥️',  hint: 'Trading platform screenshot', bgClass: 'bg-ui' },
  'exchange-bonus':  { defaultRatio: '16/9',  icon: '🎁',  hint: 'Bonus offer page screenshot',  bgClass: 'bg-bonus' },
  'exchange-app':    { defaultRatio: '9/19.5',icon: '📱',  hint: 'Mobile app screenshot',         bgClass: 'bg-app' },
  'guide-step':      { defaultRatio: '16/10', icon: '📋',  hint: 'Step-by-step guide image',      bgClass: 'bg-guide' },
  'guide-hero':      { defaultRatio: '1200/630', icon: '📖', hint: 'Guide hero image',            bgClass: 'bg-hero' },
  'compare-visual':  { defaultRatio: '3/1',   icon: '⚖️',  hint: 'Side-by-side comparison',       bgClass: 'bg-compare' },
  'coin-chart':      { defaultRatio: '8/3',   icon: '📈',  hint: 'Price chart',                   bgClass: 'bg-chart' },
  'team-photo':      { defaultRatio: '1/1',   icon: '👤',  hint: 'Reviewer profile photo',        bgClass: 'bg-team' },
  'video-thumbnail': { defaultRatio: '16/9',  icon: '▶️',  hint: 'Video thumbnail',               bgClass: 'bg-video' },
};

const config = CATEGORY_CONFIG[category] ?? CATEGORY_CONFIG['exchange-ui'];
const ratio = aspectRatio ?? config.defaultRatio;

function fmtMonth(ym: string): string {
  try {
    const d = new Date(ym + '-01');
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  } catch { return ym; }
}
---

<figure class={`ssp-wrapper ${extraClass ?? ''}`}>
  {src ? (
    <!-- Real image -->
    <div class="ssp-image-wrap" style={`aspect-ratio: ${ratio}`}>
      <img
        src={src}
        alt={alt ?? label}
        width={width}
        height={height}
        loading={lazy ? 'lazy' : 'eager'}
        decoding="async"
        class="ssp-img"
      />
      {capturedAt && (
        <span class="ssp-date-badge">Updated {fmtMonth(capturedAt)}</span>
      )}
    </div>
  ) : (
    <!-- Placeholder -->
    <div
      class={`ssp-placeholder ${config.bgClass}`}
      style={`aspect-ratio: ${ratio}`}
      role="img"
      aria-label={`${label} — screenshot coming soon`}
    >
      <div class="ssp-inner">
        <span class="ssp-icon" aria-hidden="true">{config.icon}</span>
        <span class="ssp-label">{label}</span>
        <span class="ssp-hint">{config.hint}</span>
        <span class="ssp-coming">Screenshot being prepared</span>
      </div>
    </div>
  )}

  {caption && (
    <figcaption class="ssp-caption">{caption}</figcaption>
  )}
</figure>

<style>
  .ssp-wrapper {
    margin: 0;
    width: 100%;
  }

  /* ── Real image ── */
  .ssp-image-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .ssp-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 9px;
  }

  .ssp-date-badge {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    background: rgba(0,0,0,0.6);
    color: #ccc;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  /* ── Placeholder ── */
  .ssp-placeholder {
    width: 100%;
    border-radius: 10px;
    border: 1px dashed var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-ui      { background: linear-gradient(135deg, rgba(245,197,66,0.04) 0%, rgba(245,197,66,0.01) 100%); }
  .bg-bonus   { background: linear-gradient(135deg, rgba(74,222,128,0.04) 0%, rgba(74,222,128,0.01) 100%); }
  .bg-app     { background: linear-gradient(135deg, rgba(139,92,246,0.04) 0%, rgba(139,92,246,0.01) 100%); }
  .bg-guide   { background: linear-gradient(135deg, rgba(59,130,246,0.04) 0%, rgba(59,130,246,0.01) 100%); }
  .bg-hero    { background: linear-gradient(135deg, rgba(245,197,66,0.05) 0%, rgba(245,197,66,0.01) 100%); }
  .bg-compare { background: linear-gradient(135deg, rgba(251,146,60,0.04) 0%, rgba(251,146,60,0.01) 100%); }
  .bg-chart   { background: linear-gradient(135deg, rgba(74,222,128,0.04) 0%, rgba(74,222,128,0.01) 100%); }
  .bg-team    { background: rgba(245,197,66,0.03); }
  .bg-video   { background: rgba(0,0,0,0.15); border-color: rgba(255,255,255,0.06); }

  .ssp-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 1.5rem 1rem;
    text-align: center;
    max-width: 280px;
  }

  .ssp-icon {
    font-size: 1.8rem;
    line-height: 1;
    margin-bottom: 0.1rem;
  }

  .ssp-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .ssp-hint {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .ssp-coming {
    margin-top: 0.25rem;
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    opacity: 0.6;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
  }

  /* ── Caption ── */
  .ssp-caption {
    margin-top: 0.4rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.4;
  }
</style>
