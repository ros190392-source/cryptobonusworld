---
/**
 * EditorialNote — human editorial observation block.
 *
 * Adds a genuine human voice layer to exchange reviews and comparison pages.
 * This is NOT marketing copy — it is an honest, specific editorial observation
 * that includes both strengths and caveats.
 *
 * Directly improves:
 *  - E-E-A-T (demonstrates genuine product experience)
 *  - Content differentiation (unique voice vs scraped data)
 *  - User trust (acknowledges limitations)
 *  - AI search citability (distinctive, specific quotes)
 *
 * Usage:
 *  - Exchange pages: after the bonus summary, before FAQ
 *  - Compare pages: verdict section
 *  - Use-case pages: intro context
 *
 * The `note` prop should be 40–100 words of genuine editorial observation.
 * It should mention at least one specific feature AND one genuine limitation.
 */

interface Props {
  note: string;
  /** Who wrote/approved this note — defaults to editorial team */
  author?: string;
  /** ISO date this note was last reviewed */
  reviewedAt?: string;
  /** "Editor's Note" | "Our Assessment" | "Editorial Verdict" */
  label?: string;
  /** Compact version for cards */
  compact?: boolean;
}

const {
  note,
  author = 'CryptoBonusWorld Editorial',
  reviewedAt,
  label = "Editor's Note",
  compact = false,
} = Astro.props;

function fmtMonth(iso?: string): string {
  if (!iso) return '';
  try {
    const d = new Date(iso);
    return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
  } catch { return iso; }
}
---

<div class:list={['en', compact && 'en--compact']}>
  <div class="en-header">
    <span class="en-icon" aria-hidden="true">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
    </span>
    <span class="en-label">{label}</span>
    {reviewedAt && (
      <time class="en-date" datetime={reviewedAt}>{fmtMonth(reviewedAt)}</time>
    )}
  </div>
  <blockquote class="en-text">
    <p>{note}</p>
  </blockquote>
  <cite class="en-author">— {author}</cite>
</div>

<style>
  .en {
    padding: 1rem 1.25rem;
    background: rgba(245,197,66,0.03);
    border: 1px solid rgba(245,197,66,0.14);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 10px 10px 0;
    margin: 1.25rem 0;
  }

  .en--compact {
    padding: 0.75rem 1rem;
    margin: 0.75rem 0;
  }

  .en-header {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
  }

  .en-icon {
    color: var(--color-accent);
    display: flex;
    align-items: center;
  }

  .en-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-accent);
    flex: 1;
  }

  .en-date {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .en-text {
    margin: 0 0 0.375rem;
    padding: 0;
  }

  .en-text p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-style: italic;
    margin: 0;
  }

  .en-author {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    font-style: normal;
  }
</style>
