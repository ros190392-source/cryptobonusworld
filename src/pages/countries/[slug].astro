---
import Layout from '../../layouts/Layout.astro';
import BonusTable from '../../components/BonusTable.astro';
import ExchangeCard from '../../components/ExchangeCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';

import exchanges from '../../data/exchanges.json';
import countries from '../../data/countries.json';

export async function getStaticPaths() {
  return countries.map(c => ({
    params: { slug: c.slug },
    props: { country: c },
  }));
}

const { country } = Astro.props;

const available = exchanges.filter(ex =>
  ex.countries.includes(country.slug) || ex.countries.includes('global')
);
const top3 = [...available].sort((a, b) => b.rating - a.rating).slice(0, 3);

const faqItems = [
  {
    question: `Is crypto trading legal in ${country.name}?`,
    answer: `Crypto regulations vary by country and change frequently. CryptoBonusWorld does not provide legal advice. Always check the current regulatory status of crypto trading in ${country.name} before registering on any exchange.`,
  },
  {
    question: `Which payment methods are available in ${country.name}?`,
    answer: `Common payment methods for crypto in ${country.name} include: ${country.paymentMethods.join(', ')}. Availability depends on the specific exchange and may change.`,
  },
  {
    question: `Do I need KYC to trade in ${country.name}?`,
    answer: `KYC requirements depend on the exchange. Some exchanges like MEXC and KuCoin offer access without full KYC. However, to access full features and withdraw, most major exchanges require identity verification.`,
  },
];
---

<Layout
  title={country.seoTitle}
  description={country.seoDescription}
  canonical={`/countries/${country.slug}/`}
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Countries' },
      { label: country.name },
    ]} />

    <div class="page-header">
      <div class="country-heading">
        <span class="country-flag" aria-hidden="true">{country.flag}</span>
        <h1>{country.title}</h1>
      </div>
      <p class="lead">{country.description} {available.length} exchanges available.</p>
    </div>

    <AffiliateDisclosure compact />

    <div class="local-info">
      <div class="local-info-row">
        <div class="local-info-item">
          <span class="local-info-label">Currency</span>
          <span class="local-info-value">{country.currency}</span>
        </div>
        <div class="local-info-item">
          <span class="local-info-label">Payment Methods</span>
          <span class="local-info-value">{country.paymentMethods.join(', ')}</span>
        </div>
        <div class="local-info-item">
          <span class="local-info-label">Available Exchanges</span>
          <span class="local-info-value">{available.length}</span>
        </div>
      </div>
      {country.localNotes && (
        <p class="local-notes">{country.localNotes}</p>
      )}
    </div>

    <h2 class="section-title" style="margin-top: 2rem">Top Exchanges for {country.name}</h2>
    <div class="grid-3" style="margin: 1rem 0 2rem">
      {top3.map(ex => <ExchangeCard {...ex} />)}
    </div>

    <h2 class="section-title">All Available Exchanges in {country.name}</h2>
    <BonusTable exchanges={available} filterCountry={country.slug} />

    <FAQBlock items={faqItems} title={`Crypto Bonuses in ${country.name} — FAQ`} />

    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .country-heading {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 0.5rem;
  }
  .country-flag { font-size: 2.5rem; }
  .country-heading h1 { margin: 0; }

  .local-info {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    margin: 1.5rem 0;
  }
  .local-info-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 0.75rem;
  }
  .local-info-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .local-info-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .local-info-value {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-transform: capitalize;
  }
  .local-notes {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0.75rem 0 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
</style>
