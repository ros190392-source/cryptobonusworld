<style>
  .site-footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
  }
  .footer-inner { padding: 3rem 0 2rem; }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(7, 1fr);
    gap: 1.5rem 1.25rem;
    margin-bottom: 2rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }
  .logo-icon { color: var(--color-accent); font-size: 1.25rem; }
  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }
  .footer-disclosure {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .footer-disclosure a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .footer-links h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .footer-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--color-text-primary); }
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }
  .risk-notice {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .footer-legal a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-legal a:hover { color: var(--color-text-secondary); }
  /* Clickable heading links */
  .footer-h4-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-h4-link:hover { color: var(--color-accent); }

  @media (max-width: 1280px) {
    .footer-grid { grid-template-columns: 1.4fr repeat(4, 1fr); }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: repeat(3, 1fr); }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1.25rem;
    }
    .footer-brand { grid-column: 1 / -1; }
    .footer-inner { padding: 2.5rem 0 1.5rem; }
    .footer-legal {
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.75rem;
    }
    .risk-notice { font-size: 0.72rem; }
    .footer-bottom { padding-top: 1.25rem; }
  }
  @media (max-width: 400px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
