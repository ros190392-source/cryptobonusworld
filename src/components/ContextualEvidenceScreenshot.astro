---
/**
 * ContextualEvidenceScreenshot
 *
 * Renders a single evidence screenshot contextually adjacent to the page section
 * it supports. This is NOT a gallery — it is a per-section proof/contextual image.
 *
 * Safety rules (enforced at call site in [slug].astro):
 * - Only receives screenshots with status === 'available' in evidence JSON
 * - Never receives rejected screenshot paths (registration 100 USD, bonus $1,000 rebates)
 * - Never receives reports/ paths
 * - Path must start with /screenshots/ (enforced by _screenshotImages filter)
 */

interface Props {
  /** Absolute path — must start with /screenshots/ */
  src: string;
  /** Descriptive alt text for accessibility and SEO */
  alt: string;
  /** Figcaption text — shown below the image */
  caption: string;
  /** Device type — controls aspect ratio class */
  device?: 'desktop' | 'mobile' | 'none';
  /** Optional capture date label — YYYY-MM format */
  capturedAt?: string;
  /** @deprecated — every evidence figure now opens in the global LightboxPortal */
  zoomable?: boolean;
  /** Full-size frame for the lightbox when the inline src is a crop (dense tables) */
  fullSrc?: string;
  /** Lightbox group — figures sharing a group are browsable with prev/next */
  lightboxGroup?: string;
  /** Intrinsic image dimensions — reserve layout space (CLS fix) */
  width?: number;
  height?: number;
}

const {
  src, alt, caption, device = 'desktop', capturedAt,
  fullSrc, lightboxGroup = 'evidence', width, height,
} = Astro.props;

// Safety: reject any path that doesn't start with /screenshots/ (defence-in-depth)
const isSafe = src.startsWith('/screenshots/');

// Don't append the capture date when the caption text already states one —
// otherwise editorial captions ending in "Captured … 2026-06-11" render the
// date twice ("…2026-06-11. · Captured 2026-06-11").
const showDate = !!capturedAt && !/captured|verified live|20\d\d-\d\d/i.test(caption);

// Single human-readable date format across all captions: "June 2026",
// never raw "2026-06" (three competing formats confused the page audit).
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const dateLabel = capturedAt?.match(/^(\d{4})-(\d{2})/)
  ? `${MONTHS[parseInt(capturedAt.slice(5, 7), 10) - 1]} ${capturedAt.slice(0, 4)}`
  : capturedAt;
---

{isSafe && (
  <figure
    class={`ce-shot ce-shot--${device === 'none' ? 'desktop' : device}`}
    data-lightbox-group={`ce-${lightboxGroup}`}
    data-lightbox-src={fullSrc ?? src}
    data-lightbox-alt={alt}
    data-lightbox-caption={caption}
  >
    {/* no-JS fallback: plain link to the full file; with JS the LightboxPortal
        click delegate intercepts the figure click and preventDefaults */}
    <a href={fullSrc ?? src} class="ce-shot__zoomlink" aria-label={`View full-size: ${alt}`}>
      <div class="ce-shot__frame">
        <img
          src={src}
          alt={alt}
          loading="lazy"
          decoding="async"
          width={width}
          height={height}
          class="ce-shot__img"
        />
      </div>
    </a>
    <figcaption class="ce-shot__caption">
      {caption}
      {showDate && <span class="ce-shot__date"> · Captured {dateLabel}</span>}
      <span class="ce-shot__zoomhint"> · Tap to enlarge</span>
    </figcaption>
  </figure>
)}

<style>
  .ce-shot {
    margin: 1.5rem 0 0.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border, rgba(255, 255, 255, 0.08));
    background: var(--color-surface, #13131f);
  }

  .ce-shot__frame {
    width: 100%;
    overflow: hidden;
  }

  .ce-shot--desktop .ce-shot__frame {
    /* No forced ratio: evidence captures vary (16:10, 2:1) and a fixed 16/9
       box with cover-fit cropped their edges. Height follows the image. */
    aspect-ratio: auto;
  }

  .ce-shot--mobile .ce-shot__frame {
    aspect-ratio: auto;
    max-width: 320px;
    margin: 0 auto;
  }

  .ce-shot__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ce-shot__caption {
    padding: 0.5rem 0.875rem 0.625rem;
    font-size: 0.8rem;
    color: var(--color-text-muted, #888);
    line-height: 1.45;
    font-style: italic;
  }

  .ce-shot__date {
    opacity: 0.7;
  }

  .ce-shot__zoomlink {
    display: block;
    cursor: zoom-in;
  }

  .ce-shot__zoomhint {
    opacity: 0.7;
  }
</style>
