---
interface Props {
  name: string;
  slug: string;
  description: string;
  bonusType: string;
  exchangeCount?: number;
}

const { name, slug, description, bonusType, exchangeCount = 0 } = Astro.props;

const icons: Record<string, string> = {
  signup: '🎁',
  'no-deposit': '🆓',
  deposit: '💰',
  futures: '📈',
  welcome: '👋',
  'no-kyc': '🔓',
  'trading-rewards': '🏆',
  referral: '🤝',
};
---

<a href={`/categories/${slug}/`} class="category-card">
  <div class="category-card-icon" aria-hidden="true">{icons[bonusType] ?? '💎'}</div>
  <div class="category-card-content">
    <h3 class="category-card-name">{name}</h3>
    <p class="category-card-desc">{description}</p>
    {exchangeCount > 0 && (
      <span class="category-card-count">{exchangeCount} exchanges</span>
    )}
  </div>
  <svg class="category-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <polyline points="9 18 15 12 9 6"/>
  </svg>
</a>

<style>
  .category-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .category-card:hover {
    border-color: var(--color-accent-dim);
    box-shadow: 0 2px 12px rgba(245, 197, 66, 0.06);
  }
  .category-card-icon { font-size: 1.5rem; flex-shrink: 0; }
  .category-card-content { flex: 1; min-width: 0; }
  .category-card-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.2rem;
  }
  .category-card-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .category-card-count {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-top: 0.3rem;
  }
  .category-card-arrow {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.15s;
  }
  .category-card:hover .category-card-arrow { transform: translateX(3px); }
</style>
