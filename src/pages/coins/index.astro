---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import { COINS } from '../../data/coins';
import type { PageContext } from '../../utils/analytics';

const analyticsContext: PageContext = { pageType: 'category' };
---

<Layout
  title="Best Exchanges by Coin: BTC, ETH, USDT, SOL & More 2026"
  description="Compare crypto exchanges that support Bitcoin, Ethereum, USDT, Solana and BNB. Find the best bonus, no-KYC options and deposit networks for each coin."
  canonical="/coins/"
  analyticsContext={analyticsContext}
  noindex={true}
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Coins' },
    ]} />

    <div class="page-header">
      <h1>Best Exchanges by Coin</h1>
      <p class="lead">
        Find the best crypto exchange for each major coin — compare bonuses, KYC requirements,
        supported networks and deposit methods.
      </p>
    </div>

    <AffiliateDisclosure compact />

    <div class="coins-grid">
      {COINS.map(coin => (
        <a href={`/coins/${coin.slug}/`} class="coin-card">
          <div class="coin-card-symbol">{coin.symbol}</div>
          <div class="coin-card-info">
            <span class="coin-card-name">{coin.label}</span>
            <span class="coin-card-desc">{coin.intro.split('.')[0]}.</span>
          </div>
          <span class="coin-card-arrow">→</span>
        </a>
      ))}
    </div>

    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .page-header { margin-bottom: 1.75rem; }

  .coins-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
    margin-bottom: 2rem;
  }

  .coin-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .coin-card:hover {
    border-color: rgba(245,197,66,0.3);
    background: rgba(245,197,66,0.03);
  }

  .coin-card-symbol {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(245,197,66,0.1);
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    border-radius: 10px;
    border: 1px solid rgba(245,197,66,0.18);
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .coin-card-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
    min-width: 0;
  }

  .coin-card-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .coin-card-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.45;
  }

  .coin-card-arrow {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    transition: transform 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .coin-card:hover .coin-card-arrow {
    transform: translateX(2px);
    color: var(--color-accent);
  }
</style>
