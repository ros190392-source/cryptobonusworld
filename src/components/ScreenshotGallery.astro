---
/**
 * ScreenshotGallery.astro
 * Renders a collection of screenshots with a full lightbox modal.
 * Keyboard navigable (ArrowLeft/Right, Escape).
 * Mobile optimized — swipe-friendly layout.
 */

import ScreenshotCard from './ScreenshotCard.astro';

interface GalleryImage {
  src?: string;
  alt?: string;
  caption?: string;
  capturedAt?: string;
  label?: string;
  device?: 'desktop' | 'mobile' | 'none';
  aspectRatio?: string;
  width?: number;
  height?: number;
}

interface Props {
  images: GalleryImage[];
  layout?: 'grid' | 'row' | 'single' | 'steps';
  galleryId?: string;
  heading?: string;
  lightbox?: boolean;
  /** Image fit mode forwarded to every card. 'natural' = full image, no cropping. */
  fit?: 'cover' | 'contain' | 'natural';
}

const {
  images,
  layout = 'grid',
  galleryId = `gallery-${Math.random().toString(36).slice(2, 7)}`,
  heading,
  lightbox = true,
  fit = 'cover',
} = Astro.props;

const realImages = images.filter(img => img.src);
---

<div class={`sg-wrap sg-wrap--${layout}`} data-gallery-id={galleryId}>
  {heading && <h3 class="sg-heading">{heading}</h3>}

  <div class={`sg-grid sg-grid--${layout}`}>
    {images.map((img, i) => (
      <ScreenshotCard
        src={img.src}
        alt={img.alt}
        caption={img.caption}
        capturedAt={img.capturedAt}
        label={img.label}
        device={img.device ?? 'none'}
        aspectRatio={img.aspectRatio}
        width={img.width}
        height={img.height}
        lightboxGroup={lightbox && img.src ? galleryId : undefined}
        fit={fit}
        class="sg-card"
      />
    ))}
  </div>

  {realImages.length > 1 && (
    <div class="sg-count" aria-live="polite">
      {realImages.length} screenshots
    </div>
  )}
</div>

<!-- Lightbox modal (portal appended once per page by JS) -->
{lightbox && (
  <div id={`lb-${galleryId}`} class="lb-modal" role="dialog" aria-modal="true" aria-label="Screenshot lightbox" hidden>
    <div class="lb-backdrop"></div>
    <div class="lb-content">
      <button class="lb-close" aria-label="Close lightbox" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <button class="lb-nav lb-nav--prev" aria-label="Previous image" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <div class="lb-img-wrap">
        <img src="" alt="" class="lb-img" loading="lazy" decoding="async" />
        <div class="lb-caption-wrap">
          <p class="lb-caption"></p>
          <span class="lb-counter"></span>
        </div>
      </div>
      <button class="lb-nav lb-nav--next" aria-label="Next image" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>
  </div>
)}

<script>
  (function () {
    const modals = document.querySelectorAll<HTMLElement>('.lb-modal');
    if (!modals.length) return;

    modals.forEach(modal => {
      const galleryId = modal.id.replace('lb-', '');
      const cards = Array.from(
        document.querySelectorAll<HTMLElement>(`[data-gallery-id="${galleryId}"] [data-lightbox-group]`)
      );

      if (!cards.length) return;

      const lbImg = modal.querySelector<HTMLImageElement>('.lb-img')!;
      const lbCaption = modal.querySelector<HTMLElement>('.lb-caption')!;
      const lbCounter = modal.querySelector<HTMLElement>('.lb-counter')!;
      const backdrop = modal.querySelector<HTMLElement>('.lb-backdrop')!;
      const closeBtn = modal.querySelector<HTMLElement>('.lb-close')!;
      const prevBtn = modal.querySelector<HTMLElement>('.lb-nav--prev')!;
      const nextBtn = modal.querySelector<HTMLElement>('.lb-nav--next')!;

      const images: { src: string; alt: string; caption: string }[] = [];
      let currentIdx = 0;

      cards.forEach(card => {
        const src = card.dataset.lightboxSrc;
        if (src) {
          images.push({
            src,
            alt: card.dataset.lightboxAlt ?? '',
            caption: card.dataset.lightboxCaption ?? '',
          });
        }
      });

      function openAt(idx: number) {
        currentIdx = Math.max(0, Math.min(idx, images.length - 1));
        const item = images[currentIdx];
        lbImg.src = item.src;
        lbImg.alt = item.alt;
        lbCaption.textContent = item.caption;
        lbCounter.textContent = images.length > 1 ? `${currentIdx + 1} / ${images.length}` : '';
        prevBtn.style.display = images.length > 1 ? '' : 'none';
        nextBtn.style.display = images.length > 1 ? '' : 'none';
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
        modal.focus();
      }

      function close() {
        modal.hidden = true;
        document.body.style.overflow = '';
        lbImg.src = '';
      }

      // Card clicks
      cards.forEach((card, i) => {
        const frame = card.querySelector('.sc-frame--lightbox');
        if (frame) {
          frame.addEventListener('click', () => openAt(i));
        }
        const zoomBtn = card.querySelector('.sc-zoom-btn');
        if (zoomBtn) {
          zoomBtn.addEventListener('click', (e) => { e.stopPropagation(); openAt(i); });
        }
      });

      backdrop.addEventListener('click', close);
      closeBtn.addEventListener('click', close);
      prevBtn.addEventListener('click', () => openAt(currentIdx - 1));
      nextBtn.addEventListener('click', () => openAt(currentIdx + 1));

      document.addEventListener('keydown', (e) => {
        if (modal.hidden) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') openAt(currentIdx - 1);
        if (e.key === 'ArrowRight') openAt(currentIdx + 1);
      });
    });
  })();
</script>

<style>
  .sg-wrap { width: 100%; }
  .sg-heading {
    font-size: var(--text-base, 1rem);
    font-weight: 700;
    margin: 0 0 0.875rem;
    color: var(--color-text-primary);
  }

  /* ── Grid layouts ── */
  .sg-grid--grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.875rem;
  }
  .sg-grid--row {
    display: flex;
    gap: 0.875rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.25rem;
  }
  .sg-grid--row::-webkit-scrollbar { display: none; }
  .sg-grid--row .sg-card { flex: 0 0 320px; }

  .sg-grid--single .sg-card { width: 100%; }
  .sg-grid--steps {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .sg-count {
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--color-text-muted, #666);
    text-align: right;
  }

  /* ── Lightbox ── */
  .lb-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lb-modal[hidden] { display: none; }

  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(4px);
  }

  .lb-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: min(90vw, 1100px);
    max-height: 90vh;
    padding: 0 0.5rem;
  }

  .lb-img-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .lb-img {
    max-width: 100%;
    max-height: 80vh;
    border-radius: 8px;
    border: 1px solid #333;
    object-fit: contain;
    display: block;
  }

  .lb-caption-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 1rem;
  }

  .lb-caption {
    margin: 0;
    font-size: 0.78rem;
    color: #aaa;
    line-height: 1.4;
    font-style: italic;
  }

  .lb-counter {
    font-size: 0.72rem;
    color: #666;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .lb-close {
    position: absolute;
    top: -40px;
    right: 0;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    color: #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .lb-close:hover { background: rgba(255,255,255,0.15); }

  .lb-nav {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    color: #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .lb-nav:hover { background: rgba(255,255,255,0.14); }

  @media (max-width: 600px) {
    .lb-nav { width: 32px; height: 32px; }
    .lb-close { top: -36px; right: 0; }
    .sg-grid--grid { grid-template-columns: 1fr; }
  }
</style>
