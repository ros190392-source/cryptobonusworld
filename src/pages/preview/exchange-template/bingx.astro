---
/*
 * PREVIEW ONLY — noindex, not linked from anywhere.
 * Renders BingX exchange page via the reusable ExchangePromoPage template.
 * Kept in sync with the live page at /bingx/ for internal QA reference.
 */
import CleanLayout from '../../../layouts/CleanLayout.astro';
import ExchangePromoPage from '../../../components/exchange/ExchangePromoPage.astro';
import { bingxConfig } from '../../../data/exchangePages/bingx';
---

<CleanLayout
  title={bingxConfig.pageTitle}
  description={bingxConfig.pageDescription}
  canonical={bingxConfig.canonicalUrl}
  ogImage={bingxConfig.ogImage}
  ogTitle={bingxConfig.ogTitle}
  ogDescription={bingxConfig.ogDescription}
  noindex={true}
>
  <ExchangePromoPage config={bingxConfig} />
</CleanLayout>
