---
import CleanLayout from '../../layouts/CleanLayout.astro';
import { getOffer } from '../../data/offers';
import ExchangePromoLogoSlot from '../../components/ExchangePromoLogoSlot.astro';

const offer = getOffer('bybit')!;

// Static exchange data — volatile fields come from offer
const exchange = {
  name:             'Bybit',
  slug:             'bybit',
  affiliateUrl:     '/go/bybit/',
  officialDomain:   'bybit.com',
  supportUrl:       'https://help.bybit.com',
  feeUrl:           'https://www.bybit.com/en/announcement-info/fee-rate',
  bonusMax:         30000,
  currency:         'USDT',
  minDeposit:       100,
  founded:          2018,
  users:            '30M+',
  headquarters:     'Dubai, UAE',
  licence:          'Dubai VARA',
  wordmarkImg:      '/logos/bybit-wordmark-official.png',
  articleImg:       '/media/exchanges/bybit/final/bybit-article-final-v3-1200x675.jpg',
  logoImg:          '/logos/bybit.png',
  fees: {
    spot:    { maker: '0.1%',   taker: '0.1%'   },
    futures: { maker: '0.02%',  taker: '0.055%' },
    options: { maker: '0.02%',  taker: '0.03%'  },
  },
};

const relatedExchanges = [
  { slug: 'mexc',   name: 'MEXC',   logo: '/logos/mexc.png',   bonus: 'Up to 10,000 USDT', tag: 'No KYC option',  tileBg: '#F5F3FF', pageUrl: '/mexc/' },
  { slug: 'bitget', name: 'Bitget', logo: '/logos/bitget.png', bonus: 'Up to 6,200 USDT',  tag: 'Copy trading',   tileBg: '#ECFDF5' },
  { slug: 'bingx',  name: 'BingX',  logo: '/logos/bingx.png',  bonus: 'Up to 5,125 USDT',  tag: 'Social trading', tileBg: '#EFF6FF' },
  { slug: 'okx',    name: 'OKX',    logo: '/logos/okx.png',    bonus: 'Up to 5,000 USDT',  tag: 'CEX + Web3',     tileBg: '#F3F4F6', pageUrl: '/okx/' },
];

const brandHeroTokens = {
  'bh-bgFrom':     '#0C1118',
  'bh-bgTo':       '#141B25',
  'bh-text':       '#ffffff',
  'bh-text2':      'rgba(255,255,255,0.65)',
  'bh-accent':     '#f7a600',
  'bh-codeBg':     'rgba(247,166,0,0.10)',
  'bh-codeBorder': 'rgba(247,166,0,0.40)',
  'bh-note':       'rgba(255,255,255,0.38)',
};
const bhStyle = Object.entries(brandHeroTokens).map(([k,v]) => `--${k}:${v}`).join(';');
---

<CleanLayout
  title={`${exchange.name} Referral Code 2026: ${offer.promoCode} — Up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency} Bonus`}
  description={`${exchange.name} promo code ${offer.promoCode} — up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency} welcome package + fee discount. Verified ${offer.lastChecked}. Enter code at registration before your first deposit.`}
  canonical="https://cryptobonusworld.com/bybit/"
  ogImage="/media/exchanges/bybit/final/bybit-og-final-v3-1200x630.jpg"
  ogTitle={`${exchange.name} Referral Code: ${offer.promoCode} — Claim Bonus`}
  ogDescription={`Use ${exchange.name} referral code ${offer.promoCode} to claim welcome rewards up to ${exchange.bonusMax.toLocaleString('en-US')} ${exchange.currency}. Verified ${offer.lastChecked} by CryptoBonusWorld.`}
>

<style>
  /* Design tokens via CleanLayout → src/styles/tokens.css (--cbw-*) */

  /* ── Narrow content wrapper (760px, replaces proto .container) ── */
  .bw-wrap { max-width: 760px; margin: 0 auto; padding: 0 20px; }

  /* ── Section base ─────────────────────────────────────────── */
  .bybit-section { padding: 40px 0; background: var(--cbw-bg); }
  .bybit-section + .bybit-section { border-top: 1px solid var(--cbw-gray-200); }

  /* ── Title bar ────────────────────────────────────────────── */
  .title-bar {
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    border-bottom: 1px solid var(--cbw-gray-200);
    text-align: center; padding: 9px 20px;
    color-scheme: light; forced-color-adjust: none;
  }
  .title-bar h1 {
    font-size: 20px; font-weight: 700; color: var(--cbw-gray-900);
    margin: 0; line-height: 1.25;
  }
  @media (max-width: 479px) {
    .title-bar { padding: 9px 20px; }
    .title-bar h1 { font-size: 18px; }
  }

  /* ── Brand Hero ───────────────────────────────────────────── */
  .brand-hero {
    background:
      url('/media/hero-backgrounds/bybit-hero-custom-v1.png') left center / cover no-repeat,
      linear-gradient(160deg, var(--bh-bgFrom) 0%, var(--bh-bgTo) 100%);
    padding: 35px 0 54px;
    color: var(--bh-text);
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .brand-hero { padding: 42px 0 46px; display: flex; flex-direction: column; justify-content: center; }
  }
  .bh-inner { width: 100%; max-width: 540px; margin: 0 auto; padding: 0 20px; text-align: center; box-sizing: border-box; position: relative; z-index: 1; }

  .bh-promo-label {
    display: block;
    font-family: "Barlow Condensed", "Oswald", "Arial Narrow", sans-serif;
    font-size: 24px; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.05em; color: white;
    line-height: 1; margin-top: 2px; margin-bottom: 22px;
  }
  @media (min-width: 640px) { .bh-promo-label { font-size: 34px; } }

  .bh-promo-row {
    width: 100%; max-width: 298px;
    margin-left: auto; margin-right: auto;
    display: flex; align-items: stretch;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    border: 1px solid #D1D5DB; border-radius: 8px; overflow: hidden;
    height: 56px; margin-bottom: 18px;
    transition: border-color .18s, background .18s;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-promo-row.copy-success { border-color: #22c55e !important; background: #dcfce7 !important; }

  .bh-promo-code {
    flex: 1; display: flex; align-items: center; padding: 0 14px;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 20px; font-weight: 800; letter-spacing: 0.01em; font-stretch: condensed;
    text-transform: uppercase; color: #111827; -webkit-text-fill-color: #111827;
    min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
    transition: color .18s;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .bh-promo-code { font-size: 22px; letter-spacing: 0.015em; } }
  .bh-promo-code.copy-success { color: #166534 !important; -webkit-text-fill-color: #166534 !important; }

  .bh-copy-btn {
    flex-shrink: 0; width: 68px;
    display: flex; align-items: center; justify-content: center;
    border: none; border-left: 1px solid #e5e7eb;
    font-size: 12px; font-weight: 700; color: #16a34a; -webkit-text-fill-color: #16a34a;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    cursor: pointer; transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap; letter-spacing: .03em;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-copy-btn:hover { background: #f0fdf4; }
  .bh-copy-btn.copy-success { background: #dcfce7 !important; border-color: #22c55e !important; color: #166534 !important; }

  .bh-cta-btn {
    display: flex; align-items: center; justify-content: center;
    width: 100%; max-width: 320px; margin-left: auto; margin-right: auto;
    background: var(--cbw-green); color: #fff;
    font-size: 24px; font-weight: 700; border-radius: 6px;
    height: 68px; margin-bottom: 16px;
    transition: background .15s, transform .1s; letter-spacing: 0;
    text-decoration: none;
  }
  @media (min-width: 640px) { .bh-cta-btn { font-size: 28px; } }
  .bh-cta-btn:hover { background: var(--cbw-green-hover); transform: translateY(-1px); }

  .bh-source {
    font-size: 14px; color: var(--bh-note); line-height: 1.65;
    margin: 8px 0 0; text-align: center;
  }
  @media (min-width: 640px) { .bh-source { font-size: 15px; } }
  .bh-source a { color: var(--bh-note); text-decoration: underline; text-underline-offset: 2px; text-decoration-color: rgba(255,255,255,0.35); }
  .bh-source a:hover { text-decoration-color: var(--bh-note); }

  /* ── Compact facts table ──────────────────────────────────── */
  .compact-facts {
    background: var(--cbw-white) !important;
    padding: 20px 16px 6px; color-scheme: light; forced-color-adjust: none;
  }
  .cf-inner {
    max-width: 720px; margin: 0 auto; padding: 0;
    background: var(--cbw-gray-100); border: 1px solid var(--cbw-gray-300);
    border-radius: var(--cbw-r-md); overflow: hidden;
  }
  .cf-table { width: 100%; border-collapse: collapse; font-size: 14px; background: var(--cbw-gray-100); table-layout: fixed; }
  .cf-table tr { border-bottom: 1px solid var(--cbw-gray-200); }
  .cf-table tr:last-child { border-bottom: none; }
  .cf-table td { padding: 11px 16px; vertical-align: middle; background: var(--cbw-gray-100); color: var(--cbw-gray-900); word-wrap: break-word; overflow-wrap: break-word; }
  .cf-table td:first-child { color: var(--cbw-gray-700) !important; font-size: 14px; font-weight: 500; width: 50%; }
  .cf-table td:last-child { font-weight: 600; color: var(--cbw-gray-900) !important; }
  @media (max-width: 479px) {
    .cf-table td { padding: 10px 12px; font-size: 13px; }
    .cf-table td:first-child { font-size: 13px; }
  }
  .cf-code { font-family: 'Courier New', monospace; letter-spacing: .04em; color: #c47f00 !important; -webkit-text-fill-color: #c47f00 !important; }
  .cf-good { color: #16a34a !important; -webkit-text-fill-color: #16a34a !important; }
  .cf-warn { color: #b45309 !important; -webkit-text-fill-color: #b45309 !important; font-weight: 500 !important; }

  /* ── SEO intro block ─────────────────────────────────────── */
  .seo-intro-block {
    background: #ffffff; border-bottom: 1px solid #E5E7EB;
    padding: 8px 20px 20px;
  }
  .seo-intro-inner { max-width: 720px; margin: 0 auto; }
  .seo-phrase {
    font-size: 14px; font-weight: 400; color: #9CA3AF;
    margin: 0; padding-bottom: 10px; font-style: italic;
    border-bottom: 1px solid #E5E7EB;
  }
  .seo-intro-text {
    font-size: 15px; color: #4B5563; line-height: 1.65;
    margin: 12px 0 0;
  }
  @media (max-width: 479px) {
    .seo-phrase { font-size: 13px; }
    .seo-intro-text { font-size: 14px; }
  }

  /* ═══════════════════════════════════════════════════════════
     PART 2 — SEO SKELETON
  ═══════════════════════════════════════════════════════════ */

  .p2-section {
    background: var(--cbw-white); border-bottom: 1px solid var(--cbw-gray-200);
    padding: 28px 0;
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-section-alt { background: var(--cbw-gray-50); }
  .p2-inner { max-width: 720px; margin: 0 auto; padding: 0 20px; }

  .p2-h2 { font-size: 20px; font-weight: 700; color: #111827; margin: 0 0 14px; line-height: 1.3; }
  @media (min-width: 640px) { .p2-h2 { font-size: 22px; } }
  .p2-h3 { font-size: 16px; font-weight: 700; color: #111827; margin: 20px 0 10px; line-height: 1.35; }
  @media (min-width: 640px) { .p2-h3 { font-size: 17px; } }

  .p2-placeholder {
    background: #F3F4F6; border: 1px dashed #D1D5DB; border-radius: 6px;
    padding: 12px 16px; font-size: 12px; color: #9CA3AF;
    font-family: 'Courier New', monospace; line-height: 1.5;
    color-scheme: light; forced-color-adjust: none;
  }

  .p2-cta-block { text-align: center; }
  .p2-cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--cbw-green); color: #fff;
    font-size: 16px; font-weight: 700; border-radius: 8px;
    padding: 0 28px; height: 52px;
    width: 100%; max-width: 340px;
    text-decoration: none; letter-spacing: .01em;
    transition: background .15s, transform .1s;
  }
  .p2-cta-btn:hover { background: var(--cbw-green-hover); transform: translateY(-1px); }

  .p2-text {
    font-size: 14px; color: #374151; line-height: 1.7; margin: 0 0 12px;
  }
  .p2-text:last-child { margin-bottom: 0; }
  @media (min-width: 640px) { .p2-text { font-size: 15px; } }

  /* Full-width article CTA bar — used for mid-article conversion points */
  .p2-cta-bar {
    display: flex; align-items: center; justify-content: center;
    background: var(--cbw-green); color: #fff;
    font-size: 17px; font-weight: 700; border-radius: 8px;
    padding: 0 24px; height: 56px; width: 100%; box-sizing: border-box;
    text-decoration: none; letter-spacing: .01em;
    transition: background .18s ease, transform .15s ease, box-shadow .18s ease;
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-cta-bar:hover {
    background: var(--cbw-green-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(22,163,74,0.30);
  }

  .p2-steps {
    margin: 0 0 20px; padding: 0; list-style: none;
    counter-reset: p2-step-counter;
    display: flex; flex-direction: column; gap: 10px;
  }
  .p2-step {
    display: flex; align-items: flex-start; gap: 12px;
    counter-increment: p2-step-counter;
    font-size: 14px; color: #374151; line-height: 1.55;
  }
  .p2-step::before {
    content: counter(p2-step-counter);
    flex-shrink: 0; width: 26px; height: 26px;
    background: #111827; color: #fff; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; margin-top: 1px;
  }
  @media (min-width: 640px) { .p2-step { font-size: 15px; } }

  .p2-screenshot-placeholder {
    background: #F3F4F6; border: 1px solid #E5E7EB; border-radius: 8px;
    min-height: 160px; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px; padding: 24px 20px; text-align: center;
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .p2-screenshot-placeholder { min-height: 200px; } }
  .p2-screenshot-label {
    font-family: 'Courier New', monospace; font-size: 11px; color: #9CA3AF;
    letter-spacing: .04em; text-transform: uppercase; line-height: 1.5;
  }
  .p2-screenshot-desc { font-size: 12px; color: #D1D5DB; line-height: 1.4; margin-top: 4px; }

  .p2-evidence-figure { margin: 0; text-align: center; }
  .p2-evidence-img {
    max-width: 360px; width: 100%; height: auto;
    display: block; margin: 0 auto;
    border-radius: var(--cbw-card-radius);
    box-shadow: var(--cbw-shadow-md);
  }
  .p2-evidence-caption {
    font-size: 12px; color: var(--cbw-gray-500); line-height: 1.5;
    margin-top: 8px; text-align: center;
  }
  .p2-evidence-img--wide { max-width: 740px; }

  .p2-table-wrap {
    overflow-x: auto; border-radius: var(--cbw-r-md); border: 1px solid var(--cbw-gray-300);
    margin-top: 10px; color-scheme: light; forced-color-adjust: none;
  }
  .p2-table {
    width: 100%; border-collapse: collapse; font-size: 13px;
    background: var(--cbw-gray-50); min-width: 320px;
  }
  .p2-table th {
    background: var(--cbw-gray-100); padding: 10px 14px; text-align: left;
    font-size: 12px; font-weight: 600; color: var(--cbw-gray-500);
    border-bottom: 1px solid var(--cbw-gray-200); white-space: nowrap;
  }
  .p2-table td { padding: 10px 14px; color: var(--cbw-gray-700); border-bottom: 1px solid var(--cbw-gray-100); }
  .p2-table tr:last-child td { border-bottom: none; }
  .p2-table-placeholder-row td {
    text-align: center; color: #9CA3AF;
    font-size: 12px; font-style: italic; padding: 18px 14px;
  }

  .p2-faq { display: flex; flex-direction: column; gap: 4px; }
  .p2-faq-item {
    border: 1px solid var(--cbw-gray-200); border-radius: var(--cbw-r-md);
    overflow: hidden; background: var(--cbw-white);
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-faq-q {
    padding: 13px 16px; font-size: 14px; font-weight: 600;
    color: var(--cbw-gray-900); cursor: pointer; list-style: none;
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px; transition: background .12s;
  }
  .p2-faq-q::-webkit-details-marker { display: none; }
  .p2-faq-q::after { content: '+'; flex-shrink: 0; font-size: 18px; font-weight: 400; color: #9CA3AF; }
  .p2-faq-item[open] .p2-faq-q::after { content: '−'; }
  .p2-faq-q:hover { background: #F9FAFB; }
  .p2-faq-a { padding: 0 16px 14px; font-size: 13px; color: #4B5563; font-style: normal; line-height: 1.5; }

  /* Related exchange bonuses — horizontal cards */
  .p2-related-intro { font-size: 14px; color: #6B7280; line-height: 1.6; margin: 0 0 14px; }
  .p2-related-grid { display: flex; flex-direction: column; gap: 10px; }
  .p2-rel-card {
    border: 1px solid var(--cbw-card-border); border-radius: var(--cbw-r-md); padding: 12px 14px;
    background: var(--cbw-card-bg); display: flex; align-items: center; gap: 14px;
    box-shadow: var(--cbw-card-shadow);
    color-scheme: light; forced-color-adjust: none;
  }
  /* Logo tile: 86px mobile / 96px desktop. overflow:hidden + border-radius 12px
     clips the logo to clean rounded corners. No padding — solid-background logos
     fill edge-to-edge. border rgba(0,0,0,0.08) is invisible on dark/colored tiles
     but gives a subtle outline to white-bg tiles (OKX) on the light page surface. */
  .p2-rel-logo-wrap {
    flex-shrink: 0; width: 86px; height: 86px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px; overflow: hidden;
    box-sizing: border-box; color-scheme: light;
    border: 1px solid rgba(0,0,0,0.08);
  }
  @media (min-width: 640px) { .p2-rel-logo-wrap { width: 96px; height: 96px; } }
  .p2-rel-logo { width: 100%; height: 100%; object-fit: contain; display: block; }
  .p2-rel-info { flex: 1; min-width: 0; }
  .p2-rel-name { font-size: 13px; font-weight: 700; color: #111827; line-height: 1.2; }
  .p2-rel-bonus { font-size: 12px; font-weight: 600; color: #374151; line-height: 1.3; }
  .p2-rel-tag { font-size: 11px; color: #9CA3AF; margin-top: 1px; }
  .p2-rel-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0; }
  /* CTA button: 54px height / 170px min-width / 800 weight for strong visual presence */
  .p2-rel-btn {
    display: flex; align-items: center; justify-content: center;
    background: var(--cbw-green); color: #fff;
    font-size: 15px; font-weight: 800; border-radius: 10px;
    height: 54px; min-width: 170px; padding: 0 24px; text-decoration: none; white-space: nowrap;
    transition: background .15s, color .15s;
  }
  .p2-rel-btn:hover { background: var(--cbw-green-hover); }
  .p2-rel-btn.is-activated { background: #0d9488; pointer-events: none; cursor: default; }
  .p2-rel-link { font-size: 11px; color: #9CA3AF; text-decoration: underline; text-underline-offset: 2px; white-space: nowrap; }
  .p2-rel-link:hover { color: #6B7280; }
  @media (max-width: 639px) {
    .p2-rel-card { flex-wrap: wrap; }
    .p2-rel-actions { width: 100%; flex-direction: row; align-items: center; gap: 10px; }
    .p2-rel-btn { flex: 1; min-width: 0; height: 48px; }
  }

  /* Rating block */
  .p2-rating-block { text-align: center; }
  .p2-rating-title { font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 10px; }
  .p2-stars { font-size: 28px; color: #D1D5DB; letter-spacing: 2px; margin: 0 0 8px; line-height: 1; }
  .p2-rating-empty { font-size: 13px; color: #9CA3AF; margin: 0; line-height: 1.5; }

  /* Voting block */
  .p2-vote-block { text-align: center; }
  .p2-vote-title { font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 14px; }
  .p2-vote-buttons { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
  .p2-vote-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 0 18px; height: 42px; border-radius: 8px;
    font-size: 14px; font-weight: 600; border: 1.5px solid #E5E7EB;
    background: #fff; color: #374151; cursor: pointer;
    transition: border-color .15s, background .15s, color .15s;
    color-scheme: light; forced-color-adjust: none;
  }
  .p2-vote-btn:hover { border-color: #D1D5DB; background: #F9FAFB; }
  .p2-vote-btn.is-selected-up   { border-color: #16a34a; background: #f0fdf4; color: #15803d; }
  .p2-vote-btn.is-selected-down { border-color: #dc2626; background: #fef2f2; color: #b91c1c; }
  .p2-vote-btn:disabled { cursor: default; }
  .p2-vote-status { font-size: 12px; color: #9CA3AF; margin: 0; line-height: 1.6; }

  /* Article banner — illustration CTA inside section */
  .p2-article-banner-figure { margin: 20px 0 0; }
  .p2-article-banner-img {
    width: 100%; height: auto; display: block;
    border-radius: var(--cbw-r-md);
    box-shadow: var(--cbw-shadow-md);
  }
  .p2-article-banner-caption {
    font-size: 12px; color: var(--cbw-gray-400); line-height: 1.5;
    margin-top: 8px; text-align: center; font-style: italic;
  }
  @media (prefers-color-scheme: dark) {
