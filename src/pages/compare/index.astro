---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import ExchangeLogo from '../../components/ExchangeLogo.astro';

import exchanges from '../../data/exchanges.json';
import comparePairs from '../../data/compare-pairs.json';

import { SITE_NAME, buildItemListSchema } from '../../utils/seo';

const pageTitle   = `Crypto Exchange Comparisons ${new Date().getFullYear()} — Side-by-Side Reviews`;
const pageDesc    = `Compare crypto exchanges side by side. Bonus amounts, KYC requirements, deposit minimums, fees and features — all in one place.`;

// Build exchange lookup for fast access
const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));

// Build schema items
const schemaItems = comparePairs.map(p => ({
  name: p.label,
  url: `/compare/${p.pair}/`,
  description: `Compare ${exMap[p.a]?.name ?? p.a} vs ${exMap[p.b]?.name ?? p.b} — bonuses, KYC, fees and features`,
}));

const schema = buildItemListSchema(schemaItems, 'Crypto Exchange Comparisons');

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Compare', href: '/compare/' },
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/compare/" schema={schema} noindex={true}>
  <div class="container">
    <Breadcrumbs crumbs={crumbs} />

    <div class="page-header">
      <div class="header-badge">📊 Compare Exchanges</div>
      <h1>Crypto Exchange Comparisons</h1>
      <p class="lead">
        Pick any two exchanges and see a full side-by-side breakdown — bonuses, KYC requirements,
        deposit minimums, trading volume conditions, features and more.
      </p>
    </div>

    <div class="compare-grid">
      {comparePairs.map(pair => {
        const a = exMap[pair.a];
        const b = exMap[pair.b];
        if (!a || !b) return null;
        const winner = a.rating >= b.rating ? a : b;
        return (
          <a href={`/compare/${pair.pair}/`} class="compare-card">
            <div class="compare-card__exchanges">
              <div class="compare-card__ex">
                <ExchangeLogo slug={a.slug} name={a.name} size={56} variant="square" />
                <span class="compare-card__name">{a.name}</span>
                <span class="compare-card__rating">{a.rating}</span>
              </div>
              <div class="compare-card__vs">VS</div>
              <div class="compare-card__ex">
                <ExchangeLogo slug={b.slug} name={b.name} size={56} variant="square" />
                <span class="compare-card__name">{b.name}</span>
                <span class="compare-card__rating">{b.rating}</span>
              </div>
            </div>
            <div class="compare-card__footer">
              <span class="compare-card__winner">
                🏆 Edge: <strong>{winner.name}</strong>
              </span>
              <span class="compare-card__cta">Compare →</span>
            </div>
          </a>
        );
      })}
    </div>

    <section class="hub-intro prose">
      <h2>Why Compare Crypto Exchange Bonuses?</h2>
      <p>
        Not all welcome bonuses are equal. A headline figure of "up to 30,000 USDT" may require
        significant trading volume to unlock, while a simpler "100 USDT no-deposit" bonus could
        be worth more in practice for new traders. Our comparison pages cut through the marketing
        copy and lay out the real conditions side by side.
      </p>
      <h2>What We Compare</h2>
      <ul>
        <li><strong>Bonus amount & structure</strong> — headline maximum, tiers and unlock conditions</li>
        <li><strong>KYC requirements</strong> — which exchanges allow no-KYC trading and to what level</li>
        <li><strong>Deposit requirements</strong> — minimum first deposit to activate the bonus</li>
        <li><strong>Trading volume</strong> — volume milestones required for the full bonus</li>
        <li><strong>Platform features</strong> — copy trading, futures, web3 wallet, spot depth</li>
        <li><strong>Licences & trust</strong> — regulatory approvals and years of operation</li>
      </ul>
      <p>
        All comparison data is reviewed and updated regularly. Our editorial team scores each
        exchange independently — no exchange pays for a better position in our comparisons.
      </p>
    </section>

    <section class="hub-crosslinks" aria-label="Explore more on CryptoBonusWorld">
      <h2 class="hub-crosslinks__title">More to Explore</h2>
      <div class="hub-crosslinks__grid">
        <a href="/exchanges/" class="hub-crosslinks__card">
          <span class="hub-crosslinks__icon">🏦</span>
          <div>
            <strong>All Exchange Reviews</strong>
            <p>Individual deep-dive reviews for every exchange — full conditions, walkthroughs and editor scores.</p>
          </div>
          <span class="hub-crosslinks__arrow">→</span>
        </a>
        <a href="/bonuses/" class="hub-crosslinks__card">
          <span class="hub-crosslinks__icon">🎁</span>
          <div>
            <strong>Filter All Bonus Offers</strong>
            <p>Browse and filter {exchanges.length} bonuses by type, KYC requirement and country availability.</p>
          </div>
          <span class="hub-crosslinks__arrow">→</span>
        </a>
        <a href="/use-cases/no-kyc/" class="hub-crosslinks__card">
          <span class="hub-crosslinks__icon">🔓</span>
          <div>
            <strong>Best No-KYC Exchanges</strong>
            <p>Exchanges that let you trade and claim bonuses without identity verification — ranked and compared.</p>
          </div>
          <span class="hub-crosslinks__arrow">→</span>
        </a>
        <a href="/guides/" class="hub-crosslinks__card">
          <span class="hub-crosslinks__icon">📖</span>
          <div>
            <strong>How-To Guides</strong>
            <p>Practical guides on claiming bonuses, passing KYC, using P2P, and choosing an exchange.</p>
          </div>
          <span class="hub-crosslinks__arrow">→</span>
        </a>
      </div>
    </section>

    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .container { max-width: var(--container-max); margin: 0 auto; padding: 0 var(--container-pad); }

  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }
  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: var(--radius-pill);
    padding: 0.3rem 0.75rem;
    margin-bottom: 1rem;
  }
  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .page-header .lead {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0;
  }

  /* ── Compare grid ── */
  .compare-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .compare-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: border-color var(--duration-base) var(--ease-standard),
                box-shadow var(--duration-base) var(--ease-standard),
                transform var(--duration-base) var(--ease-standard);
  }
  .compare-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-card);
    transform: translateY(-2px);
  }

  .compare-card__exchanges {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .compare-card__ex {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    text-align: center;
  }
  /* ExchangeLogo component handles logo sizing/bg — no .compare-card__logo override needed */
  .compare-card__name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .compare-card__rating {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    border-radius: var(--radius-pill);
    padding: 0.1rem 0.5rem;
  }
  .compare-card__vs {
    font-size: var(--text-xs);
    font-weight: 800;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }
  .compare-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-border-subtle);
  }
  .compare-card__winner {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }
  .compare-card__winner strong {
    color: var(--color-accent);
  }
  .compare-card__cta {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  /* ── Hub intro ── */
  .hub-intro {
    max-width: 720px;
    margin: 0 auto 3rem;
    padding: 2rem;
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  /* ── Hub cross-links ── */
  .hub-crosslinks { margin: 2.5rem 0; }
  .hub-crosslinks__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 1.25rem;
    color: var(--color-text-primary);
  }
  .hub-crosslinks__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }
  .hub-crosslinks__card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.125rem 1.25rem;
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text-primary);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .hub-crosslinks__card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent, #f5c542) inset;
  }
  .hub-crosslinks__icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 0.1rem; }
  .hub-crosslinks__card div { flex: 1; min-width: 0; }
  .hub-crosslinks__card strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--color-text-primary);
  }
  .hub-crosslinks__card p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .hub-crosslinks__arrow { font-size: 0.9rem; color: var(--color-accent); flex-shrink: 0; margin-top: 0.1rem; }

  @media (max-width: 640px) {
    .compare-grid { grid-template-columns: 1fr; }
    .hub-intro { padding: 1.25rem; }
    .hub-crosslinks__grid { grid-template-columns: 1fr; }
  }
</style>
