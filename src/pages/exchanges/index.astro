---
import CleanLayout from '../../layouts/CleanLayout.astro';
import ExchangeCard from '../../components/home/ExchangeCard.astro';
import { getFeaturedExchanges } from '../../data/exchanges';
import { getOffer } from '../../data/offers';

const exchanges = getFeaturedExchanges();
const exchangesWithOffers = exchanges.map(ex => ({
  exchange: ex,
  offer: getOffer(ex.slug),
}));
---

<CleanLayout
  title="Crypto Exchanges — Referral Codes & Promo Bonuses | CryptoBonusWorld"
  description="Verified referral codes and welcome bonuses for top crypto exchanges. Bybit, Binance, MEXC and more. Updated June 2026."
>

  <section class="page-header">
    <div class="container">
      <div class="section-label">Exchange Directory</div>
      <h1 class="section-title" style="max-width:560px">Crypto Exchange Promo Codes</h1>
      <p class="section-sub">
        Verified referral codes and welcome bonuses for the world's top crypto exchanges.
        Every code is checked against the official exchange promotions page.
      </p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="exchange-grid">
        {exchangesWithOffers.map(({ exchange, offer }) => (
          <ExchangeCard exchange={exchange} offer={offer} />
        ))}
        {(['Binance']).map(name => (
          <div class="ec-placeholder">
            <div class="ec-ph-inner">
              <div class="ec-ph-name">{name}</div>
              <div class="ec-ph-note">Coming soon</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</CleanLayout>

<style>
  .page-header { padding: 48px 0 0; background: #F7F8F4; }
  .bg-white { background: #fff; }
  .exchange-grid { display: grid; gap: 20px; grid-template-columns: 1fr; }
  @media (min-width: 560px) { .exchange-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .exchange-grid { grid-template-columns: repeat(3, 1fr); } }
  .ec-placeholder {
    border: 2px dashed #E5E7EB; border-radius: 12px;
    display: flex; align-items: center; justify-content: center; min-height: 180px; background: #FAFAFA;
  }
  .ec-ph-inner { text-align: center; }
  .ec-ph-name { font-size: 16px; font-weight: 700; color: #9CA3AF; margin-bottom: 6px; }
  .ec-ph-note { font-size: 12px; color: #D1D5DB; }
</style>
