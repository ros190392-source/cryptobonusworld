---
interface FilterOption {
  label: string;
  value: string;
  href: string;
}

interface Props {
  bonusTypes?: FilterOption[];
  countries?: FilterOption[];
  activeType?: string;
  activeCountry?: string;
}

const {
  bonusTypes = [
    { label: 'All Bonuses', value: '', href: '/bonuses/' },
    { label: 'Signup', value: 'signup', href: '/categories/signup-bonuses/' },
    { label: 'No Deposit', value: 'no-deposit', href: '/categories/no-deposit-bonuses/' },
    { label: 'Deposit', value: 'deposit', href: '/categories/deposit-bonuses/' },
    { label: 'Futures', value: 'futures', href: '/categories/futures-bonuses/' },
    { label: 'Welcome', value: 'welcome', href: '/categories/welcome-bonuses/' },
    { label: 'No KYC', value: 'no-kyc', href: '/categories/no-kyc-bonuses/' },
    { label: 'Trading', value: 'trading-rewards', href: '/categories/trading-rewards/' },
  ],
  countries = [
    { label: 'Global', value: 'global', href: '/countries/global/' },
    { label: 'Turkey', value: 'turkey', href: '/countries/turkey/' },
    { label: 'India', value: 'india', href: '/countries/india/' },
    { label: 'Indonesia', value: 'indonesia', href: '/countries/indonesia/' },
    { label: 'Nigeria', value: 'nigeria', href: '/countries/nigeria/' },
    { label: 'Brazil', value: 'brazil', href: '/countries/brazil/' },
    { label: 'Vietnam', value: 'vietnam', href: '/countries/vietnam/' },
    { label: 'Philippines', value: 'philippines', href: '/countries/philippines/' },
  ],
  activeType = '',
  activeCountry = '',
} = Astro.props;
---

<div class="filter-panel">
  <div class="filter-group">
    <span class="filter-label">Bonus Type</span>
    <div class="filter-chips">
      {bonusTypes.map(opt => (
        <a
          href={opt.href}
          class:list={['filter-chip', activeType === opt.value && 'active']}
          aria-current={activeType === opt.value ? 'page' : undefined}
        >
          {opt.label}
        </a>
      ))}
    </div>
  </div>

  <div class="filter-group">
    <span class="filter-label">Country</span>
    <div class="filter-chips">
      {countries.map(opt => (
        <a
          href={opt.href}
          class:list={['filter-chip', activeCountry === opt.value && 'active']}
          aria-current={activeCountry === opt.value ? 'page' : undefined}
        >
          {opt.label}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .filter-panel {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .filter-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .filter-chip {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-chip:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent-dim);
  }
  .filter-chip.active {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
    font-weight: 700;
  }
</style>
