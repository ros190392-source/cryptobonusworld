---
/**
 * AuthorCard — Compact inline author / reviewer attribution card.
 *
 * More visual than ReviewerBlock — intended for article pages, guide pages,
 * and anywhere a prominent "written by / reviewed by" block adds E-E-A-T value.
 *
 * Renders schema.org Person + Review markup for author understanding.
 *
 * Usage:
 *   <AuthorCard
 *     name="Alex Morgan"
 *     title="Senior Crypto Exchange Analyst"
 *     initials="AM"
 *     reviewedAt="2026-05-20"
 *     profileUrl="/reviewers/alex-morgan/"
 *     verb="Reviewed by"
 *   />
 */

interface Props {
  name?: string;
  title?: string;
  bio?: string;
  initials?: string;
  photo?: string;
  reviewedAt?: string;
  profileUrl?: string;
  verb?: 'Reviewed by' | 'Written by' | 'Verified by' | 'Updated by' | 'Analysed by';
  /** Show full bio paragraph */
  showBio?: boolean;
  /** Compact single-line variant */
  compact?: boolean;
}

const {
  name       = 'CryptoBonusWorld Editorial Team',
  title      = 'Crypto Exchange Analysts',
  bio        = 'Our editorial team manually verifies all bonus amounts, conditions and exchange data against official promotion pages.',
  initials   = 'CB',
  photo,
  reviewedAt = new Date().toISOString().split('T')[0],
  profileUrl,
  verb       = 'Reviewed by',
  showBio    = false,
  compact    = false,
} = Astro.props;

function fmtDate(iso: string): string {
  try {
    return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return iso; }
}

const dateLabel = fmtDate(reviewedAt);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  jobTitle: title,
  ...(profileUrl ? { url: `https://cryptobonusworld.com${profileUrl}` } : {}),
};
---

{compact ? (
  <div class="ac-compact" itemprop="author" itemscope itemtype="https://schema.org/Person">
    <div class="ac-avatar--sm" aria-hidden="true">
      {photo ? <img src={photo} alt={name} width="24" height="24" /> : initials}
    </div>
    <div class="ac-compact__text">
      <span class="ac-verb">{verb}: </span>
      {profileUrl
        ? <a href={profileUrl} class="ac-name" itemprop="name">{name}</a>
        : <span class="ac-name" itemprop="name">{name}</span>
      }
      <time class="ac-date" datetime={reviewedAt}> · {dateLabel}</time>
    </div>
  </div>
) : (
  <div class="ac">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <div class="ac-inner" itemprop="author" itemscope itemtype="https://schema.org/Person">
      <div class="ac-avatar" aria-hidden="true">
        {photo
          ? <img src={photo} alt={name} width="52" height="52" />
          : <span class="ac-initials">{initials}</span>
        }
      </div>
      <div class="ac-body">
        <div class="ac-header">
          <div class="ac-meta">
            <span class="ac-verb">{verb}</span>
            {profileUrl
              ? <a href={profileUrl} class="ac-name" itemprop="name">{name}</a>
              : <span class="ac-name" itemprop="name">{name}</span>
            }
          </div>
          <div class="ac-sub">
            <span class="ac-title" itemprop="jobTitle">{title}</span>
            <span class="ac-sep">·</span>
            <time class="ac-date" datetime={reviewedAt} itemprop="datePublished">{dateLabel}</time>
          </div>
        </div>
        {showBio && bio && (
          <p class="ac-bio" itemprop="description">{bio}</p>
        )}
        {profileUrl && (
          <a href={profileUrl} class="ac-profile-link">View full profile →</a>
        )}
      </div>
    </div>
  </div>
)}

<style>
  /* ── Compact variant ── */
  .ac-compact {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .ac-avatar--sm {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(245,197,66,0.15);
    color: var(--color-accent);
    font-size: 0.55rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .ac-avatar--sm img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .ac-compact__text { line-height: 1.3; }

  /* ── Full variant ── */
  .ac {
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .ac-inner {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }
  .ac-avatar {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: hidden;
  }
  .ac-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .ac-initials {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(245,197,66,0.12);
    border: 1px solid rgba(245,197,66,0.25);
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: -0.02em;
  }
  .ac-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .ac-header { display: flex; flex-direction: column; gap: 0.1rem; }
  .ac-meta {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .ac-verb {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  .ac-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
  }
  a.ac-name:hover { color: var(--color-accent); }
  .ac-sub {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .ac-title {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .ac-sep { font-size: var(--text-xs); color: var(--color-border); }
  .ac-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .ac-bio {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0.4rem 0 0.25rem;
  }
  .ac-profile-link {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.2rem;
  }

  /* Shared */
  .ac-verb { color: var(--color-text-muted); }
</style>
