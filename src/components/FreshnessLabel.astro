---
/**
 * FreshnessLabel.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * Small inline badge that shows when content was last verified.
 * Semantically correct: wraps in <time datetime="..."> for machine readability.
 *
 * Variants:
 *   generic   → "Updated June 2026"  (default)
 *   review    → "Updated June 2026"  (with review icon)
 *   bonus     → "Bonus verified 2 days ago"
 *   interface → "Interface checked June 2026"
 *
 * Usage:
 *   <FreshnessLabel dateStr={ex.lastVerified} variant="review" />
 *   <FreshnessLabel dateStr={ex.offerLastChecked} variant="bonus" />
 *   <FreshnessLabel label="Updated June 2026" />
 */

import {
  getFreshnessLabel,
  getBonusFreshnessLabel,
  getInterfaceCheckedLabel,
} from '../utils/freshness';

interface Props {
  /** ISO date string (YYYY-MM or YYYY-MM-DD) — used to compute the label */
  dateStr?: string | null;
  /** Pre-computed label — skips computation when provided */
  label?: string;
  /** Visual and copy variant */
  variant?: 'generic' | 'review' | 'bonus' | 'interface';
  /** Additional CSS classes for outer element */
  class?: string;
}

const {
  dateStr,
  label: labelProp,
  variant = 'generic',
  class: className,
} = Astro.props;

// Compute the display label
let displayLabel = labelProp ?? '';
if (!displayLabel && dateStr) {
  switch (variant) {
    case 'bonus':     displayLabel = getBonusFreshnessLabel(dateStr);     break;
    case 'interface': displayLabel = getInterfaceCheckedLabel(dateStr);    break;
    default:          displayLabel = getFreshnessLabel(dateStr);           break;
  }
}

// Normalise date for the <time> datetime attribute
const isoDate = dateStr
  ? (dateStr.length === 7 ? `${dateStr}-01` : dateStr)
  : '';
---

{displayLabel && (
  <span class:list={['fl', `fl--${variant}`, className]}>
    {isoDate
      ? <time datetime={isoDate}>{displayLabel}</time>
      : displayLabel
    }
  </span>
)}

<style>
  .fl {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted, #6b7280);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 20px;
    padding: 0.18rem 0.6rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
    line-height: 1.6;
    vertical-align: middle;
  }

  /* Checkmark prefix — generic & review */
  .fl::before {
    content: '✓';
    font-size: 0.6rem;
    color: #4ade80;
    font-weight: 900;
    flex-shrink: 0;
  }

  .fl--bonus::before     { content: '🎁'; font-size: 0.65rem; }
  .fl--interface::before { content: '🖥️'; font-size: 0.65rem; }

  time {
    color: inherit;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .fl {
      font-size: 0.68rem;
      padding: 0.15rem 0.5rem;
    }
  }
</style>
