{
  "name": "cryptobonusworld",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "audit": "node scripts/audit-exchanges.mjs",
    "audit:json": "node scripts/audit-exchanges.mjs --json",
    "audit:content": "node scripts/audit-content.mjs",
    "audit:content:json": "node scripts/audit-content.mjs --json",
    "content:draft": "node scripts/content-draft.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:links:json": "node scripts/audit-links.mjs --json",
    "audit:links:strict": "node scripts/audit-links.mjs --fail-on-missing",
    "validate": "node scripts/validate-bonuses.cjs",
    "validate:strict": "node scripts/validate-bonuses.cjs || exit 2",
    "deploy": "node scripts/deploy.mjs",
    "media-update": "node scripts/media-update.mjs",
    "evidence:audit": "node scripts/evidence-audit.mjs",
    "evidence:audit:json": "node scripts/evidence-audit.mjs --json",
    "evidence:queue": "node scripts/evidence-update-queue.mjs",
    "evidence:queue:p1": "node scripts/evidence-update-queue.mjs --priority P1",
    "evidence:queue:bybit": "node scripts/evidence-update-queue.mjs --exchange bybit",
    "evidence:queue:stale": "node scripts/evidence-update-queue.mjs --stale-only",
    "evidence:queue:md": "node scripts/evidence-update-queue.mjs --format markdown --out reports/evidence-update-queue.md",
    "screenshot:checklist": "node scripts/screenshot-checklist.mjs",
    "screenshot:checklist:missing": "node scripts/screenshot-checklist.mjs --missing-only",
    "screenshot:checklist:json": "node scripts/screenshot-checklist.mjs --json",
    "screenshot:checklist:bybit": "node scripts/screenshot-checklist.mjs --exchange bybit",
    "seo:intake": "node scripts/seo-issue-intake.mjs",
    "seo:intake:gsc": "node scripts/seo-issue-intake.mjs --source google-search-console",
    "seo:intake:critical": "node scripts/seo-issue-intake.mjs --severity critical",
    "seo:intake:open": "node scripts/seo-issue-intake.mjs --status new,classified,needs_manual_review",
    "seo:intake:inbox": "node scripts/seo-issue-intake.mjs --status new",
    "seo:intake:json": "node scripts/seo-issue-intake.mjs --format json",
    "indexnow": "node scripts/indexnow.mjs",
    "indexnow:dry": "node scripts/indexnow.mjs --dry-run"
  },
  "dependencies": {
    "astro": "^4.15.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.1.6",
    "typescript": "^5.5.0"
  }
}
