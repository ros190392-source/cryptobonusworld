# ── Analytics Providers ──────────────────────────────────────────────────────
#
# Google Tag Manager (recommended — manages GA4 + all other tags from GTM UI)
#   1. Create account at https://tagmanager.google.com
#   2. Create container → Web → copy GTM-XXXXXXX ID
#   3. Add GA4 configuration tag inside GTM (no GA4_ID needed)
#
GTM_ID=

# Google Analytics 4 (standalone — use ONLY if NOT using GTM)
#   1. Go to https://analytics.google.com
#   2. Admin → Data Streams → Web → copy Measurement ID (G-XXXXXXXXXX)
#   Note: Leave empty if GTM_ID is set — GTM manages GA4 internally.
#
GA4_ID=

# Microsoft Clarity (heatmaps + session recordings — free)
#   1. Go to https://clarity.microsoft.com
#   2. Create project → copy 10-char Project ID (e.g. "abc123defg")
#
CLARITY_ID=

# Yandex Metrika
#   1. Go to https://metrika.yandex.ru
#   2. Add counter → copy numeric counter ID (e.g. 12345678)
#
METRIKA_ID=

# ── Webmaster / Search Engine Verification ─────────────────────────────────
#
# Google Search Console
#   1. Go to https://search.google.com/search-console
#   2. Add property → Domain or URL prefix: https://cryptobonusworld.com
#   3. Verify via HTML meta tag method → copy the content="xxxxx" value
#   4. Set this variable and redeploy
#
GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster
#   1. Go to https://webmaster.yandex.com
#   2. Add site → https://cryptobonusworld.com
#   3. Choose HTML meta tag verification → copy the content="xxxxx" value
#   4. Set this variable and redeploy
#
YANDEX_SITE_VERIFICATION=

# Bing Webmaster
#   Already handled: /public/BingSiteAuth.xml contains token 2B90401F6B57E87111C6F25F046ED1FE
#   No additional env var needed. Verify in Bing Webmaster at:
#   https://www.bing.com/webmasters → Add site → XML file method → already in place.
#
# ── IndexNow (Bing / Yandex instant indexing) ─────────────────────────────
#
# IndexNow allows pushing new/updated URLs to Bing and Yandex instantly.
# To set up:
#   1. Generate a key at https://www.bing.com/indexnow or use any random UUID
#   2. Create /public/{key}.txt containing only the key value
#   3. POST to https://api.indexnow.org/indexnow with your key + URLs
#   See: https://www.indexnow.org/documentation
#
INDEXNOW_KEY=

# ── Telegram Bot (notifications & reports) ───────────────────────────────────
#
# Used by: scripts/bonus-telegram-report.mjs, scripts/affiliate-telegram-report.mjs
#          scripts/screenshots-telegram-report.mjs, scripts/lib/telegram.mjs
# Also used in GitHub Actions workflow (.github/workflows/production-monitor.yml)
#
# 1. Create a bot via @BotFather on Telegram → /newbot → copy the token
# 2. Add the bot to your channel/group as admin
# 3. Get TELEGRAM_CHAT_ID:
#    - For a channel: forward a message to @userinfobot, or use
#      https://api.telegram.org/bot{TOKEN}/getUpdates after sending a message
#    - For a private group: same getUpdates method; IDs are negative (-1001...)
# 4. Add both to GitHub → Settings → Secrets and Variables → Actions → New secret
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Production Deployment (public-key SSH only — NEVER a password) ────────────
#
# Used by: deploy.py and scripts/deploy.mjs (`npm run deploy`).
# Authentication is public-key only. There is NO password variable and no
# password fallback. Real values belong in your local secret manager or a
# protected CI secret store — never committed. Host-key verification stays on.
# See docs/security/CBW_DEPLOYMENT_CREDENTIALS_STANDARD_v1.md.
#
#   CBW_DEPLOY_HOST        production host name or IP (required)
#   CBW_DEPLOY_USER        deployment SSH user        (required)
#   CBW_DEPLOY_KEY_PATH    path to your deployment SSH private key (required)
#   CBW_DEPLOY_PORT        SSH port (optional; default 22)
#   CBW_DEPLOY_REMOTE_PATH remote web root (optional; default shown below)
#
CBW_DEPLOY_HOST=
CBW_DEPLOY_USER=
CBW_DEPLOY_PORT=22
CBW_DEPLOY_KEY_PATH=
CBW_DEPLOY_REMOTE_PATH=/var/www/cryptobonusworld/html
