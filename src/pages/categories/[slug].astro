---
import Layout from '../../layouts/Layout.astro';
import BonusTable from '../../components/BonusTable.astro';
import ExchangeCard from '../../components/ExchangeCard.astro';
import FilterPanel from '../../components/FilterPanel.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import CTAButton from '../../components/CTAButton.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import HowWeEvaluate from '../../components/HowWeEvaluate.astro';

import exchanges from '../../data/exchanges.json';
import categories from '../../data/categories.json';

import RelatedCategoriesBlock from '../../components/RelatedCategoriesBlock.astro';

import {
  categoryPageTitle,
  categoryMetaDesc,
  buildItemListSchema,
} from '../../utils/seo';
import type { PageContext } from '../../utils/analytics';

export async function getStaticPaths() {
  return categories.map(cat => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category: cat } = Astro.props;

const filtered = exchanges.filter(ex => {
  if (cat.bonusType === 'no-kyc') return !ex.kycRequired;
  if (cat.bonusType === 'no-deposit') return !ex.depositRequired;
  if (cat.bonusType === 'welcome') return ex.bonusTypes.includes('signup');
  return ex.bonusTypes.includes(cat.bonusType);
});

const top3 = [...filtered].sort((a, b) => b.rating - a.rating).slice(0, 3);

// SEO: dynamic title + description with live count + best offer
const pageTitle = categoryPageTitle(cat.seoTitle, filtered.length);
const pageDesc = categoryMetaDesc(cat as any, filtered as any);

// SEO: related categories (exclude self)
const otherCats = (categories as any[]).filter(c => c.slug !== cat.slug);

// SEO: ItemList schema for all matching exchanges
const itemListSchema = buildItemListSchema(
  [...filtered]
    .sort((a, b) => b.rating - a.rating)
    .map(ex => ({
      name: `${ex.name} ${cat.name}`,
      url: `/exchanges/${ex.slug}/`,
      description: ex.shortDescription,
    })),
  cat.title
);

const analyticsContext: PageContext = {
  pageType: 'category',
  categorySlug: cat.slug,
  categoryCount: filtered.length,
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={`/categories/${cat.slug}/`}
  schema={itemListSchema}
  analyticsContext={analyticsContext}
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Categories', href: '/bonuses/' },
      { label: cat.name },
    ]} />

    <div class="page-header">
      <h1>{cat.title}</h1>
      <p class="lead">{cat.description} {filtered.length} exchange{filtered.length !== 1 ? 's' : ''} available.</p>
    </div>

    <AffiliateDisclosure compact />

    {top3.length > 0 && (
      <AnswerBox
        question={`What is the best ${cat.name.toLowerCase()} crypto exchange?`}
        answer={`The best ${cat.name.toLowerCase()} exchange in ${new Date().getFullYear()} is ${top3[0].name} — offering up to ${top3[0].bonusAmount.toLocaleString('en-US')} ${top3[0].bonusCurrency}${!top3[0].kycRequired ? ', no KYC required' : ''}. ${filtered.length} exchanges currently offer ${cat.name.toLowerCase()}.${top3[1] ? ` ${top3[1].name} and ${top3[2]?.name ?? ''} are strong alternatives.`.replace(' and ', ' are strong alternatives.') : ''}`}
        updatedDate="May 2026"
        compact={true}
      />
    )}

    <FilterPanel activeType={cat.bonusType} />

    {cat.intro && (
      <div class="category-intro prose">
        <p>{cat.intro}</p>
      </div>
    )}

    <BonusTable exchanges={filtered} suppressSchema={true} />

    <section class="section">
      <h2 class="section-title">Top {cat.name} Picks</h2>
      <div class="grid-3">
        {top3.map(ex => <ExchangeCard {...ex} />)}
      </div>
    </section>

    <div class="cta-section">
      <p>Not what you're looking for?</p>
      <CTAButton href="/bonuses/" label="Compare All Bonuses" variant="outline" size="md" />
    </div>

    {otherCats.length > 0 && (
      <RelatedCategoriesBlock
        categories={otherCats}
        heading="Explore Other Bonus Types"
        subheading="Browse other bonus categories to find the best offer for your situation."
      />
    )}

    <!-- How we evaluate — E-E-A-T methodology reference above FAQ -->
    <HowWeEvaluate variant="compact" />

    {cat.faq && cat.faq.length > 0 && (
      <FAQBlock items={cat.faq} />
    )}

    <RiskDisclaimer />
  </div>
</Layout>

<!-- Mobile sticky CTA -->
<div class="cat-sticky">
  <span class="cat-sticky-label">{cat.name} — {filtered.length} exchanges</span>
  <a href="/bonuses/" class="cat-sticky-btn">All Bonuses →</a>
</div>

<style>
  .section { margin-top: 2rem; }
  .category-intro { margin: 1rem 0 1.5rem; }
  .cta-section {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
    padding: 1.25rem;
    background: var(--color-bg-secondary);
    border-radius: 10px;
    border: 1px solid var(--color-border);
  }
  .cta-section p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* ── Mobile sticky CTA ── */
  .cat-sticky {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 150;
    background: rgba(10, 10, 10, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.875rem;
  }
  .cat-sticky-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }
  .cat-sticky-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.625rem 1.25rem;
    background: var(--color-accent);
    color: #000;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .cat-sticky-btn:hover { opacity: 0.88; }

  @media (max-width: 768px) {
    .cat-sticky { display: flex; }
    :global(body) { padding-bottom: 72px; }
    .cta-section {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
