---
import BonusBadge from './BonusBadge.astro';
import BonusTrustLabel from './BonusTrustLabel.astro';
import CTAButton from './CTAButton.astro';
import ExchangeLogo from './ExchangeLogo.astro';
import { getCtaLabel, getCtaLabelShort } from '../utils/affiliateUtils';

interface BonusRange {
  min: number;
  max: number;
  typicalMin?: number;
  typicalMax?: number;
  currency: string;
  typicalNote?: string;
}

interface Exchange {
  name: string;
  slug: string;
  logo: string;
  rating: number;
  bonusTitle: string;
  bonusAmount: number;
  bonusCurrency: string;
  bonusTypes: string[];
  kycRequired: boolean;
  depositRequired: boolean;
  countries: string[];
  affiliateUrl: string;
  updatedAt: string;
  shortDescription?: string;
  bestFor?: string[];
  topChoice?: boolean;
  users?: string;
  // Accuracy fields
  bonusDisplayMode?: 'up-to' | 'range' | 'fixed' | 'regional' | 'campaign';
  bonusRange?: BonusRange;
  verificationStatus?: 'verified' | 'needs-review' | 'outdated' | 'unverified';
  offerLastChecked?: string;
  bonusExpiry?: { days: number; note?: string } | null;
  excludedCountries?: string[];
  realisticUserExpectation?: string;
}

interface Props {
  exchanges: Exchange[];
  filterCountry?: string;
  filterType?: string;
}

const { exchanges, filterCountry, filterType } = Astro.props;

let filtered = [...exchanges];
if (filterCountry) filtered = filtered.filter(e => e.countries.includes(filterCountry));
if (filterType)    filtered = filtered.filter(e => e.bonusTypes.includes(filterType));

const maxBonus = Math.max(...filtered.map(e => e.bonusAmount));

import { getBrandColor } from '../utils/logoConfig';

// Rank medal colors
const rankColor = ['#F5C542', '#C0C0C0', '#CD7F32'];

// Editorial labels — derived from real exchange data, no invented claims
function getLabel(ex: Exchange, rank: number): { text: string; cls: string } | null {
  if (rank === 0) return { text: '🏆 Top Choice', cls: 'lbl--gold' };
  if (!ex.kycRequired && !ex.depositRequired) return { text: '✓ No KYC · No Deposit', cls: 'lbl--green' };
  if (!ex.kycRequired) return { text: '✓ No KYC', cls: 'lbl--green' };
  if (ex.bonusTypes.includes('futures') && ex.bonusAmount >= 5000) return { text: '📈 Best Futures', cls: 'lbl--purple' };
  if (ex.rating >= 9.5 && rank > 0) return { text: '⭐ Top Rated', cls: 'lbl--blue' };
  return null;
}

// Social proof from real data — only shown when user count is significant
function getUsersLabel(ex: Exchange): string | null {
  if (!ex.users) return null;
  const n = parseInt(ex.users.replace(/[^0-9]/g, ''), 10);
  if (n >= 20) return `${ex.users} users`;
  return null;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Crypto Exchange Bonuses",
  "itemListElement": filtered.map((ex, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://cryptobonusworld.com/exchanges/${ex.slug}/`,
    "name": `${ex.name} Bonus — ${ex.bonusTitle}`,
  })),
};
---

<div class="bt-wrap">

  <!-- ── DESKTOP TABLE ───────────────────────── -->
  <table class="bt" role="table" aria-label="Crypto exchange bonus comparison">
    <thead class="bt-head">
      <tr>
        <th class="th-rank">#</th>
        <th class="th-exchange">Exchange</th>
        <th class="th-bonus">Welcome Bonus</th>
        <th class="th-type">Type</th>
        <th class="th-kyc">KYC</th>
        <th class="th-rating">Score</th>
        <th class="th-cta">Action</th>
      </tr>
    </thead>
    <tbody>
      {filtered.map((ex, i) => {
        const barPct = Math.round((ex.bonusAmount / maxBonus) * 100);
        const color  = getBrandColor(ex.slug);
        const medal  = rankColor[i] ?? null;
        const label  = getLabel(ex, i);
        const usersLabel = getUsersLabel(ex);
        const featured = i === 0;
        return (
          <tr class:list={['bt-row', featured && 'bt-row--featured']} data-slug={ex.slug}>

            {/* Rank */}
            <td class="td-rank">
              <span class="rank-num" style={medal ? `color:${medal};` : ''}>
                {i + 1}
              </span>
            </td>

            {/* Exchange */}
            <td class="td-exchange">
              <a href={`/exchanges/${ex.slug}/`} class="ex-link">
                <ExchangeLogo slug={ex.slug} name={ex.name} size={88} variant="square" />
                <div class="ex-meta">
                  <span class="ex-name">{ex.name}</span>
                  {label && (
                    <span class:list={['ex-label', label.cls]}>{label.text}</span>
                  )}
                  {ex.bestFor && ex.bestFor.length > 0 && (
                    <span class="ex-bestfor">Best for: {ex.bestFor.slice(0, 2).join(' · ')}</span>
                  )}
                  {usersLabel && (
                    <span class="ex-users">{usersLabel}</span>
                  )}
                </div>
              </a>
            </td>

            {/* Bonus */}
            <td class="td-bonus">
              <div class="bonus-amount-row">
                {ex.bonusDisplayMode === 'campaign' ? (
                  <span class="bonus-campaign-label">Active offer</span>
                ) : (
                  <>
                    <span class="bonus-eyebrow">
                      {ex.bonusDisplayMode === 'fixed' ? '' : 'UP TO'}
                    </span>
                    <span class="bonus-amount">
                      {ex.bonusAmount >= 1000
                        ? (ex.bonusAmount / 1000).toFixed(ex.bonusAmount % 1000 === 0 ? 0 : 1) + 'K'
                        : ex.bonusAmount} {ex.bonusCurrency}
                    </span>
                  </>
                )}
              </div>
              <div class="bonus-bar-track" title={ex.bonusTitle}>
                <div class="bonus-bar-fill" style={`width:${barPct}%; background:${color};`}></div>
              </div>
              <div class="bonus-meta-row">
                <BonusTrustLabel
                  verificationStatus={ex.verificationStatus ?? 'needs-review'}
                  offerLastChecked={ex.offerLastChecked ?? ex.updatedAt}
                  hasExpiry={!!(ex as any).bonusExpiry}
                  isRegional={(ex.excludedCountries ?? []).length > 0}
                  variant="chip"
                />
              </div>
              {(ex.bonusRange?.typicalNote ?? (ex as any).realisticUserExpectation) && (
                <div class="bonus-typical-row">
                  {ex.bonusRange?.typicalNote
                    ? ex.bonusRange.typicalNote
                    : (ex as any).realisticUserExpectation?.split(';')[0]}
                </div>
              )}
            </td>

            {/* Types */}
            <td class="td-types">
              <div class="badge-row">
                {ex.bonusTypes.slice(0, 2).map(t => <BonusBadge type={t} />)}
              </div>
            </td>

            {/* KYC */}
            <td class="td-kyc">
              {ex.kycRequired
                ? <span class="kyc kyc--req">KYC</span>
                : <span class="kyc kyc--none">No KYC</span>
              }
            </td>

            {/* Rating */}
            <td class="td-rating">
              <span class="score" style={ex.rating >= 9.5 ? 'color:#4ade80' : ex.rating >= 9.0 ? 'color:#facc15' : 'color:#fb923c'}>
                {ex.rating.toFixed(1)}
              </span>
              <div class="score-stars" aria-hidden="true">
                {Array.from({ length: 5 }).map((_, si) => (
                  <svg width="10" height="10" viewBox="0 0 24 24" style={si < Math.round(ex.rating / 2) ? 'fill:#f5c542' : 'fill:#333'}>
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
            </td>

            {/* CTA */}
            <td class="td-cta">
              <CTAButton
                href={ex.affiliateUrl}
                label={featured ? getCtaLabelShort(ex as any) : (!ex.kycRequired ? 'No KYC →' : 'View →')}
                exchange={ex.name}
                size={featured ? 'md' : 'sm'}
                variant={featured ? 'primary' : 'outline'}
                trackPlacement={featured ? 'table-featured' : 'table'}
                trackBonus={ex.bonusAmount}
              />
            </td>

          </tr>
        );
      })}
    </tbody>
  </table>

  <!-- ── MOBILE CARDS ───────────────────────── -->
  <div class="bt-mobile">
    {filtered.map((ex, i) => {
      const color = getBrandColor(ex.slug);
      const label = getLabel(ex, i);
      const mobileUsersLabel = getUsersLabel(ex);
      const featured = i === 0;
      return (
        <div class:list={['mc', featured && 'mc--featured']} data-slug={ex.slug}>
          <div class="mc-top">
            <a href={`/exchanges/${ex.slug}/`} class="mc-identity">
              <ExchangeLogo slug={ex.slug} name={ex.name} size={72} variant="square" />
              <div class="mc-meta">
                <span class="mc-name">{ex.name}</span>
                {label && <span class:list={['ex-label', label.cls]}>{label.text}</span>}
              </div>
            </a>
            <div class="mc-bonus">
              <div class="mc-amount-row">
                {ex.bonusDisplayMode === 'campaign' ? (
                  <span class="mc-campaign-label">Active offer</span>
                ) : (
                  <>
                    {ex.bonusDisplayMode !== 'fixed' && <span class="mc-eyebrow">Up to</span>}
                    <span class="mc-amount">
                      {ex.bonusAmount >= 1000
                        ? (ex.bonusAmount / 1000).toFixed(0) + 'K'
                        : ex.bonusAmount} {ex.bonusCurrency}
                    </span>
                  </>
                )}
              </div>
              <BonusTrustLabel
                verificationStatus={ex.verificationStatus ?? 'needs-review'}
                offerLastChecked={ex.offerLastChecked ?? ex.updatedAt}
                variant="chip"
              />
            </div>
          </div>

          <div class="mc-badges">
            {ex.bonusTypes.slice(0, 2).map(t => <BonusBadge type={t} />)}
            {ex.kycRequired
              ? <span class="kyc kyc--req">KYC</span>
              : <span class="kyc kyc--none">No KYC</span>
            }
            <span class="mc-score">★ {ex.rating.toFixed(1)}</span>
            {mobileUsersLabel && <span class="mc-users">{mobileUsersLabel}</span>}
          </div>

          <div class="mc-footer">
            <a href={`/exchanges/${ex.slug}/`} class="mc-details">Full details →</a>
            <CTAButton
              href={ex.affiliateUrl}
              label={!ex.kycRequired ? 'No KYC →' : 'View →'}
              exchange={ex.name}
              size="sm"
              trackPlacement={featured ? 'mobile-card-featured' : 'mobile-card'}
              trackBonus={ex.bonusAmount}
            />
          </div>
        </div>
      );
    })}
  </div>

</div>
<p class="bt-terms-note">Bonus amounts are advertised maximums in the exchange's native currency (USDT, USD, etc.) and are not guaranteed. Actual rewards depend on deposit size, trading volume, tasks completed and regional eligibility. <a href="/affiliate-disclosure/">Affiliate disclosure</a> · <a href="/methodology/">How we rank</a> · <a href="/disclaimer/">Full disclaimer</a>.</p>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  /* ── WRAPPER ────────────────────────────── */
  .bt-wrap {
    border-radius: 14px;
    border: 1px solid var(--color-border);
    /* clip-path preserves rounded corners without creating a scroll context,
       which would break position:sticky on the thead. Never use overflow:hidden here. */
    clip-path: inset(0 round 14px);
    margin: 1.5rem 0;
  }

  /* ── DESKTOP TABLE ──────────────────────── */
  .bt {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  /* Sticky header — offset = site header (64px) + trust strip (~33px) */
  .bt-head {
    position: sticky;
    top: 97px;
    z-index: 10;
    background: var(--surface-elevated, #151515);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 2px solid var(--color-border);
  }
  .bt-head th {
    padding: 0.875rem 1rem;
    text-align: left;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    white-space: nowrap;
    user-select: none;
  }
  .th-rank  { width: 48px; text-align: center; }
  .th-cta   { text-align: right; }

  /* Rows */
  .bt-row {
    border-bottom: 1px solid var(--color-border);
    transition: background 0.12s;
    cursor: pointer;
  }
  .bt-row:last-child { border-bottom: none; }
  .bt-row:hover { background: rgba(255,255,255,0.025); }
  .bt-row:hover .ex-name { color: var(--color-accent); }

  /* Featured row — higher visual weight for #1 pick */
  .bt-row--featured {
    background: linear-gradient(90deg, rgba(245,197,66,0.06) 0%, rgba(245,197,66,0.02) 100%);
    border-left: 4px solid var(--color-accent);
    box-shadow: inset 0 0 0 1px rgba(245,197,66,0.06);
  }
  .bt-row--featured:hover {
    background: linear-gradient(90deg, rgba(245,197,66,0.09) 0%, rgba(245,197,66,0.04) 100%);
  }
  /* Featured rank: bigger gold number */
  .bt-row--featured .rank-num {
    font-size: 1rem;
    color: var(--color-accent);
  }
  /* Featured bonus amount: slightly larger */
  .bt-row--featured .bonus-amount {
    font-size: 1.15rem;
  }

  /* Contextually featured by recommendation engine — subtle pulse on first render */
  [data-ctx-featured="true"] {
    background: rgba(245,197,66,0.04);
    border-left: 3px solid var(--color-accent);
  }
  [data-ctx-featured="true"]:hover { background: rgba(245,197,66,0.07); }

  /* Mobile card ctx-featured */
  .mc[data-ctx-featured="true"] {
    border-color: var(--color-accent);
    background: rgba(245,197,66,0.03);
  }

  /* Cells */
  .bt-row td {
    padding: 1.125rem 1rem;
    vertical-align: middle;
  }

  /* ── RANK ───────────────────────────────── */
  .td-rank { text-align: center; width: 48px; }
  .rank-num {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  /* ── EXCHANGE ───────────────────────────── */
  .ex-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }
  :global(.bt-row:hover .exlogo) {
    box-shadow: 0 0 14px rgba(245,197,66,0.18), 0 2px 8px rgba(0,0,0,0.35);
    border-color: rgba(245,197,66,0.2);
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .ex-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ex-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    transition: color 0.15s;
    white-space: nowrap;
  }

  /* Best-for micro-copy */
  .ex-bestfor {
    display: block;
    font-size: 0.63rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
    line-height: 1.3;
  }

  /* Social proof — user count from real data */
  .ex-users {
    display: block;
    font-size: 0.63rem;
    color: #60a5fa;
    margin-top: 0.1rem;
    line-height: 1.3;
    font-weight: 600;
  }

  /* Mobile card users badge */
  .mc-users {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    font-weight: 600;
    color: #60a5fa;
    background: rgba(96,165,250,0.08);
    border: 1px solid rgba(96,165,250,0.15);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    white-space: nowrap;
  }

  /* Editorial labels */
  .ex-label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .lbl--gold   { background: rgba(245,197,66,0.15); color: #f5c542; border: 1px solid rgba(245,197,66,0.25); }
  .lbl--green  { background: rgba(74,222,128,0.12); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .lbl--purple { background: rgba(192,132,252,0.12); color: #c084fc; border: 1px solid rgba(192,132,252,0.2); }
  .lbl--blue   { background: rgba(96,165,250,0.12); color: #60a5fa; border: 1px solid rgba(96,165,250,0.2); }

  /* ── BONUS ──────────────────────────────── */
  .td-bonus { min-width: 160px; }

  .bonus-amount-row {
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    line-height: 1.1;
  }
  .bonus-eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .bonus-amount {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .bonus-meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.2rem;
  }
  .bonus-typical {
    font-size: 0.62rem;
    color: var(--color-text-muted);
    opacity: 0.75;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 160px;
  }
  .bonus-typical-row {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    margin-top: 0.3rem;
    line-height: 1.4;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-style: italic;
  }
  .bonus-campaign-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.01em;
  }
  .mc-campaign-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  .bonus-bar-track {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    margin: 0.35rem 0 0.2rem;
    overflow: hidden;
  }
  .bonus-bar-fill {
    height: 100%;
    border-radius: 2px;
    opacity: 0.88;
    transition: width 0.4s ease;
  }
  .bonus-sub {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  /* ── TYPES ──────────────────────────────── */
  .td-types { min-width: 120px; }
  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  /* ── KYC ────────────────────────────────── */
  .kyc {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    white-space: nowrap;
  }
  .kyc--req  { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.2); }
  .kyc--none { background: rgba(74,222,128,0.10); color: #4ade80; border: 1px solid rgba(74,222,128,0.18); }

  /* ── RATING ─────────────────────────────── */
  .td-rating { white-space: nowrap; }
  .score {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .score-stars {
    display: flex;
    gap: 1px;
  }

  /* ── CTA ────────────────────────────────── */
  .td-cta { text-align: right; white-space: nowrap; min-width: 180px; }
  .cta-compact {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.35rem 0.75rem;
    border-radius: 7px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .cta-compact:hover {
    color: var(--color-accent);
    border-color: rgba(245,197,66,0.4);
    background: rgba(245,197,66,0.05);
  }

  /* ── MOBILE CARDS ────────────────────────── */
  .bt-mobile { display: none; }

  .mc {
    padding: 1.125rem 1rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.12s;
  }
  .mc:last-child { border-bottom: none; }

  /* Featured: gold top accent + subtle bg */
  .mc--featured {
    background: rgba(245,197,66,0.04);
    border-top: 3px solid var(--color-accent);
  }
  .mc--featured .mc-name::after {
    content: ' 🏆';
    font-size: 0.75rem;
  }

  .mc-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .mc-identity {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    min-height: 68px;
  }
  .mc-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .mc-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .mc-bonus { text-align: right; flex-shrink: 0; }
  .mc-amount-row {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 0.2rem;
  }
  .mc-eyebrow {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .mc-amount {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .mc-bonus-title {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .mc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 1rem;
    align-items: center;
  }
  .mc-score {
    font-size: 0.72rem;
    font-weight: 700;
    color: #facc15;
    background: rgba(250,204,21,0.1);
    border: 1px solid rgba(250,204,21,0.2);
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
