<script>
  // Prototype-local controller: copy (mock-local) + inert preview actions.
  const toast = document.querySelector('[data-dp-toast]') as HTMLElement;
  let toastTimer: ReturnType<typeof setTimeout> | undefined;
  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('is-shown');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('is-shown'), 1800);
  }

  document.querySelectorAll<HTMLElement>('[data-copy-row]').forEach((row) => {
    const btn = row.querySelector<HTMLButtonElement>('[data-copy-btn]');
    const code = row.querySelector<HTMLElement>('[data-role="promo-code"]');
    if (!btn || !code) return;
    btn.addEventListener('click', async () => {
      const value = code.textContent?.trim() ?? '';
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        /* clipboard unavailable — mock copy still shows success state */
      }
      row.classList.add('copy-success');
      showToast(`Mock code ${value} copied — design preview only`);
      setTimeout(() => row.classList.remove('copy-success'), 1600);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-preview-cta]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      showToast('Design preview — navigation disabled');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-copy-btn-demo]').forEach((btn) => {
    btn.addEventListener('click', () => showToast('Mock copy control — design preview only'));
  });
</script>

