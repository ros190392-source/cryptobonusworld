---
import Layout from '../layouts/Layout.astro';
import BonusTable from '../components/BonusTable.astro';
import ExchangeCard from '../components/ExchangeCard.astro';
import ExchangeLogo from '../components/ExchangeLogo.astro';
import QuickPicks from '../components/QuickPicks.astro';
import FilterPanel from '../components/FilterPanel.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CountryCard from '../components/CountryCard.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RiskDisclaimer from '../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import CTAButton from '../components/CTAButton.astro';
import MethodologyBlock from '../components/MethodologyBlock.astro';
import AdaptiveRecommendation from '../components/AdaptiveRecommendation.astro';

import exchanges from '../data/exchanges.json';
import categories from '../data/categories.json';
import countries from '../data/countries.json';
import comparePairs from '../data/compare-pairs.json';
import type { RecommendableExchange } from '../utils/recommendationEngine';

import { buildWebSiteSchema, buildOrganizationSchema, buildFAQSchema, EXCHANGE_COUNT, dataUpdatedLabel } from '../utils/seo';
import type { PageContext } from '../utils/analytics';
import guides from '../data/guides.json';

const topExchanges = [...exchanges].sort((a, b) => b.rating - a.rating).slice(0, 5);

// Homepage priority order — owner-defined display sequence for BonusTable and Bonus Claim Guides.
// Binance is position 13 in exchanges.json (added late) so raw order buries it.
// This sort does not affect exchanges.json data, affiliate links, or evidence.
const homepagePriority = [
  'bybit', 'binance', 'okx', 'mexc', 'bitget',
  'bingx', 'gate-io', 'kucoin', 'htx', 'coinex',
  'phemex', 'bitunix', 'coinbase',
];
const homepageExchanges = [...exchanges].sort((a, b) => {
  const ai = homepagePriority.indexOf(a.slug);
  const bi = homepagePriority.indexOf(b.slug);
  return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
});

// Top comparison pairs — curated by search demand (most-searched head terms first)
const TOP_COMPARE_SLUGS = [
  'binance-vs-bybit',
  'bybit-vs-mexc',
  'coinbase-vs-binance',
  'binance-vs-okx',
  'coinbase-vs-bybit',
  'okx-vs-binance',
];
const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));
const topComparePairs = TOP_COMPARE_SLUGS
  .map(slug => comparePairs.find(p => p.pair === slug))
  .filter(Boolean)
  .map(p => {
    const ea = exMap[p!.a] as any;
    const eb = exMap[p!.b] as any;
    return ea && eb ? { pair: p!.pair, nameA: ea.name, nameB: eb.name, slugA: ea.slug, slugB: eb.slug } : null;
  })
  .filter(Boolean) as Array<{ pair: string; nameA: string; nameB: string; slugA: string; slugB: string }>;

const faqItems = [
  {
    question: "What is a crypto exchange bonus?",
    answer: "A crypto exchange bonus is a promotional reward offered by a crypto exchange when you register, deposit or start trading — often through an affiliate or referral link. Bonuses may include cash rewards, trading fee vouchers or deposit match promotions.",
  },
  {
    question: "Are crypto bonuses free money?",
    answer: "No. Crypto bonuses are promotional rewards that come with conditions. Most require KYC verification, a minimum deposit, and a minimum trading volume before you can access or withdraw the bonus. Always read the official terms before claiming.",
  },
  {
    question: "Which crypto exchange has the best bonus?",
    answer: "Based on our comparison, Bybit offers up to 30,000 USDT for new users, one of the highest headline bonus amounts. However, the best bonus depends on your country, whether you can meet KYC requirements, and your planned trading volume.",
  },
  {
    question: "Can I get a crypto bonus without KYC?",
    answer: "Yes. MEXC, KuCoin, CoinEx, Phemex and Bitunix offer bonuses without requiring full identity verification. However, non-KYC accounts often have withdrawal limits and restricted features.",
  },
  {
    question: "How do I claim a crypto bonus?",
    answer: "Register on the exchange through a referral or affiliate link, complete any required KYC, make a qualifying deposit, and complete the required trading volume. Bonus amounts usually unlock progressively as you complete each milestone.",
  },
  {
    question: "Do crypto bonuses expire?",
    answer: "Yes. Most bonuses have expiration dates ranging from 7 to 30 days. Unused bonuses or unmet conditions may result in forfeiture of the reward. Always check the expiration window in the official promotion terms.",
  },
];

// SEO: WebSite + Organization + FAQPage (homepage FAQ section has 6 items)
const siteSchema = [buildWebSiteSchema(), buildOrganizationSchema(), buildFAQSchema(faqItems)];

const analyticsContext: PageContext = { pageType: 'homepage' };
---

<Layout
  title="Best Crypto Exchange Bonuses 2026 — Compare & Claim"
  description={`Compare signup rewards, deposit bonuses and futures promotions from ${EXCHANGE_COUNT} top crypto exchanges. Find the best crypto bonus for your country and trading goals.`}
  canonical="/"
  schema={siteSchema}
  analyticsContext={analyticsContext}
  ogImage="https://cryptobonusworld.com/og-default.png"
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
    </div>

    <div class="container hero-layout">

      <!-- LEFT: Editorial text column -->
      <div class="hero-text">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Live Data &middot; {EXCHANGE_COUNT} Exchanges &middot; Updated {dataUpdatedLabel()}
        </div>

        <h1 class="hero-h1">
          Best Crypto Exchange<br>
          <span class="hero-h1-accent">Bonuses</span> in 2026
        </h1>

        <p class="hero-sub">
          Compare signup rewards, deposit bonuses and futures promotions across {EXCHANGE_COUNT} exchanges. Country-tailored. Updated monthly.
        </p>

        <div class="hero-actions">
          <CTAButton href="/bonuses/" label="Compare All Bonuses" size="lg" />
          <CTAButton href="/exchanges/bybit/" label="Top Pick: Bybit →" variant="outline" size="lg" />
        </div>

        <div class="hero-kpis">
          <div class="hero-kpi">
            <span class="hero-kpi-num">$30K</span>
            <span class="hero-kpi-lbl">Max Bonus</span>
          </div>
          <div class="hero-kpi-sep"></div>
          <div class="hero-kpi">
            <span class="hero-kpi-num">{EXCHANGE_COUNT}</span>
            <span class="hero-kpi-lbl">Exchanges</span>
          </div>
          <div class="hero-kpi-sep"></div>
          <div class="hero-kpi">
            <span class="hero-kpi-num">Zero</span>
            <span class="hero-kpi-lbl">Paid Rankings</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Premium exchange showcase -->
      <div class="hero-cards" aria-label="Top bonus offers">

        <!-- Featured card: #1 exchange -->
        {topExchanges[0] && (
          <a href={`/exchanges/${topExchanges[0].slug}/`} class="exc-feat">
            <div class="exc-feat-header">
              <span class="exc-feat-pick">★ Editor's Top Pick</span>
              <span class="exc-feat-score">{topExchanges[0].rating}/10</span>
            </div>
            <div class="exc-feat-body">
              <ExchangeLogo slug={topExchanges[0].slug} name={topExchanges[0].name} size={54} variant="square" lazy={false} />
              <div class="exc-feat-meta">
                <span class="exc-feat-name">{topExchanges[0].name}</span>
                <span class="exc-feat-amount">Up to {topExchanges[0].bonusAmount.toLocaleString()} {topExchanges[0].bonusCurrency}</span>
                {(topExchanges[0] as any).bonusRange?.typicalNote && (
                  <span class="exc-feat-realistic">{(topExchanges[0] as any).bonusRange.typicalNote}</span>
                )}
              </div>
            </div>
            <div class="exc-feat-cta">
              View Offer
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
          </a>
        )}

        <!-- 2-column row: next 2 exchanges -->
        <div class="exc-row">
          {topExchanges.slice(1, 3).map(ex => (
            <a href={`/exchanges/${ex.slug}/`} class="exc-sm">
              <ExchangeLogo slug={ex.slug} name={ex.name} size={38} variant="square" lazy={false} />
              <div class="exc-sm-info">
                <span class="exc-sm-name">{ex.name}</span>
                <span class="exc-sm-amount">{(ex as any).bonusDisplayMode === 'fixed' ? '' : 'Up to '}{ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
                {(ex as any).bestFor?.[0] && (
                  <span class="exc-sm-bestfor">{(ex as any).bestFor[0]}</span>
                )}
              </div>
              <span class="exc-sm-arrow">→</span>
            </a>
          ))}
        </div>

        <p class="hero-cards-note">Conditions apply. Always verify official terms.</p>
      </div>

    </div>

    <!-- Exchange strip: all exchanges at a glance -->
    <div class="exc-strip-wrap">
      <div class="container exc-strip-inner">
        <span class="exc-strip-label">All exchanges</span>
        <div class="exc-strip-scroll">
          {exchanges.map(ex => (
            <a href={`/exchanges/${ex.slug}/`} class="exc-strip-item">
              <ExchangeLogo slug={ex.slug} name={ex.name} size={18} variant="square" lazy={false} />
              <span class="exc-strip-name">{ex.name}</span>
              <span class="exc-strip-bonus">
                {ex.bonusAmount >= 1000
                  ? (ex.bonusAmount / 1000).toFixed(ex.bonusAmount % 1000 === 0 ? 0 : 1) + 'K'
                  : ex.bonusAmount} {ex.bonusCurrency}
              </span>
            </a>
          ))}
        </div>
        <a href="/exchanges/" class="exc-strip-all">All {EXCHANGE_COUNT} →</a>
      </div>
    </div>

  </section>

  <!-- Affiliate Disclosure -->
  <div class="container">
    <AffiliateDisclosure compact />
  </div>

  <!-- Filters -->
  <div class="container">
    <FilterPanel />
  </div>

  <!-- Bonus Table -->
  <section class="container section">
    <h2 class="section-title">Top Crypto Exchange Bonuses</h2>
    <QuickPicks exchanges={homepageExchanges} />
    <BonusTable exchanges={homepageExchanges} />
    <AdaptiveRecommendation
      exchanges={exchanges as unknown as RecommendableExchange[]}
      pageType="homepage"
      showHint={true}
    />
    <MethodologyBlock compact />
  </section>

  <!-- Top Exchange Cards -->
  <section class="container section">
    <h2 class="section-title">Editor's Top Picks</h2>
    <div class="grid-3">
      {topExchanges.slice(0, 3).map(ex => (
        <ExchangeCard {...ex} />
      ))}
    </div>
    <div class="grid-2" style="margin-top: 1.25rem">
      {topExchanges.slice(3, 5).map(ex => (
        <ExchangeCard {...ex} />
      ))}
    </div>
    <div class="view-all-wrap">
      <CTAButton href="/bonuses/" label={`View All ${EXCHANGE_COUNT} Exchanges`} variant="outline" size="md" />
    </div>
  </section>

  <!-- Quick Find — visual category grid -->
  <section class="container section">
    <h2 class="section-title">Find the Right Bonus</h2>
    <p class="section-subtitle">Browse by bonus type, exchange or country — find the offer that fits your needs.</p>
    <div class="qf-grid">
      <a href="/bonuses/" class="qf-card qf-card--featured">
        <span class="qf-icon">🏆</span>
        <div class="qf-info">
          <span class="qf-label">Top Bonus Exchanges</span>
          <span class="qf-meta">Up to 30,000 USDT available</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/categories/no-kyc-bonuses/" class="qf-card">
        <span class="qf-icon">🔓</span>
        <div class="qf-info">
          <span class="qf-label">No-KYC Bonuses</span>
          <span class="qf-meta">Trade without ID verification</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/categories/signup-bonuses/" class="qf-card">
        <span class="qf-icon">🚀</span>
        <div class="qf-info">
          <span class="qf-label">Signup Bonuses</span>
          <span class="qf-meta">Free rewards for new users</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/categories/futures-bonuses/" class="qf-card">
        <span class="qf-icon">📈</span>
        <div class="qf-info">
          <span class="qf-label">Futures Bonuses</span>
          <span class="qf-meta">For derivatives & perpetuals</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/compare/" class="qf-card">
        <span class="qf-icon">⚖️</span>
        <div class="qf-info">
          <span class="qf-label">Compare Exchanges</span>
          <span class="qf-meta">Side-by-side bonus analysis</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/countries/" class="qf-card">
        <span class="qf-icon">🌍</span>
        <div class="qf-info">
          <span class="qf-label">Bonuses by Country</span>
          <span class="qf-meta">Check availability in your region</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Bonus Landing Page Links -->
  <section class="container section">
    <h2 class="section-title">Bonus Claim Guides</h2>
    <p class="section-subtitle">How to register with a referral code and unlock each exchange's welcome offer — step by step.</p>
    <div class="bonus-links-grid">
      {homepageExchanges.slice(0, 6).map(ex => (
        <a href={`/bonuses/${ex.slug}-bonus/`} class="bonus-link-card">
          <ExchangeLogo slug={ex.slug} name={ex.name} size={44} variant="square" />
          <div class="bonus-link-info">
            <span class="bonus-link-name">{ex.name}</span>
            <span class="bonus-link-amount">{(ex as any).bonusDisplayMode === 'fixed' ? '' : 'Up to '}{ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
            <span class="bonus-link-cta">How to claim →</span>
          </div>
        </a>
      ))}
    </div>
    <div class="view-all-wrap">
      <a href="/bonuses/" class="text-link">View all bonus claim guides →</a>
    </div>
  </section>

  <!-- Top Comparisons — money page priority boost -->
  <section class="container section">
    <h2 class="section-title">Compare Exchanges Side by Side</h2>
    <p class="section-subtitle">Fees, bonuses, KYC requirements and features — compared in one place.</p>
    <div class="compare-grid">
      {topComparePairs.map(p => (
        <a href={`/compare/${p.pair}/`} class="compare-hp-card">
          <div class="compare-hp-logos">
            <ExchangeLogo slug={p.slugA} name={p.nameA} size={32} variant="square" />
            <span class="compare-hp-vs">vs</span>
            <ExchangeLogo slug={p.slugB} name={p.nameB} size={32} variant="square" />
          </div>
          <span class="compare-hp-label">{p.nameA} vs {p.nameB}</span>
          <span class="compare-hp-arrow">→</span>
        </a>
      ))}
    </div>
    <div class="view-all-wrap">
      <a href="/compare/" class="text-link">View all exchange comparisons →</a>
    </div>
  </section>

  <!-- Categories -->
  <section class="container section">
    <h2 class="section-title">Bonuses by Category</h2>
    <div class="grid-2">
      {categories.slice(0, 6).map(cat => (
        <CategoryCard
          name={cat.name}
          slug={cat.slug}
          description={cat.description}
          bonusType={cat.bonusType}
          exchangeCount={exchanges.filter(e => e.bonusTypes.includes(cat.bonusType) || (cat.bonusType === 'no-kyc' && !e.kycRequired) || (cat.bonusType === 'welcome' && e.bonusTypes.includes('signup'))).length}
        />
      ))}
    </div>
  </section>

  <!-- Countries -->
  <section class="container section">
    <h2 class="section-title">Bonuses by Country</h2>
    <div class="grid-4">
      {countries.slice(0, 8).map(c => (
        <CountryCard
          name={c.name}
          slug={c.slug}
          flag={c.flag}
          description={c.description}
          exchangeCount={exchanges.filter(e => e.countries.includes(c.slug)).length}
        />
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="container section">
    <h2 class="section-title">How Crypto Bonuses Work</h2>
    <div class="how-it-works">
      <div class="how-step">
        <div class="how-step-num">1</div>
        <h3>Compare Offers</h3>
        <p>Use our table to filter by country, KYC requirement and bonus type. Honest expectations shown for each.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">2</div>
        <h3>Check the Conditions</h3>
        <p>Every bonus has terms — deposit minimums, trading volume thresholds and expiry windows. Read them first.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">3</div>
        <h3>Register via Referral Link</h3>
        <p>Click through our link to ensure the promo code is pre-applied. It cannot be added retroactively.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">4</div>
        <h3>Complete the Milestones</h3>
        <p>Verify identity if required, deposit and reach the trading volume thresholds to unlock each bonus tier.</p>
      </div>
    </div>
    <div style="margin-top: 1.25rem">
      <a href="/methodology/" class="text-link">Learn more: How we review crypto bonuses →</a>
    </div>
  </section>

  <!-- Guides -->
  <section class="container section">
    <h2 class="section-title">In-Depth Guides</h2>
    <p class="section-subtitle">Learn how crypto bonuses, exchanges and passive income strategies really work.</p>
    <div class="guides-strip">
      {guides.slice(0, 6).map(g => (
        <a href={`/guides/${g.slug}/`} class="guide-strip-card">
          <span class="guide-strip-cat">{g.category}</span>
          <span class="guide-strip-title">{g.title}</span>
          <span class="guide-strip-meta">{g.readTime} read →</span>
        </a>
      ))}
    </div>
    <div class="view-all-wrap">
      <a href="/guides/" class="text-link">View all {guides.length} guides →</a>
    </div>
  </section>

  <!-- By Trading Goal — use-case hub links -->
  <section class="container section">
    <h2 class="section-title">Find the Best Exchange for Your Goal</h2>
    <p class="section-subtitle">Not all exchanges are equal. We rank the top picks for every trading style and need.</p>
    <div class="goal-grid">
      <a href="/use-cases/beginners/" class="goal-card">
        <span class="goal-icon">🎓</span>
        <div class="goal-info">
          <span class="goal-label">Best for Beginners</span>
          <span class="goal-meta">Easy onboarding, low minimums</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/futures/" class="goal-card">
        <span class="goal-icon">📈</span>
        <div class="goal-info">
          <span class="goal-label">Futures Trading</span>
          <span class="goal-meta">Best bonuses for derivatives</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/no-kyc/" class="goal-card">
        <span class="goal-icon">🔓</span>
        <div class="goal-info">
          <span class="goal-label">No KYC Required</span>
          <span class="goal-meta">Trade without ID verification</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/copy-trading/" class="goal-card">
        <span class="goal-icon">🔁</span>
        <div class="goal-info">
          <span class="goal-label">Copy Trading</span>
          <span class="goal-meta">Follow top traders automatically</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/low-fees/" class="goal-card">
        <span class="goal-icon">💸</span>
        <div class="goal-info">
          <span class="goal-label">Lowest Fees</span>
          <span class="goal-meta">Minimize trading costs</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/p2p/" class="goal-card">
        <span class="goal-icon">🤝</span>
        <div class="goal-info">
          <span class="goal-label">P2P Trading</span>
          <span class="goal-meta">Buy crypto with local payment</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/altcoins/" class="goal-card">
        <span class="goal-icon">🪙</span>
        <div class="goal-info">
          <span class="goal-label">Altcoin Trading</span>
          <span class="goal-meta">Access to 1,000+ tokens</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
      <a href="/use-cases/high-leverage/" class="goal-card">
        <span class="goal-icon">⚡</span>
        <div class="goal-info">
          <span class="goal-label">High Leverage</span>
          <span class="goal-meta">Up to 125× perpetuals</span>
        </div>
        <span class="goal-arrow">→</span>
      </a>
    </div>
    <div class="view-all-wrap">
      <a href="/use-cases/" class="text-link">View all trading goals →</a>
    </div>
  </section>

  <!-- Popular Coins — links to /coins/ pages -->
  <section class="container section">
    <h2 class="section-title">Buy Crypto With a Bonus</h2>
    <p class="section-subtitle">Find the best exchange to buy each major coin — with the highest new-user bonus available.</p>
    <div class="coins-strip">
      <a href="/coins/bitcoin/" class="coin-strip-card">
        <span class="coin-strip-sym">BTC</span>
        <span class="coin-strip-name">Bitcoin</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/ethereum/" class="coin-strip-card">
        <span class="coin-strip-sym">ETH</span>
        <span class="coin-strip-name">Ethereum</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/usdt/" class="coin-strip-card">
        <span class="coin-strip-sym">USDT</span>
        <span class="coin-strip-name">Tether</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/solana/" class="coin-strip-card">
        <span class="coin-strip-sym">SOL</span>
        <span class="coin-strip-name">Solana</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/bnb/" class="coin-strip-card">
        <span class="coin-strip-sym">BNB</span>
        <span class="coin-strip-name">BNB</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/xrp/" class="coin-strip-card">
        <span class="coin-strip-sym">XRP</span>
        <span class="coin-strip-name">XRP</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/doge/" class="coin-strip-card">
        <span class="coin-strip-sym">DOGE</span>
        <span class="coin-strip-name">Dogecoin</span>
        <span class="coin-strip-arrow">→</span>
      </a>
      <a href="/coins/ada/" class="coin-strip-card">
        <span class="coin-strip-sym">ADA</span>
        <span class="coin-strip-name">Cardano</span>
        <span class="coin-strip-arrow">→</span>
      </a>
    </div>
    <div class="view-all-wrap">
      <a href="/coins/" class="text-link">View all coins →</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container section">
    <FAQBlock items={faqItems} suppressSchema={true} />
  </section>

  <!-- Risk Disclaimer -->
  <div class="container">
    <RiskDisclaimer />
  </div>
</Layout>

<!-- Mobile sticky CTA (scroll-triggered, hidden on desktop) -->
<div class="hp-sticky" id="hp-sticky" aria-hidden="true">
  <div class="hp-sticky-left">
    <span class="hp-sticky-headline">Up to 30,000 USDT</span>
    <span class="hp-sticky-sub">Compare {EXCHANGE_COUNT} exchange bonuses</span>
