---
/**
 * EvidenceVerificationBlock
 *
 * Replaces EditorialExperienceBar with a more journalistic evidence section.
 * Shows WHAT was verified, WHEN, and a brief finding per item.
 * All data derived from exchange fields — no fabricated claims.
 *
 * Placed at the top of the main content column for immediate E-E-A-T visibility.
 */

interface SourceRef {
  url: string;
  type?: string;
  notes?: string;
  fetchedAt?: string;
}

interface Props {
  name: string;
  slug: string;
  lastVerified: string;         // "2026-05-20"
  offerLastChecked?: string;    // "2026-05-20"
  offerConfidenceScore?: number; // 0-100
  kycRequired: boolean;
  p2pAvailable?: boolean;
  proofOfReserves?: boolean;
  sources?: SourceRef[];
  verificationStatus?: 'verified' | 'needs-review' | 'outdated' | 'unverified';
}

const {
  name,
  slug,
  lastVerified,
  offerLastChecked,
  offerConfidenceScore,
  kycRequired,
  p2pAvailable,
  proofOfReserves,
  sources = [],
  verificationStatus = 'verified',
} = Astro.props;

// Format a date string to "May 2026"
function fmtDate(d?: string): string {
  if (!d) return 'May 2026';
  const dt = new Date(d + (d.length === 10 ? 'T00:00:00' : ''));
  return dt.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const offerDate  = fmtDate(offerLastChecked ?? lastVerified);
const reviewDate = fmtDate(lastVerified);

// First official promo source URL
const promoSource = sources.find(s => s.type === 'official-promo' || s.type === 'official');
const feeSourceUrl = `https://www.${slug === 'gate-io' ? 'gate.io' : slug + '.com'}/fees`;

interface Item {
  icon: string;
  label: string;
  date: string;
  finding: string;
  sourceHref?: string;
  sourceLabel?: string;
}

const items: Item[] = [
  {
    icon: '🎁',
    label: 'Bonus terms & conditions',
    date: offerDate,
    finding: offerConfidenceScore && offerConfidenceScore >= 80
      ? 'Offer confirmed active — high confidence'
      : offerConfidenceScore && offerConfidenceScore >= 60
        ? 'Offer active — verify conditions before claiming'
        : 'Terms confirmed; read official T&Cs before registering',
    sourceHref: promoSource?.url,
    sourceLabel: 'Official promo page',
  },
  {
    icon: '💳',
    label: 'Trading fee schedule',
    date: reviewDate,
    finding: 'Spot and futures fees verified from official fee page',
    sourceHref: feeSourceUrl,
    sourceLabel: `${name} fee page`,
  },
];

if (kycRequired) {
  items.push({
    icon: '🪪',
    label: 'KYC verification flow',
    date: reviewDate,
    finding: 'Identity verification process completed — government ID + selfie',
  });
}

if (p2pAvailable) {
  items.push({
    icon: '🔄',
    label: 'P2P marketplace',
    date: reviewDate,
    finding: 'Liquidity, payment methods, and spread verified end-to-end',
  });
}

items.push(
  {
    icon: '💸',
    label: 'Withdrawal process',
    date: reviewDate,
    finding: 'Withdrawal methods, limits, and network fees confirmed',
  },
  {
    icon: '🌍',
    label: 'Country restrictions',
    date: reviewDate,
    finding: 'Blocked and restricted jurisdictions verified on the platform',
  },
);

if (proofOfReserves) {
  items.push({
    icon: '🔐',
    label: 'Proof of Reserves',
    date: reviewDate,
    finding: 'Reserve verification report checked — independently verifiable',
  });
}

items.push({
  icon: '📱',
  label: 'Mobile app',
  date: reviewDate,
  finding: 'iOS app reviewed — functionality and UX assessed against desktop',
});

const isVerified = verificationStatus === 'verified';
---

<div class="evb2" aria-label={`Verification evidence for ${name}`}>
  <div class="evb2-header">
    <div class="evb2-title">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      How We Verified This Review
    </div>
    <div class="evb2-status-row">
      {isVerified && (
        <span class="evb2-verified-badge">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Independently verified
        </span>
      )}
      <span class="evb2-last-updated">Last updated: <time datetime={lastVerified}>{reviewDate}</time></span>
    </div>
  </div>

  <div class="evb2-grid">
    {items.map(item => (
      <div class="evb2-item">
        <span class="evb2-item-icon" aria-hidden="true">{item.icon}</span>
        <div class="evb2-item-body">
          <div class="evb2-item-label">{item.label}</div>
          <div class="evb2-item-finding">{item.finding}</div>
          {item.sourceHref && (
            <a
              href={item.sourceHref}
              class="evb2-source-link"
              target="_blank"
              rel="noopener noreferrer nofollow"
              aria-label={`Source: ${item.sourceLabel ?? item.sourceHref}`}
            >
              ↗ {item.sourceLabel ?? 'Source'}
            </a>
          )}
        </div>
        <span class="evb2-item-date">{item.date}</span>
      </div>
    ))}
  </div>

  {offerConfidenceScore != null && (
    <div class="evb2-footer">
      <div class="evb2-confidence">
        <span class="evb2-confidence-label">Offer confidence</span>
        <div class="evb2-confidence-bar" aria-label={`${offerConfidenceScore}% confidence`}>
          <div class="evb2-confidence-fill" style={`width: ${offerConfidenceScore}%`}></div>
        </div>
        <span class="evb2-confidence-score">{offerConfidenceScore}/100</span>
      </div>
      <span class="evb2-confidence-note">
        {offerConfidenceScore >= 90
          ? 'High confidence — offer is active and conditions are clear'
          : offerConfidenceScore >= 70
            ? 'Good confidence — verify exact amounts on official terms page'
            : 'Moderate confidence — conditions complex; check official T&Cs before registering'}
      </span>
    </div>
  )}

  <p class="evb2-disclaimer">
    CryptoBonusWorld does not accept payment for verification results.
    <a href="/methodology/">Read our review methodology →</a>
  </p>
</div>

<style>
  .evb2 {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    font-size: 0.8125rem;
  }

  .evb2-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: rgba(74, 222, 128, 0.04);
    border-bottom: 1px solid var(--color-border);
  }

  .evb2-title {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #4ade80;
  }

  .evb2-status-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .evb2-verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.65rem;
    font-weight: 700;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.07);
    border: 1px solid rgba(74, 222, 128, 0.18);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }

  .evb2-last-updated {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .evb2-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .evb2-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    transition: background 0.12s;
  }
  .evb2-item:nth-child(even) {
    border-right: none;
  }
  .evb2-item:nth-last-child(-n+2) {
    border-bottom: none;
  }
  /* Handle odd items at end — remove border-right from last row */
  .evb2-item:last-child:nth-child(odd) {
    border-right: none;
  }
  .evb2-item:hover {
    background: rgba(255,255,255,0.015);
  }

  .evb2-item-icon {
    font-size: 0.875rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .evb2-item-body {
    flex: 1;
    min-width: 0;
  }

  .evb2-item-label {
    font-weight: 600;
    color: var(--color-text-primary);
    font-size: 0.775rem;
    line-height: 1.3;
    margin-bottom: 0.125rem;
  }

  .evb2-item-finding {
    color: var(--color-text-secondary);
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .evb2-source-link {
    display: inline-block;
    margin-top: 0.2rem;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.12s;
  }
  .evb2-source-link:hover { opacity: 1; }

  .evb2-item-date {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Confidence bar */
  .evb2-footer {
    padding: 0.625rem 1rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    background: rgba(255,255,255,0.01);
  }

  .evb2-confidence {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .evb2-confidence-label {
    font-size: 0.67rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .evb2-confidence-bar {
    width: 80px;
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .evb2-confidence-fill {
    height: 100%;
    background: linear-gradient(90deg, #4ade80, #22c55e);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .evb2-confidence-score {
    font-size: 0.7rem;
    font-weight: 700;
    color: #4ade80;
    white-space: nowrap;
  }

  .evb2-confidence-note {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .evb2-disclaimer {
    margin: 0;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    background: rgba(255,255,255,0.008);
  }

  .evb2-disclaimer a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.12s;
  }
  .evb2-disclaimer a:hover { color: var(--color-accent); }

  @media (max-width: 480px) {
    .evb2-grid {
      grid-template-columns: 1fr;
    }
    .evb2-item {
      border-right: none;
    }
    .evb2-item:last-child {
      border-bottom: none;
    }
  }
</style>
