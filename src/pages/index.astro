---
import Layout from '../layouts/Layout.astro';
import BonusTable from '../components/BonusTable.astro';
import ExchangeCard from '../components/ExchangeCard.astro';
import FilterPanel from '../components/FilterPanel.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CountryCard from '../components/CountryCard.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RiskDisclaimer from '../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import CTAButton from '../components/CTAButton.astro';
import MethodologyBlock from '../components/MethodologyBlock.astro';
import AdaptiveRecommendation from '../components/AdaptiveRecommendation.astro';

import exchanges from '../data/exchanges.json';
import categories from '../data/categories.json';
import countries from '../data/countries.json';
import type { RecommendableExchange } from '../utils/recommendationEngine';

import { buildWebSiteSchema, buildOrganizationSchema } from '../utils/seo';
import type { PageContext } from '../utils/analytics';

const topExchanges = [...exchanges].sort((a, b) => b.rating - a.rating).slice(0, 5);

const faqItems = [
  {
    question: "What is a crypto exchange bonus?",
    answer: "A crypto exchange bonus is a promotional reward offered by a crypto exchange when you register, deposit or start trading — often through an affiliate or referral link. Bonuses may include cash rewards, trading fee vouchers or deposit match promotions.",
  },
  {
    question: "Are crypto bonuses free money?",
    answer: "No. Crypto bonuses are promotional rewards that come with conditions. Most require KYC verification, a minimum deposit, and a minimum trading volume before you can access or withdraw the bonus. Always read the official terms before claiming.",
  },
  {
    question: "Which crypto exchange has the best bonus?",
    answer: "Based on our comparison, Bybit offers up to 30,000 USDT for new users, one of the highest headline bonus amounts. However, the best bonus depends on your country, whether you can meet KYC requirements, and your planned trading volume.",
  },
  {
    question: "Can I get a crypto bonus without KYC?",
    answer: "Yes. MEXC, KuCoin, CoinEx and Bitunix offer bonuses without requiring full identity verification. However, non-KYC accounts often have withdrawal limits and restricted features.",
  },
  {
    question: "How do I claim a crypto bonus?",
    answer: "Register on the exchange through a referral or affiliate link, complete any required KYC, make a qualifying deposit, and complete the required trading volume. Bonus amounts usually unlock progressively as you complete each milestone.",
  },
  {
    question: "Do crypto bonuses expire?",
    answer: "Yes. Most bonuses have expiration dates ranging from 7 to 30 days. Unused bonuses or unmet conditions may result in forfeiture of the reward. Always check the expiration window in the official promotion terms.",
  },
];

// SEO: richer schema array — WebSite + Organization together
const siteSchema = [buildWebSiteSchema(), buildOrganizationSchema()];

const analyticsContext: PageContext = { pageType: 'homepage' };
---

<Layout
  title="Best Crypto Exchange Bonuses 2026 — Compare & Claim"
  description="Compare signup rewards, deposit bonuses, futures bonuses and crypto trading promotions from top exchanges. Find the best crypto bonus for your country and trading goals."
  canonical="/"
  schema={siteSchema}
  analyticsContext={analyticsContext}
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
    </div>

    <div class="container hero-container">
      <!-- Left column -->
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Live Data &middot; 12 Exchanges &middot; Updated May 2026
        </div>

        <h1 class="hero-title">
          Best Crypto Exchange<br>
          <span class="hero-title-accent">Bonuses</span> in 2026
        </h1>

        <p class="hero-subtitle">
          Compare signup rewards, deposit bonuses and futures promotions from top exchanges. Find the best offer for your country.
        </p>

        <div class="hero-ctas">
          <CTAButton href="/bonuses/" label="Compare All Bonuses" size="lg" />
          <CTAButton href="/exchanges/bybit/" label="Top Bonus: 30,000 USDT →" variant="outline" size="lg" />
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-num">$30K</span>
            <span class="hero-stat-label">Max Bonus</span>
          </div>
          <div class="hero-stat-sep"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">12</span>
            <span class="hero-stat-label">Exchanges</span>
          </div>
          <div class="hero-stat-sep"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">8</span>
            <span class="hero-stat-label">Countries</span>
          </div>
          <div class="hero-stat-sep"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">Free</span>
            <span class="hero-stat-label">No Signup</span>
          </div>
        </div>
      </div>

      <!-- Right column: top bonus cards -->
      <div class="hero-right" aria-label="Top bonus offers">
        {topExchanges.slice(0, 3).map((ex, i) => (
          <a href={`/exchanges/${ex.slug}/`} class:list={['hbc', i === 0 && 'hbc--featured']}>
            <div class="hbc-logo" aria-hidden="true">{ex.name.charAt(0)}</div>
            <div class="hbc-info">
              <span class="hbc-name">{ex.name}</span>
              <span class="hbc-amount">Up to {ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
            </div>
            <span class="hbc-cta">Claim →</span>
          </a>
        ))}
        <p class="hero-right-note">Conditions apply. Always verify official terms.</p>
      </div>
    </div>

    <!-- Ticker -->
    <div class="hero-ticker" aria-hidden="true">
      <div class="hero-ticker-inner">
        {[...exchanges, ...exchanges].map(ex => (
          <span class="ticker-item">
            <span class="ticker-name">{ex.name}</span>
            <span class="ticker-sep">·</span>
            <span class="ticker-amount">{ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <div class="container">
    <AffiliateDisclosure compact />
  </div>

  <!-- Filters -->
  <div class="container">
    <FilterPanel />
  </div>

  <!-- Bonus Table -->
  <section class="container section">
    <h2 class="section-title">Top Crypto Exchange Bonuses</h2>
    <BonusTable exchanges={exchanges} />
    <AdaptiveRecommendation
      exchanges={exchanges as unknown as RecommendableExchange[]}
      pageType="homepage"
      showHint={true}
    />
    <MethodologyBlock compact />
  </section>

  <!-- Top Exchange Cards -->
  <section class="container section">
    <h2 class="section-title">Top Bonus Offers This Month</h2>
    <div class="grid-3">
      {topExchanges.slice(0, 3).map(ex => (
        <ExchangeCard {...ex} />
      ))}
    </div>
    <div class="grid-2" style="margin-top: 1rem">
      {topExchanges.slice(3, 5).map(ex => (
        <ExchangeCard {...ex} />
      ))}
    </div>
    <div class="view-all-wrap">
      <CTAButton href="/bonuses/" label="View All 12 Exchanges" variant="outline" size="md" />
    </div>
  </section>

  <!-- Categories -->
  <section class="container section">
    <h2 class="section-title">Bonuses by Category</h2>
    <div class="grid-2">
      {categories.slice(0, 6).map(cat => (
        <CategoryCard
          name={cat.name}
          slug={cat.slug}
          description={cat.description}
          bonusType={cat.bonusType}
          exchangeCount={exchanges.filter(e => e.bonusTypes.includes(cat.bonusType) || (cat.bonusType === 'no-kyc' && !e.kycRequired) || (cat.bonusType === 'welcome' && e.bonusTypes.includes('signup'))).length}
        />
      ))}
    </div>
  </section>

  <!-- Countries -->
  <section class="container section">
    <h2 class="section-title">Bonuses by Country</h2>
    <div class="grid-4">
      {countries.slice(0, 8).map(c => (
        <CountryCard
          name={c.name}
          slug={c.slug}
          flag={c.flag}
          description={c.description}
          exchangeCount={exchanges.filter(e => e.countries.includes(c.slug)).length}
        />
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="container section">
    <h2 class="section-title">How Crypto Bonuses Work</h2>
    <div class="how-it-works">
      <div class="how-step">
        <div class="how-step-num">1</div>
        <h3>Compare Bonuses</h3>
        <p>Use our comparison table to find the best bonus for your country, trading style and KYC preference.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">2</div>
        <h3>Read the Conditions</h3>
        <p>Every bonus has conditions — KYC requirements, deposit minimums and trading volume. Check them before registering.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">3</div>
        <h3>Register via Referral Link</h3>
        <p>Use the affiliate or referral link on this page to ensure the bonus is applied to your new account.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">4</div>
        <h3>Complete the Requirements</h3>
        <p>Deposit qualifying funds, complete KYC if required, and trade the minimum volume to unlock your bonus.</p>
      </div>
    </div>
    <div style="margin-top: 1.25rem">
      <a href="/methodology/" class="text-link">Learn more: How we review crypto bonuses →</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container section">
    <FAQBlock items={faqItems} />
  </section>

  <!-- Risk Disclaimer -->
  <div class="container">
    <RiskDisclaimer />
  </div>
</Layout>

<!-- Mobile sticky CTA (scroll-triggered, hidden on desktop) -->
<div class="hp-sticky" id="hp-sticky" aria-hidden="true">
  <div class="hp-sticky-left">
    <span class="hp-sticky-headline">Up to 30,000 USDT</span>
    <span class="hp-sticky-sub">Compare 12 exchange bonuses</span>
  </div>
  <a href="/bonuses/" class="hp-sticky-btn">Compare Now →</a>
</div>

<script>
  const hpSticky = document.getElementById('hp-sticky');
  if (hpSticky) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const show = window.scrollY > 480;
          hpSticky.classList.toggle('hp-sticky--visible', show);
          hpSticky.setAttribute('aria-hidden', String(!show));
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>

<style>
  /* ── HERO ─────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    padding: 5rem 0 0;
  }

  /* Background layers */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow {
    position: absolute;
    top: -120px;
    left: -80px;
    width: 700px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(245,197,66,0.10) 0%, rgba(245,197,66,0.03) 45%, transparent 70%);
    border-radius: 50%;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 30% 40%, black 20%, transparent 80%);
  }

  /* Layout */
  .hero-container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 3rem;
    align-items: center;
    padding-bottom: 4rem;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: rgba(245,197,66,0.08);
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(245,197,66,0.25);
    letter-spacing: 0.01em;
  }
  .hero-badge-dot {
    width: 7px;
    height: 7px;
    background: #ef4444;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(239,68,68,0.8);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  /* Title */
  .hero-title {
    font-size: clamp(2.2rem, 4.5vw, 3.25rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin: 0 0 1.25rem;
  }
  .hero-title-accent {
    background: linear-gradient(135deg, #f5c542 0%, #fbbf24 40%, #f59e0b 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  /* Subtitle */
  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 520px;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.25rem;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: 0.75rem;
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0 1.25rem;
  }
  .hero-stat:first-child { padding-left: 0; }
  .hero-stat-num {
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .hero-stat-sep {
    width: 1px;
    height: 32px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Right column: bonus cards */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .hbc {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    position: relative;
  }
  .hbc:hover {
    border-color: rgba(245,197,66,0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .hbc--featured {
    border-color: rgba(245,197,66,0.35);
    background: linear-gradient(135deg, #1a1a0e 0%, #111111 100%);
    box-shadow: 0 0 0 1px rgba(245,197,66,0.15), 0 4px 20px rgba(245,197,66,0.06);
  }
  .hbc--featured::before {
    content: '🏆 #1';
    position: absolute;
    top: -10px;
    right: 12px;
    font-size: 0.65rem;
    font-weight: 800;
    background: var(--color-accent);
    color: #000;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    letter-spacing: 0.04em;
  }
  .hbc-logo {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .hbc-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .hbc-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .hbc-amount {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .hbc-cta {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.15s;
  }
  .hbc:hover .hbc-cta { opacity: 1; }
  .hero-right-note {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    text-align: center;
    margin: 0.25rem 0 0;
    line-height: 1.4;
  }

  /* Ticker */
  .hero-ticker {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    background: rgba(255,255,255,0.015);
    overflow: hidden;
    padding: 0.625rem 0;
  }
  .hero-ticker-inner {
    display: flex;
    gap: 0;
    width: max-content;
    animation: ticker-scroll 40s linear infinite;
  }
  .hero-ticker:hover .hero-ticker-inner { animation-play-state: paused; }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 2rem;
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .ticker-name {
    font-weight: 700;
    color: var(--color-text-secondary);
  }
  .ticker-sep { color: var(--color-border); }
  .ticker-amount {
    font-weight: 700;
    color: var(--color-accent);
  }

  .section { padding: 2.5rem 0 0; }

  .view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .how-it-works {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .how-step {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    position: relative;
  }
  .how-step-num {
    width: 32px;
    height: 32px;
    background: var(--color-accent);
    color: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }
  .how-step h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
  }
  .how-step p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0;
  }

  .text-link {
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.15s;
  }
  .text-link:hover { opacity: 0.8; }

  @media (max-width: 1024px) {
    .hero-container { grid-template-columns: 1fr; gap: 2rem; }
    .hero-right { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.625rem; }
    .hero-right-note { grid-column: 1 / -1; }
    .hbc--featured::before { display: none; }
    .how-it-works { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    /* extra padding-bottom for sticky CTA bar — never overlaps content */
    :global(body) { padding-bottom: 76px; }
  }

  @media (max-width: 640px) {
    .hero { padding: 2rem 0 0; }
    .hero-container { padding-bottom: 2rem; }
    .hero-right { grid-template-columns: 1fr; }
    .hero-title { font-size: clamp(1.75rem, 7vw, 2.25rem); }
    .hero-subtitle { font-size: 0.9375rem; }
    .hero-badge { font-size: 0.7rem; }
    .hero-ctas { flex-direction: column; }
    .hero-ctas :global(.cta-btn) { width: 100%; justify-content: center; }
    .hero-stats { gap: 0; }
    .hero-stat { padding: 0 0.875rem; }
    .hero-stat:first-child { padding-left: 0; }
    .how-it-works { grid-template-columns: 1fr; }
  }

  @media (max-width: 400px) {
    .hero-stats { flex-wrap: nowrap; overflow-x: auto; }
    .hero-stat { flex-shrink: 0; padding: 0 0.75rem; }
    .hero-stat-sep { flex-shrink: 0; }
  }

  /* ── Mobile sticky CTA ── */
  .hp-sticky {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 150;
    background: rgba(10, 10, 10, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hp-sticky--visible {
    transform: translateY(0);
  }
  .hp-sticky-left {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .hp-sticky-headline {
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--color-accent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hp-sticky-sub {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .hp-sticky-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.625rem 1.25rem;
    background: var(--color-accent);
    color: #000;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .hp-sticky-btn:hover { opacity: 0.88; }

  @media (max-width: 768px) {
    .hp-sticky { display: flex; }
  }
</style>
