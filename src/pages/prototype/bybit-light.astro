<script>
  function setupCopyBtn(id: string) {
    const btn = document.getElementById(id) as HTMLButtonElement | null;
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('CRYPTOBONUSW').then(() => {
        const row = btn.closest('.bh-promo-row') as HTMLElement | null;
        const codeSpan = row?.querySelector('.bh-promo-code') as HTMLElement | null;
        btn.textContent = 'Copied ✓';
        btn.classList.add('copy-success');
        row?.classList.add('copy-success');
        codeSpan?.classList.add('copy-success');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copy-success');
          row?.classList.remove('copy-success');
          codeSpan?.classList.remove('copy-success');
        }, 1800);
      });
    });
  }
  setupCopyBtn('copy-btn-hero');
</script>

