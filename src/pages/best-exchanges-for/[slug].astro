---
/**
 * /best-exchanges-for/[slug]/ — Programmatic SEO framework pages.
 *
 * ARCHITECTURE STATUS: Framework complete, content parity pending.
 *
 * These pages target the query pattern "best crypto exchange for [intent]"
 * (e.g. "best crypto exchange for beginners", "best exchange for futures").
 *
 * They reuse the same ranked exchange data as /use-cases/[slug]/ but present
 * the content under a more direct, intent-matching URL pattern.
 *
 * INDEXATION POLICY:
 *   - Currently: robots="noindex, follow"
 *     Pages render full content, links are crawlable, but pages are NOT indexed.
 *     This prevents duplicate content penalties while the URL structure matures.
 *   - Future: remove robots directive → pages become indexable and target
 *     "best [exchange/intent]" query variants distinctly from /use-cases/.
 *
 * CANONICAL: Self-canonical (NOT pointing to /use-cases/).
 *   When these pages graduate to full indexation, the canonical is already correct.
 *   Link equity is distributed via internal links from the canonical use-case pages.
 *
 * LAUNCH CHECKLIST (before removing noindex):
 *   [ ] Content differentiated from /use-cases/ equivalent (unique angle/depth)
 *   [ ] Internal links from /use-cases/[slug]/ pointing here
 *   [ ] Added to sitemap.xml.ts
 *   [ ] robots directive removed from this Layout call
 *   [ ] Page included in the Batch 5+ content audit
 */

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BonusTable from '../../components/BonusTable.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import CTAButton from '../../components/CTAButton.astro';
import ExchangeLogo from '../../components/ExchangeLogo.astro';

import { USE_CASES } from '../../data/use-cases';
import exchanges from '../../data/exchanges.json';
import { rankExchangesForUseCase, buildItemListSchema, YEAR } from '../../utils/seo';
import type { PageContext } from '../../utils/analytics';

export async function getStaticPaths() {
  return USE_CASES.map(uc => ({
    params: { slug: uc.slug },
    props: { useCase: uc },
  }));
}

const { useCase } = Astro.props;

// Rank exchanges — same logic as /use-cases/[slug]/
const ranked = rankExchangesForUseCase(exchanges as any, useCase.scoring);
const topPick = ranked[0];

// Build alternative SEO title targeting the "best...for" query pattern
const pageTitle = `Best Crypto Exchange for ${useCase.label} ${YEAR} — Top ${ranked.length} Picks`;
const pageDesc = `Find the best crypto exchange for ${useCase.label.toLowerCase()} in ${YEAR}. ${useCase.metaDesc}`;

// Schema — same data as use-case page
const itemListSchema = buildItemListSchema(
  ranked.map(ex => ({
    name: `${ex.name} — Best for ${useCase.label}`,
    url: `/exchanges/${ex.slug}/`,
    description: ex.shortDescription,
  })),
  `Best Crypto Exchange for ${useCase.label} ${YEAR}`
);

const analyticsContext: PageContext = { pageType: 'category' };
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={`/best-exchanges-for/${useCase.slug}/`}
  schema={itemListSchema}
  analyticsContext={analyticsContext}
  robots="noindex, follow"
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Best Exchanges For', href: '/use-cases/' },
      { label: useCase.label },
    ]} />

    <div class="page-header">
      <div class="bef-badge">{useCase.label}</div>
      <h1>Best Crypto Exchange for {useCase.label} in {YEAR}</h1>
      <p class="lead">{useCase.intro}</p>
    </div>

    <AffiliateDisclosure compact />

    <!-- Top pick CTA -->
    {topPick && (
      <div class="bef-top-pick" aria-label={`Top pick: ${topPick.name}`}>
        <div class="bef-top-pick__inner">
          <ExchangeLogo slug={topPick.slug} name={topPick.name} size={72} variant="square" lazy={false} />
          <div class="bef-top-pick__text">
            <span class="bef-top-pick__label">🏆 Editor's Top Pick for {useCase.label}</span>
            <span class="bef-top-pick__name">{topPick.name}</span>
            <span class="bef-top-pick__desc">Up to {(topPick as any).bonusAmount?.toLocaleString('en-US')} {(topPick as any).bonusCurrency}</span>
          </div>
          <div class="bef-top-pick__cta">
            <CTAButton
              href={`/exchanges/${topPick.slug}/`}
              label={`Read ${topPick.name} Review →`}
              variant="primary"
              size="sm"
            />
          </div>
        </div>
      </div>
    )}

    <!-- Full ranked table -->
    <section>
      <h2 class="section-title">All {ranked.length} Exchanges Ranked for {useCase.label}</h2>
      <BonusTable exchanges={ranked} />
    </section>

    <!-- Why it matters -->
    <section class="bef-why">
      <h2>Why Exchange Choice Matters for {useCase.label}</h2>
      <p>{useCase.whyMatters}</p>
      <p>
        See the full <a href={`/use-cases/${useCase.slug}/`}>best exchanges for {useCase.label.toLowerCase()} comparison</a> with deeper analysis, scoring breakdown and quick facts.
      </p>
    </section>

    <FAQBlock items={useCase.faq} />
    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .bef-badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: var(--radius-pill);
    padding: 0.3rem 0.75rem;
    margin-bottom: 1rem;
  }

  .bef-top-pick {
    background: var(--surface-elevated);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0 2rem;
  }
  .bef-top-pick__inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .bef-top-pick__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .bef-top-pick__label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-accent);
    opacity: 0.9;
  }
  .bef-top-pick__name {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text-primary);
  }
  .bef-top-pick__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .bef-why {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    margin: 2rem 0;
  }
  .bef-why h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    color: var(--color-text-primary);
  }
  .bef-why p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }
  .bef-why p:last-child { margin-bottom: 0; }
  .bef-why a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 520px) {
    .bef-top-pick__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
