---
/**
 * InfoLayout — light-shell wrapper for info/legal prose pages.
 *
 * Migrates the info/legal pages (methodology, about, editorial-policy,
 * update-policy, affiliate-disclosure, disclaimer, privacy-policy, terms)
 * off the old dark Layout.astro onto CleanLayout, so the whole site shares
 * one header/footer/theme.
 *
 * It bridges the legacy design tokens (--color-*, --surface-*, --text-*,
 * --radius-*) to light-theme values so the pages' existing scoped styles
 * (badges, TOC, criteria grids, schedule tables) render correctly without
 * rewriting their markup. Prose is capped at --cbw-prose-max (800px) per
 * the unified width standard.
 */
import CleanLayout from './CleanLayout.astro';

export interface Props {
  title: string;
  description?: string;
  /** Path ("/about/") or absolute URL — normalized to the full canonical. */
  canonical?: string;
  noindex?: boolean;
  /** Optional JSON-LD object, rendered as a script tag (body placement is valid). */
  schema?: Record<string, unknown>;
}

const { title, description = '', canonical, noindex = false, schema } = Astro.props;

const siteBase = 'https://cryptobonusworld.com';
const fullCanonical = canonical
  ? (canonical.startsWith('http') ? canonical : `${siteBase}${canonical}`)
  : undefined;
---

<CleanLayout title={title} description={description} canonical={fullCanonical} noindex={noindex}>
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <div class="info-page">
    <slot />
  </div>
</CleanLayout>

<style is:global>
  .info-page {
    /* ── Legacy token bridge (light values) ─────────────────────── */
    --color-bg: #F7F8F4;
    --color-bg-secondary: #F3F4F6;
    --color-border: #E5E7EB;
    --color-border-subtle: #F3F4F6;
    --surface-base: #FFFFFF;
    --surface-raised: #FFFFFF;
    --surface-elevated: #FFFFFF;
    --surface-overlay: #F9FAFB;
    --color-accent: #B45309;            /* amber-700 — readable link/badge accent on light bg */
    --color-accent-dim: rgba(180,83,9,.45);
    --color-accent-muted: rgba(247,147,26,.10);
    --color-text-primary: #111827;
    --color-text-secondary: #374151;
    --color-text-muted: #6B7280;
    --text-xs: 0.75rem;
    --text-sm: 0.875rem;
    --text-base: 1rem;
    --radius-xs: 4px;
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 14px;
    --radius-xl: 20px;
    --radius-pill: 100px;
    --container-pad: var(--cbw-pad-mobile, 20px);

    padding-bottom: 64px;
  }
  @media (min-width: 640px) { .info-page { --container-pad: var(--cbw-pad-tablet, 24px); } }
  @media (min-width: 820px) { .info-page { --container-pad: var(--cbw-pad-desktop, 32px); } }

  /* Prose container — unified 800px measure for readable text columns */
  .info-page .container {
    max-width: var(--cbw-prose-max, 800px);
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }

  /* ── Page header (shared across info pages) ───────────────────── */
  .info-page .page-header {
    padding: 2.75rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }
  .info-page .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
  }
  .info-page .page-header .lead {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }
  .info-page .page-header .meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Prose typography (light) ─────────────────────────────────── */
  .info-page .prose { max-width: var(--cbw-prose-max, 800px); }
  .info-page .prose h2 {
    font-size: 1.3rem; font-weight: 700;
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
  }
  .info-page .prose h3 {
    font-size: 1.1rem; font-weight: 700;
    color: var(--color-text-primary);
    margin: 1.5rem 0 0.5rem;
  }
  .info-page .prose p { color: var(--color-text-secondary); line-height: 1.75; margin: 0 0 1rem; }
  .info-page .prose ul, .info-page .prose ol { color: var(--color-text-secondary); padding-left: 1.5rem; margin: 0 0 1rem; }
  .info-page .prose li { margin-bottom: 0.375rem; line-height: 1.65; }
  .info-page .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .info-page .prose a:hover { opacity: .8; }
  .info-page .prose strong { color: var(--color-text-primary); }
  .info-page .prose em { color: var(--color-text-muted); }
  .info-page .prose code {
    font-family: 'SFMono-Regular', Consolas, monospace;
    font-size: 0.85em;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xs);
    padding: 1px 6px;
    color: var(--color-text-primary);
  }
</style>
