---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class:list={['methodology-block', compact && 'methodology-block--compact']}>
  <div class="methodology-header">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
      <polyline points="22 4 12 14.01 9 11.01"/>
    </svg>
    <span class="methodology-label">Our Methodology</span>
  </div>
  {!compact && (
    <p class="methodology-text">
      CryptoBonusWorld evaluates exchanges based on bonus amount, clarity of conditions, KYC requirements, country availability, exchange reputation, and ease of claiming. Bonus data is manually verified against official exchange promotion pages.
      <a href="/methodology/">Learn how we rate exchanges</a>
    </p>
  )}
  {compact && (
    <p class="methodology-text">
      Bonuses independently verified. <a href="/methodology/">Our methodology</a>
    </p>
  )}
</div>

<style>
  .methodology-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.875rem 1rem;
    margin: 1rem 0;
  }
  .methodology-block--compact { flex-direction: row; align-items: center; gap: 0.625rem; }
  .methodology-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent);
  }
  .methodology-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }
  .methodology-text {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
  .methodology-text a {
    color: var(--color-accent);
    text-decoration: none;
    margin-left: 0.25rem;
  }
</style>
