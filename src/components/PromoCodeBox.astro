---
interface Props {
  code: string;
  exchange: string;
  /** Exchange slug for tracking (e.g. 'bybit'). Falls back to lowercased name. */
  slug?: string;
}
const { code, exchange, slug } = Astro.props;
const exchangeKey = slug ?? exchange.toLowerCase().replace(/\s+/g, '-');
---

{code && (
  <div class="promo-code-box">
    <div class="promo-code-info">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
        <line x1="7" y1="7" x2="7.01" y2="7"/>
      </svg>
      <div>
        <div class="promo-code-title">Promo Code for {exchange}</div>
        <div class="promo-code-note">Enter this code during registration</div>
      </div>
    </div>
    <div class="promo-code-value-wrap">
      <code class="promo-code-value" id="promo-code-value">{code}</code>
      <button
        class="promo-copy-btn"
        data-code={code}
        data-exchange={exchangeKey}
        data-track="bonus_copy"
        aria-label={`Copy promo code ${code}`}
      >
        Copy
      </button>
    </div>
  </div>
)}

<script>
  import { analytics } from '../lib/analytics';

  document.querySelectorAll<HTMLButtonElement>('[data-track="bonus_copy"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code     = btn.dataset.code     ?? '';
      const exchange = btn.dataset.exchange ?? '';
      await navigator.clipboard.writeText(code).catch(() => {});
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      // Track: bonus_copy goal
      analytics.trackBonusCopy({ exchange, code });
    });
  });
</script>

<style>
  .promo-code-box {
    background: #1a1a0a;
    border: 1px dashed var(--color-accent-dim);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 1rem 0;
  }
  .promo-code-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-accent);
  }
  .promo-code-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .promo-code-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .promo-code-value-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .promo-code-value {
    font-family: monospace;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    background: var(--color-bg-tertiary);
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--color-accent-dim);
  }
  .promo-copy-btn {
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    background: var(--color-accent);
    color: #000;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .promo-copy-btn:hover { opacity: 0.85; }
</style>
