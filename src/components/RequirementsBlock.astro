---
interface Props {
  requirements: string;
  kycRequired: boolean;
  depositRequired: boolean;
  futuresRequired: boolean;
}
const { requirements, kycRequired, depositRequired, futuresRequired } = Astro.props;

const steps = [
  { label: 'Register', desc: 'Create your account using the referral link', always: true },
  { label: 'KYC Verification', desc: 'Submit identity documents', required: kycRequired },
  { label: 'Make a Deposit', desc: 'Fund your account with qualifying amount', required: depositRequired },
  { label: 'Trade', desc: 'Complete required trading volume', always: true },
  { label: 'Futures Trading', desc: 'Trade futures contracts to unlock bonus', required: futuresRequired },
].filter(s => s.always || s.required);
---

<div class="requirements-block">
  <h3 class="req-title">How to Claim This Bonus</h3>
  <ol class="req-steps">
    {steps.map((step, i) => (
      <li class="req-step">
        <div class="req-step-num" aria-hidden="true">{i + 1}</div>
        <div class="req-step-content">
          <strong>{step.label}</strong>
          <p>{step.desc}</p>
        </div>
      </li>
    ))}
  </ol>
  {requirements && (
    <div class="req-note">
      <p>{requirements}</p>
    </div>
  )}
</div>

<style>
  .requirements-block {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }
  .req-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 1.25rem;
    color: var(--color-text-primary);
  }
  .req-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .req-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .req-step-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    color: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 800;
    margin-top: 2px;
  }
  .req-step-content strong {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-primary);
    margin-bottom: 0.15rem;
  }
  .req-step-content p {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .req-note {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .req-note p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }
</style>
