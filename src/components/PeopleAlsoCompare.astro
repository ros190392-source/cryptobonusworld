---
/**
 * PeopleAlsoCompare — behavioral SEO widget for exchange pages.
 *
 * Shows a curated list of head-to-head compare pairs related to the current exchange.
 * Signals topical depth to Google/AI crawlers + drives internal CTR on compare pages.
 */

interface ComparePair {
  pair: string;  // e.g. "bybit-vs-mexc"
  a: string;
  b: string;
}

interface ExchangeData {
  name: string;
  slug: string;
  rating: number;
  spotMakerFee?: number;
  kycRequired: boolean;
  bonusAmount?: number;
  bonusCurrency?: string;
}

interface Props {
  pairs: ComparePair[];
  exchanges: Record<string, ExchangeData>;
  currentSlug: string;
  /** Max cards to render (default: 5) */
  limit?: number;
}

const { pairs, exchanges, currentSlug, limit = 5 } = Astro.props;

const visiblePairs = pairs.slice(0, limit);

const BRAND_COLORS: Record<string, string> = {
  bybit:    '#F7A600',
  binance:  '#F3BA2F',
  coinbase: '#0086FF',
  okx:      '#EEEEEE',
  mexc:     '#0BCDFF',
  bitget:   '#00E5BE',
  bingx:    '#1B78F2',
  'gate-io':'#2354E6',
  kucoin:   '#24AE8F',
  htx:      '#2856EE',
  coinex:   '#00CFC5',
  phemex:   '#BE79DF',
  bitunix:  '#F97316',
  lbank:    '#3B82F6',
};

function brand(slug: string): string {
  return BRAND_COLORS[slug] ?? '#F5C542';
}

function feeLabel(ex: ExchangeData | undefined): string {
  if (!ex) return '—';
  if ((ex as any).spotMakerFee !== undefined) {
    return `${(ex as any).spotMakerFee}% fee`;
  }
  return 'Fees vary';
}

function kycLabel(ex: ExchangeData | undefined): string {
  if (!ex) return '—';
  return ex.kycRequired ? 'KYC required' : 'No KYC';
}

function winner(a: ExchangeData | undefined, b: ExchangeData | undefined, metric: 'fee' | 'kyc' | 'bonus'): 'a' | 'b' | 'tie' {
  if (!a || !b) return 'tie';
  if (metric === 'fee') {
    const fa = (a as any).spotMakerFee ?? 0.1;
    const fb = (b as any).spotMakerFee ?? 0.1;
    if (fa < fb) return 'a';
    if (fb < fa) return 'b';
    return 'tie';
  }
  if (metric === 'kyc') {
    if (!a.kycRequired && b.kycRequired) return 'a';
    if (!b.kycRequired && a.kycRequired) return 'b';
    return 'tie';
  }
  if (metric === 'bonus') {
    const ba = a.bonusAmount ?? 0;
    const bb = b.bonusAmount ?? 0;
    if (ba > bb) return 'a';
    if (bb > ba) return 'b';
    return 'tie';
  }
  return 'tie';
}
---

<div class="pac-block" aria-label="People also compare">
  <div class="pac-header">
    <span class="pac-label" aria-hidden="true">⚡</span>
    <h3 class="pac-title">People Also Compare</h3>
  </div>

  <div class="pac-grid">
    {visiblePairs.map(p => {
      const exA = exchanges[p.a] as ExchangeData | undefined;
      const exB = exchanges[p.b] as ExchangeData | undefined;
      const isCurrent = p.a === currentSlug || p.b === currentSlug;
      const feeWin = winner(exA, exB, 'fee');
      const kycWin = winner(exA, exB, 'kyc');
      const bonusWin = winner(exA, exB, 'bonus');
      return (
        <a
          href={`/compare/${p.pair}/`}
          class="pac-card"
          data-track="compare_click"
          data-pair={p.pair}
          data-exchange-a={p.a}
          data-exchange-b={p.b}
          data-placement="people-also-compare"
          aria-label={`Compare ${exA?.name ?? p.a} vs ${exB?.name ?? p.b}`}
        >
          {/* Exchange A */}
          <div class="pac-side pac-side--a">
            <span class="pac-dot" style={`background:${brand(p.a)}`} aria-hidden="true" />
            <span class="pac-name" style={`color:${brand(p.a)}`}>{exA?.name ?? p.a}</span>
            <div class="pac-stats">
              <span class={`pac-stat${feeWin === 'a' ? ' pac-stat--win' : ''}`}>{feeLabel(exA)}</span>
              <span class={`pac-stat${kycWin === 'a' ? ' pac-stat--win' : ''}`}>{kycLabel(exA)}</span>
              {exA?.bonusAmount ? <span class={`pac-stat${bonusWin === 'a' ? ' pac-stat--win' : ''}`}>Up to {exA.bonusAmount.toLocaleString()} {exA.bonusCurrency}</span> : null}
            </div>
          </div>

          {/* VS divider */}
          <div class="pac-vs" aria-hidden="true">VS</div>

          {/* Exchange B */}
          <div class="pac-side pac-side--b">
            <span class="pac-dot" style={`background:${brand(p.b)}`} aria-hidden="true" />
            <span class="pac-name" style={`color:${brand(p.b)}`}>{exB?.name ?? p.b}</span>
            <div class="pac-stats">
              <span class={`pac-stat${feeWin === 'b' ? ' pac-stat--win' : ''}`}>{feeLabel(exB)}</span>
              <span class={`pac-stat${kycWin === 'b' ? ' pac-stat--win' : ''}`}>{kycLabel(exB)}</span>
              {exB?.bonusAmount ? <span class={`pac-stat${bonusWin === 'b' ? ' pac-stat--win' : ''}`}>Up to {exB.bonusAmount.toLocaleString()} {exB.bonusCurrency}</span> : null}
            </div>
          </div>

          {/* CTA arrow */}
          <div class="pac-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </div>
        </a>
      );
    })}
  </div>

  <div class="pac-footer">
    <a
      href="/compare/"
      class="pac-see-all"
      data-track="compare_click"
      data-placement="people-also-compare-footer"
    >View all comparisons →</a>
  </div>
</div>

<style>
  .pac-block {
    margin: 2rem 0;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
  }

  .pac-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .pac-label {
    font-size: 1rem;
  }

  .pac-title {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .pac-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pac-card {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }

  .pac-card:hover {
    border-color: rgba(245, 197, 66, 0.3);
    background: rgba(245, 197, 66, 0.03);
    transform: translateX(2px);
  }

  .pac-side {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .pac-side--b {
    text-align: right;
    align-items: flex-end;
  }

  .pac-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .pac-name {
    font-size: 0.95rem;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pac-stats {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .pac-side--b .pac-stats {
    align-items: flex-end;
  }

  .pac-stat {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .pac-stat--win {
    color: #4ade80;
    font-weight: 600;
  }

  .pac-vs {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--color-text-muted);
    opacity: 0.5;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .pac-arrow {
    color: var(--color-text-muted);
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.15s;
  }

  .pac-card:hover .pac-arrow {
    opacity: 0.9;
    transform: translateX(2px);
  }

  .pac-footer {
    margin-top: 1rem;
    text-align: right;
  }

  .pac-see-all {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .pac-see-all:hover { opacity: 0.75; }

  @media (max-width: 480px) {
    .pac-card {
      grid-template-columns: 1fr auto 1fr auto;
      padding: 0.6rem 0.75rem;
      gap: 0.5rem;
    }
    .pac-name { font-size: 0.85rem; }
  }
</style>
