---
interface Props {
  href: string;
  label?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  exchange?: string;
  rel?: string;
}

const {
  href,
  label = 'Claim Bonus',
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  exchange,
  rel = 'noopener noreferrer nofollow sponsored',
} = Astro.props;

const isExternal = href.startsWith('http') || href === '#';
const target = isExternal ? '_blank' : undefined;
const displayLabel = exchange ? `Claim ${exchange} Bonus` : label;
---

<a
  href={href}
  class:list={['cta-btn', `cta-btn--${variant}`, `cta-btn--${size}`, fullWidth && 'cta-btn--full']}
  target={target}
  rel={isExternal ? rel : undefined}
  aria-label={displayLabel}
>
  {displayLabel}
  {isExternal && <span class="cta-arrow" aria-hidden="true">→</span>}
</a>

<style>
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md, 10px);
    transition:
      background var(--duration-base, 200ms) var(--ease-standard, ease),
      box-shadow var(--duration-base, 200ms) var(--ease-standard, ease),
      transform var(--duration-fast, 120ms) var(--ease-spring, ease),
      opacity var(--duration-fast, 120ms) var(--ease-standard, ease);
    cursor: pointer;
    border: 2px solid transparent;
    white-space: nowrap;
    /* Minimum touch target */
    min-height: 44px;
    position: relative;
    isolation: isolate;
  }

  .cta-btn:active {
    transform: scale(0.96) !important;
    transition-duration: 80ms !important;
  }

  /* ── Primary ── */
  .cta-btn--primary {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .cta-btn--primary:hover {
    box-shadow: var(--glow-cta, 0 4px 20px rgba(245,197,66,0.35));
    transform: translateY(-2px);
    background: var(--color-accent-warm, #fbbf24);
    border-color: var(--color-accent-warm, #fbbf24);
  }

  /* ── Secondary ── */
  .cta-btn--secondary {
    background: var(--surface-overlay, #1a1a1a);
    color: var(--color-text-primary);
    border-color: var(--color-border, #252525);
  }
  .cta-btn--secondary:hover {
    background: var(--surface-elevated, #151515);
    border-color: var(--color-accent-dim, rgba(245,197,66,0.15));
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ── Outline ── */
  .cta-btn--outline {
    background: transparent;
    color: var(--color-accent);
    border-color: var(--color-accent-dim, rgba(245,197,66,0.35));
  }
  .cta-btn--outline:hover {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
    box-shadow: var(--glow-gold-sm, 0 0 12px rgba(245,197,66,0.2));
    transform: translateY(-1px);
  }

  /* ── Sizes ── */
  .cta-btn--sm {
    font-size: var(--text-sm, 0.875rem);
    padding: 0.4rem 1rem;
    min-height: 40px;
    border-radius: var(--radius-sm, 6px);
  }
  .cta-btn--md {
    font-size: var(--text-sm, 0.875rem);
    padding: 0.6rem 1.375rem;
  }
  .cta-btn--lg {
    font-size: var(--text-base, 1rem);
    padding: 0.8rem 1.875rem;
    letter-spacing: -0.01em;
  }
  .cta-btn--full { width: 100%; }

  .cta-arrow {
    font-size: 0.875em;
    transition: transform var(--duration-base, 200ms) var(--ease-out, ease);
  }
  .cta-btn:hover .cta-arrow {
    transform: translateX(3px);
  }
</style>
