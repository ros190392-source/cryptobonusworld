{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://cryptobonusworld.com/schemas/annotation-config.json",
  "title": "AnnotationConfig",
  "description": "CryptoBonusWorld screenshot annotation configuration. One file per (exchange × category × date). Consumed by scripts/annotate-screenshot.mjs.",
  "type": "object",
  "required": ["version", "exchange", "category", "screenshotWidth", "screenshotHeight", "annotations"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Config schema version"
    },
    "exchange": {
      "type": "string",
      "description": "Exchange slug — matches exchanges.json"
    },
    "category": {
      "type": "string",
      "enum": ["registration", "kyc", "bonus", "deposit", "p2p", "spot", "futures", "fees", "mobile_app", "proof_of_reserves"]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "ISO YYYY-MM capture date"
    },
    "screenshotWidth": {
      "type": "integer",
      "description": "Width of the processed screenshot in pixels (post-resize)"
    },
    "screenshotHeight": {
      "type": "integer",
      "description": "Height of the processed screenshot in pixels (post-resize)"
    },
    "annotations": {
      "type": "array",
      "description": "Ordered list of annotation elements. Rendered in order (last = top).",
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/ArrowAnnotation" },
          { "$ref": "#/definitions/CalloutAnnotation" },
          { "$ref": "#/definitions/FocusAnnotation" },
          { "$ref": "#/definitions/StepAnnotation" },
          { "$ref": "#/definitions/HighlightAnnotation" },
          { "$ref": "#/definitions/BlurAnnotation" }
        ]
      }
    },
    "aiReady": {
      "type": "boolean",
      "default": false,
      "description": "True when AI has reviewed and validated these annotations"
    },
    "aiCandidates": {
      "type": "array",
      "description": "AI-suggested annotations not yet promoted to the main annotations array",
      "items": { "$ref": "#/definitions/AICandidate" }
    },
    "notes": {
      "type": "string",
      "description": "Editorial notes about this annotation config"
    }
  },

  "definitions": {

    "Point": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2,
      "description": "[x, y] pixel coordinates"
    },

    "Rect": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4,
      "description": "[x, y, width, height] pixel rectangle"
    },

    "ArrowAnnotation": {
      "type": "object",
      "required": ["type", "from", "to"],
      "properties": {
        "type": { "type": "string", "enum": ["arrow"] },
        "from": { "$ref": "#/definitions/Point" },
        "to":   { "$ref": "#/definitions/Point" },
        "style": {
          "type": "string",
          "enum": ["curved", "straight", "elbow"],
          "default": "curved",
          "description": "Arrow path style. curved = cubic bezier. elbow = L-shape."
        },
        "color": {
          "type": "string",
          "default": "#6C63FF",
          "description": "Arrow stroke color — must follow style guide"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.82
        },
        "strokeWidth": {
          "type": "number",
          "default": 2.5
        },
        "label": {
          "type": "string",
          "description": "Optional text label near the arrow tail"
        }
      }
    },

    "CalloutAnnotation": {
      "type": "object",
      "required": ["type", "text", "anchor"],
      "properties": {
        "type": { "type": "string", "enum": ["callout"] },
        "text": {
          "type": "string",
          "maxLength": 60,
          "description": "Callout label text — keep concise"
        },
        "anchor": { "$ref": "#/definitions/Point" },
        "side": {
          "type": "string",
          "enum": ["above", "below", "left", "right"],
          "default": "above",
          "description": "Which side of anchor the callout box appears on"
        },
        "style": {
          "type": "string",
          "enum": ["glass", "solid"],
          "default": "glass",
          "description": "glass = glassmorphism dark. solid = opaque #1E1E30."
        },
        "arrowLine": {
          "type": "boolean",
          "default": false,
          "description": "Draw a thin connector line from callout to anchor"
        }
      }
    },

    "FocusAnnotation": {
      "type": "object",
      "required": ["type", "rect"],
      "properties": {
        "type": { "type": "string", "enum": ["focus"] },
        "rect": { "$ref": "#/definitions/Rect" },
        "radius": {
          "type": "number",
          "default": 6,
          "description": "Corner radius of the focus ring rectangle"
        },
        "intensity": {
          "type": "string",
          "enum": ["subtle", "normal", "strong"],
          "default": "normal",
          "description": "Glow intensity — affects fill opacity and outer ring size"
        }
      }
    },

    "StepAnnotation": {
      "type": "object",
      "required": ["type", "n", "x", "y"],
      "properties": {
        "type": { "type": "string", "enum": ["step"] },
        "n": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9,
          "description": "Step number displayed in the badge"
        },
        "x": { "type": "number", "description": "Badge center X" },
        "y": { "type": "number", "description": "Badge center Y" },
        "label": {
          "type": "string",
          "description": "Optional small text below the badge"
        }
      }
    },

    "HighlightAnnotation": {
      "type": "object",
      "required": ["type", "rect"],
      "properties": {
        "type": { "type": "string", "enum": ["highlight"] },
        "rect": { "$ref": "#/definitions/Rect" },
        "radius": { "type": "number", "default": 4 },
        "color": {
          "type": "string",
          "default": "#6C63FF",
          "description": "Highlight accent color"
        }
      }
    },

    "BlurAnnotation": {
      "type": "object",
      "required": ["type", "rect"],
      "properties": {
        "type": { "type": "string", "enum": ["blur"] },
        "rect": { "$ref": "#/definitions/Rect" },
        "radius": {
          "type": "number",
          "default": 12,
          "description": "Gaussian blur sigma — higher = more blur"
        },
        "reason": {
          "type": "string",
          "enum": ["email", "balance", "address", "phone", "name", "2fa", "other"],
          "description": "Why this region is blurred — for audit trail"
        }
      }
    },

    "AICandidate": {
      "type": "object",
      "description": "AI-suggested annotation, pending human review. Structure matches the standard annotation types.",
      "required": ["type", "confidence"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Same type values as main annotations"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "AI confidence score for this suggestion"
        },
        "detectedElement": {
          "type": "string",
          "description": "What UI element the AI identified (e.g. 'email input', 'submit button')"
        },
        "approved": {
          "type": "boolean",
          "default": false,
          "description": "Set true to promote this candidate to the main annotations array"
        }
      },
      "additionalProperties": true
    }

  }
}
