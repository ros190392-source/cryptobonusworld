---
/*
 * PREVIEW ONLY — noindex, not linked from anywhere.
 * Renders MEXC exchange page via the reusable ExchangePromoPage template.
 * Compare to live page at /mexc/ to validate visual equivalence.
 *
 * Live page:    /mexc/           (src/pages/mexc/index.astro) — DO NOT TOUCH
 * Preview page: /preview/exchange-template/mexc/  ← you are here
 */
import CleanLayout from '../../../layouts/CleanLayout.astro';
import ExchangePromoPage from '../../../components/exchange/ExchangePromoPage.astro';
import { mexcConfig } from '../../../data/exchangePages/mexc';
---

<CleanLayout
  title={mexcConfig.pageTitle}
  description={mexcConfig.pageDescription}
  canonical={mexcConfig.canonicalUrl}
  ogImage={mexcConfig.ogImage}
  ogTitle={mexcConfig.ogTitle}
  ogDescription={mexcConfig.ogDescription}
  noindex={true}
>
  <ExchangePromoPage config={mexcConfig} />
</CleanLayout>
