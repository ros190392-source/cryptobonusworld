---
const navLinks = [
  { href: '/bonuses/', label: 'All Bonuses' },
  { href: '/exchanges/', label: 'Exchanges' },
  { href: '/categories/signup-bonuses/', label: 'Signup Bonuses' },
  { href: '/categories/no-deposit-bonuses/', label: 'No Deposit' },
  { href: '/categories/futures-bonuses/', label: 'Futures' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="CryptoBonusWorld Home">
      <span class="logo-icon">₿</span>
      <span class="logo-text">CryptoBonusWorld</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${currentPath.startsWith(link.href) ? 'active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/bonuses/" class="header-cta">Compare Bonuses</a>

    <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" aria-label="Mobile navigation">
    <ul class="mobile-nav-list">
      {navLinks.map(link => (
        <li><a href={link.href} class="mobile-nav-link">{link.label}</a></li>
      ))}
      <li><a href="/bonuses/" class="mobile-nav-cta">Compare Bonuses</a></li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobileNav?.classList.toggle('open');
  });
</script>

<style>
  .site-header {
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 64px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-icon {
    font-size: 1.5rem;
    color: var(--color-accent);
  }
  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }
  .main-nav { flex: 1; }
  .nav-list {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text-primary);
    background: var(--color-bg-tertiary);
  }
  .header-cta {
    flex-shrink: 0;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: #000;
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .header-cta:hover { opacity: 0.85; }
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }
  .mobile-menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: transform 0.2s;
  }
  .mobile-nav {
    display: none;
    border-top: 1px solid var(--color-border);
  }
  .mobile-nav.open { display: block; }
  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem;
  }
  .mobile-nav-link,
  .mobile-nav-cta {
    display: block;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 6px;
  }
  .mobile-nav-cta {
    color: var(--color-accent);
    font-weight: 700;
    margin-top: 0.25rem;
  }
  @media (max-width: 768px) {
    .main-nav,
    .header-cta { display: none; }
    .mobile-menu-toggle { display: flex; }
  }
</style>
