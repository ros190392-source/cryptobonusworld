---
/**
 * GeoRegulatoryNote.astro
 * =======================
 * Renders geo-aware regulatory / availability note for an exchange.
 *
 * Behaviour:
 *  - At SSG time: renders a static default disclaimer (SEO safe)
 *  - Client-side: upgrades to exchange-specific regulatory note for the visitor's geo
 *
 * This component is optional — only renders when a regulatory note
 * exists for the detected geo. Falls back to the standard disclaimer.
 *
 * Props:
 *   exchangeSlug   — Exchange slug (used to look up geo override)
 *   exchangeName   — Exchange name (used in fallback text)
 *   defaultNote    — Custom default text (overrides the generic disclaimer)
 *   showAlways     — Always render fallback (default: true)
 */

import type { GeoExchange } from '../utils/geoConfig';
import { serializeGeoConfigsForExchange, REGION_MAP } from '../utils/geoConfig';

interface Props {
  exchange: { slug: string; name: string; affiliateUrl: string; affiliateLinks?: any; paymentMethods?: string[] };
  defaultNote?: string;
  showAlways?: boolean;
}

const { exchange: ex, defaultNote, showAlways = true } = Astro.props;

const geoConfigs = serializeGeoConfigsForExchange(ex as GeoExchange);
const geoConfigsJson = JSON.stringify(geoConfigs);
const regionMapJson = JSON.stringify(REGION_MAP);

const blockId = `geo-reg-${Math.random().toString(36).slice(2, 8)}`;
const hasAnyNote = Object.values(geoConfigs).some((c: any) => c.regulatoryNote);

const fallbackText = defaultNote ??
  `Availability, bonus campaigns and regulatory requirements for ${ex.name} may vary by country. Always verify current terms and conditions on the exchange website before registering.`;
---

{(showAlways || hasAnyNote) && (
  <div
    class="geo-reg"
    id={blockId}
    data-default-note={fallbackText}
  >
    <span class="geo-reg__icon" aria-hidden="true">⚖️</span>
    <p class="geo-reg__text" data-geo-reg-text>{fallbackText}</p>
  </div>
)}

<script define:vars={{ blockId, geoConfigsJson, regionMapJson }}>
  (function () {
    const wrapper = document.getElementById(blockId);
    if (!wrapper) return;

    const textEl = wrapper.querySelector('[data-geo-reg-text]');
    const geoConfigs = JSON.parse(geoConfigsJson);
    const regionMap = JSON.parse(regionMapJson);

    function resolveConfig(countryCode) {
      if (!countryCode) return null;
      var cc = countryCode.toLowerCase();
      if (geoConfigs[cc]) return geoConfigs[cc];
      var region = regionMap[cc];
      if (region && geoConfigs['region:' + region]) return geoConfigs['region:' + region];
      return null;
    }

    function tryApply() {
      var geo = null;
      try { geo = localStorage.getItem('cbw_geo'); } catch (e) {}
      if (!geo) return;

      var config = resolveConfig(geo);
      if (!config) return;

      // Show regulatory note if one exists for this geo
      if (textEl && config.regulatoryNote) {
        textEl.textContent = config.regulatoryNote;
        wrapper.classList.add('geo-reg--specific');
      }

      // If exchange is unavailable here, add unavailable class and expand the note
      if (config.availabilityStatus === 'unavailable') {
        wrapper.classList.add('geo-reg--unavailable');
        wrapper.setAttribute('role', 'alert');
        // Replace the small ⚖️ icon with a blocked icon for unavailable state
        var iconEl = wrapper.querySelector('.geo-reg__icon');
        if (iconEl) iconEl.textContent = '🚫';
        // Show the ctaNote as alternatives hint if present
        if (config.ctaNote) {
          var altEl = wrapper.querySelector('[data-geo-reg-alt]');
          if (!altEl) {
            altEl = document.createElement('p');
            altEl.setAttribute('data-geo-reg-alt', '');
            altEl.className = 'geo-reg__alt';
            wrapper.appendChild(altEl);
          }
          altEl.textContent = config.ctaNote;
        }
      } else if (config.availabilityStatus === 'limited' || config.availabilityStatus === 'restricted') {
        wrapper.classList.add('geo-reg--limited');
      }
    }

    tryApply();
    window.addEventListener('cbw:geo', function () { tryApply(); });
  })();
</script>

<style>
  .geo-reg {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    padding: 0.625rem 0.875rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.78rem;
  }

  .geo-reg__icon {
    font-size: 0.9rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .geo-reg__text {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* When a specific geo regulatory note is showing */
  .geo-reg--specific {
    background: color-mix(in srgb, #3b82f6 6%, transparent);
    border-color: color-mix(in srgb, #3b82f6 25%, transparent);
  }
  .geo-reg--specific .geo-reg__text {
    color: var(--color-text-secondary);
  }

  /* Unavailable state */
  .geo-reg--unavailable {
    background: color-mix(in srgb, #ef4444 8%, transparent);
    border-color: color-mix(in srgb, #ef4444 30%, transparent);
    border-left-width: 3px;
  }
  .geo-reg--unavailable .geo-reg__text {
    color: #fca5a5;
    font-weight: 500;
  }
  .geo-reg__alt {
    margin: 0.375rem 0 0;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Limited state */
  .geo-reg--limited {
    background: color-mix(in srgb, #f59e0b 6%, transparent);
    border-color: color-mix(in srgb, #f59e0b 25%, transparent);
  }
</style>
