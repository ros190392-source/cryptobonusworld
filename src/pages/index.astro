---
import Layout from '../layouts/Layout.astro';
import BonusTable from '../components/BonusTable.astro';
import ExchangeCard from '../components/ExchangeCard.astro';
import ExchangeLogo from '../components/ExchangeLogo.astro';
import QuickPicks from '../components/QuickPicks.astro';
import FilterPanel from '../components/FilterPanel.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CountryCard from '../components/CountryCard.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RiskDisclaimer from '../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import CTAButton from '../components/CTAButton.astro';
import MethodologyBlock from '../components/MethodologyBlock.astro';
import AdaptiveRecommendation from '../components/AdaptiveRecommendation.astro';

import exchanges from '../data/exchanges.json';
import categories from '../data/categories.json';
import countries from '../data/countries.json';
import comparePairs from '../data/compare-pairs.json';
import type { RecommendableExchange } from '../utils/recommendationEngine';

import { buildWebSiteSchema, buildOrganizationSchema } from '../utils/seo';
import type { PageContext } from '../utils/analytics';
import guides from '../data/guides.json';

const topExchanges = [...exchanges].sort((a, b) => b.rating - a.rating).slice(0, 5);

// Top comparison pairs — curated by search demand (most-searched head terms first)
const TOP_COMPARE_SLUGS = [
  'binance-vs-bybit',
  'bybit-vs-mexc',
  'coinbase-vs-binance',
  'binance-vs-okx',
  'coinbase-vs-bybit',
  'okx-vs-binance',
];
const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));
const topComparePairs = TOP_COMPARE_SLUGS
  .map(slug => comparePairs.find(p => p.pair === slug))
  .filter(Boolean)
  .map(p => {
    const ea = exMap[p!.a] as any;
    const eb = exMap[p!.b] as any;
    return ea && eb ? { pair: p!.pair, nameA: ea.name, nameB: eb.name, slugA: ea.slug, slugB: eb.slug } : null;
  })
  .filter(Boolean) as Array<{ pair: string; nameA: string; nameB: string; slugA: string; slugB: string }>;

const faqItems = [
  {
    question: "What is a crypto exchange bonus?",
    answer: "A crypto exchange bonus is a promotional reward offered by a crypto exchange when you register, deposit or start trading — often through an affiliate or referral link. Bonuses may include cash rewards, trading fee vouchers or deposit match promotions.",
  },
  {
    question: "Are crypto bonuses free money?",
    answer: "No. Crypto bonuses are promotional rewards that come with conditions. Most require KYC verification, a minimum deposit, and a minimum trading volume before you can access or withdraw the bonus. Always read the official terms before claiming.",
  },
  {
    question: "Which crypto exchange has the best bonus?",
    answer: "Based on our comparison, Bybit offers up to 30,000 USDT for new users, one of the highest headline bonus amounts. However, the best bonus depends on your country, whether you can meet KYC requirements, and your planned trading volume.",
  },
  {
    question: "Can I get a crypto bonus without KYC?",
    answer: "Yes. MEXC, KuCoin, CoinEx and Bitunix offer bonuses without requiring full identity verification. However, non-KYC accounts often have withdrawal limits and restricted features.",
  },
  {
    question: "How do I claim a crypto bonus?",
    answer: "Register on the exchange through a referral or affiliate link, complete any required KYC, make a qualifying deposit, and complete the required trading volume. Bonus amounts usually unlock progressively as you complete each milestone.",
  },
  {
    question: "Do crypto bonuses expire?",
    answer: "Yes. Most bonuses have expiration dates ranging from 7 to 30 days. Unused bonuses or unmet conditions may result in forfeiture of the reward. Always check the expiration window in the official promotion terms.",
  },
];

// SEO: richer schema array — WebSite + Organization together
const siteSchema = [buildWebSiteSchema(), buildOrganizationSchema()];

const analyticsContext: PageContext = { pageType: 'homepage' };
---

<Layout
  title="Best Crypto Exchange Bonuses 2026 — Compare & Claim"
  description="Compare signup rewards, deposit bonuses, futures bonuses and crypto trading promotions from top exchanges. Find the best crypto bonus for your country and trading goals."
  canonical="/"
  schema={siteSchema}
  analyticsContext={analyticsContext}
  ogImage="https://cryptobonusworld.com/og-default.png"
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
    </div>

    <div class="container hero-container">
      <!-- Left column -->
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Live Data &middot; 13 Exchanges &middot; Updated May 2026
        </div>

        <h1 class="hero-title">
          Best Crypto Exchange<br>
          <span class="hero-title-accent">Bonuses</span> in 2026
        </h1>

        <p class="hero-subtitle">
          Compare signup rewards, deposit bonuses and futures promotions from top exchanges. Find the best offer for your country.
        </p>

        <div class="hero-ctas">
          <CTAButton href="/bonuses/" label="Compare All Bonuses" size="lg" />
          <CTAButton href="/exchanges/bybit/" label="Top Bonus: 30,000 USDT →" variant="outline" size="lg" />
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-num">$30K</span>
            <span class="hero-stat-label">Max Bonus</span>
          </div>
          <div class="hero-stat-sep"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">13</span>
            <span class="hero-stat-label">Exchanges</span>
          </div>
          <div class="hero-stat-sep"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">8</span>
            <span class="hero-stat-label">Countries</span>
          </div>
          <div class="hero-stat-sep"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">Free</span>
            <span class="hero-stat-label">No Signup</span>
          </div>
        </div>
      </div>

      <!-- Right column: top bonus cards -->
      <div class="hero-right" aria-label="Top bonus offers">
        {topExchanges.slice(0, 3).map((ex, i) => (
          <a href={`/exchanges/${ex.slug}/`} class:list={['hbc', i === 0 && 'hbc--featured']}>
            <ExchangeLogo slug={ex.slug} name={ex.name} size={64} variant="square" lazy={false} />
            <div class="hbc-info">
              <span class="hbc-name">{ex.name}</span>
              <span class="hbc-amount">Up to {ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
            </div>
            <span class="hbc-cta">Claim →</span>
          </a>
        ))}
        <p class="hero-right-note">Conditions apply. Always verify official terms.</p>
      </div>
    </div>

    <!-- Ticker -->
    <div class="hero-ticker" aria-hidden="true">
      <div class="hero-ticker-inner">
        {[...exchanges, ...exchanges].map(ex => (
          <span class="ticker-item">
            <span class="ticker-name">{ex.name}</span>
            <span class="ticker-sep">·</span>
            <span class="ticker-amount">{ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <div class="container">
    <AffiliateDisclosure compact />
  </div>

  <!-- Filters -->
  <div class="container">
    <FilterPanel />
  </div>

  <!-- Bonus Table -->
  <section class="container section">
    <h2 class="section-title">Top Crypto Exchange Bonuses</h2>
    <QuickPicks exchanges={exchanges} />
    <BonusTable exchanges={exchanges} />
    <AdaptiveRecommendation
      exchanges={exchanges as unknown as RecommendableExchange[]}
      pageType="homepage"
      showHint={true}
    />
    <MethodologyBlock compact />
  </section>

  <!-- Top Exchange Cards -->
  <section class="container section">
    <h2 class="section-title">Top Bonus Offers This Month</h2>
    <div class="grid-3">
      {topExchanges.slice(0, 3).map(ex => (
        <ExchangeCard {...ex} />
      ))}
    </div>
    <div class="grid-2" style="margin-top: 1rem">
      {topExchanges.slice(3, 5).map(ex => (
        <ExchangeCard {...ex} />
      ))}
    </div>
    <div class="view-all-wrap">
      <CTAButton href="/bonuses/" label="View All 13 Exchanges" variant="outline" size="md" />
    </div>
  </section>

  <!-- Quick Find — visual category grid -->
  <section class="container section">
    <h2 class="section-title">Find the Right Bonus</h2>
    <p class="section-subtitle">Browse by bonus type, exchange or country — find the offer that fits your needs.</p>
    <div class="qf-grid">
      <a href="/bonuses/" class="qf-card qf-card--featured">
        <span class="qf-icon">🏆</span>
        <div class="qf-info">
          <span class="qf-label">Top Bonus Exchanges</span>
          <span class="qf-meta">Up to 30,000 USDT available</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/categories/no-kyc-bonuses/" class="qf-card">
        <span class="qf-icon">🔓</span>
        <div class="qf-info">
          <span class="qf-label">No-KYC Bonuses</span>
          <span class="qf-meta">Trade without ID verification</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/categories/signup-bonuses/" class="qf-card">
        <span class="qf-icon">🚀</span>
        <div class="qf-info">
          <span class="qf-label">Signup Bonuses</span>
          <span class="qf-meta">Free rewards for new users</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/categories/futures-bonuses/" class="qf-card">
        <span class="qf-icon">📈</span>
        <div class="qf-info">
          <span class="qf-label">Futures Bonuses</span>
          <span class="qf-meta">For derivatives & perpetuals</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/compare/" class="qf-card">
        <span class="qf-icon">⚖️</span>
        <div class="qf-info">
          <span class="qf-label">Compare Exchanges</span>
          <span class="qf-meta">Side-by-side bonus analysis</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
      <a href="/countries/" class="qf-card">
        <span class="qf-icon">🌍</span>
        <div class="qf-info">
          <span class="qf-label">Bonuses by Country</span>
          <span class="qf-meta">Check availability in your region</span>
        </div>
        <span class="qf-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Bonus Landing Page Links -->
  <section class="container section">
    <h2 class="section-title">Claim Your Exchange Bonus</h2>
    <p class="section-subtitle">Step-by-step guides to claim the best bonus from each exchange.</p>
    <div class="bonus-links-grid">
      {exchanges.slice(0, 6).map(ex => (
        <a href={`/bonuses/${ex.slug}-bonus/`} class="bonus-link-card">
          <span class="bonus-link-name">{ex.name}</span>
          <span class="bonus-link-amount">Up to {ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</span>
          <span class="bonus-link-cta">Claim Guide →</span>
        </a>
      ))}
    </div>
    <div class="view-all-wrap">
      <a href="/bonuses/" class="text-link">View all bonus claim guides →</a>
    </div>
  </section>

  <!-- Top Comparisons — money page priority boost -->
  <section class="container section">
    <h2 class="section-title">Compare Exchanges Side by Side</h2>
    <p class="section-subtitle">Fees, bonuses, KYC requirements and features — compared in one place.</p>
    <div class="compare-grid">
      {topComparePairs.map(p => (
        <a href={`/compare/${p.pair}/`} class="compare-hp-card">
          <div class="compare-hp-logos">
            <img src={`/logos/${p.slugA}.svg`} alt={p.nameA} width="32" height="32" loading="lazy" />
            <span class="compare-hp-vs">vs</span>
            <img src={`/logos/${p.slugB}.svg`} alt={p.nameB} width="32" height="32" loading="lazy" />
          </div>
          <span class="compare-hp-label">{p.nameA} vs {p.nameB}</span>
          <span class="compare-hp-arrow">→</span>
        </a>
      ))}
    </div>
    <div class="view-all-wrap">
      <a href="/compare/" class="text-link">View all exchange comparisons →</a>
    </div>
  </section>

  <!-- Categories -->
  <section class="container section">
    <h2 class="section-title">Bonuses by Category</h2>
    <div class="grid-2">
      {categories.slice(0, 6).map(cat => (
        <CategoryCard
          name={cat.name}
          slug={cat.slug}
          description={cat.description}
          bonusType={cat.bonusType}
          exchangeCount={exchanges.filter(e => e.bonusTypes.includes(cat.bonusType) || (cat.bonusType === 'no-kyc' && !e.kycRequired) || (cat.bonusType === 'welcome' && e.bonusTypes.includes('signup'))).length}
        />
      ))}
    </div>
  </section>

  <!-- Countries -->
  <section class="container section">
    <h2 class="section-title">Bonuses by Country</h2>
    <div class="grid-4">
      {countries.slice(0, 8).map(c => (
        <CountryCard
          name={c.name}
          slug={c.slug}
          flag={c.flag}
          description={c.description}
          exchangeCount={exchanges.filter(e => e.countries.includes(c.slug)).length}
        />
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="container section">
    <h2 class="section-title">How Crypto Bonuses Work</h2>
    <div class="how-it-works">
      <div class="how-step">
        <div class="how-step-num">1</div>
        <h3>Compare Bonuses</h3>
        <p>Use our comparison table to find the best bonus for your country, trading style and KYC preference.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">2</div>
        <h3>Read the Conditions</h3>
        <p>Every bonus has conditions — KYC requirements, deposit minimums and trading volume. Check them before registering.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">3</div>
        <h3>Register via Referral Link</h3>
        <p>Use the affiliate or referral link on this page to ensure the bonus is applied to your new account.</p>
      </div>
      <div class="how-step">
        <div class="how-step-num">4</div>
        <h3>Complete the Requirements</h3>
        <p>Deposit qualifying funds, complete KYC if required, and trade the minimum volume to unlock your bonus.</p>
      </div>
    </div>
    <div style="margin-top: 1.25rem">
      <a href="/methodology/" class="text-link">Learn more: How we review crypto bonuses →</a>
    </div>
  </section>

  <!-- Guides -->
  <section class="container section">
    <h2 class="section-title">In-Depth Guides</h2>
    <p class="section-subtitle">Learn how crypto bonuses, exchanges and passive income strategies really work.</p>
    <div class="guides-strip">
      {guides.slice(0, 6).map(g => (
        <a href={`/guides/${g.slug}/`} class="guide-strip-card">
          <span class="guide-strip-cat">{g.category}</span>
          <span class="guide-strip-title">{g.title}</span>
          <span class="guide-strip-meta">{g.readTime} read →</span>
        </a>
      ))}
    </div>
    <div class="view-all-wrap">
      <a href="/guides/" class="text-link">View all {guides.length} guides →</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container section">
    <FAQBlock items={faqItems} />
  </section>

  <!-- Risk Disclaimer -->
  <div class="container">
    <RiskDisclaimer />
  </div>
</Layout>

<!-- Mobile sticky CTA (scroll-triggered, hidden on desktop) -->
<div class="hp-sticky" id="hp-sticky" aria-hidden="true">
  <div class="hp-sticky-left">
    <span class="hp-sticky-headline">Up to 30,000 USDT</span>
    <span class="hp-sticky-sub">Compare 12 exchange bonuses</span>
  </div>
  <a href="/bonuses/" class="hp-sticky-btn">Compare Now →</a>
</div>

<script>
  const hpSticky = document.getElementById('hp-sticky');
  if (hpSticky) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const show = window.scrollY > 480;
          hpSticky.classList.toggle('hp-sticky--visible', show);
          hpSticky.setAttribute('aria-hidden', String(!show));
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>

<style>
  /* ── HERO ─────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    padding: 5rem 0 0;
  }

  /* Background layers */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow {
    position: absolute;
    top: -120px;
    left: -80px;
    width: 700px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(245,197,66,0.10) 0%, rgba(245,197,66,0.03) 45%, transparent 70%);
    border-radius: 50%;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 30% 40%, black 20%, transparent 80%);
  }

  /* Layout */
  .hero-container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 3rem;
    align-items: center;
    padding-bottom: 4rem;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: rgba(245,197,66,0.08);
    padding: 0.35rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(245,197,66,0.25);
    letter-spacing: 0.01em;
  }
  .hero-badge-dot {
    width: 7px;
    height: 7px;
    background: #ef4444;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(239,68,68,0.8);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  /* Title */
  .hero-title {
    font-size: clamp(2.2rem, 4.5vw, 3.25rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin: 0 0 1.25rem;
  }
  .hero-title-accent {
    background: linear-gradient(135deg, #f5c542 0%, #fbbf24 40%, #f59e0b 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  /* Subtitle */
  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 520px;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.25rem;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: 0.75rem;
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0 1.25rem;
  }
  .hero-stat:first-child { padding-left: 0; }
  .hero-stat-num {
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .hero-stat-sep {
    width: 1px;
    height: 32px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Right column: bonus cards */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .hbc {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
    position: relative;
  }
  .hbc:hover {
    border-color: rgba(245,197,66,0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .hbc--featured {
    border-color: rgba(245,197,66,0.35);
    background: linear-gradient(135deg, #1a1a0e 0%, #111111 100%);
    box-shadow: 0 0 0 1px rgba(245,197,66,0.15), 0 4px 20px rgba(245,197,66,0.06);
  }
  .hbc--featured::before {
    content: '🏆 #1';
    position: absolute;
    top: -10px;
    right: 12px;
    font-size: 0.65rem;
    font-weight: 800;
    background: var(--color-accent);
    color: #000;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    letter-spacing: 0.04em;
  }
  /* .hbc-logo removed — replaced by ExchangeLogo component */
  .hbc-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .hbc-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .hbc-amount {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .hbc-cta {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.15s;
  }
  .hbc:hover .hbc-cta { opacity: 1; }
  .hero-right-note {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    text-align: center;
    margin: 0.25rem 0 0;
    line-height: 1.4;
  }

  /* Ticker */
  .hero-ticker {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    background: rgba(255,255,255,0.015);
    overflow: hidden;
    padding: 0.625rem 0;
  }
  .hero-ticker-inner {
    display: flex;
    gap: 0;
    width: max-content;
    animation: ticker-scroll 40s linear infinite;
  }
  .hero-ticker:hover .hero-ticker-inner { animation-play-state: paused; }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 2rem;
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .ticker-name {
    font-weight: 700;
    color: var(--color-text-secondary);
  }
  .ticker-sep { color: var(--color-border); }
  .ticker-amount {
