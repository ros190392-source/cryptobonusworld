---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ExchangeLogo from '../../components/ExchangeLogo.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import ComparisonSummaryBlock from '../../components/ComparisonSummaryBlock.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import RelatedNextReads from '../../components/RelatedNextReads.astro';

import exchanges from '../../data/exchanges.json';
import comparePairs from '../../data/compare-pairs.json';

import {
  comparePageTitle,
  compareMetaDesc,
  buildComparisonSchema,
  getRelatedComparePairs,
  parseUserCount,
  SITE_URL,
  YEAR,
} from '../../utils/seo';
import { getCtaLabel } from '../../utils/affiliateUtils';
import type { PageContext } from '../../utils/analytics';
import {
  generateCompareFAQs,
  applyFAQOverrides,
  type ContentExchange,
} from '../../utils/contentEngine';
import contentOverrides from '../../data/content-overrides.json';

export async function getStaticPaths() {
  const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));
  return comparePairs
    .filter(p => exMap[p.a] && exMap[p.b])
    .map(p => ({
      params: { pair: p.pair },
      props: { pairDef: p },
    }));
}

const { pairDef } = Astro.props;
const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));

const exA = exMap[pairDef.a] as any;
const exB = exMap[pairDef.b] as any;

// ── SEO ──────────────────────────────────────────────────────────────────────
const seoTitle = comparePageTitle(exA, exB);
const seoDesc  = compareMetaDesc(exA, exB);
const schema   = buildComparisonSchema(exA, exB);
const canonical = `/compare/${pairDef.pair}/`;

// ── Related compare pairs ─────────────────────────────────────────────────────
const relatedPairs = getRelatedComparePairs(pairDef.pair, comparePairs, pairDef.a, pairDef.b, 4);

// ── Winner determination logic ───────────────────────────────────────────────
type Verdict = 'a' | 'b' | 'tie';

function winnerBonus(): Verdict {
  if (exA.bonusAmount > exB.bonusAmount) return 'a';
  if (exB.bonusAmount > exA.bonusAmount) return 'b';
  return 'tie';
}
function winnerKyc(): Verdict {
  if (!exA.kycRequired && exB.kycRequired) return 'a';
  if (!exB.kycRequired && exA.kycRequired) return 'b';
  return 'tie';
}
function winnerDeposit(): Verdict {
  const da = exA.minDeposit?.amount ?? 9999;
  const db = exB.minDeposit?.amount ?? 9999;
  if (da < db) return 'a';
  if (db < da) return 'b';
  return 'tie';
}
function winnerRating(): Verdict {
  if (exA.rating > exB.rating) return 'a';
  if (exB.rating > exA.rating) return 'b';
  return 'tie';
}
function winnerVolume(): Verdict {
  const va = exA.tradingVolumeRequired?.amount ?? 0;
  const vb = exB.tradingVolumeRequired?.amount ?? 0;
  // Lower volume requirement = easier = better for users
  if (va < vb) return 'a';
  if (vb < va) return 'b';
  return 'tie';
}
function winnerEstablished(): Verdict {
  const fa = exA.founded ?? 9999;
  const fb = exB.founded ?? 9999;
  // Older (lower year) = more established
  if (fa < fb) return 'a';
  if (fb < fa) return 'b';
  return 'tie';
}
function winnerUsers(): Verdict {
  const ua = parseUserCount(exA.users);
  const ub = parseUserCount(exB.users);
  if (ua > ub) return 'a';
  if (ub > ua) return 'b';
  return 'tie';
}
function winnerLicences(): Verdict {
  const la = (exA.licences ?? []).length;
  const lb = (exB.licences ?? []).length;
  if (la > lb) return 'a';
  if (lb > la) return 'b';
  return 'tie';
}
function winnerFeatures(): Verdict {
  const fa = (exA.featureBadges ?? []).length;
  const fb = (exB.featureBadges ?? []).length;
  if (fa > fb) return 'a';
  if (fb > fa) return 'b';
  return 'tie';
}
function winnerCountries(): Verdict {
  const ca = exA.countries.includes('global') ? 999 : exA.countries.length;
  const cb = exB.countries.includes('global') ? 999 : exB.countries.length;
  if (ca > cb) return 'a';
  if (cb > ca) return 'b';
  return 'tie';
}

// Count points for overall winner
const verdicts = [
  winnerBonus(), winnerKyc(), winnerDeposit(), winnerRating(),
  winnerVolume(), winnerEstablished(), winnerUsers(), winnerLicences(),
  winnerFeatures(), winnerCountries(),
];
const pointsA = verdicts.filter(v => v === 'a').length;
const pointsB = verdicts.filter(v => v === 'b').length;
const overallWinner: Verdict = pointsA > pointsB ? 'a' : pointsB > pointsA ? 'b' : 'tie';
const overallEx = overallWinner === 'tie' ? null : overallWinner === 'a' ? exA : exB;

// ── Formatters ───────────────────────────────────────────────────────────────
function fmt(n: number): string { return n.toLocaleString('en-US'); }
function kycLabel(required: boolean) { return required ? 'Required' : 'Not Required'; }
function depositLabel(md: { amount: number; currency: string } | undefined | null) {
  if (!md || md.amount === 0) return 'None';
  return `${fmt(md.amount)} ${md.currency}`;
}
function volumeLabel(vr: { amount: number; currency: string; note?: string } | undefined | null) {
  if (!vr || vr.amount === 0) return 'None';
  return `${fmt(vr.amount)} ${vr.currency}`;
}
function feeLabel(pct: number | undefined): string {
  if (pct === undefined || pct === null) return 'N/A';
  return `${pct}%`;
}
function leverageLabel(lev: number | undefined): string {
  if (!lev) return 'N/A';
  return `Up to ${lev}x`;
}

// ── Beginner recommendation logic ────────────────────────────────────────────
function beginnerExchange(): typeof exA | typeof exB | null {
  // Coinbase > Bybit > others for beginners (known user-friendliness)
  const beginnerRanks: Record<string, number> = {
    coinbase: 10, bybit: 8, binance: 7, kucoin: 6, bitget: 5,
  };
  const ra = beginnerRanks[exA.slug] ?? 3;
  const rb = beginnerRanks[exB.slug] ?? 3;
  if (ra > rb) return exA;
  if (rb > ra) return exB;
  // Fallback: lower KYC friction + higher rating
  if (!exA.kycRequired && exB.kycRequired) return exA;
  if (!exB.kycRequired && exA.kycRequired) return exB;
  return exA.rating >= exB.rating ? exA : exB;
}

// ── Comparison rows config ────────────────────────────────────────────────────
const rows = [
  {
    category: 'Bonus Amount',
    icon: '💰',
    valueA: `Up to ${fmt(exA.bonusAmount)} ${exA.bonusCurrency}`,
    valueB: `Up to ${fmt(exB.bonusAmount)} ${exB.bonusCurrency}`,
    winner: winnerBonus(),
    note: 'Maximum advertised welcome bonus',
  },
  {
    category: 'Overall Rating',
    icon: '⭐',
    valueA: `${exA.rating} / 10`,
    valueB: `${exB.rating} / 10`,
    winner: winnerRating(),
    note: 'Editorial score based on product quality, trust and value',
  },
  {
    category: 'KYC Requirement',
    icon: '🪪',
    valueA: kycLabel(exA.kycRequired),
    valueB: kycLabel(exB.kycRequired),
    winner: winnerKyc(),
    note: '"Not Required" means basic trading available without identity verification',
  },
  {
    category: 'Minimum Deposit',
    icon: '💳',
    valueA: depositLabel(exA.minDeposit),
    valueB: depositLabel(exB.minDeposit),
    winner: winnerDeposit(),
    note: 'Minimum first deposit to activate the welcome bonus',
  },
  {
    category: 'Volume to Unlock',
    icon: '📊',
    valueA: volumeLabel(exA.tradingVolumeRequired),
    valueB: volumeLabel(exB.tradingVolumeRequired),
    winner: winnerVolume(),
    note: 'Trading volume required for upper bonus tiers (lower = easier)',
  },
  {
    category: 'Established',
    icon: '🏛️',
    valueA: exA.founded ? `${exA.founded}` : 'N/A',
    valueB: exB.founded ? `${exB.founded}` : 'N/A',
    winner: winnerEstablished(),
    note: 'Founded year — older exchanges have longer operational track records',
  },
  {
    category: 'Registered Users',
    icon: '👥',
    valueA: exA.users ?? 'N/A',
    valueB: exB.users ?? 'N/A',
    winner: winnerUsers(),
    note: 'Approximate registered user count per exchange disclosures',
  },
  {
    category: 'Regulatory Licences',
    icon: '📋',
    valueA: (exA.licences ?? []).length > 0 ? (exA.licences as string[]).join(', ') : 'Not listed',
    valueB: (exB.licences ?? []).length > 0 ? (exB.licences as string[]).join(', ') : 'Not listed',
    winner: winnerLicences(),
    note: 'Major regulatory approvals held by the exchange',
  },
  {
    category: 'Platform Features',
    icon: '🔧',
    valueA: `${(exA.featureBadges ?? []).length} features`,
    valueB: `${(exB.featureBadges ?? []).length} features`,
    winner: winnerFeatures(),
    note: 'Spot, futures, copy trading, earn, web3, etc.',
  },
  {
    category: 'Country Coverage',
    icon: '🌍',
    valueA: exA.countries.includes('global') ? 'Global' : `${exA.countries.length} listed`,
    valueB: exB.countries.includes('global') ? 'Global' : `${exB.countries.length} listed`,
    winner: winnerCountries(),
    note: '"Global" exchanges operate in most jurisdictions',
  },
];

// ── Breadcrumbs ───────────────────────────────────────────────────────────────
const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Compare', href: '/compare/' },
  { label: pairDef.label, href: canonical },
];

// ── FAQ — generated centrally, editorial overrides applied ────────────────────
const _faqGenerated = generateCompareFAQs({
  exA: exA as unknown as ContentExchange,
  exB: exB as unknown as ContentExchange,
  overallWinner,
  pointsA,
  pointsB,
});
const _faqOverride = (contentOverrides.compare as Record<string, any>)[pairDef.pair];
const faqItems = applyFAQOverrides(_faqGenerated, _faqOverride);

// ── Related Next Reads — both exchange reviews + contextual guides ─────────────
const compareRnrItems = [
  {
    type: 'exchange' as const,
    label: `${exA.name} Bonus ${YEAR} — Full Review`,
    href: `/exchanges/${exA.slug}/`,
    meta: `${exA.bonusAmount.toLocaleString()} ${exA.bonusCurrency}`,
  },
  {
    type: 'exchange' as const,
    label: `${exB.name} Bonus ${YEAR} — Full Review`,
    href: `/exchanges/${exB.slug}/`,
    meta: `${exB.bonusAmount.toLocaleString()} ${exB.bonusCurrency}`,
  },
  ...(exA.p2pAvailable || exB.p2pAvailable ? [{
    type: 'guide' as const,
    label: 'How to Use P2P Trading to Buy Crypto',
    href: '/guides/how-to-use-p2p/',
    meta: '8 min read',
  }] : []),
  ...(((exA.maxFuturesLeverage ?? 0) > 0 || (exB.maxFuturesLeverage ?? 0) > 0) ? [{
    type: 'guide' as const,
    label: 'How to Trade Crypto Futures for Beginners',
    href: '/guides/how-to-trade-futures/',
    meta: '12 min read',
  }] : []),
];

// ── Analytics context ─────────────────────────────────────────────────────────
const analyticsContext: PageContext = {
  pageType: 'compare',
  comparePair: pairDef.pair,
  compareExchangeA: pairDef.a,
  compareExchangeB: pairDef.b,
  compareWinner: overallWinner === 'tie' ? null : overallWinner === 'a' ? exA.slug : exB.slug,
};
---

<Layout title={seoTitle} description={seoDesc} canonical={canonical} schema={schema} analyticsContext={analyticsContext}>
  <div class="container">
    <Breadcrumbs crumbs={crumbs} />

    <!-- ── COMPARE HERO ─────────────────────────────────────────────── -->
    <div class="compare-hero">
      <div class="compare-hero__badge">📊 Side-by-Side Comparison</div>
      <h1 class="compare-hero__title">{exA.name} vs {exB.name}: {YEAR} Comparison</h1>

      <div class="compare-hero__cards">
        <!-- Exchange A -->
        <div class={`hero-ex ${overallWinner === 'a' ? 'hero-ex--winner' : ''}`}>
          {overallWinner === 'a' && <div class="hero-ex__winner-badge">🏆 Overall Winner</div>}
          <ExchangeLogo slug={exA.slug} name={exA.name} size={100} variant="square" class="hero-ex__logo-wrap" lazy={false} />
          <h2 class="hero-ex__name">{exA.name}</h2>
          <div class="hero-ex__score">{exA.rating}<span>/10</span></div>
          <div class="hero-ex__bonus">Up to {fmt(exA.bonusAmount)} {exA.bonusCurrency}</div>
          <div class="hero-ex__tags">
            {!exA.kycRequired && <span class="hero-ex__tag hero-ex__tag--green">No KYC</span>}
            {!exA.depositRequired && <span class="hero-ex__tag hero-ex__tag--blue">No Deposit</span>}
            {exA.kycRequired && <span class="hero-ex__tag hero-ex__tag--grey">KYC Required</span>}
          </div>
          <div class="hero-ex__points">{pointsA} / {verdicts.length} wins</div>
          <a
            href={exA.affiliateUrl}
            class="hero-ex__cta"
            target="_blank"
            rel="noopener noreferrer nofollow sponsored"
            data-track="affiliate-cta"
            data-exchange={exA.slug}
            data-placement="compare-hero"
            data-bonus={String(exA.bonusAmount)}
          >
            {getCtaLabel(exA as any)} →
          </a>
        </div>

        <!-- VS divider -->
        <div class="compare-hero__vs">
          <span class="vs-label">VS</span>
          {overallWinner === 'tie' && <span class="vs-tie">Tied</span>}
        </div>

        <!-- Exchange B -->
        <div class={`hero-ex ${overallWinner === 'b' ? 'hero-ex--winner' : ''}`}>
          {overallWinner === 'b' && <div class="hero-ex__winner-badge">🏆 Overall Winner</div>}
          <ExchangeLogo slug={exB.slug} name={exB.name} size={100} variant="square" class="hero-ex__logo-wrap" lazy={false} />
          <h2 class="hero-ex__name">{exB.name}</h2>
          <div class="hero-ex__score">{exB.rating}<span>/10</span></div>
          <div class="hero-ex__bonus">Up to {fmt(exB.bonusAmount)} {exB.bonusCurrency}</div>
          <div class="hero-ex__tags">
            {!exB.kycRequired && <span class="hero-ex__tag hero-ex__tag--green">No KYC</span>}
            {!exB.depositRequired && <span class="hero-ex__tag hero-ex__tag--blue">No Deposit</span>}
            {exB.kycRequired && <span class="hero-ex__tag hero-ex__tag--grey">KYC Required</span>}
          </div>
          <div class="hero-ex__points">{pointsB} / {verdicts.length} wins</div>
          <a
            href={exB.affiliateUrl}
            class="hero-ex__cta"
            target="_blank"
            rel="noopener noreferrer nofollow sponsored"
            data-track="affiliate-cta"
            data-exchange={exB.slug}
            data-placement="compare-hero"
            data-bonus={String(exB.bonusAmount)}
          >
            {getCtaLabel(exB as any)} →
          </a>
        </div>
      </div>

      {overallWinner !== 'tie' && overallEx && (
        <div class="compare-hero__verdict">
          <strong>{overallEx.name}</strong> wins {overallWinner === 'a' ? pointsA : pointsB} of {verdicts.length} categories in our editorial comparison.
          Scroll down for the full breakdown.
        </div>
      )}
    </div>

    <AffiliateDisclosure />

    <AuthorCard
      compact
      verb="Reviewed by"
      name="Alexandr Shadurskyi"
      title="Crypto Exchange Analyst & Editor-in-Chief"
      initials="AS"
      photo="/avatars/alexandr-shadurskyi.webp"
      reviewedAt={new Date().toISOString().slice(0, 10)}
      profileUrl="/reviewers/alexandr-shadurskyi/"
    />

    <!-- ── AI ANSWER BOX ─────────────────────────────────────────────── -->
    <AnswerBox
      question={`${exA.name} vs ${exB.name}: which is better?`}
      answer={overallWinner === 'tie'
        ? `${exA.name} and ${exB.name} are closely matched. ${exA.name} offers up to ${fmt(exA.bonusAmount)} ${exA.bonusCurrency}${!exA.kycRequired ? ' with no KYC' : ''}; ${exB.name} offers up to ${fmt(exB.bonusAmount)} ${exB.bonusCurrency}${!exB.kycRequired ? ' with no KYC' : ''}. Choose based on your preferred trading features.`
        : `${overallEx!.name} wins this comparison with ${overallWinner === 'a' ? pointsA : pointsB} of ${verdicts.length} category advantages. ${overallEx!.name} offers up to ${fmt(overallEx!.bonusAmount)} ${overallEx!.bonusCurrency}${!(overallEx as any).kycRequired ? ', no KYC required' : ''}. Score: ${exA.name} ${pointsA}–${pointsB} ${exB.name}.`}
      updatedDate={`May ${YEAR}`}
      compact={true}
    />

    <!-- ── AI-READABLE SUMMARY TABLE ─────────────────────────────────── -->
    <ComparisonSummaryBlock
      labelA={exA.name}
      labelB={exB.name}
      heading={`${exA.name} vs ${exB.name} — Quick Comparison`}
      rows={rows.slice(0, 5).map(r => ({
        attribute: r.category,
        a: r.valueA,
        b: r.valueB,
        winner: r.winner,
      }))}
      verdict={overallWinner === 'tie'
        ? `${exA.name} and ${exB.name} are tied overall — choose based on your preferred trading style.`
        : `${overallEx!.name} has the edge in this comparison (${overallWinner === 'a' ? pointsA : pointsB}/${verdicts.length} categories).`}
    />

    <!-- ── COMPARISON TABLE ───────────────────────────────────────────── -->
    <section class="compare-section">
      <h2 class="section-heading">Full Comparison Table</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="ct-category">Category</th>
              <th class={`ct-val ${overallWinner === 'a' ? 'ct-winner-col' : ''}`}>{exA.name}</th>
              <th class={`ct-val ${overallWinner === 'b' ? 'ct-winner-col' : ''}`}>{exB.name}</th>
            </tr>
          </thead>
          <tbody>
            {rows.map(row => (
              <tr>
                <td class="ct-category">
                  <span class="ct-icon">{row.icon}</span>
                  <div>
                    <span class="ct-label">{row.category}</span>
                    <span class="ct-note">{row.note}</span>
                  </div>
                </td>
                <td class={`ct-val ${row.winner === 'a' ? 'ct-win' : row.winner === 'tie' ? 'ct-tie' : 'ct-lose'}`}>
                  {row.winner === 'a' && <span class="ct-badge ct-badge--win">✓ Better</span>}
                  {row.winner === 'tie' && <span class="ct-badge ct-badge--tie">= Tied</span>}
                  <span class="ct-data">{row.valueA}</span>
                </td>
                <td class={`ct-val ${row.winner === 'b' ? 'ct-win' : row.winner === 'tie' ? 'ct-tie' : 'ct-lose'}`}>
                  {row.winner === 'b' && <span class="ct-badge ct-badge--win">✓ Better</span>}
                  {row.winner === 'tie' && <span class="ct-badge ct-badge--tie">= Tied</span>}
                  <span class="ct-data">{row.valueB}</span>
                </td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="ct-total-row">
              <td class="ct-category"><strong>Category Wins</strong></td>
              <td class={`ct-val ct-total ${overallWinner === 'a' ? 'ct-total--winner' : ''}`}>
                <strong>{pointsA}</strong>
              </td>
              <td class={`ct-val ct-total ${overallWinner === 'b' ? 'ct-total--winner' : ''}`}>
                <strong>{pointsB}</strong>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </section>

    <!-- ── CHOOSE X IF ────────────────────────────────────────────────── -->
    <section class="compare-section">
      <h2 class="section-heading">Which Exchange Should You Choose?</h2>
      <div class="choose-grid">
        <div class="choose-card">
          <div class="choose-card__header">
            <ExchangeLogo slug={exA.slug} name={exA.name} size={48} variant="square" />
            <h3>Choose {exA.name} if…</h3>
          </div>
          <ul class="choose-list">
            {(exA.bestFor ?? []).map((item: string) => (
              <li><span class="choose-check">✓</span> {item}</li>
            ))}
            {exA.depositRequired && !exB.depositRequired && (
              <li><span class="choose-check">✓</span> You can make an initial deposit to unlock the larger bonus</li>
            )}
            {!exA.kycRequired && exB.kycRequired && (
              <li><span class="choose-check">✓</span> You want to start trading without KYC verification</li>
            )}
          </ul>
          <a href={`/exchanges/${exA.slug}/`} class="choose-card__link">
            Full {exA.name} review →
          </a>
        </div>

        <div class="choose-card">
          <div class="choose-card__header">
            <ExchangeLogo slug={exB.slug} name={exB.name} size={48} variant="square" />
            <h3>Choose {exB.name} if…</h3>
          </div>
          <ul class="choose-list">
            {(exB.bestFor ?? []).map((item: string) => (
              <li><span class="choose-check">✓</span> {item}</li>
            ))}
            {exB.depositRequired && !exA.depositRequired && (
              <li><span class="choose-check">✓</span> You can make an initial deposit to unlock the larger bonus</li>
            )}
            {!exB.kycRequired && exA.kycRequired && (
              <li><span class="choose-check">✓</span> You want to start trading without KYC verification</li>
            )}
          </ul>
          <a href={`/exchanges/${exB.slug}/`} class="choose-card__link">
            Full {exB.name} review →
          </a>
        </div>
      </div>
    </section>

    <!-- ── BONUS BREAKDOWN ────────────────────────────────────────────── -->
    <section class="compare-section">
      <h2 class="section-heading">Bonus Breakdown</h2>
      <div class="bonus-grid">
        {[exA, exB].map((ex: any) => (
          <div class="bonus-card">
            <div class="bonus-card__head">
              <ExchangeLogo slug={ex.slug} name={ex.name} size={48} variant="square" />
              <h3>{ex.name}</h3>
              <span class="bonus-card__headline">{ex.bonusTitle}</span>
            </div>
            {(ex.bonusTiers ?? []).length > 0 && (
              <ul class="bonus-tier-list">
                {(ex.bonusTiers as any[]).map((tier: any) => (
                  <li class="bonus-tier">
                    <div class="bonus-tier__amount">{fmt(tier.amount)} {tier.currency}</div>
                    <div class="bonus-tier__info">
                      <span class="bonus-tier__title">{tier.title}</span>
                      <span class="bonus-tier__cond">{tier.condition}</span>
                    </div>
                  </li>
                ))}
              </ul>
            )}
            <div class="bonus-card__cta">
              <a href={ex.affiliateUrl} target="_blank" rel="noopener noreferrer nofollow" class="bonus-cta-btn">
                Claim {ex.name} Bonus
              </a>
              <a href={`/exchanges/${ex.slug}/`} class="bonus-review-link">Full review →</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── PROS & CONS ────────────────────────────────────────────────── -->
    <section class="compare-section">
      <h2 class="section-heading">Pros &amp; Cons</h2>
      <div class="proscons-grid">
        {[exA, exB].map((ex: any) => (
          <div class="proscons-card">
            <div class="proscons-card__head">
              <ExchangeLogo slug={ex.slug} name={ex.name} size={44} variant="square" />
              <h3>{ex.name}</h3>
            </div>
