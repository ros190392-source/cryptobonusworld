---
/**
 * PromoCodeBox — standard promo code display used on all exchange pages.
 * Shows label + large code badge + copy button.
 * Copy JS is self-contained and works with multiple instances on one page.
 */
export interface Props {
  code: string;
  label?: string;
}

const { code, label = 'Referral / Promo Code' } = Astro.props;
---

<div class="pcb" data-promo-box>
  <div class="pcb-label">{label}</div>
  <div class="pcb-row">
    <span class="pcb-code" data-promo-code>{code}</span>
    <button class="pcb-btn" data-copy-btn aria-label={`Copy code ${code}`}>
      <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M3 11H2.5A1.5 1.5 0 0 1 1 9.5V2.5A1.5 1.5 0 0 1 2.5 1h7A1.5 1.5 0 0 1 11 2.5V3" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <span class="pcb-btn-label">Copy</span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-promo-box]').forEach(box => {
    const codeEl = box.querySelector<HTMLElement>('[data-promo-code]');
    const btn    = box.querySelector<HTMLButtonElement>('[data-copy-btn]');
    const label  = btn?.querySelector<HTMLElement>('.pcb-btn-label');
    if (!btn || !codeEl || !label) return;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(codeEl.textContent?.trim() ?? '');
      } catch {
        const sel = window.getSelection();
        const range = document.createRange();
        range.selectNodeContents(codeEl);
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
      label.textContent = 'Copied!';
      btn.classList.add('pcb-copied');
      setTimeout(() => {
        label.textContent = 'Copy';
        btn.classList.remove('pcb-copied');
      }, 2000);
    });
  });
</script>

<style>
  .pcb { /* wrapper — no background, fits into parent card */ }

  .pcb-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: #9CA3AF; margin-bottom: 8px;
  }

  .pcb-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    margin-bottom: 0;
  }

  /* Code badge — the canonical style for the whole site */
  .pcb-code {
    font-size: 28px; font-weight: 900;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
    color: #C2410C;
    background: #FFF7ED;
    border: 2px solid #FED7AA;
    padding: 8px 20px; border-radius: 10px;
    letter-spacing: .06em;
    user-select: all; cursor: text;
    line-height: 1.2;
  }
  @media (min-width: 480px) { .pcb-code { font-size: 32px; } }
  @media (min-width: 640px) { .pcb-code { font-size: 36px; } }

  /* Copy button */
  .pcb-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px; border-radius: 8px;
    background: #111827; color: #fff;
    font-size: 13px; font-weight: 700; font-family: inherit;
    border: none; cursor: pointer;
    transition: background .15s, transform .1s;
    white-space: nowrap; flex-shrink: 0;
  }
  .pcb-btn:hover  { background: #374151; }
  .pcb-btn:active { transform: scale(.97); }
  .pcb-btn.pcb-copied { background: #16A34A; }
</style>
