          <li><a href="/categories/signup-bonuses/">Signup Bonuses</a></li>
          <li><a href="/categories/no-deposit-bonuses/">No Deposit Bonuses</a></li>
          <li><a href="/categories/deposit-bonuses/">Deposit Bonuses</a></li>
          <li><a href="/categories/futures-bonuses/">Futures Bonuses</a></li>
          <li><a href="/categories/welcome-bonuses/">Welcome Bonuses</a></li>
          <li><a href="/categories/no-kyc-bonuses/">No KYC Bonuses</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>Top Exchanges</h4>
        <ul>
          <li><a href="/exchanges/bybit/">Bybit Bonus</a></li>
          <li><a href="/exchanges/mexc/">MEXC Bonus</a></li>
          <li><a href="/exchanges/okx/">OKX Bonus</a></li>
          <li><a href="/exchanges/bitget/">Bitget Bonus</a></li>
          <li><a href="/exchanges/bingx/">BingX Bonus</a></li>
          <li><a href="/exchanges/kucoin/">KuCoin Bonus</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>Bonuses by Country</h4>
        <ul>
          <li><a href="/countries/global/">Global</a></li>
          <li><a href="/countries/turkey/">Turkey</a></li>
          <li><a href="/countries/india/">India</a></li>
          <li><a href="/countries/indonesia/">Indonesia</a></li>
          <li><a href="/countries/nigeria/">Nigeria</a></li>
          <li><a href="/countries/brazil/">Brazil</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>About</h4>
        <ul>
          <li><a href="/methodology/">Our Methodology</a></li>
          <li><a href="/about/">About Us</a></li>
          <li><a href="/affiliate-disclosure/">Affiliate Disclosure</a></li>
