---
import CleanLayout from '../../layouts/CleanLayout.astro';
import { getOffer } from '../../data/offers';

const offer = getOffer('bybit')!;

// Static exchange data — volatile fields come from offer
const exchange = {
  name:             'Bybit',
  affiliateUrl:     '/go/bybit',
  bonusMax:         30000,
  currency:         'USDT',
  minDeposit:       100,
  founded:          2018,
  users:            '30M+',
  headquarters:     'Dubai, UAE',
  licence:          'Dubai VARA',
  wordmarkImg:      '/logos/bybit-wordmark-official.png',
  articleImg:       '/media/exchanges/bybit/article/bybit-article-1200x675.png',
  logoImg:          '/logos/bybit.png',
};

const alternatives = [
  { name: 'MEXC',   logo: '/logos/mexc.png',   bonus: '8,000 USDT',  code: 'mexc-CryptoBonus',   url: 'https://www.mexc.com/acquisition/custom-sign-up?shareCode=mexc-CryptoBonus',  tag: 'No KYC option'  },
  { name: 'Bitget', logo: '/logos/bitget.png',  bonus: '6,200 USDT',  code: 'CryptoBonW',          url: 'https://partner.bitget.com/bg/CryptoBonW',                                  tag: 'Copy trading'   },
  { name: 'BingX',  logo: '/logos/bingx.png',   bonus: '5,125 USDT',  code: 'CRYPTOBONUSWORLD',    url: 'https://bingxdao.com/partner/CRYPTOBONUSWORLD/',                             tag: 'Social trading' },
];

const brandHeroTokens = {
  'bh-bgFrom':     '#0d1117',
  'bh-bgTo':       '#1a1f2e',
  'bh-text':       '#ffffff',
  'bh-text2':      'rgba(255,255,255,0.65)',
  'bh-accent':     '#f7a600',
  'bh-codeBg':     'rgba(247,166,0,0.10)',
  'bh-codeBorder': 'rgba(247,166,0,0.40)',
  'bh-note':       'rgba(255,255,255,0.38)',
};
const bhStyle = Object.entries(brandHeroTokens).map(([k,v]) => `--${k}:${v}`).join(';');
---

<CleanLayout
  title={`Bybit Referral Code 2026: ${offer.promoCode} — Up to 30,000 USDT Bonus`}
  description={`Bybit promo code ${offer.promoCode} — up to 30,000 USDT welcome package + fee discount. Verified ${offer.lastChecked}. Enter code at registration before your first deposit.`}
  canonical="https://cryptobonusworld.com/bybit/"
  ogImage="/media/exchanges/bybit/share/bybit-og-1200x630.png"
  ogTitle={`Bybit Referral Code 2026: ${offer.promoCode} — Up to 30,000 USDT`}
  ogDescription={`Use Bybit promo code ${offer.promoCode} for up to 30,000 USDT welcome bonus + fee discount. Verified ${offer.lastChecked} by CryptoBonusWorld.`}
>

<style>
  /* ── Proto design tokens (replaces ProtoLayout :root vars) ─ */
  :root {
    --proto-bg:             #F7F8F4;
    --proto-surface:        #ffffff;
    --proto-surface-2:      #F3F4F6;
    --proto-border:         #E5E7EB;
    --proto-border-strong:  #D1D5DB;
    --proto-text:           #111827;
    --proto-text-2:         #4B5563;
    --proto-text-3:         #9CA3AF;
    --proto-accent:         #f7a600;
    --proto-accent-dark:    #c47f00;
    --proto-cta:            #16A34A;
    --proto-cta-hover:      #15803D;
    --proto-verified:       #16A34A;
    --proto-verified-light: #f0fdf4;
    --proto-warning:        #b45309;
    --proto-warning-light:  #fffbeb;
    --proto-danger:         #dc2626;
    --proto-radius:         10px;
    --proto-radius-lg:      16px;
    --proto-shadow:         0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --proto-shadow-md:      0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  }

  /* ── Narrow content wrapper (760px, replaces proto .container) ── */
  .bw-wrap { max-width: 760px; margin: 0 auto; padding: 0 20px; }

  /* ── Section base ─────────────────────────────────────────── */
  .bybit-section { padding: 40px 0; background: var(--proto-bg); }
  .bybit-section + .bybit-section { border-top: 1px solid var(--proto-border); }

  /* ── Title bar ────────────────────────────────────────────── */
  .title-bar {
    background: #ffffff;
    background-image: linear-gradient(#ffffff 0 0);
    border-bottom: 1px solid var(--proto-border);
    text-align: center; padding: 9px 20px;
    color-scheme: light; forced-color-adjust: none;
  }
  .title-bar h1 {
    font-size: 20px; font-weight: 700; color: var(--proto-text);
    margin: 0; line-height: 1.25;
  }
  @media (max-width: 479px) {
    .title-bar { padding: 9px 20px; }
    .title-bar h1 { font-size: 18px; }
  }

  /* ── Brand Hero ───────────────────────────────────────────── */
  .brand-hero {
    background: linear-gradient(160deg, var(--bh-bgFrom) 0%, var(--bh-bgTo) 100%);
    padding: 35px 0 54px;
    color: var(--bh-text);
  }
  @media (min-width: 640px) {
    .brand-hero { padding: 42px 0 46px; display: flex; flex-direction: column; justify-content: center; }
  }
  .bh-inner { width: 100%; max-width: 540px; margin: 0 auto; padding: 0 20px; text-align: center; box-sizing: border-box; }

  .bh-wordmark { display: block; width: 165px; height: auto; margin: 0 auto 10px; filter: none; opacity: 1; }
  @media (min-width: 640px) { .bh-wordmark { width: 210px; } }
  @media (max-width: 359px) { .bh-wordmark { width: 140px; } }

  .bh-promo-label {
    display: block;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 22px; font-weight: 700; text-transform: uppercase;
    font-stretch: condensed; letter-spacing: 0.09em; color: var(--bh-text);
    line-height: 1.1; margin-top: 16px; margin-bottom: 24px;
  }
  @media (min-width: 640px) { .bh-promo-label { font-size: 18px; letter-spacing: 0.10em; margin-top: 18px; margin-bottom: 26px; } }

  .bh-promo-row {
    width: 100%; max-width: 298px;
    margin-left: auto; margin-right: auto;
    display: flex; align-items: stretch;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    border: 1px solid #D1D5DB; border-radius: 8px; overflow: hidden;
    height: 56px; margin-bottom: 14px;
    transition: border-color .18s, background .18s;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-promo-row.copy-success { border-color: #22c55e !important; background: #dcfce7 !important; }

  .bh-promo-code {
    flex: 1; display: flex; align-items: center; padding: 0 14px;
    font-family: "Arial Narrow", "Roboto Condensed", "Inter Tight", Inter, system-ui, sans-serif;
    font-size: 20px; font-weight: 800; letter-spacing: 0.01em; font-stretch: condensed;
    text-transform: uppercase; color: #111827; -webkit-text-fill-color: #111827;
    min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
    transition: color .18s;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    color-scheme: light; forced-color-adjust: none;
  }
  @media (min-width: 640px) { .bh-promo-code { font-size: 22px; letter-spacing: 0.015em; } }
  .bh-promo-code.copy-success { color: #166534 !important; -webkit-text-fill-color: #166534 !important; }

  .bh-copy-btn {
    flex-shrink: 0; width: 68px;
    display: flex; align-items: center; justify-content: center;
    border: none; border-left: 1px solid #e5e7eb;
    font-size: 12px; font-weight: 700; color: #16a34a; -webkit-text-fill-color: #16a34a;
    background: #ffffff; background-image: linear-gradient(#ffffff 0 0);
    cursor: pointer; transition: background .15s, color .15s, border-color .15s;
    white-space: nowrap; letter-spacing: .03em;
    color-scheme: light; forced-color-adjust: none;
  }
  .bh-copy-btn:hover { background: #f0fdf4; }
  .bh-copy-btn.copy-success { background: #dcfce7 !important; border-color: #22c55e !important; color: #166534 !important; }

  .bh-cta-btn {
    display: flex; align-items: center; justify-content: center;
    width: 100%; max-width: 320px; margin-left: auto; margin-right: auto;
    background: #55C72F; color: #fff;
    font-size: 24px; font-weight: 700; border-radius: 6px;
    height: 68px; margin-bottom: 12px;
    transition: background .15s, transform .1s; letter-spacing: 0;
    text-decoration: none;
  }
  @media (min-width: 640px) { .bh-cta-btn { font-size: 28px; } }
  .bh-cta-btn:hover { background: #46b024; transform: translateY(-1px); }

  .bh-source {
    font-size: 14px; color: var(--bh-note); line-height: 1.65;
    margin: 8px 0 0; text-align: center;
  }
  @media (min-width: 640px) { .bh-source { font-size: 15px; } }
  .bh-source a { color: var(--bh-note); text-decoration: underline; text-underline-offset: 2px; text-decoration-color: rgba(255,255,255,0.35); }
  .bh-source a:hover { text-decoration-color: var(--bh-note); }

  /* ── Compact facts table ──────────────────────────────────── */
  .compact-facts {
    background: #ffffff !important;
    padding: 20px 16px 6px; color-scheme: light; forced-color-adjust: none;
  }
  .cf-inner {
    max-width: 720px; margin: 0 auto; padding: 0;
    background: #F3F4F6; border: 1px solid #D1D5DB;
    border-radius: 8px; overflow: hidden;
  }
  .cf-table { width: 100%; border-collapse: collapse; font-size: 14px; background: #F3F4F6; table-layout: fixed; }
  .cf-table tr { border-bottom: 1px solid #E5E7EB; }
  .cf-table tr:last-child { border-bottom: none; }
  .cf-table td { padding: 11px 16px; vertical-align: middle; background: #F3F4F6; color: #111827; word-wrap: break-word; overflow-wrap: break-word; }
  .cf-table td:first-child { color: #374151 !important; font-size: 14px; font-weight: 500; width: 50%; }
  .cf-table td:last-child { font-weight: 600; color: #111827 !important; }
  @media (max-width: 479px) {
    .cf-table td { padding: 10px 12px; font-size: 13px; }
    .cf-table td:first-child { font-size: 13px; }
  }
  .cf-code { font-family: 'Courier New', monospace; letter-spacing: .04em; color: #c47f00 !important; -webkit-text-fill-color: #c47f00 !important; }
  .cf-good { color: #16a34a !important; -webkit-text-fill-color: #16a34a !important; }
  .cf-warn { color: #b45309 !important; -webkit-text-fill-color: #b45309 !important; font-weight: 500 !important; }

  /* ── SEO intro block ─────────────────────────────────────── */
  .seo-intro-block {
    background: #ffffff; border-bottom: 1px solid #E5E7EB;
    padding: 8px 20px 20px;
  }
  .seo-intro-inner { max-width: 720px; margin: 0 auto; }
  .seo-phrase {
    font-size: 14px; font-weight: 400; color: #9CA3AF;
    margin: 0; padding-bottom: 10px; font-style: italic;
    border-bottom: 1px solid #E5E7EB;
  }
  .seo-intro-text {
    font-size: 15px; color: #4B5563; line-height: 1.65;
    margin: 12px 0 0;
  }
  @media (max-width: 479px) {
    .seo-phrase { font-size: 13px; }
    .seo-intro-text { font-size: 14px; }
  }

  /* ── Post-table CTA ───────────────────────────────────────── */
  .post-table-cta {
    background: var(--proto-surface-2); border-bottom: 1px solid var(--proto-border);
    padding: 24px 0;
  }
  @media (min-width: 640px) { .post-table-cta { padding-top: 32px; } }
  .ptc-inner { max-width: 540px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .ptc-intro { font-size: 13.5px; color: var(--proto-text-2); line-height: 1.6; margin-bottom: 14px; }
  .ptc-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: #16a34a; color: #fff;
    font-size: 15px; font-weight: 700; border-radius: 10px;
    padding: 0 28px; height: 48px; width: 100%; max-width: 310px;
    transition: background .15s, transform .1s; letter-spacing: .01em;
    text-decoration: none;
  }
  .ptc-btn:hover { background: #15803d; transform: translateY(-1px); }

  /* ── Registration proof ───────────────────────────────────── */
  .reg-proof { background: var(--proto-surface-2); border-bottom: 1px solid var(--proto-border); padding: 28px 0; }
  .reg-proof-inner { max-width: 760px; margin: 0 auto; padding: 0 20px; }
  .reg-proof-label { font-size: 11px; font-weight: 700; color: var(--proto-verified); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 14px; display: flex; align-items: center; gap: 5px; }
  .reg-proof-grid { display: flex; flex-direction: column; gap: 14px; }
  @media (min-width: 640px) {
    .reg-proof-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .reg-proof-main { grid-column: 1 / -1; }
    .reg-proof-sub .reg-proof-img { height: 180px; object-fit: cover; object-position: center top; }
  }
  .reg-proof-item { background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius); overflow: hidden; }
  .reg-proof-img { width: 100%; display: block; }
  .reg-proof-body { padding: 10px 12px; }
  .reg-proof-item-title { font-size: 12px; font-weight: 600; color: var(--proto-text); margin-bottom: 4px; display: flex; align-items: center; gap: 6px; }
  .reg-proof-num { font-size: 11px; font-weight: 700; color: var(--proto-text-3); background: var(--proto-surface-2); border: 1px solid var(--proto-border); border-radius: 4px; padding: 1px 5px; flex-shrink: 0; }
  .reg-proof-cap { font-size: 12px; color: var(--proto-text-3); line-height: 1.4; }

  /* ── Bybit proof badge ────────────────────────────────────── */
  .bybit-proof-badge {
    display: inline-flex; align-items: center; gap: 10px;
    background: #111827; border: 1px solid #2d3748;
    border-radius: 8px; padding: 9px 16px; margin-bottom: 16px;
  }
  .badge-brand { font-size: 13px; font-weight: 900; letter-spacing: .05em; color: #fff; font-family: 'Arial Black', Arial, sans-serif; }
  .badge-brand-i { color: #f7a600; }
  .badge-pipe { color: #374151; font-size: 15px; font-weight: 300; }
  .badge-label { font-size: 11px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: #d1d5db; }
  .badge-dot { width: 6px; height: 6px; background: #22c55e; border-radius: 50%; flex-shrink: 0; }
  .badge-meta { font-size: 11px; color: #6b7280; }

  /* ── Shared section heading ───────────────────────────────── */
  h2.section-title { font-size: 20px; font-weight: 700; color: var(--proto-text); margin-bottom: 16px; line-height: 1.3; }

  /* ── Card ─────────────────────────────────────────────────── */
  .card { background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius); padding: 20px; box-shadow: var(--proto-shadow); }

  /* ── Steps ────────────────────────────────────────────────── */
  .steps { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .step { display: flex; gap: 14px; align-items: flex-start; }
  .step-num { flex-shrink: 0; width: 28px; height: 28px; background: var(--proto-accent); color: #1a1a18; font-size: 13px; font-weight: 700; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
  .step-text { font-size: 14px; line-height: 1.55; color: var(--proto-text); }
  .step-text strong { font-weight: 600; }

  /* ── Article banner ───────────────────────────────────────── */
  .article-banner {
    display: block; border-radius: var(--proto-radius); overflow: hidden;
    margin: 28px 0 0; box-shadow: var(--proto-shadow-md);
    transition: transform .15s, box-shadow .15s;
  }
  .article-banner:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
  .article-banner-img { width: 100%; height: auto; display: block; }
  .article-banner-cap { font-size: 12px; color: var(--proto-text-3); text-align: center; margin: 8px 0 28px; line-height: 1.4; }
  .article-banner-cap strong { color: var(--proto-text-2); }

  /* ── Conditions table ─────────────────────────────────────── */
  .conditions-wrap { overflow-x: auto; }
  .conditions-table { width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 440px; }
  .conditions-table thead { background: var(--proto-surface-2); }
  .conditions-table th { padding: 9px 12px; text-align: left; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; color: var(--proto-text-3); border-bottom: 1px solid var(--proto-border); }
  .conditions-table td { padding: 10px 12px; border-bottom: 1px solid var(--proto-border); color: var(--proto-text); line-height: 1.4; background: var(--proto-surface); }
  .conditions-table tr:last-child td { border-bottom: none; }
  .cond-required { color: var(--proto-warning); font-weight: 500; }
  .cond-ok { color: var(--proto-verified); font-weight: 500; }
  .cond-note { font-size: 12px; color: var(--proto-text-3); margin-top: 3px; }
  .fact-warn { color: var(--proto-warning); }

  /* ── Realistic value ──────────────────────────────────────── */
  .value-grid { display: grid; gap: 12px; }
  @media (min-width: 480px) { .value-grid { grid-template-columns: 1fr 1fr; } }
  .value-card { border: 1px solid var(--proto-border); border-radius: var(--proto-radius); padding: 16px; background: var(--proto-surface); }
  .value-card.highlight { border-color: var(--proto-verified); background: var(--proto-verified-light); }
  .value-card-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--proto-text-3); margin-bottom: 6px; }
  .value-card-amount { font-size: 22px; font-weight: 700; color: var(--proto-text); margin-bottom: 4px; }
  .value-card-amount.green { color: var(--proto-verified); }
  .value-card-desc { font-size: 13px; color: var(--proto-text-2); line-height: 1.45; }

  /* ── Availability ─────────────────────────────────────────── */
  .availability-box { background: var(--proto-warning-light); border: 1px solid #fcd34d; border-radius: var(--proto-radius); padding: 16px 20px; font-size: 14px; color: var(--proto-text); line-height: 1.55; }
  .availability-box strong { display: block; margin-bottom: 6px; color: var(--proto-warning); font-size: 13px; text-transform: uppercase; letter-spacing: .04em; }
  .excluded-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .excluded-chip { background: #fff; border: 1px solid #fcd34d; border-radius: 6px; padding: 3px 10px; font-size: 12px; font-weight: 500; color: var(--proto-warning); }

  /* ── Verdict ──────────────────────────────────────────────── */
  .verdict-grid { display: grid; gap: 12px; }
  @media (min-width: 500px) { .verdict-grid { grid-template-columns: 1fr 1fr; } }
  .verdict-card { border-radius: var(--proto-radius); padding: 16px 18px; font-size: 14px; line-height: 1.55; }
  .verdict-card.worth-it { background: var(--proto-verified-light); border: 1px solid #86efac; }
  .verdict-card.not-ideal { background: #fff7f7; border: 1px solid #fca5a5; }
  .verdict-card-head { font-weight: 600; font-size: 13px; margin-bottom: 8px; }
  .verdict-card.worth-it .verdict-card-head { color: var(--proto-verified); }
  .verdict-card.not-ideal .verdict-card-head { color: var(--proto-danger); }
  .verdict-card ul { padding-left: 16px; }
  .verdict-card li { margin-bottom: 5px; }

  /* ── Mini review ──────────────────────────────────────────── */
  .mini-review { font-size: 14px; line-height: 1.7; color: var(--proto-text); }
  .mini-review p { margin-bottom: 12px; }
  .mini-review p:last-child { margin-bottom: 0; }

  /* ── Alternatives ─────────────────────────────────────────── */
  .alt-grid { display: flex; flex-direction: column; gap: 10px; }
  .alt-card { display: flex; align-items: center; gap: 14px; background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius); padding: 14px 16px; transition: border-color .15s; }
  .alt-card:hover { border-color: var(--proto-border-strong); }
  .alt-logo { width: 36px; height: 36px; border-radius: 8px; object-fit: contain; border: 1px solid var(--proto-border); padding: 4px; flex-shrink: 0; background: #fff; }
  .alt-info { flex: 1; min-width: 0; }
  .alt-name { font-weight: 600; font-size: 14px; color: var(--proto-text); }
  .alt-bonus { font-size: 13px; color: var(--proto-text-2); }
  .alt-tag { font-size: 11px; color: var(--proto-text-3); margin-top: 2px; }
  .alt-btn { flex-shrink: 0; background: var(--proto-surface-2); border: 1px solid var(--proto-border); border-radius: 8px; padding: 7px 14px; font-size: 13px; font-weight: 500; color: var(--proto-text); transition: background .15s; }
  .alt-btn:hover { background: var(--proto-border); }

  /* ── FAQ ──────────────────────────────────────────────────── */
  details.faq-item { border: 1px solid var(--proto-border); border-radius: var(--proto-radius); margin-bottom: 8px; background: var(--proto-surface); overflow: hidden; }
  details.faq-item[open] { border-color: var(--proto-border-strong); }
  summary.faq-q { padding: 14px 16px; font-size: 14px; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: var(--proto-text); user-select: none; }
  summary.faq-q::-webkit-details-marker { display: none; }
  summary.faq-q::after { content: '+'; font-size: 18px; font-weight: 400; color: var(--proto-text-3); flex-shrink: 0; margin-left: 12px; }
  details[open] summary.faq-q::after { content: '−'; }
  .faq-a { padding: 12px 16px 14px; font-size: 13.5px; color: var(--proto-text-2); line-height: 1.6; border-top: 1px solid var(--proto-border); }

  /* ── Final CTA ────────────────────────────────────────────── */
  .final-cta { background: var(--proto-surface); border: 1px solid var(--proto-border); border-radius: var(--proto-radius-lg); padding: 28px 24px; text-align: center; box-shadow: var(--proto-shadow-md); }
  .final-cta-logo { width: 44px; height: 44px; border-radius: 10px; border: 1px solid var(--proto-border); padding: 5px; margin: 0 auto 12px; object-fit: contain; background: #fff; }
  .final-cta-amount { font-size: 28px; font-weight: 700; color: var(--proto-text); margin-bottom: 4px; }
  .final-cta-typical { font-size: 13px; color: var(--proto-text-3); margin-bottom: 20px; }
  .final-cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--proto-cta); color: #fff;
    font-size: 16px; font-weight: 700; border-radius: 12px;
    padding: 0 24px; height: 46px; width: 100%; max-width: 260px; margin: 0 auto;
    transition: background .15s, transform .1s; letter-spacing: .01em; text-align: center;
    text-decoration: none;
  }
  .final-cta-btn:hover { background: var(--proto-cta-hover); transform: translateY(-1px); }
  .final-cta-disclaimer { font-size: 12px; color: var(--proto-text-3); margin-top: 14px; line-height: 1.5; }

  /* ── Disclosure ───────────────────────────────────────────── */
  .disclosure { font-size: 12px; color: var(--proto-text-3); background: var(--proto-surface-2); border-radius: var(--proto-radius); padding: 12px 14px; line-height: 1.55; margin-top: 20px; }

  /* ── Samsung / forced-dark mode override ─────────────────────
     Samsung One UI dark mode can override color-scheme:light.
     Re-assert explicit colours for elements that must stay light.
     brand-hero is intentionally dark — excluded.
  ──────────────────────────────────────────────────────────── */
  @media (prefers-color-scheme: dark) {
    .title-bar {
      background: #ffffff !important; border-bottom-color: #E5E7EB !important;
      color-scheme: light !important; forced-color-adjust: none;
    }
    .title-bar h1 { color: #111827 !important; -webkit-text-fill-color: #111827 !important; }
    .bh-promo-row {
      background: #ffffff !important; border-color: #D1D5DB !important;
      color-scheme: light !important; forced-color-adjust: none;
    }
    .bh-promo-code {
      background: #ffffff !important;
      color: #111827 !important; -webkit-text-fill-color: #111827 !important;
      forced-color-adjust: none;
    }
    .bh-copy-btn {
      background: #ffffff !important;
      color: #16a34a !important; -webkit-text-fill-color: #16a34a !important;
      border-left-color: #E5E7EB !important; forced-color-adjust: none;
    }
    .bh-copy-btn:hover { background: #f0fdf4 !important; }
    .bh-promo-row.copy-success { background: #dcfce7 !important; border-color: #22c55e !important; }
    .bh-promo-row.copy-success .bh-promo-code { background: #dcfce7 !important; color: #166534 !important; -webkit-text-fill-color: #166534 !important; }
    .bh-promo-row.copy-success .bh-copy-btn { background: #dcfce7 !important; color: #166534 !important; -webkit-text-fill-color: #166534 !important; }
    .compact-facts { background: #ffffff !important; color-scheme: light !important; forced-color-adjust: none; }
    .cf-inner { background: #ffffff !important; border-color: #E5E7EB !important; }
    .cf-table, .cf-table tr, .cf-table td { background: #F3F4F6 !important; color-scheme: light !important; forced-color-adjust: none; }
    .cf-table tr { border-bottom-color: #E5E7EB !important; }
    .cf-table td:first-child { color: #374151 !important; -webkit-text-fill-color: #374151 !important; }
    .cf-table td:last-child { color: #111827 !important; -webkit-text-fill-color: #111827 !important; }
    .cf-code { color: #c47f00 !important; -webkit-text-fill-color: #c47f00 !important; }
    .cf-good { color: #16a34a !important; -webkit-text-fill-color: #16a34a !important; }
    .cf-warn { color: #b45309 !important; -webkit-text-fill-color: #b45309 !important; }
    .post-table-cta { background: #F3F4F6 !important; forced-color-adjust: none; }
    .bybit-section { background: #F7F8F4 !important; }
    .card { background: #ffffff !important; color: #111827 !important; }
    .reg-proof { background: #F3F4F6 !important; }
    .bh-wordmark { filter: none !important; opacity: 1 !important; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════
     BLOCK 1 — TITLE BAR (white strip above dark hero)
═══════════════════════════════════════════════════════════ -->
<div class="title-bar">
  <h1>Bybit Referral Code</h1>
</div>

<!-- ═══════════════════════════════════════════════════════════
     BLOCK 2 — BRAND HERO (dark, compact conversion header)
═══════════════════════════════════════════════════════════ -->
<section class="brand-hero" style={bhStyle}>
  <div class="bh-inner">

    <a href={exchange.affiliateUrl} rel="noopener sponsored" style="display:block;line-height:0;">
      <img
        src={exchange.wordmarkImg}
        alt="Bybit"
        class="bh-wordmark"
        width="210" height="78"
      />
    </a>

    <p class="bh-promo-label">PROMO CODE</p>
    <div class="bh-promo-row">
      <span class="bh-promo-code">{offer.promoCode}</span>
      <button class="bh-copy-btn" id="copy-btn-hero" type="button">Copy</button>
    </div>

    <a href={exchange.affiliateUrl} class="bh-cta-btn" rel="noopener sponsored">
      Get Bonus
    </a>

    <p class="bh-source">Verified June 2026 on <a href="https://www.bybit.com/en/promo/new-user/" target="_blank" rel="noopener noreferrer nofollow">Bybit.com</a></p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     BLOCK 3 — COMPACT FACTS TABLE (directly under hero)
═══════════════════════════════════════════════════════════ -->
<div class="compact-facts">
  <div class="cf-inner">
    <table class="cf-table">
      <tbody>
        <tr><td>👉 Bybit</td><td>bybit.com</td></tr>
        <tr><td>➡️ Referral Code</td><td class="cf-code">{offer.promoCode}</td></tr>
        <tr><td>💰 Bonus</td><td>Up to 30,000 USDT</td></tr>
        <tr><td>✅ Valid</td><td>June 2026</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     BLOCK 3b — SEO PHRASE + INTRO SENTENCE
═══════════════════════════════════════════════════════════ -->
<div class="seo-intro-block">
  <div class="seo-intro-inner">
    <p class="seo-phrase">Bybit Promo Code Bonus</p>
    <p class="seo-intro-text">Looking for a Bybit referral code? Use <strong>CRYPTOBONUSW</strong> to open the official Bybit bonus page and check the latest sign-up rewards for new users.</p>
  </div>
</div>


<script define:vars={{ promoCode: offer.promoCode }}>
  (function () {
    var btn = document.getElementById('copy-btn-hero');
    if (!btn) return;
    btn.addEventListener('click', function () {
      navigator.clipboard.writeText(promoCode).then(function () {
        var row = btn.closest('.bh-promo-row');
        var codeSpan = row ? row.querySelector('.bh-promo-code') : null;
        btn.textContent = 'Copied ✓';
        btn.classList.add('copy-success');
        if (row) row.classList.add('copy-success');
        if (codeSpan) codeSpan.classList.add('copy-success');
        setTimeout(function () {
          btn.textContent = 'Copy';
          btn.classList.remove('copy-success');
          if (row) row.classList.remove('copy-success');
          if (codeSpan) codeSpan.classList.remove('copy-success');
        }, 1800);
      });
    });
  })();
</script>

</CleanLayout>
