---
import CleanLayout from '../layouts/CleanLayout.astro';
---

<CleanLayout
  title="Page Not Found — CryptoBonusWorld"
  description="The page you were looking for doesn't exist. Find the best crypto exchange bonuses on CryptoBonusWorld."
  noindex={true}
>
  <div class="nf-container">
    <div class="not-found">
      <div class="not-found-code">404</div>
      <h1 class="not-found-title">Page Not Found</h1>
      <p class="not-found-desc">
        The page you were looking for doesn't exist or may have been moved.
      </p>
      <div class="not-found-links">
        <a href="/" class="btn-primary">← Back to Home</a>
        <a href="/exchanges/" class="btn-secondary">Browse All Exchanges</a>
      </div>
      <div class="not-found-popular">
        <p class="popular-label">Popular pages:</p>
        <ul class="popular-list">
          <li><a href="/promo-codes/">All Promo Codes</a></li>
          <li><a href="/bybit/">Bybit Bonus</a></li>
          <li><a href="/mexc/">MEXC Bonus</a></li>
          <li><a href="/okx/">OKX Bonus</a></li>
          <li><a href="/bitget/">Bitget Bonus</a></li>
          <li><a href="/kucoin/">KuCoin Bonus</a></li>
          <li><a href="/bingx/">BingX Bonus</a></li>
        </ul>
      </div>
    </div>
  </div>
</CleanLayout>

<style>
  .nf-container {
    max-width: var(--cbw-page-max, 1180px);
    margin: 0 auto;
    padding: 0 var(--cbw-pad-mobile, 20px);
  }
  @media (min-width: 640px) { .nf-container { padding: 0 var(--cbw-pad-tablet, 24px); } }
  @media (min-width: 820px) { .nf-container { padding: 0 var(--cbw-pad-desktop, 32px); } }

  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem;
    min-height: 60vh;
    justify-content: center;
  }

  .not-found-code {
    font-size: 6rem;
    font-weight: 900;
    color: #F7931A;
    line-height: 1;
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .not-found-title {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1rem;
  }

  .not-found-desc {
    font-size: 1rem;
    color: #4B5563;
    margin-bottom: 2rem;
    max-width: 400px;
  }

  .not-found-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .not-found-popular { text-align: center; }

  .popular-label {
    font-size: 0.8rem;
    color: #6B7280;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .popular-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .popular-list a {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 20px;
    font-size: 0.8rem;
    color: #4B5563;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .popular-list a:hover {
    border-color: #F7931A;
    color: #B45309;
  }

  @media (max-width: 480px) {
    .not-found-code { font-size: 4rem; }
    .not-found-title { font-size: 1.5rem; }
    .not-found-links { flex-direction: column; align-items: center; }
  }
</style>
