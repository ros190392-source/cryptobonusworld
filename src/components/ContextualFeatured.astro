---
import ExchangeLogo from './ExchangeLogo.astro';
/**
 * ContextualFeatured.astro
 *
 * GEO-aware featured exchange spotlight.
 * Renders a server-side default (top editorial pick), then client-side
 * JS swaps to the contextually best exchange for the user's detected region.
 *
 * Use on:
 *  - Homepage hero section
 *  - Top of bonuses listing page
 *  - Top of country pages (alongside existing content)
 *
 * Props:
 *   exchanges     — Full exchange array (scored client-side)
 *   defaultSlug   — Server-side fallback (shown before geo detected, best for SSR/SEO)
 *   heading       — Optional heading override
 *   showReason    — Whether to show the "why this exchange" reason label
 *
 * Trust guarantee:
 *   Only exchanges with rating >= 8.5 can be featured.
 *   This component never reorders the main table — it's a separate spotlight.
 */

interface Exchange {
  slug: string;
  name: string;
  rating: number;
  bonusAmount: number;
  bonusCurrency: string;
  bonusTitle: string;
  kycRequired: boolean;
  depositRequired: boolean;
  bonusTypes: string[];
  paymentMethods: string[];
  countries: string[];
  excludedCountries: string[];
  affiliateUrl: string;
  topChoice?: boolean;
  status?: string;
  shortDescription?: string;
  editorNote?: string;
  bestFor?: string[];
  affiliateLinks?: { geo?: Record<string, string> };
  minDeposit?: { amount: number; currency: string } | null;
}

interface Props {
  exchanges: Exchange[];
  defaultSlug?: string;
  heading?: string;
  showReason?: boolean;
}

const {
  exchanges,
  defaultSlug,
  heading = 'Featured Bonus',
  showReason = true,
} = Astro.props;

// Server-side default: use provided slug or the top editorial pick
const defaultEx = defaultSlug
  ? (exchanges.find(e => e.slug === defaultSlug) ?? exchanges[0])
  : exchanges[0];

if (!defaultEx) return;

const geoHrefsJson = JSON.stringify(
  Object.fromEntries(
    Object.entries(defaultEx.affiliateLinks?.geo ?? {})
      .filter(([, v]) => v && v !== '#')
  )
);

const exchangesJson = JSON.stringify(
  exchanges.map(e => ({
    slug: e.slug,
    name: e.name,
    rating: e.rating,
    kycRequired: e.kycRequired,
    depositRequired: e.depositRequired,
    bonusAmount: e.bonusAmount,
    bonusCurrency: e.bonusCurrency,
    bonusTitle: e.bonusTitle,
    bonusTypes: e.bonusTypes,
    paymentMethods: e.paymentMethods ?? [],
    countries: e.countries ?? [],
    excludedCountries: e.excludedCountries ?? [],
    topChoice: e.topChoice ?? false,
    status: e.status ?? 'active',
    affiliateUrl: e.affiliateUrl,
    geoHrefs: Object.fromEntries(
      Object.entries(e.affiliateLinks?.geo ?? {}).filter(([, v]) => v && v !== '#')
    ),
    shortDescription: e.shortDescription ?? '',
    editorNote: e.editorNote ?? '',
    bestFor: e.bestFor ?? [],
    minDeposit: e.minDeposit ?? null,
  }))
);
---

<div class="ctx-featured" id="ctx-featured-block" data-exchanges={exchangesJson}>

  <!-- Heading + reason label -->
  <div class="ctx-featured__header">
    <span class="ctx-featured__heading">{heading}</span>
    {showReason && (
      <span class="ctx-featured__reason" id="ctx-featured-reason" aria-live="polite">
        Top editorial pick
      </span>
    )}
  </div>

  <!-- Exchange card — server default, swapped client-side -->
  <div class="ctx-featured__card">

    <div class="ctx-featured__info">
      <!-- Logo: uses shared ExchangeLogo component for visual consistency -->
      <div id="ctx-featured-logo" class="ctx-featured__logo-wrap">
        <ExchangeLogo
          slug={defaultEx.slug}
          name={defaultEx.name}
          size={72}
          variant="square"
          lazy={false}
        />
      </div>

      <div class="ctx-featured__meta">
        <a
          href={`/exchanges/${defaultEx.slug}/`}
          class="ctx-featured__name"
          id="ctx-featured-name-link"
        >
          {defaultEx.name}
        </a>
        <p class="ctx-featured__desc" id="ctx-featured-desc">
          {defaultEx.shortDescription ?? defaultEx.bonusTitle}
        </p>
        {defaultEx.bestFor && defaultEx.bestFor.length > 0 && (
          <div class="ctx-featured__bestfor" id="ctx-featured-bestfor">
            {defaultEx.bestFor.slice(0, 3).map(tag => (
              <span class="ctx-featured__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>

    <div class="ctx-featured__action">
      <div class="ctx-featured__bonus" id="ctx-featured-bonus">
        <span class="ctx-featured__bonus-amount">
          {defaultEx.bonusAmount >= 1000
            ? (defaultEx.bonusAmount / 1000).toFixed(0) + 'K'
            : defaultEx.bonusAmount} {defaultEx.bonusCurrency}
        </span>
        <span class="ctx-featured__bonus-label">max bonus</span>
      </div>

      <div class="ctx-featured__badges">
        {!defaultEx.kycRequired && (
          <span class="ctx-featured__badge ctx-featured__badge--green">No KYC</span>
        )}
        {!defaultEx.depositRequired && (
          <span class="ctx-featured__badge ctx-featured__badge--blue">No Deposit</span>
        )}
      </div>

      <a
        href={defaultEx.affiliateUrl}
        id="ctx-featured-cta"
        class="ctx-featured__cta"
        target="_blank"
        rel="noopener noreferrer nofollow sponsored"
        data-track="affiliate-cta"
        data-exchange={defaultEx.slug}
        data-placement="contextual-featured"
        data-bonus={String(defaultEx.bonusAmount)}
        data-geo-href={geoHrefsJson !== '{}' ? geoHrefsJson : undefined}
      >
        <span id="ctx-featured-cta-text">
          {!defaultEx.kycRequired && !defaultEx.depositRequired
            ? `Get ${defaultEx.name} Bonus — No KYC or Deposit`
            : !defaultEx.kycRequired
              ? `Claim ${defaultEx.name} Bonus — No KYC`
              : `Claim ${defaultEx.name} Bonus`}
        </span>
        <span class="ctx-featured__cta-arrow" aria-hidden="true">→</span>
      </a>

      <a href={`/exchanges/${defaultEx.slug}/`} class="ctx-featured__review" id="ctx-featured-review">
        Read full review
      </a>
    </div>

  </div>
</div>

<script define:vars={{ __cfExchanges: exchangesJson }}>
(function () {
  'use strict';

  var TRUST_CAP    = 2.0;
  var RATING_FLOOR = 8.5;
  var NOKYCPREF_GEOS = { tr:1, in:1, id:1, ng:1, vn:1 };
  var GEO_PAYMENT_PREF = {
    tr:['p2p','bank transfer'], in:['p2p','upi'], id:['p2p','bank transfer'],
    ng:['p2p','crypto'], br:['pix','bank transfer','p2p'], vn:['p2p','bank transfer'], ph:['p2p','bank transfer','card'],
  };
  var GEO_TO_COUNTRY_SLUG = { tr:'turkey',in:'india',id:'indonesia',ng:'nigeria',br:'brazil',vn:'vietnam',ph:'philippines' };
  var BRAND_COLORS = { bybit:'#F7A600',mexc:'#0BCDFF',okx:'#EEEEEE',bitget:'#00E5BE',bingx:'#1B78F2','gate-io':'#2354E6',kucoin:'#24AE8F',htx:'#2856EE',coinex:'#00CFC5',phemex:'#BE79DF',bitunix:'#F97316',lbank:'#3B82F6' };

  function editorialBase(ex) {
    var s = ex.rating * 2.0;
    if (!ex.kycRequired)    s += 1.5;
    if (!ex.depositRequired) s += 1.0;
    if (ex.topChoice)        s += 2.5;
    s += Math.log10(ex.bonusAmount + 1) * 0.5;
    return s;
  }

  function contextBoost(ex, ctx) {
    var statusMul = (ex.status && ex.status !== 'active') ? 0.5 : 1.0;
    var boost = 0;
    if (ctx.geo !== 'unknown') {
      var countrySlug = GEO_TO_COUNTRY_SLUG[ctx.geo] || ctx.geo;
      var excluded = ex.excludedCountries || [];
      if (excluded.indexOf(countrySlug) !== -1 || excluded.indexOf(ctx.geo) !== -1) return -999;
      var available = ex.countries.indexOf('global') !== -1 || ex.countries.indexOf(countrySlug) !== -1;
      if (available) {
        if (NOKYCPREF_GEOS[ctx.geo] && !ex.kycRequired) boost += ctx.geo === 'ng' ? 1.2 : 0.8;
        var pref = GEO_PAYMENT_PREF[ctx.geo] || [];
        var exM  = (ex.paymentMethods || []).map(function(m){ return m.toLowerCase(); });
        var ov = pref.filter(function(p){ return exM.some(function(m){ return m.indexOf(p) !== -1; }); }).length;
        boost += Math.min(ov * 0.3, 0.6);
      }
    }
    if (ctx.device === 'mobile') {
      if (!ex.kycRequired)    boost += 0.2;
      if (!ex.depositRequired) boost += 0.2;
    }
    if (ctx.noKycPreference && !ex.kycRequired) boost += 0.3;
    return Math.min(boost * statusMul, TRUST_CAP);
  }

  function getContextReason(ex, ctx) {
    var GEO_NAMES = { tr:'Turkey',in:'India',id:'Indonesia',ng:'Nigeria',br:'Brazil',vn:'Vietnam',ph:'Philippines' };
    if (ctx.geo !== 'unknown' && NOKYCPREF_GEOS[ctx.geo] && !ex.kycRequired) return 'Best for ' + (GEO_NAMES[ctx.geo] || 'your region');
    if (!ex.kycRequired && !ex.depositRequired) return 'Easiest to start';
    if (!ex.kycRequired) return 'No KYC required';
    if (ex.topChoice) return 'Top editorial pick';
    return 'Top rated';
  }

  function getCTA(ex, ctx) {
    if (NOKYCPREF_GEOS[ctx.geo] && !ex.kycRequired && !ex.depositRequired) return 'Get ' + ex.name + ' Bonus — No KYC or Deposit';
    if (NOKYCPREF_GEOS[ctx.geo] && !ex.kycRequired) return 'Claim ' + ex.name + ' — No KYC Required';
    if (!ex.kycRequired && !ex.depositRequired) return 'Get ' + ex.name + ' Bonus — No KYC or Deposit';
    if (!ex.kycRequired) return 'Claim ' + ex.name + ' Bonus — No KYC';
    return 'Claim ' + ex.name + ' Bonus';
  }

  function run() {
    var exchanges;
    try { exchanges = JSON.parse(__cfExchanges); } catch(_){ return; }

    var geo    = (window.cbw && window.cbw.meta && window.cbw.meta.geoCode) || localStorage.getItem('cbw_geo') || 'unknown';
    var device = (window.cbw && window.cbw.meta && window.cbw.meta.deviceType) || localStorage.getItem('cbw_device') || 'desktop';
    var ctx    = { geo: geo, device: device, noKycPreference: !!(geo !== 'unknown' && NOKYCPREF_GEOS[geo]) };

    // Score and find best
    var best = null, bestScore = -Infinity;
    for (var i = 0; i < exchanges.length; i++) {
      var ex = exchanges[i];
      if ((ex.rating || 0) < RATING_FLOOR) continue;
      var boost = contextBoost(ex, ctx);
      if (boost === -999) continue;
      var total = editorialBase(ex) + Math.min(boost, TRUST_CAP);
      if (total > bestScore) { bestScore = total; best = ex; }
    }
    if (!best) return;

    // Update DOM
    var reason = getContextReason(best, ctx);
    var cta    = getCTA(best, ctx);
    var brand  = BRAND_COLORS[best.slug] || '#f5c542';
    var bonusStr = best.bonusAmount >= 1000
      ? Math.round(best.bonusAmount / 1000) + 'K'
      : String(best.bonusAmount);

    function setText(id, val) {
      var el = document.getElementById(id);
      if (el && val) el.textContent = val;
    }
    function setHref(id, href) {
      var el = document.getElementById(id);
      if (el) el.setAttribute('href', href);
    }
    function setAttr(id, attr, val) {
      var el = document.getElementById(id);
      if (el) el.setAttribute(attr, val);
    }

    setText('ctx-featured-reason', reason);
    setText('ctx-featured-cta-text', cta);
    setText('ctx-featured-desc', best.editorNote || best.shortDescription || '');
    setText('ctx-featured-bonus', ''); // clear then rebuild

    var bonusEl = document.getElementById('ctx-featured-bonus');
    if (bonusEl) {
      bonusEl.innerHTML = '<span class="ctx-featured__bonus-amount">' + bonusStr + ' ' + best.bonusCurrency + '</span>' +
        '<span class="ctx-featured__bonus-label">max bonus</span>';
    }

    // Update ExchangeLogo DOM — mirrors LOGO_CONTAINER_BG / LOGO_PADDING
    // from ExchangeLogo.astro (keep in sync when either map changes)
    var LOGO_CONTAINER_BG = {
      htx: '#FFFFFF', coinex: '#FFFFFF',
      phemex: '#0C0C0C', bitunix: '#121212', kucoin: '#FFFFFF',
      bybit: '#232635', binance: '#060606',
      bingx: '#2A54FF', mexc: '#F3F4F8', okx: '#FFFFFF',
      'gate-io': '#FFFFFF', bitget: '#69E6F8',
    };
    // % padding per side; opaque edge-to-edge logos must stay 0
    var LOGO_PADDING = { coinbase: 2 };
    var logoWrap = document.getElementById('ctx-featured-logo');
    if (logoWrap) {
      var exlogoDiv = logoWrap.querySelector('.exlogo');
      if (exlogoDiv) {
        var newBg = LOGO_CONTAINER_BG[best.slug] || 'var(--surface-overlay, #1a1a1a)';
        exlogoDiv.style.background = newBg;
        exlogoDiv.setAttribute('aria-label', best.name);
        var imgEl = exlogoDiv.querySelector('.exlogo-img');
        var fbEl  = exlogoDiv.querySelector('.exlogo-fallback');
        if (imgEl) {
          imgEl.style.display = '';
          var padPx = Math.round(72 * (LOGO_PADDING[best.slug] || 0) / 100);
          imgEl.style.padding = padPx + 'px';
          imgEl.src = '/logos/' + best.slug + '.png';
          imgEl.alt = best.name;
          imgEl.setAttribute('data-slug', best.slug);
          imgEl.onerror = function() {
            imgEl.style.display = 'none';
            if (fbEl) { fbEl.textContent = best.name.charAt(0); fbEl.style.display = 'flex'; }
          };
        }
        if (fbEl) { fbEl.style.display = 'none'; fbEl.textContent = best.name.charAt(0); }
      }
    }

    setHref('ctx-featured-name-link', '/exchanges/' + best.slug + '/');
    setAttr('ctx-featured-name-link', 'textContent', best.name);
    setText('ctx-featured-name-link', best.name);
    setHref('ctx-featured-review', '/exchanges/' + best.slug + '/');

    // Update bestFor tags
    var bfEl = document.getElementById('ctx-featured-bestfor');
    if (bfEl && best.bestFor && best.bestFor.length) {
      bfEl.innerHTML = best.bestFor.slice(0, 3).map(function(t){
        return '<span class="ctx-featured__tag">' + t + '</span>';
      }).join('');
    }

    // Update CTA link
    var ctaEl = document.getElementById('ctx-featured-cta');
    if (ctaEl) {
      var href = (best.geoHrefs && best.geoHrefs[geo] && best.geoHrefs[geo] !== '#')
        ? best.geoHrefs[geo]
        : best.affiliateUrl;
      ctaEl.setAttribute('href', href);
      ctaEl.setAttribute('data-exchange', best.slug);
      ctaEl.setAttribute('data-bonus', String(best.bonusAmount));
      if (best.geoHrefs && Object.keys(best.geoHrefs).length > 0) {
        ctaEl.setAttribute('data-geo-href', JSON.stringify(best.geoHrefs));
      }
    }

    // Update badges
    var actionEl = ctaEl && ctaEl.closest('.ctx-featured__action');
    if (actionEl) {
      var oldBadges = actionEl.querySelector('.ctx-featured__badges');
      if (oldBadges) {
        oldBadges.innerHTML = '';
        if (!best.kycRequired) {
          var b1 = document.createElement('span');
          b1.className = 'ctx-featured__badge ctx-featured__badge--green';
          b1.textContent = 'No KYC';
          oldBadges.appendChild(b1);
        }
        if (!best.depositRequired) {
          var b2 = document.createElement('span');
          b2.className = 'ctx-featured__badge ctx-featured__badge--blue';
          b2.textContent = 'No Deposit';
          oldBadges.appendChild(b2);
        }
      }
    }
  }

  if (window.cbw && window.cbw.meta) {
    run();
  } else {
    window.addEventListener('cbw:geo', run, { once: true });
    window.addEventListener('load', function(){ setTimeout(run, 60); }, { once: true });
  }
})();
</script>

<style>
  .ctx-featured {
    background: var(--surface-elevated, #151515);
    border: 1px solid var(--color-accent-dim, rgba(245,197,66,0.2));
    border-radius: var(--radius-lg, 14px);
    padding: 1.125rem 1.25rem;
    margin-bottom: 1.5rem;
  }

  .ctx-featured__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .ctx-featured__heading {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .ctx-featured__reason {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #000;
    background: var(--color-accent, #f5c542);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
  }

  .ctx-featured__card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .ctx-featured__info {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    flex: 1;
    min-width: 200px;
  }

  /* Logo wrapper — ExchangeLogo component handles all sizing, bg, padding */
  .ctx-featured__logo-wrap {
    flex-shrink: 0;
  }

  .ctx-featured__meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .ctx-featured__name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1.2;
  }
  .ctx-featured__name:hover { color: var(--color-accent); }

  .ctx-featured__desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .ctx-featured__bestfor {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }

  .ctx-featured__tag {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-accent);
    background: rgba(245,197,66,0.08);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: 100px;
    padding: 0.15rem 0.55rem;
    white-space: nowrap;
  }

  .ctx-featured__action {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    flex-shrink: 0;
    min-width: 180px;
  }

  .ctx-featured__bonus {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .ctx-featured__bonus-amount {
    font-size: 1.35rem;
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .ctx-featured__bonus-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ctx-featured__badges {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .ctx-featured__badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .ctx-featured__badge--green {
    background: rgba(74,222,128,0.1);
    color: #4ade80;
    border: 1px solid rgba(74,222,128,0.2);
  }
  .ctx-featured__badge--blue {
    background: rgba(96,165,250,0.1);
    color: #60a5fa;
    border: 1px solid rgba(96,165,250,0.2);
  }

  .ctx-featured__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--color-accent, #f5c542);
    color: #000;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-md, 10px);
    text-decoration: none;
    white-space: nowrap;
    transition: box-shadow 0.2s, transform 0.12s;
    min-height: 44px;
  }
  .ctx-featured__cta:hover {
    box-shadow: 0 4px 20px rgba(245,197,66,0.35);
    transform: translateY(-1px);
    background: var(--color-accent-warm, #fbbf24);
  }

  .ctx-featured__cta-arrow {
    font-size: 0.9em;
    transition: transform 0.2s ease;
  }
  .ctx-featured__cta:hover .ctx-featured__cta-arrow { transform: translateX(3px); }

  .ctx-featured__review {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .ctx-featured__review:hover { color: var(--color-text-secondary); }

  @media (max-width: 640px) {
    .ctx-featured__card { flex-direction: column; }
    .ctx-featured__action { width: 100%; }
    .ctx-featured__cta { width: 100%; justify-content: center; }
  }
</style>
