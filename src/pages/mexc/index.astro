       data-vote-widget="code-helpfulness"
       data-exchange={exchange.slug}
       data-code={offer.promoCode}>
    <h3 class="p2-vote-title">Was this {exchange.name} referral code helpful?</h3>
    <div class="p2-vote-buttons">
      <button class="p2-vote-btn" id="vote-up"   type="button" data-vote="up">👍 Works for me</button>
      <button class="p2-vote-btn" id="vote-down" type="button" data-vote="down">👎 Didn't work</button>
    </div>
    <p class="p2-vote-status" id="vote-status">No votes yet — be the first to rate this code.</p>
  </div>
