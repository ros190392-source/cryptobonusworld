---
/**
 * ExchangeVerdictBlock — AI-extractable structured recommendation block
 *
 * Shows a compact "Quick Verdict" section with:
 *   • One-sentence summary recommendation
 *   • "Best For" list (green ✅) — who should choose this exchange
 *   • "Avoid If" list (red ❌) — clear disqualifiers
 *   • Key Limitation warning — the one thing you must know
 *
 * Positioned in the main content column, early in the page.
 * Uses schema.org ItemList microdata for AI/LLM retrieval.
 * Intentionally different from EditorSummary — adds "Avoid If" and
 * "Key Limitation" dimensions that don't exist elsewhere on the page.
 */

interface VerdictItem {
  label: string;
  note?: string;
}

interface Props {
  name: string;
  quickVerdict?: string;
  bestFor: (string | VerdictItem)[];
  avoidIf: (string | VerdictItem)[];
  keyLimitation?: string;
}

const { name, quickVerdict, bestFor, avoidIf, keyLimitation } = Astro.props;

function normalize(item: string | VerdictItem): VerdictItem {
  return typeof item === 'string' ? { label: item } : item;
}

const bestForItems = bestFor.map(normalize);
const avoidIfItems = avoidIf.map(normalize);

// Only render if there's something meaningful to show
const hasContent = bestForItems.length > 0 || avoidIfItems.length > 0;
---

{hasContent && (
  <div class="evb" data-track-verdict={name} itemscope itemtype="https://schema.org/WebPageElement" aria-label={`Quick verdict for ${name}`}>
    <div class="evb-header">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      <span>Quick Verdict</span>
    </div>

    {quickVerdict && (
      <p class="evb-verdict" itemprop="description">{quickVerdict}</p>
    )}

    <div class="evb-grid">
      <!-- Best For -->
      {bestForItems.length > 0 && (
        <div class="evb-col evb-col--good" itemscope itemtype="https://schema.org/ItemList" aria-label={`${name} is best for`}>
          <div class="evb-col-header">
            <span class="evb-col-icon" aria-hidden="true">✅</span>
            <span class="evb-col-label">Best For</span>
          </div>
          <ul class="evb-list">
            {bestForItems.map((item, i) => (
              <li class="evb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <meta itemprop="position" content={String(i + 1)} />
                <span itemprop="name">{item.label}</span>
                {item.note && <span class="evb-item-note">{item.note}</span>}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Avoid If -->
      {avoidIfItems.length > 0 && (
        <div class="evb-col evb-col--bad" itemscope itemtype="https://schema.org/ItemList" aria-label={`Who should avoid ${name}`}>
          <div class="evb-col-header">
            <span class="evb-col-icon" aria-hidden="true">❌</span>
            <span class="evb-col-label">Avoid If</span>
          </div>
          <ul class="evb-list">
            {avoidIfItems.map((item, i) => (
              <li class="evb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <meta itemprop="position" content={String(i + 1)} />
                <span itemprop="name">{item.label}</span>
                {item.note && <span class="evb-item-note">{item.note}</span>}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    {keyLimitation && (
      <div class="evb-limitation">
        <span class="evb-limitation-icon" aria-hidden="true">⚠️</span>
        <span class="evb-limitation-label">Key Limitation:</span>
        <span class="evb-limitation-text">{keyLimitation}</span>
      </div>
    )}
  </div>
)}

<style>
  .evb {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .evb-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: rgba(245, 197, 66, 0.06);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-accent);
  }

  .evb-verdict {
    padding: 0.875rem 1rem 0.75rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-text-primary);
    margin: 0;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border);
  }

  .evb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .evb-col {
    padding: 0.875rem 1rem;
  }

  .evb-col--good {
    border-right: 1px solid var(--color-border);
  }

  .evb-col-header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.625rem;
  }

  .evb-col-icon {
    font-size: 0.8rem;
    line-height: 1;
  }

  .evb-col-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
  }

  .evb-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .evb-item {
    font-size: 0.8375rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    padding-left: 0.625rem;
    border-left: 2px solid transparent;
    transition: border-color 0.15s;
  }

  .evb-col--good .evb-item {
    border-left-color: rgba(74, 222, 128, 0.3);
  }

  .evb-col--bad .evb-item {
    border-left-color: rgba(248, 113, 113, 0.3);
  }

  .evb-item-note {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.1rem;
  }

  /* Key Limitation */
  .evb-limitation {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    padding: 0.625rem 1rem;
    background: rgba(251, 146, 60, 0.05);
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    line-height: 1.45;
    flex-wrap: wrap;
  }

  .evb-limitation-icon {
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .evb-limitation-label {
    font-weight: 700;
    color: #fb923c;
    flex-shrink: 0;
    font-size: 0.8rem;
  }

  .evb-limitation-text {
    color: var(--color-text-secondary);
  }

  @media (max-width: 540px) {
    .evb-grid {
      grid-template-columns: 1fr;
    }
    .evb-col--good {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
