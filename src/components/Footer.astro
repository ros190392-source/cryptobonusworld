---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="CryptoBonusWorld Home">
          <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true" style="flex-shrink:0">
            <defs>
              <linearGradient id="ftr-ring" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#fbbf24"/>
                <stop offset="100%" stop-color="#d97706"/>
              </linearGradient>
            </defs>
            <circle cx="16" cy="16" r="15.5" fill="url(#ftr-ring)"/>
            <circle cx="16" cy="16" r="11.5" fill="#0a0a0a"/>
            <rect x="10" y="7.5" width="2.5" height="17" rx="1.25" fill="#f5c542"/>
            <path d="M12.5 7.5 h3.5 a4 4 0 0 1 0 8 h-3.5 z" fill="#f5c542"/>
            <path d="M12.5 15.5 h4 a4.5 4.5 0 0 1 0 9 h-4 z" fill="#f5c542"/>
          </svg>
          <span>Crypto<strong style="background:linear-gradient(135deg,#fbbf24,#f5c542,#d97706);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Bonus</strong>World</span>
