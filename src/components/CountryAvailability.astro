---
interface Props {
  countries: string[];
  excludedCountries: string[];
}

const { countries, excludedCountries } = Astro.props;

// Countries that have dedicated guide pages (linkable)
const linkedSlugs = new Set([
  'turkey', 'india', 'indonesia', 'nigeria', 'brazil', 'vietnam', 'philippines',
]);

const countryMeta: Record<string, { label: string; linked: boolean }> = {
  global:      { label: '🌍 Global', linked: false },
  turkey:      { label: '🇹🇷 Turkey', linked: true },
  india:       { label: '🇮🇳 India', linked: true },
  indonesia:   { label: '🇮🇩 Indonesia', linked: true },
  nigeria:     { label: '🇳🇬 Nigeria', linked: true },
  brazil:      { label: '🇧🇷 Brazil', linked: true },
  vietnam:     { label: '🇻🇳 Vietnam', linked: true },
  philippines: { label: '🇵🇭 Philippines', linked: true },
  us:          { label: '🇺🇸 United States', linked: false },
  uk:          { label: '🇬🇧 United Kingdom', linked: false },
  canada:      { label: '🇨🇦 Canada', linked: false },
};
---

<div class="country-availability">
  {countries.length > 0 && (
    <div class="ca-section">
      <h4 class="ca-label ca-label--available">Available in</h4>
      <div class="ca-tags">
        {countries.map(c => {
          const meta = countryMeta[c];
          const label = meta?.label ?? c;
          // Country tags render as plain labels — /countries/ pages retired
          // (Legacy Retirement v1); country UX lives in the homepage GEO finder.
          return <span class="ca-tag ca-tag--available">{label}</span>;
        })}
      </div>
    </div>
  )}

  {excludedCountries.length > 0 && (
    <div class="ca-section">
      <h4 class="ca-label ca-label--excluded">Not available in</h4>
      <div class="ca-tags">
        {excludedCountries.map(c => {
          const meta = countryMeta[c];
          const label = meta?.label ?? c;
          return (
            <span class="ca-tag ca-tag--excluded">{label}</span>
          );
        })}
      </div>
    </div>
  )}
</div>

<style>
  .country-availability {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
  }
  .ca-section { display: flex; flex-direction: column; gap: 0.5rem; }
  .ca-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }
  .ca-label--available { color: #4ade80; }
  .ca-label--excluded { color: #f87171; }
  .ca-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .ca-tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    font-weight: 500;
  }
  .ca-tag--available {
    background: #1a3a2a;
    color: #4ade80;
    border: 1px solid #1a3a2a;
  }
  .ca-tag--excluded {
    background: #3a1a1a;
    color: #f87171;
    border: 1px solid #3a1a1a;
  }
  .ca-tag--link {
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    cursor: pointer;
  }
  .ca-tag--link:hover {
    background: #1f4a32;
    border-color: #4ade80;
  }
</style>
