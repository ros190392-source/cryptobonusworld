---
import BonusBadge from './BonusBadge.astro';
import CTAButton from './CTAButton.astro';

interface Exchange {
  name: string;
  slug: string;
  logo: string;
  rating: number;
  bonusTitle: string;
  bonusAmount: number;
  bonusCurrency: string;
  bonusTypes: string[];
  kycRequired: boolean;
  depositRequired: boolean;
  countries: string[];
  affiliateUrl: string;
  updatedAt: string;
  shortDescription?: string;
}

interface Props {
  exchanges: Exchange[];
  filterCountry?: string;
  filterType?: string;
}

const { exchanges, filterCountry, filterType } = Astro.props;

let filtered = [...exchanges];
if (filterCountry) filtered = filtered.filter(e => e.countries.includes(filterCountry));
if (filterType)    filtered = filtered.filter(e => e.bonusTypes.includes(filterType));

const maxBonus = Math.max(...filtered.map(e => e.bonusAmount));

// Brand colors per exchange
const brandColor: Record<string, string> = {
  bybit:    '#F7A600',
  mexc:     '#0BCDFF',
  okx:      '#EEEEEE',
  bitget:   '#00E5BE',
  bingx:    '#1B78F2',
  'gate-io':'#2354E6',
  kucoin:   '#24AE8F',
  htx:      '#2856EE',
  coinex:   '#00CFC5',
  phemex:   '#BE79DF',
  bitunix:  '#F97316',
  lbank:    '#3B82F6',
};

// Rank medal colors
const rankColor = ['#F5C542', '#C0C0C0', '#CD7F32'];

// Editorial labels — derived from data, no JSON changes
function getLabel(ex: Exchange, rank: number): { text: string; cls: string } | null {
  if (rank === 0) return { text: '🏆 Top Choice', cls: 'lbl--gold' };
  if (!ex.kycRequired && !ex.depositRequired) return { text: '✓ No KYC · No Deposit', cls: 'lbl--green' };
  if (!ex.kycRequired) return { text: '✓ No KYC', cls: 'lbl--green' };
  if (ex.bonusTypes.includes('futures') && ex.bonusAmount >= 5000) return { text: '📈 Best Futures', cls: 'lbl--purple' };
  if (ex.rating >= 9.5 && rank > 0) return { text: '⭐ Top Rated', cls: 'lbl--blue' };
  return null;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Crypto Exchange Bonuses",
  "itemListElement": filtered.map((ex, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://cryptobonusworld.com/exchanges/${ex.slug}/`,
    "name": `${ex.name} Bonus — ${ex.bonusTitle}`,
  })),
};
---

<div class="bt-wrap">

  <!-- ── DESKTOP TABLE ───────────────────────── -->
  <table class="bt" role="table" aria-label="Crypto exchange bonus comparison">
    <thead class="bt-head">
      <tr>
        <th class="th-rank">#</th>
        <th class="th-exchange">Exchange</th>
        <th class="th-bonus">Welcome Bonus</th>
        <th class="th-type">Type</th>
        <th class="th-kyc">KYC</th>
        <th class="th-rating">Score</th>
        <th class="th-cta">Action</th>
      </tr>
    </thead>
    <tbody>
      {filtered.map((ex, i) => {
        const barPct = Math.round((ex.bonusAmount / maxBonus) * 100);
        const color  = brandColor[ex.slug] ?? '#f5c542';
        const medal  = rankColor[i] ?? null;
        const label  = getLabel(ex, i);
        const featured = i === 0;
        return (
          <tr class:list={['bt-row', featured && 'bt-row--featured']}>

            {/* Rank */}
            <td class="td-rank">
              <span class="rank-num" style={medal ? `color:${medal};` : ''}>
                {i + 1}
              </span>
            </td>

            {/* Exchange */}
            <td class="td-exchange">
              <a href={`/exchanges/${ex.slug}/`} class="ex-link">
                <div class="ex-logo" style={`--brand:${color}`} aria-hidden="true">
                  {ex.name.charAt(0)}
                </div>
                <div class="ex-meta">
                  <span class="ex-name">{ex.name}</span>
                  {label && (
                    <span class:list={['ex-label', label.cls]}>{label.text}</span>
                  )}
                </div>
              </a>
            </td>

            {/* Bonus */}
            <td class="td-bonus">
              <span class="bonus-amount">
                {ex.bonusAmount >= 1000
                  ? (ex.bonusAmount / 1000).toFixed(ex.bonusAmount % 1000 === 0 ? 0 : 1) + 'K'
                  : ex.bonusAmount} {ex.bonusCurrency}
              </span>
              <div class="bonus-bar-track" title={`${ex.bonusTitle}`}>
                <div class="bonus-bar-fill" style={`width:${barPct}%; background:${color};`}></div>
              </div>
              <span class="bonus-sub">{ex.bonusTitle}</span>
            </td>

            {/* Types */}
            <td class="td-types">
              <div class="badge-row">
                {ex.bonusTypes.slice(0, 2).map(t => <BonusBadge type={t} />)}
              </div>
            </td>

            {/* KYC */}
            <td class="td-kyc">
              {ex.kycRequired
                ? <span class="kyc kyc--req">KYC</span>
                : <span class="kyc kyc--none">No KYC</span>
              }
            </td>

            {/* Rating */}
            <td class="td-rating">
              <span class="score" style={ex.rating >= 9.5 ? 'color:#4ade80' : ex.rating >= 9.0 ? 'color:#facc15' : 'color:#fb923c'}>
                {ex.rating.toFixed(1)}
              </span>
              <div class="score-stars" aria-hidden="true">
                {Array.from({ length: 5 }).map((_, si) => (
                  <svg width="10" height="10" viewBox="0 0 24 24" style={si < Math.round(ex.rating / 2) ? 'fill:#f5c542' : 'fill:#333'}>
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
            </td>

            {/* CTA */}
            <td class="td-cta">
              {featured
                ? <CTAButton href={ex.affiliateUrl} exchange={ex.name} size="sm" />
                : (
                  <a href={ex.affiliateUrl} class="cta-compact" target="_blank" rel="noopener noreferrer nofollow sponsored">
                    Claim →
                  </a>
                )
              }
            </td>

          </tr>
        );
      })}
    </tbody>
  </table>

  <!-- ── MOBILE CARDS ───────────────────────── -->
  <div class="bt-mobile">
    {filtered.map((ex, i) => {
      const color = brandColor[ex.slug] ?? '#f5c542';
      const label = getLabel(ex, i);
      const featured = i === 0;
      return (
        <div class:list={['mc', featured && 'mc--featured']}>
          <div class="mc-top">
            <a href={`/exchanges/${ex.slug}/`} class="mc-identity">
              <div class="mc-logo" style={`--brand:${color}`} aria-hidden="true">
                {ex.name.charAt(0)}
              </div>
              <div class="mc-meta">
                <span class="mc-name">{ex.name}</span>
                {label && <span class:list={['ex-label', label.cls]}>{label.text}</span>}
              </div>
            </a>
            <div class="mc-bonus">
              <span class="mc-amount">
                {ex.bonusAmount >= 1000
                  ? (ex.bonusAmount / 1000).toFixed(0) + 'K'
                  : ex.bonusAmount} {ex.bonusCurrency}
              </span>
              <span class="mc-bonus-title">{ex.bonusTitle}</span>
            </div>
          </div>

          <div class="mc-badges">
            {ex.bonusTypes.slice(0, 2).map(t => <BonusBadge type={t} />)}
            {ex.kycRequired
              ? <span class="kyc kyc--req">KYC</span>
              : <span class="kyc kyc--none">No KYC</span>
            }
            <span class="mc-score">★ {ex.rating.toFixed(1)}</span>
          </div>

          <div class="mc-footer">
            <a href={`/exchanges/${ex.slug}/`} class="mc-details">View details</a>
            <CTAButton href={ex.affiliateUrl} exchange={ex.name} size="sm" />
          </div>
        </div>
      );
    })}
  </div>

</div>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  /* ── WRAPPER ────────────────────────────── */
  .bt-wrap {
    border-radius: 14px;
    border: 1px solid var(--color-border);
    overflow: hidden;
    margin: 1.5rem 0;
  }

  /* ── DESKTOP TABLE ──────────────────────── */
  .bt {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  /* Sticky header */
  .bt-head {
    position: sticky;
    top: 64px;
    z-index: 10;
    background: #161616;
    border-bottom: 1px solid var(--color-border);
  }
  .bt-head th {
    padding: 0.875rem 1rem;
    text-align: left;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    white-space: nowrap;
    user-select: none;
  }
  .th-rank  { width: 48px; text-align: center; }
  .th-cta   { text-align: right; }

  /* Rows */
  .bt-row {
    border-bottom: 1px solid var(--color-border);
    transition: background 0.12s;
    cursor: pointer;
  }
  .bt-row:last-child { border-bottom: none; }
  .bt-row:hover { background: rgba(255,255,255,0.025); }
  .bt-row:hover .ex-name { color: var(--color-accent); }

  /* Featured row */
  .bt-row--featured {
    background: rgba(245,197,66,0.04);
    border-left: 3px solid var(--color-accent);
  }
  .bt-row--featured:hover { background: rgba(245,197,66,0.07); }

  /* Cells */
  .bt-row td {
    padding: 1rem 1rem;
    vertical-align: middle;
  }

  /* ── RANK ───────────────────────────────── */
  .td-rank { text-align: center; width: 48px; }
  .rank-num {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  /* ── EXCHANGE ───────────────────────────── */
  .ex-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  .ex-logo {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--brand) 12%, #1a1a1a);
    border: 1px solid color-mix(in srgb, var(--brand) 30%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 900;
    color: var(--brand);
    flex-shrink: 0;
    transition: box-shadow 0.15s;
  }
  .bt-row:hover .ex-logo {
    box-shadow: 0 0 12px color-mix(in srgb, var(--brand) 25%, transparent);
  }
  .ex-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ex-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary);
    transition: color 0.15s;
    white-space: nowrap;
  }

  /* Editorial labels */
  .ex-label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .lbl--gold   { background: rgba(245,197,66,0.15); color: #f5c542; border: 1px solid rgba(245,197,66,0.25); }
  .lbl--green  { background: rgba(74,222,128,0.12); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .lbl--purple { background: rgba(192,132,252,0.12); color: #c084fc; border: 1px solid rgba(192,132,252,0.2); }
  .lbl--blue   { background: rgba(96,165,250,0.12); color: #60a5fa; border: 1px solid rgba(96,165,250,0.2); }

  /* ── BONUS ──────────────────────────────── */
  .td-bonus { min-width: 160px; }
  .bonus-amount {
    display: block;
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .bonus-bar-track {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    margin: 0.35rem 0 0.2rem;
    overflow: hidden;
  }
  .bonus-bar-fill {
    height: 100%;
    border-radius: 2px;
    opacity: 0.7;
    transition: width 0.4s ease;
  }
  .bonus-sub {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  /* ── TYPES ──────────────────────────────── */
  .td-types { min-width: 120px; }
  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  /* ── KYC ────────────────────────────────── */
  .kyc {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    white-space: nowrap;
  }
  .kyc--req  { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.2); }
  .kyc--none { background: rgba(74,222,128,0.10); color: #4ade80; border: 1px solid rgba(74,222,128,0.18); }

  /* ── RATING ─────────────────────────────── */
  .td-rating { white-space: nowrap; }
  .score {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .score-stars {
    display: flex;
    gap: 1px;
  }

  /* ── CTA ────────────────────────────────── */
  .td-cta { text-align: right; white-space: nowrap; }
  .cta-compact {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.35rem 0.75rem;
    border-radius: 7px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .cta-compact:hover {
    color: var(--color-accent);
    border-color: rgba(245,197,66,0.4);
    background: rgba(245,197,66,0.05);
  }

  /* ── MOBILE CARDS ────────────────────────── */
  .bt-mobile { display: none; }

  .mc {
    padding: 1.125rem 1rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.12s;
  }
  .mc:last-child { border-bottom: none; }

  /* Featured: gold top accent + subtle bg */
  .mc--featured {
    background: rgba(245,197,66,0.04);
    border-top: 3px solid var(--color-accent);
  }
  .mc--featured .mc-name::after {
    content: ' 🏆';
    font-size: 0.75rem;
  }

  .mc-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .mc-identity {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    /* ensure tappable area */
    min-height: 44px;
  }
  .mc-logo {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--brand) 12%, #1a1a1a);
    border: 1px solid color-mix(in srgb, var(--brand) 30%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 900;
    color: var(--brand);
    flex-shrink: 0;
  }
  .mc-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .mc-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .mc-bonus { text-align: right; flex-shrink: 0; }
  .mc-amount {
    display: block;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .mc-bonus-title {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .mc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 1rem;
    align-items: center;
  }
  .mc-score {
    font-size: 0.72rem;
    font-weight: 700;
    color: #facc15;
    background: rgba(250,204,21,0.1);
    border: 1px solid rgba(250,204,21,0.2);
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
  }

  .mc-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  /* "View details" — proper touch target */
  .mc-details {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
    font-weight: 500;
  }
  .mc-details:hover { color: var(--color-text-primary); }
  .mc-details::after { content: ' →'; }

  /* ── RESPONSIVE ─────────────────────────── */
  @media (max-width: 768px) {
    .bt { display: none; }
    .bt-mobile { display: block; }
    .bt-wrap { border-radius: 12px; }
  }
</style>
