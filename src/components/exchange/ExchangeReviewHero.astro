---
/**
 * ExchangeReviewHero — unified exchange review hero (2026-07 site hero system).
 *
 * One shared hero for all six exchange review pages, built on the site-level
 * hero contract: exact heights 360 / 384 (≥641px) / 432 (≥1024px), the shared
 * 1180px container, the shared panel styling, and the shared typography
 * rhythm — while preserving each exchange's approved factory hero artwork
 * (passed in via props; never replaced by the generic site artwork).
 *
 * The H1 lives inside the hero (replaces the old detached white title-bar).
 * Promo code renders through the shared PromoCodeCopy component; the CTA
 * keeps the approved /go/ route + outbound target/rel behavior (a4d89d4).
 *
 * All facts come from the caller's existing registry-backed values — this
 * component hardcodes nothing.
 */
import ExchangePromoLogoSlot from '../ExchangePromoLogoSlot.astro';
import PromoCodeCopy from '../promo/PromoCodeCopy.astro';

export interface Props {
  name: string;
  /** Existing approved factory artwork for THIS exchange. */
  heroBackgroundImg: string;
  /** Desktop artwork focal position (presentation only, never factual data). */
  heroBackgroundPosition?: string;
  /** Tablet (641–1023px) artwork focal position; falls back to desktop. */
  heroBackgroundPositionTablet?: string;
  /** Mobile (≤640px) artwork focal position; falls back to tablet/desktop.
      Each artwork has its own focal composition — do not reuse one generic value. */
  heroBackgroundPositionMobile?: string;
  /** Optional mobile artwork scale override (background-size); default 'cover'. */
  heroBackgroundSizeMobile?: string;
  /** Brand gradient behind the artwork (existing per-exchange tokens). */
  bgFrom: string;
  bgTo: string;
  wordmarkImg: string;
  logoVisualScale?: number;
  /** "PROMO CODE" or "REFERRAL CODE" (existing approved label). */
  promoLabel: string;
  promoCode: string;
  /** Approved offer headline (offers.ts bonusHeadline). */
  bonusHeadline: string;
  lastChecked: string;
  sourceUrl: string;
  officialDomain: string;
  /** Existing approved /go/[slug] route. */
  affiliateUrl: string;
}

const {
  name,
  heroBackgroundImg,
  heroBackgroundPosition = 'left center',
  heroBackgroundPositionTablet,
  heroBackgroundPositionMobile,
  heroBackgroundSizeMobile,
  bgFrom,
  bgTo,
  wordmarkImg,
  logoVisualScale = 1,
  promoLabel,
  promoCode,
  bonusHeadline,
  lastChecked,
  sourceUrl,
  officialDomain,
  affiliateUrl,
} = Astro.props;

// Responsive focal-point fallback chain: mobile → tablet → desktop.
const posDesktop = heroBackgroundPosition;
const posTablet = heroBackgroundPositionTablet ?? posDesktop;
const posMobile = heroBackgroundPositionMobile ?? posTablet;
const sizeMobile = heroBackgroundSizeMobile ?? 'cover';
---

<section
  class="erh"
  style={`--erh-img:url('${heroBackgroundImg}');--erh-pos:${posDesktop};--erh-pos-t:${posTablet};--erh-pos-m:${posMobile};--erh-size-m:${sizeMobile};--erh-from:${bgFrom};--erh-to:${bgTo}`}
>
  <div class="erh-inner">
    <div class="erh-main">
      <a class="erh-logo-link" href={affiliateUrl} target="_blank" rel="noopener noreferrer sponsored" aria-label={`Get ${name} bonus`}>
        <ExchangePromoLogoSlot src={wordmarkImg} alt={name} mode="clean" visualScale={logoVisualScale} fetchpriority="high" />
      </a>
      <h1 class="erh-h1">{name} Referral Code</h1>
      <p class="erh-offer">{bonusHeadline}</p>
      <p class="erh-checked">Checked {lastChecked}</p>
    </div>

    <aside class="erh-panel" aria-label={`${name} promo code`}>
      <p class="erh-label">{promoLabel}</p>
      <div class={'erh-code' + (promoCode.length >= 14 ? ' erh-code-long' : '')}>
        <PromoCodeCopy code={promoCode} exchange={name} />
      </div>
      <a class="erh-cta" href={affiliateUrl} target="_blank" rel="noopener noreferrer sponsored">Get Bonus</a>
      <p class="erh-cond">Verified {lastChecked} on <a href={sourceUrl} target="_blank" rel="noopener noreferrer nofollow">{officialDomain}</a></p>
    </aside>
  </div>
</section>

<style>
  .erh {
    position: relative;
    display: flex;
    align-items: center;
    color: #fff;
    overflow: hidden;
    /* longhand so the artwork focal position is per-breakpoint tunable */
    background-image: var(--erh-img), linear-gradient(160deg, var(--erh-from) 0%, var(--erh-to) 100%);
    background-position: var(--erh-pos), center;
    background-size: cover, cover;
    background-repeat: no-repeat;
    /* exact site-level hero heights — no content-driven growth */
    height: 360px;
  }
  @media (min-width: 641px)  { .erh { height: 384px; } }
  @media (min-width: 1024px) { .erh { height: 432px; } }
  /* per-exchange responsive focal points (fallback chain resolved in frontmatter) */
  @media (max-width: 1023px) { .erh { background-position: var(--erh-pos-t), center; } }
  @media (max-width: 640px) {
    .erh {
      background-position: var(--erh-pos-m), center;
      background-size: var(--erh-size-m, cover), cover;
    }
  }

  /* readability overlay over the artwork (no recoloring, no filters) */
  .erh::before {
    content: '';
    position: absolute; inset: 0; z-index: 0;
    background: linear-gradient(
      90deg,
      rgba(8, 12, 20, 0.82) 0%,
      rgba(8, 12, 20, 0.55) 48%,
      rgba(8, 12, 20, 0.28) 100%
    );
  }

  .erh-inner {
    position: relative; z-index: 1;
    box-sizing: border-box; width: 100%;
    max-width: var(--cbw-page-max, 1180px);
    margin: 0 auto;
    padding: 24px 20px;
    display: flex; align-items: center; gap: 36px;
  }
  @media (min-width: 640px) { .erh-inner { padding: 24px 24px; } }
  @media (min-width: 820px) { .erh-inner { padding: 24px 32px; } }

  .erh-main { flex: 1 1 auto; min-width: 0; }

  .erh-logo-link { display: inline-block; line-height: 0; margin-bottom: 10px; }
  .erh-logo-link:focus-visible { outline: 2px solid #F7931A; outline-offset: 3px; border-radius: 6px; }
  /* keep the wordmark slot compact inside the fixed hero */
  .erh-logo-link :global(img) { max-height: 44px; width: auto; }

  .erh-h1 {
    font-size: clamp(26px, 3.4vw, 38px); font-weight: 800;
    line-height: 1.12; letter-spacing: -.02em; color: #fff; margin: 0 0 10px;
  }
  .erh-offer {
    font-size: clamp(15px, 1.6vw, 18px); font-weight: 700; color: #9FE8B9;
    line-height: 1.45; max-width: 540px; margin: 0 0 8px;
  }
  .erh-checked { font-size: 13px; color: rgba(255, 255, 255, 0.6); margin: 0; }

  /* shared panel styling (site hero system) */
  .erh-panel {
    flex: 0 0 330px; box-sizing: border-box;
    background: rgba(7, 24, 48, 0.86);
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 12px; padding: 16px 18px;
    backdrop-filter: blur(3px);
  }
  @media (max-width: 1023px) and (min-width: 641px) { .erh-panel { flex-basis: 300px; } }

  .erh-label {
    font-size: 10.5px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: #8FA5C4; margin: 0 0 8px;
  }
  .erh-code { margin-bottom: 10px; }
  .erh-code :global(.pcc-row) { max-width: none; width: 100%; box-sizing: border-box; height: 50px; }
  .erh-code :global(.pcc-code) { font-size: 19px; }
  .erh-code-long :global(.pcc-code) { font-size: 15px; letter-spacing: 0; }

  .erh-cta {
    display: flex; align-items: center; justify-content: center;
    box-sizing: border-box; width: 100%; height: 48px;
    background: var(--cbw-green, #16A34A); color: #fff; border-radius: 8px;
    font-size: 16px; font-weight: 750; text-decoration: none;
    transition: background .15s; margin-bottom: 9px;
  }
  .erh-cta:hover { background: var(--cbw-green-hover, #15803D); }
  .erh-cta:focus-visible { outline: 2px solid #F7931A; outline-offset: 2px; }

  .erh-cond { font-size: 11.5px; line-height: 1.5; color: #8FA5C4; margin: 0; }
  .erh-cond a { color: #8FA5C4; text-decoration: underline; text-underline-offset: 2px; }
  .erh-cond a:hover { color: #C8D8EE; }
  .erh-cond a:focus-visible { outline: 2px solid #F7931A; outline-offset: 2px; }

  /* ── Mobile: stacked, essentials only (checked/conditions live in the
        facts table directly below the hero).
        Composition rhythm (approved targets): focal/logo → H1 ≈ 14px,
        H1 → offer ≈ 6px, offer → panel ≈ 12px, controls ≥ 44px, all
        centered inside the exact 360px band. ── */
  @media (max-width: 640px) {
    /* vertical readability overlay: artwork focal stays visible at the top,
       text zone darkens toward the bottom (no artwork recoloring) */
    .erh::before {
      background: linear-gradient(
        180deg,
        rgba(8, 12, 20, 0.44) 0%,
        rgba(8, 12, 20, 0.60) 48%,
        rgba(8, 12, 20, 0.80) 100%
      );
    }
    .erh-inner { flex-direction: column; align-items: stretch; justify-content: center; gap: 12px; padding-top: 16px; padding-bottom: 16px; }
    /* one centered composition: focal mark directly above the H1 */
    .erh-main { flex: none; text-align: center; }
    .erh-offer { margin-left: auto; margin-right: auto; }
    .erh-logo-link { margin-bottom: 14px; }
    .erh-logo-link :global(img) { max-height: 32px; }
    .erh-h1 { font-size: 22px; margin-bottom: 6px; text-shadow: 0 1px 10px rgba(8, 12, 20, 0.65); }
    .erh-offer { font-size: 13.5px; line-height: 1.4; margin-bottom: 0; text-shadow: 0 1px 8px rgba(8, 12, 20, 0.65); }
    .erh-checked { display: none; }
    .erh-panel { flex: none; width: 100%; padding: 12px 14px; }
    .erh-label { margin-bottom: 6px; }
    .erh-code { margin-bottom: 8px; }
    .erh-code :global(.pcc-row) { height: 46px; }
    .erh-code :global(.pcc-code) { font-size: 16px; }
    .erh-code-long :global(.pcc-code) { font-size: 13px; }
    .erh-cta { height: 46px; font-size: 15px; margin-bottom: 0; }
    .erh-cond { display: none; }
  }
  /* narrowest phones: two-line offers (KuCoin/BingX) must still fit in 360 */
  @media (max-width: 374px) {
    .erh-inner { padding-top: 14px; padding-bottom: 14px; }
    .erh-offer { font-size: 13px; }
  }
</style>
