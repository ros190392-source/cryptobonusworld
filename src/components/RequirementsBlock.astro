---
interface Props {
  requirements: string;
  kycRequired: boolean;
  depositRequired: boolean;
  futuresRequired: boolean;
  exchangeName?: string;
  minDeposit?: { amount: number; currency: string } | null;
  affiliateUrl?: string;
  bonusAmount?: number;
  bonusCurrency?: string;
}
const {
  requirements,
  kycRequired,
  depositRequired,
  futuresRequired,
  exchangeName,
  minDeposit,
  affiliateUrl,
  bonusAmount,
  bonusCurrency,
} = Astro.props;

// Build exchange-specific step descriptions
const step1Desc = exchangeName
  ? `Use our ${exchangeName} referral link to open the sign-up page — it activates your welcome bonus automatically.`
  : 'Use our affiliate link to open the exchange registration page. The bonus is activated through the referral link.';

const step4Desc = minDeposit && minDeposit.amount > 0
  ? `Transfer at least ${minDeposit.amount.toLocaleString('en-US')} ${minDeposit.currency} to your account. Crypto deposits are typically confirmed within minutes.`
  : 'Deposit when you are ready — no minimum is required to start earning your first bonus reward.';

const allSteps = [
  {
    num: 1,
    icon: '🔗',
    label: 'Click Referral Link',
    desc: step1Desc,
    always: true,
  },
  {
    num: 2,
    icon: '📧',
    label: 'Create Account',
    desc: 'Register with your email or phone number. Account creation takes under 2 minutes.',
    always: true,
  },
  {
    num: 3,
    icon: '🪪',
    label: 'KYC Verification',
    desc: 'Upload a government-issued ID photo for identity verification. Required before claiming the full bonus.',
    required: kycRequired,
  },
  {
    num: 4,
    icon: '💰',
    label: 'Make a Deposit',
    desc: step4Desc,
    required: depositRequired,
  },
  {
    num: 5,
    icon: '📈',
    label: 'Start Trading',
    desc: 'Complete trading tasks to hit volume milestones. Each tier unlocks additional bonus rewards automatically.',
    always: true,
  },
  {
    num: 6,
    icon: '🎁',
    label: 'Claim Bonus',
    desc: 'Bonus vouchers are credited automatically or via the Rewards Center in your account dashboard.',
    always: true,
  },
];

const steps = allSteps.filter(s => s.always || s.required);
---

<div class="req-block">
  <h2 class="req-heading">How to Claim This Bonus</h2>

  <div class="req-timeline" style={`--step-count: ${steps.length};`}>
    {steps.map((step, i) => (
      <div class:list={['req-step', i === steps.length - 1 && 'req-step--last']}>
        <div class="req-step-marker">
          <div class="req-step-circle">
            <span class="req-step-num">{i + 1}</span>
          </div>
          {i < steps.length - 1 && <div class="req-step-line" aria-hidden="true" />}
        </div>
        <div class="req-step-body">
          <div class="req-step-icon" aria-hidden="true">{step.icon}</div>
          <div class="req-step-text">
            <strong class="req-step-label">{step.label}</strong>
            <p class="req-step-desc">{step.desc}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  {requirements && (
    <div class="req-note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>{requirements}</p>
    </div>
  )}

  {affiliateUrl && affiliateUrl !== '#' && (
    <div class="req-cta-bar">
      <div class="req-cta-left">
        <span class="req-cta-label">Ready to claim?</span>
        {bonusAmount && bonusCurrency && (
          <span class="req-cta-amount">Up to {bonusAmount.toLocaleString()} {bonusCurrency}</span>
        )}
      </div>
      <a
        href={affiliateUrl}
        class="req-cta-btn"
        target="_blank"
        rel="noopener noreferrer nofollow sponsored"
        data-track="affiliate-cta"
        data-exchange={exchangeName?.toLowerCase().replace(/\s+/g, '-') ?? ''}
        data-placement="requirements-cta"
        data-bonus={bonusAmount ? String(bonusAmount) : undefined}
      >
        {kycRequired ? `Claim ${exchangeName ?? ''} Bonus →` : `Claim — No KYC →`}
      </a>
    </div>
  )}
</div>

<style>
  .req-block {
    margin: 2rem 0;
  }

  .req-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
  }

  /* Desktop: horizontal timeline */
  .req-timeline {
    display: grid;
    grid-template-columns: repeat(var(--step-count, 5), 1fr);
    gap: 0;
    position: relative;
  }

  .req-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 0 0.5rem;
  }

  .req-step-marker {
    display: flex;
    align-items: center;
    width: 100%;
    margin-bottom: 0.875rem;
    position: relative;
  }

  .req-step-circle {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    margin: 0 auto;
    box-shadow: 0 0 12px rgba(245, 197, 66, 0.3);
  }

  .req-step-num {
    font-size: 0.8rem;
    font-weight: 800;
  }

  /* Connecting line between circles */
  .req-step-line {
    position: absolute;
    top: 18px;
    left: calc(50% + 18px);
    right: calc(-50% + 18px);
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-dim));
    z-index: 0;
  }

  .req-step--last .req-step-line { display: none; }

  .req-step-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.875rem 0.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    width: 100%;
    min-height: 100px;
    transition: border-color 0.15s;
  }

  .req-step-body:hover {
    border-color: var(--color-accent-dim);
  }

  .req-step-icon {
    font-size: 1.375rem;
    line-height: 1;
  }

  .req-step-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
    display: block;
    line-height: 1.3;
  }

  .req-step-desc {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .req-note {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.875rem 1rem;
    margin-top: 1.25rem;
    color: var(--color-text-muted);
  }

  .req-note svg { flex-shrink: 0; margin-top: 1px; }

  .req-note p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* ── CTA bar after steps ────────────────── */
  .req-cta-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(135deg, rgba(245,197,66,0.07) 0%, rgba(245,197,66,0.03) 100%);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: 12px;
  }

  .req-cta-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .req-cta-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .req-cta-amount {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .req-cta-btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.6rem 1.375rem;
    background: var(--color-accent);
    color: #000;
    font-size: 0.875rem;
    font-weight: 800;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
  }
  .req-cta-btn:hover {
    background: var(--color-accent-warm, #fbbf24);
    transform: translateY(-2px);
    box-shadow: var(--glow-cta, 0 4px 20px rgba(245,197,66,0.35));
  }
  .req-cta-btn:active {
    transform: scale(0.97);
  }

  @media (max-width: 600px) {
    .req-cta-bar {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
    .req-cta-left { align-items: center; }
    .req-cta-btn { width: 100%; justify-content: center; }
  }

  /* Mobile: vertical timeline */
  @media (max-width: 700px) {
    .req-timeline {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .req-step {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      padding: 0;
      gap: 0.875rem;
    }

    .req-step-marker {
      flex-direction: column;
      align-items: center;
      width: 36px;
      flex-shrink: 0;
      margin-bottom: 0;
    }

    .req-step-circle { margin: 0; }

    /* Vertical connecting line */
    .req-step-line {
      position: static;
      width: 2px;
      height: 100%;
      min-height: 24px;
      flex: 1;
      background: linear-gradient(180deg, var(--color-accent), var(--color-accent-dim));
      margin: 4px 0;
    }

    .req-step-body {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
      min-height: unset;
      padding: 0.875rem;
    }

    .req-step-icon {
      font-size: 1.25rem;
      flex-shrink: 0;
    }
  }
</style>
