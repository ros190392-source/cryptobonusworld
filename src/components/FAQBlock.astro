---
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  items: FAQItem[];
  title?: string;
  pageUrl?: string;
  /** Exchange slug for tracking (e.g. 'bybit'). Leave empty on non-exchange pages. */
  exchangeSlug?: string;
  /**
   * Set true when the parent page already emits a FAQPage schema (e.g. via
   * buildFAQSchema in its schema array). Prevents a duplicate JSON-LD block.
   */
  suppressSchema?: boolean;
}

const { items, title = 'Frequently Asked Questions', pageUrl, exchangeSlug = '', suppressSchema = false } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      // Strip any HTML tags for plain-text schema requirement (FAQPage spec)
      "text": item.answer.replace(/<[^>]+>/g, ''),
    },
  })),
};
---

<section class="faq-block" data-faq-exchange={exchangeSlug}>
  <h2 class="faq-title">{title}</h2>
  <div class="faq-list">
    {items.map((item, i) => (
      <details class="faq-item" data-faq-question={item.question.slice(0, 80)} open={i === 0}>
        <summary class="faq-question">
          <span>{item.question}</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="faq-answer">
          <p set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>

{!suppressSchema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

<script>
  import { analytics } from '../lib/analytics';

  // Track FAQ opens (not closes, not the pre-opened first item via server render).
  // 'toggle' only fires on user-initiated state changes — safe to track all opens.
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(details => {
    details.addEventListener('toggle', () => {
      if (!details.open) return;  // skip close events
      const question = details.dataset.faqQuestion ?? '';
      const exchange = (details.closest('[data-faq-exchange]') as HTMLElement | null)
        ?.dataset.faqExchange ?? '';
      analytics.trackFAQExpand({ question, exchange });
    });
  });
</script>

<style>
  .faq-block { margin: 2.5rem 0; }
  .faq-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }
  .faq-item[open] { border-color: var(--color-accent-dim); }
  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer {
    padding: 0 1.25rem 1rem;
    border-top: 1px solid var(--color-border);
  }
  .faq-answer p {
    margin: 0.75rem 0 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .faq-answer p a {
    color: var(--color-accent, #f0b90b);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .faq-answer p a:hover {
    opacity: 0.85;
  }
</style>
