---
import Layout from '../../layouts/Layout.astro';
import ExchangeHero from '../../components/ExchangeHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BonusBadge from '../../components/BonusBadge.astro';
import ProsConsBlock from '../../components/ProsConsBlock.astro';
import RequirementsBlock from '../../components/RequirementsBlock.astro';
import CountryAvailability from '../../components/CountryAvailability.astro';
import AlternativesBlock from '../../components/AlternativesBlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import CTAButton from '../../components/CTAButton.astro';
import ReviewerBlock from '../../components/ReviewerBlock.astro';
import EditorialNote from '../../components/EditorialNote.astro';
import HowWeEvaluate from '../../components/HowWeEvaluate.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import ExchangeLogo from '../../components/ExchangeLogo.astro';
import OfferRealism from '../../components/OfferRealism.astro';
import EditorialExperienceBar from '../../components/EditorialExperienceBar.astro';
import EvidenceVerificationBlock from '../../components/EvidenceVerificationBlock.astro';
import FactCheckPanel from '../../components/FactCheckPanel.astro';
import ExchangeExperienceGrid from '../../components/ExchangeExperienceGrid.astro';
import type { ExperienceData } from '../../components/ExchangeExperienceGrid.astro';

import exchanges from '../../data/exchanges.json';
import categories from '../../data/categories.json';
import countries from '../../data/countries.json';
import comparePairs from '../../data/compare-pairs.json';
import allGuides from '../../data/guides.json';
import { USE_CASES } from '../../data/use-cases';
import { COINS } from '../../data/coins';
import { BONUS_CODES } from '../../data/bonus-codes';

import RelatedCategoriesBlock from '../../components/RelatedCategoriesBlock.astro';
import CountryCrossLinksBlock from '../../components/CountryCrossLinksBlock.astro';
import EditorSummary from '../../components/EditorSummary.astro';
import GeoContentBlock from '../../components/GeoContentBlock.astro';
import GeoPaymentBlock from '../../components/GeoPaymentBlock.astro';
import GeoRegulatoryNote from '../../components/GeoRegulatoryNote.astro';
import RelatedGuidesBlock from '../../components/RelatedGuidesBlock.astro';
import WalkthroughFlow from '../../components/WalkthroughFlow.astro';
import WalkthroughStepImage from '../../components/WalkthroughStepImage.astro';
import FeeSnippetBlock from '../../components/FeeSnippetBlock.astro';
import RelatedNextReads from '../../components/RelatedNextReads.astro';
import PromoCodeBox from '../../components/PromoCodeBox.astro';
import PeopleAlsoCompare from '../../components/PeopleAlsoCompare.astro';
import ExchangeVerdictBlock from '../../components/ExchangeVerdictBlock.astro';
import ScreenshotGallery from '../../components/ScreenshotGallery.astro';

import {
  exchangePageTitle,
  exchangeMetaDesc,
  buildProductSchema,
  buildReviewPageSchema,
  buildFAQSchema,
  getRelatedCategories,
  getCountryCrossLinks,
} from '../../utils/seo';
import { buildFinancialServiceSchema } from '../../utils/schema';
import FreshnessLabel from '../../components/FreshnessLabel.astro';
import { getFlowsBySlug } from '../../data/exchange-walkthroughs';
import { getReviewersForExchange } from '../../data/reviewers';
import type { PageContext } from '../../utils/analytics';
import {
  generateExchangeFAQs,
  applyFAQOverrides,
  BONUS_TYPE_DEFS,
  type ContentExchange,
} from '../../utils/contentEngine';
import contentOverrides from '../../data/content-overrides.json';
import { getExchangeEvidence } from '../../data/evidence/index';

export async function getStaticPaths() {
  return exchanges.map(ex => ({
    params: { slug: ex.slug },
    props: { exchange: ex },
  }));
}

const { exchange: ex } = Astro.props;

// ── Reviewer lookup ───────────────────────────────────────────────────────────
// Pull the primary reviewer for this exchange from the central registry.
// Falls back gracefully — ReviewerBlock has a named default (Oleksandr Shadurskyi).
const _exReviewers = getReviewersForExchange(ex.slug);
const _primaryReviewer = _exReviewers[0]; // lead reviewer (most authoritative)
const pageReviewer = _primaryReviewer ? {
  name:       _primaryReviewer.name,
  title:      _primaryReviewer.title,
  bio:        _primaryReviewer.bio,
  reviewedAt: (ex as any).lastVerified ?? ex.updatedAt,
  profileUrl: `/reviewers/${_primaryReviewer.slug}/`,
  initials:   _primaryReviewer.initials,
  avatarSrc:  _primaryReviewer.photo ?? undefined,
  expertise:  _primaryReviewer.expertise,
} : undefined; // undefined → ReviewerBlock uses its built-in named default

// SEO: dynamic title, meta description, cross-link data
const seoTitle = exchangePageTitle(ex as any);
const seoDesc = exchangeMetaDesc(ex as any);
const relatedCats = getRelatedCategories(ex.bonusTypes, ex.kycRequired, ex.depositRequired, categories as any);
const countryCrossLinks = getCountryCrossLinks(ex.countries, countries as any);

const pageTitle = `${ex.name} Bonus 2026: ${ex.bonusTitle}`;

// Bonus type definitions — centralised in contentEngine.ts
const bonusTypeDefs = BONUS_TYPE_DEFS;

// Use structured bonusTiers from data if available, else fall back to bonusTypeDefs
const activeBonusTiers = (ex as any).bonusTiers?.length
  ? (ex as any).bonusTiers
  : ex.bonusTypes.map(t => bonusTypeDefs[t]).filter(Boolean);
const hasBonusTierData = !!(ex as any).bonusTiers?.length;

// ── KYC claim safety check ─────────────────────────────────────────────────
// Prevents unverified no-KYC assertions from rendering on the page.
// A "no KYC required" claim is only safe to display when evidence has:
//   conflictStatus === 'ok', manualReviewRequired === false, confidenceScore ≥ 0.70
// Per KYC_ACCESS_CLAIMS_POLICY.md §6 (CHECKED tier publish threshold).
// kycRequired === true exchanges are always safe — claim is factual, not promotional.
// Note: ev is also declared later (line ~287) for fee/bonus checks — this is a free Map
// lookup so calling getExchangeEvidence twice at build time has zero cost.
const _evKyc = getExchangeEvidence(ex.slug);
const _kycFact = _evKyc?.facts.find(f => f.field === 'kyc_required');
const _kycClaimSafe = ex.kycRequired === true || !!(
  _kycFact &&
  _kycFact.conflictStatus === 'ok' &&
  _kycFact.manualReviewRequired !== true &&
  typeof _kycFact.confidenceScore === 'number' &&
  (_kycFact.confidenceScore as number) >= 0.70
);

// ── SEO safety overrides for KYC claims ────────────────────────────────────
// Re-generates title/description with kycClaimSafe:false when evidence is
// unverified, removing "No KYC Required" from <title>, og:title, twitter:title,
// <meta name="description">, og:description, and twitter:description.
// All six tags are driven by the same title+description props in Layout → SeoHead,
// so this single override covers all of them.
const _seoTitle = (!_kycClaimSafe && !ex.kycRequired)
  ? exchangePageTitle(ex as any, { kycClaimSafe: false })
  : seoTitle;
const _seoDesc = (!_kycClaimSafe && !ex.kycRequired)
  ? exchangeMetaDesc(ex as any, { kycClaimSafe: false })
  : seoDesc;

// Conditions data for icon grid
const minDeposit = (ex as any).minDeposit;
const tradingVol = (ex as any).tradingVolumeRequired;
const bonusExpiry = (ex as any).bonusExpiry;

const conditions = [
  {
    icon: '💰',
    label: 'Max Bonus',
    value: `${ex.bonusAmount.toLocaleString()} ${ex.bonusCurrency}`,
    highlight: true,
  },
  {
    icon: '🪪',
    label: 'KYC Required',
    value: ex.kycRequired ? 'Yes — ID verification' : _kycClaimSafe ? 'No KYC needed' : 'Check current requirements',
    ok: !ex.kycRequired && _kycClaimSafe,
  },
  {
    icon: '🏦',
    label: 'Min Deposit',
    value: minDeposit
      ? (minDeposit.amount > 0 ? `${minDeposit.amount.toLocaleString()} ${minDeposit.currency}` : 'No deposit needed')
      : (ex.depositRequired ? 'Deposit required' : 'No deposit needed'),
    ok: minDeposit ? minDeposit.amount === 0 : !ex.depositRequired,
  },
  {
    icon: '📈',
    label: 'Trading Volume',
    value: tradingVol && tradingVol.amount > 0
      ? `${tradingVol.amount.toLocaleString()} ${tradingVol.currency}`
      : 'None required',
    ok: !tradingVol || tradingVol.amount === 0,
  },
  {
    icon: '⏳',
    label: 'Bonus Expiry',
    value: bonusExpiry ? `${bonusExpiry.days} days after signup` : 'See official terms',
  },
  {
    icon: '💳',
    label: 'Payment Methods',
    value: ex.paymentMethods.join(', '),
  },
];

// FAQ — generated centrally, then editorial overrides applied
const _faqGenerated = generateExchangeFAQs(ex as unknown as ContentExchange, { kycClaimSafe: _kycClaimSafe });
const _faqOverride = (contentOverrides.exchanges as Record<string, any>)[ex.slug];
const faqItems = applyFAQOverrides(_faqGenerated, _faqOverride);

// Analytics context
const analyticsContext: PageContext = {
  pageType:        'exchange',
  exchangeSlug:    ex.slug,
  exchangeRating:  ex.rating,
  exchangeBonus:   ex.bonusAmount,
  exchangeKyc:     ex.kycRequired,
  exchangeDeposit: ex.depositRequired,
};

// Compare pairs for this exchange
const exMap = Object.fromEntries(exchanges.map(e => [e.slug, e]));
const myComparePairs = comparePairs
  .filter(p => p.a === ex.slug || p.b === ex.slug)
  .slice(0, 6);

// Pass primary reviewer as Person entity when available (E-E-A-T signal).
// Falls back to Organization author when no reviewer is assigned.
const _reviewerEntity = _primaryReviewer
  ? { name: _primaryReviewer.name, url: `https://cryptobonusworld.com/reviewers/${_primaryReviewer.slug}/` }
  : undefined;
const reviewPageSchema = buildReviewPageSchema(ex as any, _reviewerEntity);
// FinancialService schema — standalone entity with licences, areaServed, serviceType
const financialServiceSchema = buildFinancialServiceSchema(ex as any);
// FAQ schema — emits FAQPage JSON-LD for the FAQ block rendered below
const faqSchema = faqItems.length > 0 ? buildFAQSchema(faqItems) : null;

// ── Trust paragraph helpers ────────────────────────────────────────────────────
const LICENCE_FULL_NAMES: Record<string, string> = {
  'Dubai VARA':              'the Dubai Virtual Assets Regulatory Authority (VARA)',
  'Bahamas SCB':             'the Securities Commission of the Bahamas (SCB)',
  'ASIC Australia':          'the Australian Securities and Investments Commission (ASIC)',
  'Multiple regional licences': 'multiple regulatory bodies worldwide',
  'SEC':   'the U.S. Securities and Exchange Commission (SEC)',
  'FinCEN': 'FinCEN (Financial Crimes Enforcement Network)',
  'FCA':   'the UK Financial Conduct Authority (FCA)',
  'MiCA':  'MiCA (EU Markets in Crypto-Assets Regulation)',
  'CySEC': 'the Cyprus Securities and Exchange Commission (CySEC)',
  'MAS':   'the Monetary Authority of Singapore (MAS)',
};

function getLicenceText(licences: string[]): string {
  if (!licences?.length) return '';
  const names = licences.map(l => LICENCE_FULL_NAMES[l] ?? l);
  if (names.length === 1) return names[0];
  if (names.length === 2) return `${names[0]} and ${names[1]}`;
  return names.slice(0, -1).join(', ') + ', and ' + names[names.length - 1];
}

function getLicenceShort(licences: string[]): string {
  return licences?.join(' · ') ?? '';
}

function getExchangeTypeDesc(e: typeof ex): string {
  const features: string[] = [];
  const bt = e.bonusTypes ?? [];
  if (bt.includes('futures')) features.push('derivatives (futures & perpetuals)');
  if ((e as any).p2pAvailable) features.push('P2P trading');
  if ((e as any).featureBadges?.includes('copy-trading')) features.push('copy trading');
  if (bt.includes('staking') || (e as any).featureBadges?.includes('earn')) features.push('earn/staking');
  if (features.length === 0) return 'spot trading';
  return 'spot and ' + (features.length === 1
    ? features[0]
    : features.slice(0, -1).join(', ') + ', and ' + features[features.length - 1]);
}

// Related guides — pick guides that reference this exchange
const relatedGuides = allGuides
  .filter(g => g.relatedExchanges?.includes(ex.slug))
  .slice(0, 4);

// Related use cases — use cases where this exchange is in the pool
const relatedUseCases = USE_CASES.filter(uc =>
  uc.exchangePool === 'all' ||
  (Array.isArray(uc.exchangePool) && uc.exchangePool.includes(ex.slug))
).slice(0, 6);

// Visual walkthroughs — only available for select exchanges (bybit, binance, mexc)
const walkthroughFlows = getFlowsBySlug(ex.slug);

// Top coins traded on this exchange (for cross-linking to /coins/ pages)
// Priority coins: BTC, ETH, USDT, BNB, SOL, XRP + any exchange-specific spotlight
const TOP_COINS = ['bitcoin', 'ethereum', 'usdt', 'solana', 'bnb', 'xrp'];
const relatedCoins = COINS
  .filter(c =>
    TOP_COINS.includes(c.slug) ||
    (Array.isArray(c.supportedBy) && (c.supportedBy as string[]).includes(ex.slug))
  )
  .sort((a, b) => TOP_COINS.indexOf(a.slug) - TOP_COINS.indexOf(b.slug))
  .slice(0, 6);

// Bonus code entry for this exchange (for cross-linking to /bonus-codes/)
const hasBonusCode = BONUS_CODES.some(b => b.exchangeSlug === ex.slug);

// ── Walkthrough HowTo schema helpers ──────────────────────────────────────────
const SITE_URL = 'https://cryptobonusworld.com';

const FLOW_TIMES: Record<string, string> = {
  'bybit-account-creation': 'PT5M',
  'bybit-kyc':              'PT10M',
  'bybit-p2p-purchase':     'PT15M',
  'bybit-first-deposit':    'PT10M',
  'bybit-spot-trading':     'PT10M',
  'bybit-futures-setup':    'PT20M',
};

function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
}

function getFlowShortTitle(id: string): string {
  if (id.includes('account-creation'))              return 'Account Setup';
  if (id.includes('kyc'))                           return 'KYC Verification';
  if (id.includes('p2p-purchase') || id.includes('-p2p')) return 'Buy via P2P';
  if (id.includes('first-deposit') || id.includes('deposit')) return 'Deposit Crypto';
  if (id.includes('spot-trading') || id.includes('spot')) return 'Spot Trading';
  if (id.includes('futures'))                       return 'Futures Trading';
  return id;
}

// Evidence registry lookup — drives FactCheckPanel and real fee source URLs
const ev = getExchangeEvidence(ex.slug);

// ── Screenshot gallery images — public evidence only ──────────────────────
// Only 'available' screenshots whose path starts with /screenshots/ are shown.
// Authenticated pages, reports/, and nulls are silently excluded.
const _SCREENSHOT_LABELS: Record<string, string> = {
  registration:          'Registration',
  kyc:                   'KYC flow',
  bonus:                 'Bonus page',
  deposit:               'Deposit',
  p2p:                   'P2P',
  spot:                  'Spot trading',
  futures:               'Futures',
  fees:                  'Fees',
  mobile_app:            'Mobile app',
  proof_of_reserves:     'Proof of reserves',
  bonus_referral_landing:'Bonus landing',
};

const _screenshotImages = ev?.screenshots
  ? Object.entries(ev.screenshots)
      .filter(([, entry]) =>
        entry?.status === 'available' &&
        entry.path !== null &&
        typeof entry.path === 'string' &&
        (entry.path as string).startsWith('/screenshots/')
      )
      .map(([slot, entry]) => ({
        src:        entry!.path as string,
        alt:        `${ex.name} — ${_SCREENSHOT_LABELS[slot] ?? slot} screenshot`,
        caption:    (entry!.notes && entry!.notes.length > 5) ? entry!.notes : undefined,
        capturedAt: entry!.capturedAt ?? undefined,
        label:      _SCREENSHOT_LABELS[slot] ?? slot,
        device:     (entry!.device ?? 'desktop') as 'desktop' | 'mobile' | 'none',
      }))
  : [];

// Pull the official fee source URL from evidence (if available)
const _feeSourceFact = ev?.facts.find(f => f.field === 'spot_maker_fee');
const _feeSourceUrl = _feeSourceFact?.officialSourceUrl
  ?? (_feeSourceFact?.officialSourceKey ? ev?.sources[_feeSourceFact.officialSourceKey as string]?.url : undefined)
  ?? undefined;

// Evidence-aware bonus trust flag — used in trust-details block
const _bonusAmountFact = ev?.facts.find(f => f.field === 'bonus_amount');
const _bonusTrustOutdated = _bonusAmountFact?.conflictStatus === 'outdated' || _bonusAmountFact?.manualReviewRequired === true;
const _bonusCheckedDate = (ex as any).offerLastChecked ?? (ex as any).lastVerified;

// Schema price safety: suppress machine-readable offers.price when bonus evidence
// is not fully verified. All three conditions must hold: conflictStatus=ok,
// no manual review flag, and confidenceScore ≥ 0.5.
// Currently false for all 14 exchanges (all have bonus_amount.conflictStatus=outdated).
// Will auto-enable per-exchange once live verification updates their evidence.
const _bonusPriceSafe = !!(
  _bonusAmountFact &&
  _bonusAmountFact.conflictStatus === 'ok' &&
  _bonusAmountFact.manualReviewRequired !== true &&
  typeof _bonusAmountFact.confidenceScore === 'number' &&
  (_bonusAmountFact.confidenceScore as number) >= 0.5
);

// SEO: use utility builder for richer, consistent Product schema.
// Evidence guard passed so offers.price is only emitted when bonus data is verified.
const schema = buildProductSchema(ex as any, undefined, { bonusPriceSafe: _bonusPriceSafe });

// ── Related Next Reads — top compare pairs + related guides for internal distribution
const rnrItems = [
  ...myComparePairs.slice(0, 2).map(p => {
    const otherSlug = p.a === ex.slug ? p.b : p.a;
    const other = exMap[otherSlug] as any;
    return {
      type: 'compare' as const,
      label: `${ex.name} vs ${other?.name ?? otherSlug} — Fees, Bonuses & KYC`,
      href: `/compare/${p.pair}/`,
    };
  }),
  ...relatedGuides.slice(0, 2).map(g => ({
    type: 'guide' as const,
    label: g.title,
    href: `/guides/${g.slug}/`,
    meta: g.readTime + ' read',
  })),
];
---

<Layout
  title={_seoTitle}
  description={_seoDesc}
  canonical={`/exchanges/${ex.slug}/`}
  schema={faqSchema ? [schema, reviewPageSchema, financialServiceSchema, faqSchema] : [schema, reviewPageSchema, financialServiceSchema]}
  analyticsContext={analyticsContext}
  ogImage={`https://cryptobonusworld.com/og/exchange-${ex.slug}.png`}
  ogType="article"
  publishedTime={(ex as any).updatedAt}
  modifiedTime={(ex as any).lastVerified ?? (ex as any).updatedAt}
>
  <div class="container ex-page">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Exchanges', href: '/exchanges/' },
      { label: ex.name },
    ]} />

    <AffiliateDisclosure compact />

    <AuthorCard
      compact
      verb="Reviewed by"
      name="Oleksandr Shadurskyi"
      title="Crypto Exchange Analyst & Editor-in-Chief"
      initials="AS"
      photo="/avatars/alexandr-shadurskyi.webp"
      reviewedAt={(ex as any).lastVerified ?? ex.updatedAt}
      profileUrl="/reviewers/alexandr-shadurskyi/"
    />
    <div class="ex-freshness-row">
      <FreshnessLabel dateStr={(ex as any).lastVerified ?? ex.updatedAt} variant="review" />
      {(ex as any).offerLastChecked && (
        <FreshnessLabel dateStr={(ex as any).offerLastChecked} variant="bonus" />
      )}
    </div>

    <!-- Full-width hero with h1 -->
    <ExchangeHero
      name={ex.name}
      slug={ex.slug}
      rating={ex.rating}
      pageTitle={pageTitle}
      bonusTitle={ex.bonusTitle}
      bonusAmount={ex.bonusAmount}
      bonusCurrency={ex.bonusCurrency}
      bonusTypes={ex.bonusTypes}
      kycRequired={ex.kycRequired}
      depositRequired={ex.depositRequired}
      affiliateUrl={ex.affiliateUrl}
      promoCode={ex.promoCode}
      updatedAt={ex.updatedAt}
      countries={ex.countries}
      paymentMethods={ex.paymentMethods}
      licences={(ex as any).licences}
      founded={(ex as any).founded}
      users={(ex as any).users}
      bonusExpiry={(ex as any).bonusExpiry ?? null}
      geoHrefs={(ex as any).affiliateLinks?.geo ?? undefined}
      lastVerified={(ex as any).lastVerified}
      verificationStatus={(ex as any).verificationStatus}
      bonusNote={(ex as any).bonusNote ?? null}
      bonusSourceUrl={(ex as any).bonusSourceUrl ?? null}
      excludedCountries={(ex as any).excludedCountries ?? null}
      bonusDisplayMode={(ex as any).bonusDisplayMode ?? 'up-to'}
      partnerStatus={(ex as any).partner_status ?? 'full'}
    />

    <!-- Editorial summary: verdict, best-for, feature badges (EEAT anchor) -->
    <EditorSummary
      name={ex.name}
      rating={ex.rating}
      shortDescription={ex.shortDescription}
      bestFor={(ex as any).bestFor ?? []}
      featureBadges={(ex as any).featureBadges ?? []}
      lastVerified={(ex as any).lastVerified ?? ex.updatedAt}
      topChoice={(ex as any).topChoice ?? false}
      founded={(ex as any).founded}
      users={(ex as any).users}
      editorNote={
        // Content override takes priority over exchange data field
        (_faqOverride?.editorNote?.length > 0 ? _faqOverride.editorNote : null) ??
        ((ex as any).editorNote?.length > 0 ? (ex as any).editorNote : undefined)
      }
    />

    <!-- E-E-A-T: Editorial reviewer block — emits Person schema JSON-LD -->
    <!-- reviewer resolved from central registry (reviewers.ts); consistent with AuthorCard above -->
    <ReviewerBlock
      reviewer={pageReviewer}
      reviewedAt={(ex as any).lastVerified ?? ex.updatedAt}
      verb="Reviewed by"
    />

    <!-- "Why trust this review?" expandable trust block (E-E-A-T) -->
    <details class="trust-details">
      <summary class="trust-details-summary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Why trust this review?
        <svg class="trust-details-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <ul class="trust-details-list">
        <li>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong>Screenshots captured manually</strong> on the live {ex.name} platform — not sourced from press materials or third parties.</span>
        </li>
        <li>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          {_bonusTrustOutdated ? (
            <span><strong>Bonus offer last checked</strong> on {_bonusCheckedDate}. Current bonus terms are under active review — verify the latest offer on the official {ex.name} promotion page before registering.</span>
          ) : (
            <span><strong>Bonus conditions verified</strong> against the official {ex.name} promotion page. Bonus amounts, expiry periods and tier conditions were checked on {_bonusCheckedDate}.</span>
          )}
        </li>
        {ex.kycRequired && (
          <li>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>KYC flow tested</strong> with a real registered account — every step of the identity verification process was completed and documented, including document scan and face verification.</span>
          </li>
        )}
        <li>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong>Withdrawal limits confirmed</strong> from official account settings — KYC Level 1 and Level 2 daily limits reviewed directly in the platform UI.</span>
        </li>
        <li>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong>Trading fees sourced from the official fee schedule</strong> — spot, futures and P2P fee rates verified against the {ex.name} website. No affiliate arrangement affects these figures.</span>
        </li>
        {(ex as any).p2pAvailable && (
          <li>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>P2P flow completed end-to-end</strong> — a real purchase was made to verify the escrow process, payment method confirmation and order release steps.</span>
          </li>
        )}
        <li>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong>GEO restrictions verified</strong> — country availability and blocked jurisdictions confirmed. {ex.excludedCountries && ex.excludedCountries.length > 0 ? `Blocked regions (${(ex.excludedCountries as string[]).map((c: string) => c.toUpperCase()).join(', ')}) tested directly.` : ''}</span>
        </li>
      </ul>
      <p class="trust-details-footer">
        CryptoBonusWorld does not accept payment for ratings or review content.
