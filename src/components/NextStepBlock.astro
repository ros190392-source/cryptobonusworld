---
/**
 * NextStepBlock — Continuation nudge at the end of guide sections.
 *
 * Eliminates dead-ends by surfacing one strong "next step" action:
 *  - A related guide to read next
 *  - An exchange to explore
 *  - A comparison to check
 *
 * Usage:
 *   <NextStepBlock
 *     heading="Your next step"
 *     body="Ready to buy USDT for the first time? Bybit offers the most payment options and the largest P2P market."
 *     cta="Open Bybit account"
 *     href="https://..."
 *     secondaryCta="Compare all P2P exchanges"
 *     secondaryHref="/guides/best-p2p-crypto-exchanges/"
 *     type="exchange"   (exchange | guide | compare)
 *   />
 */

interface Props {
  heading?: string;
  body: string;
  cta: string;
  href: string;
  secondaryCta?: string;
  secondaryHref?: string;
  /** Visual flavour: exchange (gold CTA), guide (blue), compare (slate) */
  type?: 'exchange' | 'guide' | 'compare';
  /** Disable affiliate noopener warning (for internal links) */
  internal?: boolean;
}

const {
  heading = 'Your next step',
  body,
  cta,
  href,
  secondaryCta,
  secondaryHref,
  type = 'guide',
  internal = false,
} = Astro.props;

const rel = internal ? undefined : 'noopener noreferrer sponsored';
const target = internal ? undefined : '_blank';
---

<div class:list={['nsb', `nsb--${type}`]}>
  <div class="nsb__icon" aria-hidden="true">
    {type === 'exchange' && '🎯'}
    {type === 'guide' && '📖'}
    {type === 'compare' && '⚖️'}
  </div>
  <div class="nsb__content">
    <p class="nsb__heading">{heading}</p>
    <p class="nsb__body">{body}</p>
    <div class="nsb__actions">
      <a
        href={href}
        class="nsb__cta nsb__cta--primary"
        rel={rel}
        target={target}
      >
        {cta}
        {!internal && <span class="nsb__ext-icon" aria-hidden="true">↗</span>}
      </a>
      {secondaryCta && secondaryHref && (
        <a href={secondaryHref} class="nsb__cta nsb__cta--secondary">
          {secondaryCta}
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .nsb {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    border-left: 4px solid var(--nsb-accent, #d4a017);
    background: var(--nsb-bg, rgba(212, 160, 23, 0.07));
  }

  /* Exchange variant — gold */
  .nsb--exchange {
    --nsb-accent: #d4a017;
    --nsb-bg: rgba(212, 160, 23, 0.07);
    --nsb-btn-bg: #d4a017;
    --nsb-btn-hover: #b8891a;
    --nsb-btn-text: #0d0d0d;
  }

  /* Guide variant — blue */
  .nsb--guide {
    --nsb-accent: #4a9eff;
    --nsb-bg: rgba(74, 158, 255, 0.07);
    --nsb-btn-bg: #4a9eff;
    --nsb-btn-hover: #2d88ee;
    --nsb-btn-text: #fff;
  }

  /* Compare variant — slate */
  .nsb--compare {
    --nsb-accent: #7b93b0;
    --nsb-bg: rgba(123, 147, 176, 0.07);
    --nsb-btn-bg: #7b93b0;
    --nsb-btn-hover: #617a96;
    --nsb-btn-text: #fff;
  }

  .nsb__icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .nsb__content {
    flex: 1;
    min-width: 0;
  }

  .nsb__heading {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--nsb-accent);
    margin: 0 0 0.35rem;
    opacity: 0.9;
  }

  .nsb__body {
    margin: 0 0 0.9rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-secondary, #c0c8d8);
  }

  .nsb__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .nsb__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 1.1rem;
    border-radius: 7px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease, opacity 0.15s ease;
    line-height: 1;
  }

  .nsb__cta--primary {
    background: var(--nsb-btn-bg);
    color: var(--nsb-btn-text);
  }

  .nsb__cta--primary:hover {
    background: var(--nsb-btn-hover);
  }

  .nsb__cta--secondary {
    background: transparent;
    color: var(--nsb-accent);
    border: 1.5px solid var(--nsb-accent);
    opacity: 0.85;
  }

  .nsb__cta--secondary:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.05);
  }

  .nsb__ext-icon {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  @media (max-width: 480px) {
    .nsb {
      flex-direction: column;
      gap: 0.5rem;
    }
    .nsb__actions {
      flex-direction: column;
      align-items: stretch;
    }
    .nsb__cta {
      justify-content: center;
    }
  }
</style>
