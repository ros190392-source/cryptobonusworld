---
import type { Exchange } from '../../data/exchanges';
import type { Offer } from '../../data/offers';

export interface Props {
  exchange: Exchange;
  offer?: Offer;
}

const { exchange: ex, offer } = Astro.props;
---

<div class="ec">
  <a href={ex.pageUrl ?? `/exchanges/${ex.slug}/`} class="ec-img-link" tabindex="-1" aria-label={`${ex.name} exchange page`}>
    <div class="ec-img-wrap">
      <img
        src={ex.cardImage}
        alt={`${ex.name} referral code — claim bonus`}
        class="ec-img"
        width="1200" height="800"
        loading="eager"
      />
    </div>
  </a>
  <div class="ec-body">
    <a href={ex.pageUrl ?? `/exchanges/${ex.slug}/`} class="ec-name">{ex.name}</a>
    {offer && (
      <div class="ec-bonus">{offer.bonusHeadline}</div>
    )}
    {offer && (
      <div class="ec-code-band">
        <span class="ec-code-label">Promo code</span>
        <button
          class="ec-code-btn"
          data-code={offer.promoCode}
          aria-label={`Copy promo code ${offer.promoCode}`}
          type="button"
        >
          <span class="ec-code-text">{offer.promoCode}</span>
          <span class="ec-copy-icon" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="5.5" y="1.5" width="9" height="11" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M10.5 1.5V1A1.5 1.5 0 0 0 9 -0.5H2A1.5 1.5 0 0 0 .5 1v9A1.5 1.5 0 0 0 2 11.5h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="ec-copy-check" aria-hidden="true">✓</span>
        </button>
        {offer.status === 'verified' && <span class="ec-verified">✓ verified</span>}
      </div>
    )}
    <a href={ex.affiliateUrl} class="ec-cta">Claim Bonus →</a>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.ec-code-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code ?? '';
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = code;
        ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1800);
    });
  });
</script>

<style>
  .ec {
    display: flex; flex-direction: column;
    background: var(--cbw-card-bg, #fff);
    border: 1px solid var(--cbw-card-border, #E5E7EB);
    border-radius: var(--cbw-card-radius, 12px);
    overflow: hidden;
    box-shadow: var(--cbw-card-shadow, 0 2px 6px rgba(0,0,0,0.06));
    transition: box-shadow .2s, transform .15s, border-color .2s;
  }
  .ec:hover {
    box-shadow: var(--cbw-card-shadow-h, 0 6px 20px rgba(0,0,0,0.11));
    transform: translateY(-3px);
    border-color: var(--cbw-card-border-h, #C7D2FE);
  }

  .ec-img-link { display: block; text-decoration: none; }
  .ec-img-wrap {
    overflow: hidden;
    border-bottom: 1px solid var(--cbw-gray-100, #F3F4F6);
    aspect-ratio: 16/9;
  }
  .ec-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .35s; }
  .ec:hover .ec-img { transform: scale(1.025); }

  .ec-body { padding: 12px 14px 14px; display: flex; flex-direction: column; gap: 5px; }

  .ec-name {
    font-size: 15px; font-weight: 800; color: var(--cbw-gray-900, #111827);
    letter-spacing: -.01em; text-decoration: none; display: block;
  }
  .ec-name:hover { color: #1D4ED8; text-decoration: underline; }

  .ec-bonus { font-size: 13px; color: var(--cbw-gray-700, #374151); line-height: 1.45; }

  /* Promo code band */
  .ec-code-band {
    display: flex; align-items: center; gap: 7px; flex-wrap: wrap;
    background: var(--cbw-coupon-bg, #FFFBF5);
    border: 1px dashed var(--cbw-coupon-border, #FCD34D);
    border-radius: 7px; padding: 7px 10px;
  }
  .ec-code-label {
    font-size: 10px; text-transform: uppercase; letter-spacing: .07em;
    color: var(--cbw-coupon-label, #92400E); font-weight: 600; white-space: nowrap;
  }

  /* Click-to-copy button */
  .ec-code-btn {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 13px; font-weight: 900;
    font-family: var(--cbw-font-mono, 'SFMono-Regular', Consolas, monospace);
    background: var(--cbw-coupon-code-bg, #FFF7ED);
    border: 1.5px solid var(--cbw-coupon-code-bd, #FED7AA);
    color: var(--cbw-coupon-code-tx, #C2410C);
    padding: 3px 8px 3px 10px; border-radius: 5px;
    letter-spacing: .07em; cursor: pointer;
    transition: background .12s, border-color .12s, transform .1s;
    user-select: all;
  }
  .ec-code-btn:hover {
    background: #FEF3C7; border-color: #F59E0B;
    transform: scale(1.02);
  }
  .ec-copy-icon { color: var(--cbw-coupon-code-tx, #C2410C); opacity: .55; flex-shrink: 0; display: flex; }
  .ec-copy-check { display: none; font-size: 12px; color: var(--cbw-green, #16A34A); font-weight: 900; }

  .ec-code-btn.copied { background: #F0FDF4; border-color: #86EFAC; color: #15803D; }
  .ec-code-btn.copied .ec-copy-icon { display: none; }
  .ec-code-btn.copied .ec-copy-check { display: inline; }

  .ec-verified { font-size: 10px; color: var(--cbw-green, #16A34A); font-weight: 700; white-space: nowrap; }

  .ec-cta {
    margin-top: 4px;
    display: block; text-align: center; text-decoration: none;
    background: var(--cbw-green, #16A34A); color: #fff;
    font-size: 13px; font-weight: 700;
    padding: 8px 14px; border-radius: 8px;
    transition: background .15s;
  }
  .ec-cta:hover { background: var(--cbw-green-hover, #15803D); }
</style>
