---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE_NAME } from '../utils/seo';

const pageTitle = `Our Methodology — How We Rate Crypto Exchange Bonuses | ${SITE_NAME}`;
const pageDesc  = 'How CryptoBonusWorld evaluates crypto exchange bonuses. Full methodology: six-factor rating system, data verification standards, KYC testing, and freshness policy.';

const methodologySchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'CryptoBonusWorld Rating Methodology',
  description: pageDesc,
  url: 'https://cryptobonusworld.com/methodology/',
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    url: 'https://cryptobonusworld.com',
  },
  dateModified: '2026-05-25',
};

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Methodology' },
];
---

<Layout title={pageTitle} description={pageDesc} canonical="/methodology/" schema={methodologySchema}>
  <div class="container">
    <Breadcrumbs crumbs={crumbs} />

    <div class="page-header">
      <div class="header-badge">🔬 Methodology</div>
      <h1>Our Methodology</h1>
      <p class="lead">
        How CryptoBonusWorld researches, verifies, and scores crypto exchange bonus offers.
        Every rating is based on defined criteria, applied consistently across all exchanges.
      </p>
      <p class="meta">Last updated: <time datetime="2026-05-25">May 2026</time></p>
    </div>

    <nav class="toc" aria-label="Contents">
      <div class="toc__title">Contents</div>
      <ol class="toc__list">
        <li><a href="#what-we-do">What We Do</a></li>
        <li><a href="#data-sources">Data Sources</a></li>
        <li><a href="#rating-system">Rating System</a></li>
        <li><a href="#criteria">Rating Criteria (6 Factors)</a></li>
        <li><a href="#kyc-assessment">KYC Assessment Method</a></li>
        <li><a href="#bonus-types">Bonus Type Classification</a></li>
        <li><a href="#freshness">Data Freshness</a></li>
        <li><a href="#independence">Editorial Independence</a></li>
        <li><a href="#limitations">Limitations</a></li>
      </ol>
    </nav>

    <div class="prose">

      <h2 id="what-we-do">1. What We Do</h2>
      <p>
        CryptoBonusWorld is a crypto exchange bonus comparison platform. We research, verify
        and compare promotional offers from centralised crypto exchanges to help users find
        bonuses that match their trading goals and country of residence.
      </p>
      <p>
        We do not place deposits, execute trades, or provide investment advice. We compare
        publicly available promotional information sourced directly from official exchange pages.
      </p>
      <p>
        Our scope covers: welcome bonuses, deposit match bonuses, trading rewards, referral
        bonuses, futures bonuses, no-KYC bonus offers, and promotional code-activated offers.
      </p>

      <h2 id="data-sources">2. Data Sources</h2>
      <p>All bonus data on this site is sourced exclusively from:</p>
      <ul>
        <li><strong>Official exchange promotion pages</strong> — the canonical source for all
            bonus amounts and conditions</li>
        <li><strong>Exchange terms and conditions documents</strong> — for trading volume
            requirements, expiry dates, and eligibility conditions</li>
        <li><strong>Official exchange announcements</strong> — blog posts, press releases, and
            verified email campaigns where promotion terms are clarified</li>
        <li><strong>Direct account testing</strong> — where feasible, our team creates test
            accounts to verify sign-up flow, KYC steps, and bonus activation</li>
      </ul>
      <p>
        We do not use other comparison websites, user-submitted data, or AI-generated summaries
        as primary sources. All factual claims must be traceable to an official source.
      </p>

      <h2 id="rating-system">3. Rating System</h2>
      <p>
        Exchange ratings are expressed as a single score from <strong>1.0 to 10.0</strong>,
        computed from six weighted criteria. Scores are calculated mechanically — no subjective
        adjustment is permitted after the criteria scores are set.
      </p>
      <p>
        A score of 8.0+ indicates an excellent bonus offer with clear conditions, broad country
        support, and strong exchange reputation. A score below 5.0 indicates significant
        limitations that may make the bonus difficult to claim or less valuable in practice.
      </p>

      <div class="score-scale">
        <div class="scale-item scale-item--excellent"><span class="scale-range">8.0 – 10.0</span><span class="scale-label">Excellent</span></div>
        <div class="scale-item scale-item--good"><span class="scale-range">6.5 – 7.9</span><span class="scale-label">Good</span></div>
        <div class="scale-item scale-item--fair"><span class="scale-range">5.0 – 6.4</span><span class="scale-label">Fair</span></div>
        <div class="scale-item scale-item--poor"><span class="scale-range">< 5.0</span><span class="scale-label">Below Average</span></div>
      </div>

      <h2 id="criteria">4. Rating Criteria</h2>
      <p>The six criteria and their weights:</p>

      <div class="criteria-grid">
        <div class="criterion">
          <div class="criterion__header">
            <span class="criterion__weight">25%</span>
            <span class="criterion__name">Bonus Value</span>
          </div>
          <p>
            The headline bonus amount compared to the industry average for the exchange's
            size tier. We account for conditions: a 30,000 USDT bonus requiring $1M in
            trading volume is scored lower than a 500 USDT bonus that unlocks at $5,000
            volume. We calculate an effective bonus value based on a typical new user
            deposit of $500.
          </p>
        </div>
        <div class="criterion">
          <div class="criterion__header">
            <span class="criterion__weight">20%</span>
            <span class="criterion__name">Conditions Clarity</span>
          </div>
          <p>
            We assess how clearly the exchange communicates: trading volume requirements,
            bonus expiry dates, eligible trading pairs, minimum deposit thresholds, and
            step-by-step activation instructions. Exchanges that bury key conditions in
            footnotes or link to terms hosted in a different language are penalised.
          </p>
        </div>
        <div class="criterion">
          <div class="criterion__header">
            <span class="criterion__weight">15%</span>
            <span class="criterion__name">KYC Requirements</span>
          </div>
          <p>
            We score three KYC tiers: No KYC required (highest score), partial KYC
            required for bonus activation (mid score), and full identity verification
            required before any withdrawal (lowest score). This criterion reflects
            accessibility for new users, not a judgment on AML practices.
          </p>
        </div>
        <div class="criterion">
          <div class="criterion__header">
            <span class="criterion__weight">15%</span>
            <span class="criterion__name">Country Availability</span>
          </div>
          <p>
            Based on the number of countries where the exchange operates without
            restrictions, from our tracked list of 60+ countries. Exchanges with active
            licences in major markets (EU, UK, Australia, Canada) score higher. We
            explicitly exclude exchanges that restrict access for 50%+ of our user base.
          </p>
        </div>
        <div class="criterion">
          <div class="criterion__header">
            <span class="criterion__weight">15%</span>
            <span class="criterion__name">Exchange Reputation</span>
          </div>
          <p>
            Based on: years of operation (more years = higher score), absence of major
            security incidents or unresolved fund loss events, regulatory compliance
            record (active licences, no enforcement actions), and community trust signals
            (verified positive patterns from independent sources, not paid reviews).
          </p>
        </div>
        <div class="criterion">
          <div class="criterion__header">
            <span class="criterion__weight">10%</span>
            <span class="criterion__name">Ease of Claiming</span>
          </div>
          <p>
            The number of steps required to activate and receive the bonus, based on
            direct account testing where possible. Exchanges with one-click activation
            or automatic credit on deposit score highest. Exchanges requiring manual
            support tickets to activate bonuses score lowest.
          </p>
        </div>
      </div>

      <h2 id="kyc-assessment">5. KYC Assessment Method</h2>
      <p>We classify KYC requirements into four levels:</p>
      <ul>
        <li><strong>Level 0 — No KYC:</strong> Trading and withdrawal possible without any identity verification (up to exchange limits)</li>
        <li><strong>Level 1 — Email only:</strong> Account creation requires email; no document upload for basic trading access</li>
        <li><strong>Level 2 — Partial KYC:</strong> Photo ID required for withdrawals above a threshold, but trading starts without verification</li>
        <li><strong>Level 3 — Full KYC:</strong> Full identity verification required before any trading or withdrawal</li>
      </ul>
      <p>
        KYC level is determined through direct testing of the sign-up and withdrawal flow, not
        solely from published terms (which may be out of date or ambiguous).
      </p>

      <h2 id="bonus-types">6. Bonus Type Classification</h2>
      <p>We classify bonuses into the following types:</p>
      <ul>
        <li><strong>Welcome Bonus:</strong> Awarded upon first registration — may include a no-deposit component</li>
        <li><strong>Deposit Bonus:</strong> Match bonus activated by first or subsequent deposit</li>
        <li><strong>Trading Reward:</strong> Volume-based reward unlocked by completing trading milestones</li>
        <li><strong>Futures Bonus:</strong> Credited specifically to the futures/derivatives trading account</li>
        <li><strong>No-Deposit Bonus:</strong> Awarded without requiring a deposit — typically smaller and volume-locked</li>
        <li><strong>Referral Bonus:</strong> Earned by referring new users</li>
        <li><strong>Promotional Code Bonus:</strong> Activated by entering a specific code at sign-up</li>
      </ul>
      <p>
        When an exchange offers multiple bonus types, we rate the primary welcome package
        (the offer presented to new users at sign-up). Additional bonus types are noted
        as supplementary features.
      </p>

      <h2 id="freshness">7. Data Freshness</h2>
      <p>
        Exchange data is re-verified on the following schedule as a minimum:
      </p>
      <ul>
        <li>Exchange pages and bonus landing pages: every 30 days</li>
        <li>Bonus code pages: every 21 days</li>
        <li>Compare pages: every 45 days or when either exchange updates</li>
      </ul>
      <p>
        The "Last Verified" date shown on exchange pages is the date of most recent manual
        confirmation, not the most recent content change. We do not publish data that is
        more than 45 days old without re-verification.
      </p>
      <p>See our <a href="/update-policy/">Content Update Policy</a> for full details.</p>

      <h2 id="independence">8. Editorial Independence</h2>
      <p>
        CryptoBonusWorld earns affiliate commissions when users register through our links.
        This does not affect our ratings. Specifically:
      </p>
      <ul>
        <li>No exchange can pay to improve its score</li>
        <li>No exchange can pay for a specific position in comparison tables</li>
        <li>Affiliate status does not determine listing eligibility</li>
        <li>We list cons, limitations, and conditions for every exchange regardless of commercial relationship</li>
      </ul>
      <p>
        All affiliate links are disclosed inline and via our
        <a href="/affiliate-disclosure/">Affiliate Disclosure page</a>. See also our full
        <a href="/editorial-policy/">Editorial Policy</a>.
      </p>

      <h2 id="limitations">9. Limitations of Our Data</h2>
      <p>
        Users should be aware of the following limitations before relying on our data:
      </p>
      <ul>
        <li><strong>Bonus terms can change without notice.</strong> Always check the official exchange promotion page before registering or depositing.</li>
        <li><strong>Country restrictions may be more granular than we report.</strong> Some exchanges restrict access at the state or province level, which we may not capture.</li>
        <li><strong>Effective bonus value varies by user.</strong> Our calculations assume a standard new user with a $500 starting deposit. Your actual bonus value may differ.</li>
        <li><strong>We cannot verify every exchange's financial standing.</strong> Our reputation scoring is based on available public information; it is not an audit or regulatory assessment.</li>
        <li><strong>We are not a regulated financial service.</strong> Nothing on this site constitutes financial advice or a recommendation to open an account with any exchange.</li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  .container { max-width: 820px; margin: 0 auto; padding: 0 var(--container-pad); }

  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }
  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: var(--color-accent-muted);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: var(--radius-pill);
    padding: 0.3rem 0.75rem;
    margin-bottom: 1rem;
  }
  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .page-header .lead { font-size: 1.05rem; color: var(--color-text-secondary); margin: 0 0 0.5rem; }
  .page-header .meta { font-size: var(--text-xs); color: var(--color-text-muted); margin: 0; }

  /* TOC */
  .toc {
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }
  .toc__title {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .toc__list {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem;
  }
  .toc__list a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-weight: 500;
  }
  .toc__list a:hover { color: var(--color-accent); }

  /* Score scale */
  .score-scale {
    display: flex;
    gap: 0.5rem;
    margin: 1rem 0 1.5rem;
    flex-wrap: wrap;
  }
  .scale-item {
    flex: 1;
    min-width: 120px;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-lg);
    text-align: center;
    border: 1px solid var(--color-border);
  }
  .scale-range { display: block; font-size: 1.1rem; font-weight: 800; }
  .scale-label { display: block; font-size: var(--text-xs); color: var(--color-text-muted); margin-top: 0.2rem; }
  .scale-item--excellent { border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.06); }
  .scale-item--excellent .scale-range { color: #22c55e; }
  .scale-item--good      { border-color: rgba(245,197,66,0.3); background: rgba(245,197,66,0.06); }
  .scale-item--good      .scale-range { color: var(--color-accent); }
  .scale-item--fair      { border-color: rgba(249,115,22,0.3); background: rgba(249,115,22,0.06); }
  .scale-item--fair      .scale-range { color: #f97316; }
  .scale-item--poor      { border-color: rgba(239,68,68,0.3); background: rgba(239,68,68,0.06); }
  .scale-item--poor      .scale-range { color: #ef4444; }

  /* Criteria grid */
  .criteria-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1rem 0 1.5rem;
  }
  .criterion {
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }
  .criterion__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .criterion__weight {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-accent);
    flex-shrink: 0;
    min-width: 44px;
  }
  .criterion__name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .criterion p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 640px) {
    .toc__list { grid-template-columns: 1fr; }
    .criteria-grid { grid-template-columns: 1fr; }
    .score-scale { gap: 0.375rem; }
  }
</style>
