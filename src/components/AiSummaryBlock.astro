---
/**
 * AiSummaryBlock — structured factual summary block.
 *
 * Optimised for:
 *  - Google AI Overviews (structured answer signals)
 *  - ChatGPT citations (factual, quotable blocks)
 *  - Perplexity (clear heading + concise answer format)
 *  - Bing Copilot (machine-readable structured content)
 *
 * Use at the top of key comparison/category pages.
 */
import ExchangeLogo from './ExchangeLogo.astro';

interface SummaryItem {
  label: string;
  value: string;
  note?: string;
  slug?: string;
}

interface Props {
  title: string;
  intro: string;
  items: SummaryItem[];
  updatedDate?: string;
  showMethodologyLink?: boolean;
}

const {
  title,
  intro,
  items,
  updatedDate,
  showMethodologyLink = true,
} = Astro.props;
---

<div class="ai-summary" itemscope itemtype="https://schema.org/ItemList">
  <div class="ai-summary-header">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
    </svg>
    <span class="ai-summary-label">Quick Summary</span>
    {updatedDate && <span class="ai-summary-date">Updated {updatedDate}</span>}
  </div>

  <h2 class="ai-summary-title">{title}</h2>
  <p class="ai-summary-intro">{intro}</p>

  <ul class="ai-summary-list" role="list">
    {items.map((item, i) => (
      <li class="ai-summary-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content={String(i + 1)} />
        {item.slug
          ? <ExchangeLogo slug={item.slug} name={item.label} size={32} variant="square" />
          : <span class="ai-summary-num">{i + 1}</span>
        }
        <div class="ai-summary-content">
          <span class="ai-summary-item-label" itemprop="name">{item.label}</span>
          <span class="ai-summary-item-value">{item.value}</span>
          {item.note && <span class="ai-summary-item-note">{item.note}</span>}
        </div>
      </li>
    ))}
  </ul>

  {showMethodologyLink && (
    <div class="ai-summary-footer">
      <a href="/methodology/" class="ai-summary-method-link">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
        How we rank exchanges — our methodology
      </a>
    </div>
  )}
</div>

<style>
  .ai-summary {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.75rem;
  }
  .ai-summary-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.625rem;
  }
  .ai-summary-header svg { color: var(--color-accent); }
  .ai-summary-label {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    flex: 1;
  }
  .ai-summary-date {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .ai-summary-title {
    font-size: 1.05rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--color-text-primary);
  }
  .ai-summary-intro {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 1rem;
  }
  .ai-summary-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ai-summary-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    background: rgba(255,255,255,0.025);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.04);
  }
  .ai-summary-num {
    width: 22px;
    height: 22px;
    background: rgba(245,197,66,0.15);
    color: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 800;
    flex-shrink: 0;
  }
  .ai-summary-content {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .ai-summary-item-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .ai-summary-item-value {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .ai-summary-item-note {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .ai-summary-footer {
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .ai-summary-method-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .ai-summary-method-link:hover { color: var(--color-accent); }
  .ai-summary-method-link svg { flex-shrink: 0; }
</style>
