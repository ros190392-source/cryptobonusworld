---
import ProtoLayout from '../../layouts/ProtoLayout.astro';
const base = 'http://localhost:4322';
---

<ProtoLayout
  title="Owner Review — CBW MVP"
  description="Pre-merge owner review checklist for clean-promo-rebuild-mvp branch"
  noindex={true}
>

<style>
  body { font-family: system-ui, sans-serif; font-size: 15px; color: #111; background: #F7F8F4; }
  .wrap { max-width: 900px; margin: 0 auto; padding: 32px 20px 80px; }

  .page-title { font-size: 26px; font-weight: 800; margin-bottom: 4px; }
  .page-meta { font-size: 13px; color: #6B7280; margin-bottom: 32px; }
  .branch-badge {
    display: inline-block; font-size: 11px; font-weight: 700; font-family: monospace;
    background: #1E3A5F; color: #93C5FD; padding: 3px 10px; border-radius: 4px; margin-right: 8px;
  }
  .commit-badge {
    display: inline-block; font-size: 11px; font-family: monospace;
    background: #F3F4F6; color: #374151; padding: 3px 10px; border-radius: 4px;
  }

  /* Quick links */
  .links-bar { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 40px; }
  .link-btn {
    display: inline-block; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
    background: #fff; border: 1.5px solid #D1D5DB; color: #111; text-decoration: none;
    transition: border-color .15s, background .15s;
  }
  .link-btn:hover { border-color: #6B7280; background: #F9FAFB; }
  .link-btn.primary { background: #16A34A; color: #fff; border-color: #16A34A; }
  .link-btn.primary:hover { background: #15803D; border-color: #15803D; }

  /* Sections */
  .section { background: #fff; border: 1px solid #E5E7EB; border-radius: 12px; padding: 24px; margin-bottom: 20px; }
  .section-title {
    font-size: 16px; font-weight: 800; margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid #F3F4F6; display: flex; align-items: center; gap: 8px;
  }
  .section-num {
    width: 26px; height: 26px; border-radius: 50%; background: #F7931A; color: #fff;
    font-size: 12px; font-weight: 900; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .checklist { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
  .checklist li {
    display: flex; align-items: flex-start; gap: 10px; padding: 8px 10px;
    border-radius: 6px; border: 1px solid #F3F4F6;
    font-size: 14px; color: #374151;
  }
  .checklist li input[type="checkbox"] {
    margin-top: 2px; width: 16px; height: 16px; flex-shrink: 0; cursor: pointer; accent-color: #16A34A;
  }
  .checklist li label { cursor: pointer; line-height: 1.5; }
  .checklist li:has(input:checked) { background: #F0FDF4; border-color: #BBF7D0; }
  .checklist li:has(input:checked) label { color: #15803D; }

  /* Decision block */
  .decision-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media (max-width: 560px) { .decision-grid { grid-template-columns: 1fr; } }
  .decision-btn {
    border: 2px solid #E5E7EB; border-radius: 10px; padding: 16px;
    cursor: pointer; background: #fff; text-align: left; font-family: inherit;
    transition: border-color .15s, background .15s;
  }
  .decision-btn:hover { border-color: #9CA3AF; background: #F9FAFB; }
  .decision-btn.approve { border-color: #16A34A; }
  .decision-btn.approve:hover { background: #F0FDF4; }
  .decision-btn.hold { border-color: #DC2626; }
  .decision-btn.hold:hover { background: #FEF2F2; }
  .decision-btn.change { border-color: #F7931A; }
  .decision-btn.change:hover { background: #FFF7ED; }
  .decision-label { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
  .decision-desc { font-size: 12px; color: #6B7280; }

  /* QA results */
  .qa-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .qa-table th { text-align: left; padding: 6px 10px; background: #F9FAFB; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: #6B7280; border-bottom: 1px solid #E5E7EB; }
  .qa-table td { padding: 7px 10px; border-bottom: 1px solid #F3F4F6; vertical-align: top; }
  .qa-table tr:last-child td { border-bottom: none; }
  .pass { color: #16A34A; font-weight: 700; }
  .fail { color: #DC2626; font-weight: 700; }
  .na { color: #9CA3AF; }

  /* iframe previews */
  .iframe-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }
  @media (max-width: 640px) { .iframe-row { grid-template-columns: 1fr; } }
  .iframe-wrap { border: 1px solid #E5E7EB; border-radius: 8px; overflow: hidden; background: #fff; }
  .iframe-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #6B7280; padding: 8px 12px; border-bottom: 1px solid #F3F4F6; background: #F9FAFB; }
  .iframe-wrap iframe { width: 100%; border: none; display: block; height: 400px; }

  .note { font-size: 12px; color: #6B7280; margin-top: 10px; padding: 8px 12px; background: #F9FAFB; border-radius: 6px; border-left: 3px solid #D1D5DB; }
  .note strong { color: #374151; }
</style>

<div class="wrap">
  <div class="page-title">CBW MVP — Owner Review</div>
  <div class="page-meta">
    <span class="branch-badge">clean-promo-rebuild-mvp</span>
    <span class="commit-badge">8f7309e</span>
    &nbsp; · &nbsp; Pre-merge QA · June 2026 · <strong>noindex · not deployed</strong>
  </div>

  <!-- Quick links -->
  <div class="links-bar">
    <a class="link-btn primary" href="/" target="_blank">Homepage /</a>
    <a class="link-btn" href="/exchanges/" target="_blank">Exchanges /exchanges/</a>
    <a class="link-btn" href="/bybit/" target="_blank">Bybit /bybit/</a>
    <a class="link-btn" href="/go/bybit" target="_blank">/go/bybit →</a>
    <a class="link-btn" href="/prototype/visual-assets-bybit/" target="_blank">Visual Assets QA</a>
    <a class="link-btn" href="/prototype/bybit-light/" target="_blank">Bybit Light Prototype</a>
  </div>

  <!-- ── SECTION 1: Homepage ── -->
  <div class="section">
    <div class="section-title"><span class="section-num">1</span> Homepage Review <code style="font-size:12px;color:#6B7280;margin-left:auto">/</code></div>
    <ul class="checklist">
      <li><input type="checkbox" id="c-hero"><label for="c-hero"><strong>Hero:</strong> H1 "Crypto Promo Codes / That Actually Work" visible, orange gradient on accent line</label></li>
      <li><input type="checkbox" id="c-grid"><label for="c-grid"><strong>Exchange card grid:</strong> Bybit card renders with 1200×800 image (no crop, no distortion), Binance/MEXC placeholders visible</label></li>
      <li><input type="checkbox" id="c-cta"><label for="c-cta"><strong>CTA clarity:</strong> "Browse Exchanges" (green) and "Bybit CRYPTOBONUSW →" (ghost) buttons in hero; "Get Bonus →" on each card</label></li>
      <li><input type="checkbox" id="c-trust"><label for="c-trust"><strong>Trust/verification block:</strong> "Source-verified", "Last-checked dates", "Transparent affiliate" cards visible</label></li>
      <li><input type="checkbox" id="c-mobile-home"><label for="c-mobile-home"><strong>Mobile density:</strong> 1-column grid on narrow viewport, no overflow, text readable</label></li>
    </ul>
    <div class="iframe-row">
      <div class="iframe-wrap">
        <div class="iframe-label">Desktop (full width)</div>
        <iframe src="/"></iframe>
      </div>
      <div class="iframe-wrap">
        <div class="iframe-label" style="display:flex;align-items:center;justify-content:space-between">
          Mobile (375px)
        </div>
        <iframe src="/" style="width:375px;max-width:100%"></iframe>
      </div>
    </div>
  </div>

  <!-- ── SECTION 2: Bybit page ── -->
  <div class="section">
    <div class="section-title"><span class="section-num">2</span> Bybit Page Review <code style="font-size:12px;color:#6B7280;margin-left:auto">/exchanges/bybit/</code></div>
    <ul class="checklist">
      <li><input type="checkbox" id="b-code"><label for="b-code"><strong>Promo code above the fold:</strong> "CRYPTOBONUSW" displayed in orange code badge before article image</label></li>
      <li><input type="checkbox" id="b-copy"><label for="b-copy"><strong>Copy button:</strong> clicking copies CRYPTOBONUSW to clipboard; button text changes to "Copied!"</label></li>
      <li><input type="checkbox" id="b-cta"><label for="b-cta"><strong>CTA:</strong> green "Get Bybit Bonus" button links to /go/bybit</label></li>
      <li><input type="checkbox" id="b-table"><label for="b-table"><strong>Facts table:</strong> exchange, code, bonus, fee discount, KYC, availability, verified status, last-checked, official URL all present</label></li>
      <li><input type="checkbox" id="b-img"><label for="b-img"><strong>Article image:</strong> bybit-article-1200x675.png appears below the promo conversion block, full width, no crop</label></li>
      <li><input type="checkbox" id="b-faq"><label for="b-faq"><strong>FAQ:</strong> 5 collapsible questions visible, expand on click</label></li>
      <li><input type="checkbox" id="b-final-cta"><label for="b-final-cta"><strong>Final CTA:</strong> dark navy bottom section with CRYPTOBONUSW badge and "Open Bybit Account →" green button</label></li>
    </ul>
    <div class="iframe-row">
      <div class="iframe-wrap">
        <div class="iframe-label">Desktop</div>
        <iframe src="/exchanges/bybit/"></iframe>
      </div>
      <div class="iframe-wrap">
        <div class="iframe-label">Mobile (375px)</div>
        <iframe src="/exchanges/bybit/" style="width:375px;max-width:100%"></iframe>
      </div>
    </div>
  </div>

  <!-- ── SECTION 3: Visual assets ── -->
  <div class="section">
    <div class="section-title"><span class="section-num">3</span> Visual Assets Review</div>
    <ul class="checklist">
      <li><input type="checkbox" id="v-og"><label for="v-og"><strong>OG image 1200×630:</strong> <a href="/media/exchanges/bybit/share/bybit-og-1200x630.png" target="_blank">bybit-og-1200x630.png</a> — design clean, no promo code, no date, no bonus amount</label></li>
      <li><input type="checkbox" id="v-article"><label for="v-article"><strong>Article image 1200×675:</strong> <a href="/media/exchanges/bybit/article/bybit-article-1200x675.png" target="_blank">bybit-article-1200x675.png</a> — evergreen, no promo code/date</label></li>
      <li><input type="checkbox" id="v-card"><label for="v-card"><strong>Card image 1200×800 (3:2):</strong> <a href="/media/exchanges/bybit/cards/bybit-card-1200x800.png" target="_blank">bybit-card-1200x800.png</a> — approved v1.1, no crop on grid</label></li>
    </ul>
    <div class="note"><strong>Evergreen rule:</strong> images must NOT contain promo code, bonus amount, date, verified claim, or temporary conditions. Volatile data lives in HTML only.</div>
  </div>

  <!-- ── SECTION 4: Mobile review ── -->
  <div class="section">
    <div class="section-title"><span class="section-num">4</span> Mobile Review</div>
    <ul class="checklist">
      <li><input type="checkbox" id="m-375"><label for="m-375"><strong>375px:</strong> 1-column grid, no horizontal overflow, images scale correctly</label></li>
      <li><input type="checkbox" id="m-390"><label for="m-390"><strong>390px (iPhone 14):</strong> layout intact, hero text fits, CTA buttons full width</label></li>
      <li><input type="checkbox" id="m-768"><label for="m-768"><strong>768px (tablet):</strong> 2-column card grid, comfortable spacing</label></li>
      <li><input type="checkbox" id="m-overflow"><label for="m-overflow"><strong>No horizontal overflow:</strong> no scrollbar on any viewport ≤ 375px</label></li>
      <li><input type="checkbox" id="m-nocrop"><label for="m-nocrop"><strong>No cropped images:</strong> card images maintain 3:2 ratio on all viewports</label></li>
    </ul>
    <div class="note">Tip: open <a href="/" target="_blank">/</a> in Chrome DevTools → Toggle device toolbar → test at 375, 390, 768px.</div>
  </div>

  <!-- ── SECTION 5: Pre-merge decision ── -->
  <div class="section">
    <div class="section-title"><span class="section-num">5</span> Pre-Merge Decision</div>
    <p style="font-size:13px;color:#4B5563;margin-bottom:14px">Check all items above, then select a decision. No merge or deploy happens until you confirm explicitly in the chat.</p>
    <div class="decision-grid">
      <button class="decision-btn approve" onclick="this.style.background='#DCFCE7';this.style.borderColor='#16A34A'">
        <div class="decision-label" style="color:#16A34A">✅ Approve as MVP</div>
        <div class="decision-desc">Merge clean-promo-rebuild-mvp → master and deploy to production</div>
      </button>
      <button class="decision-btn change" onclick="this.style.background='#FFF7ED';this.style.borderColor='#F7931A'">
        <div class="decision-label" style="color:#C2410C">🎨 Request visual changes</div>
        <div class="decision-desc">Specific layout or design changes needed before merge</div>
      </button>
      <button class="decision-btn change" onclick="this.style.background='#FFF7ED';this.style.borderColor='#F7931A'">
        <div class="decision-label" style="color:#C2410C">✏️ Request copy changes</div>
        <div class="decision-desc">Text or content updates needed before merge</div>
      </button>
      <button class="decision-btn hold" onclick="this.style.background='#FEF2F2';this.style.borderColor='#DC2626'">
        <div class="decision-label" style="color:#DC2626">⏸ Hold deploy</div>
        <div class="decision-desc">Branch stays on hold — no changes, no deploy yet</div>
      </button>
    </div>
    <div class="note" style="margin-top:12px"><strong>Note:</strong> clicking a button above is visual only. To execute a decision, send the instruction in the chat.</div>
  </div>

</div>

</ProtoLayout>
