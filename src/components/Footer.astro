---
import { EXCHANGE_COUNT } from '../utils/seo';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="CryptoBonusWorld Home">
          <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true" style="flex-shrink:0">
            <defs>
              <linearGradient id="ftr-gold" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#fcd34d"/>
                <stop offset="100%" stop-color="#d97706"/>
              </linearGradient>
            </defs>
            <circle cx="16" cy="16" r="16" fill="#0a0c14"/>
            <circle
              cx="16" cy="16" r="10.75"
              fill="none"
              stroke="url(#ftr-gold)"
              stroke-width="4.5"
              stroke-linecap="butt"
              stroke-dasharray="48.78 18.76"
              transform="rotate(50 16 16)"
            />
          </svg>
          <span>Crypto<strong style="background:linear-gradient(135deg,#fbbf24,#f5c542,#d97706);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Bonus</strong>World</span>
        </a>
        <p class="footer-tagline">Compare crypto exchange bonuses and claim the best rewards for your trading goals.</p>
        <p class="footer-disclosure">
          CryptoBonusWorld may receive compensation when users register through affiliate links on this site.
          <a href="/affiliate-disclosure/">Read our affiliate disclosure</a>
        </p>
      </div>

      <div class="footer-links">
        <h4>Top Exchanges</h4>
        <ul>
          <li><a href="/bybit/">Bybit Bonus</a></li>
          <li><a href="/okx/">OKX Bonus</a></li>
          <li><a href="/mexc/">MEXC Bonus</a></li>
          <li><a href="/bitget/">Bitget Bonus</a></li>
          <li><a href="/kucoin/">KuCoin Bonus</a></li>
          <li><a href="/bingx/">BingX Bonus</a></li>
          <li><a href="/exchanges/">All {EXCHANGE_COUNT} Exchanges →</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4><a href="/promo-codes/" class="footer-h4-link">Promo Codes</a></h4>
        <ul>
          <li><a href="/promo-codes/">All Crypto Promo Codes</a></li>
          <li><a href="/bybit/">Bybit Referral Code</a></li>
          <li><a href="/mexc/">MEXC Referral Code</a></li>
          <li><a href="/okx/">OKX Referral Code</a></li>
          <li><a href="/bitget/">Bitget Referral Code</a></li>
          <li><a href="/kucoin/">KuCoin Referral Code</a></li>
          <li><a href="/bingx/">BingX Referral Code</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>Resources</h4>
        <ul>
          <li><a href="/methodology/">Our Methodology</a></li>
          <li><a href="/update-policy/">Update Policy</a></li>
          <li><a href="/about/">About Us</a></li>
          <li><a href="/editorial-policy/">Editorial Policy</a></li>
          <li><a href="/affiliate-disclosure/">Affiliate Disclosure</a></li>
          <li><a href="/disclaimer/">Disclaimer</a></li>
          <li><a href="/privacy-policy/">Privacy Policy</a></li>
          <li><a href="/terms/">Terms of Use</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="risk-notice">
        <strong>Risk Warning:</strong> Crypto trading involves significant risk of loss. Bonuses may include KYC requirements, deposit conditions, trading volume requirements and expiration dates. This website does not constitute financial or investment advice. Always read official promotion terms before claiming any bonus.
      </p>
      <div class="footer-legal">
        <span>© {year} CryptoBonusWorld.com — All rights reserved</span>
        <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
        <a href="/disclaimer/">Disclaimer</a>
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms/">Terms of Use</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
  }
  .footer-inner { padding: 3rem 0 2rem; }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    gap: 1.5rem 1.25rem;
    margin-bottom: 2rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }
  .logo-icon { color: var(--color-accent); font-size: 1.25rem; }
  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }
  .footer-disclosure {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .footer-disclosure a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .footer-links h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .footer-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--color-text-primary); }
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }
  .risk-notice {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .footer-legal a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-legal a:hover { color: var(--color-text-secondary); }
  /* Clickable heading links */
  .footer-h4-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-h4-link:hover { color: var(--color-accent); }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: repeat(3, 1fr); }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1.25rem;
    }
    .footer-brand { grid-column: 1 / -1; }
    .footer-inner { padding: 2.5rem 0 1.5rem; }
    .footer-legal {
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.75rem;
    }
    .risk-notice { font-size: 0.72rem; }
    .footer-bottom { padding-top: 1.25rem; }
  }
  @media (max-width: 400px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
