---
/**
 * EditorialExperienceBar.astro
 * Subtle E-E-A-T signals: shows what our team actually tested/verified.
 * Keeps language calm and factual — no fake urgency, no overclaiming.
 */

type Signal =
  | 'desktop-tested'
  | 'mobile-tested'
  | 'withdrawal-verified'
  | 'p2p-checked'
  | 'bonus-checked'
  | 'fees-verified'
  | 'kyc-tested'
  | 'editorial-reviewed'
  | 'content-fresh';

interface Props {
  signals: Signal[];
  verifiedAt?: string;   // "May 2026"
  compact?: boolean;
}

const { signals, verifiedAt, compact = false } = Astro.props;

const SIGNAL_LABELS: Record<Signal, { icon: string; text: string }> = {
  'desktop-tested':     { icon: '🖥️', text: 'Tested on desktop' },
  'mobile-tested':      { icon: '📱', text: 'Tested on mobile' },
  'withdrawal-verified':{ icon: '✓',  text: 'Withdrawal process verified' },
  'p2p-checked':        { icon: '🔄', text: 'P2P liquidity checked' },
  'bonus-checked':      { icon: '✓',  text: 'Bonus terms verified' },
  'fees-verified':      { icon: '✓',  text: 'Fee structure confirmed' },
  'kyc-tested':         { icon: '🪪', text: 'KYC flow tested' },
  'editorial-reviewed': { icon: '✓',  text: 'Editorial team reviewed' },
  'content-fresh':      { icon: '✓',  text: `Updated ${verifiedAt ?? '2026'}` },
};

const displaySignals = signals.filter(s => SIGNAL_LABELS[s]);
---

{displaySignals.length > 0 && (
  <div class={`eeb-wrap ${compact ? 'eeb-wrap--compact' : ''}`} role="note" aria-label="Editorial verification signals">
    {displaySignals.map(signal => {
      const def = SIGNAL_LABELS[signal];
      return (
        <span class="eeb-item">
          <span class="eeb-icon" aria-hidden="true">{def.icon}</span>
          <span class="eeb-text">{def.text}</span>
        </span>
      );
    })}
  </div>
)}

<style>
  .eeb-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.625rem 0;
    margin-bottom: 1rem;
  }

  .eeb-wrap--compact {
    padding: 0.375rem 0;
    margin-bottom: 0.75rem;
  }

  .eeb-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted, #666);
    background: var(--surface-overlay, #151515);
    border: 1px solid var(--color-border-subtle, #1c1c1c);
    border-radius: var(--radius-pill, 100px);
    padding: 0.2rem 0.625rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .eeb-icon {
    font-size: 0.65rem;
    line-height: 1;
    color: #4ade80;
  }

  .eeb-wrap--compact .eeb-item {
    padding: 0.15rem 0.5rem;
    font-size: 0.65rem;
  }
</style>
