---
/**
 * ScreenshotCard.astro
 * Production-ready screenshot component.
 *
 * FIT MODES (controls how image renders inside the frame):
 *   'cover'   — (default) fill container, may crop. Good for grids/galleries.
 *   'contain' — fit inside box with dark letterboxing. No cropping.
 *   'natural' — image at its true proportions, frame height follows image.
 *               Preferred for step-by-step tutorial screenshots.
 *
 * Other features:
 *   - Dark frame with rounded corners
 *   - Optional browser/mobile chrome
 *   - Lightbox trigger via data-lightbox-group
 *   - Lazy loading, responsive scaling
 *   - Placeholder mode when src is absent (always uses aspect-ratio for layout stability)
 *   - CLS prevention: aspect-ratio on <img> when fit=natural and no width/height given
 */

type Device = 'desktop' | 'mobile' | 'none';
type Fit    = 'cover' | 'contain' | 'natural';

interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  capturedAt?: string;       // "YYYY-MM"
  aspectRatio?: string;      // CSS value: "16/9" | "2/1" | "4/3" etc.
  width?: number;
  height?: number;
  lazy?: boolean;
  lightboxGroup?: string;    // if set, click opens lightbox modal
  device?: Device;           // adds chrome frame
  label?: string;            // shown on placeholder + lightbox
  class?: string;
  /** Emit schema.org ImageObject JSON-LD for this image */
  schema?: boolean;
  /** Absolute URL for schema.org contentUrl (falls back to src) */
  canonicalUrl?: string;
  /** Media category tag shown in caption (e.g. "P2P Trading", "Futures") */
  mediaCategory?: string;
  /**
   * How the image fills its frame:
   *   'cover'   — fill+crop (default, backward-compat for galleries)
   *   'contain' — fit with dark bars, no crop
   *   'natural' — no forced aspect-ratio on container, image at true proportions
   */
  fit?: Fit;
}

const {
  src,
  alt,
  caption,
  capturedAt,
  aspectRatio = '16/9',
  width,
  height,
  lazy = true,
  lightboxGroup,
  device = 'none',
  label,
  class: extraClass,
  schema: emitSchema = false,
  canonicalUrl,
  mediaCategory,
  fit = 'cover',
} = Astro.props;

function fmtMonth(ym: string): string {
  try {
    const d = new Date(ym + '-01');
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  } catch { return ym; }
}

const isPlaceholder = !src;
const hasLightbox   = !!lightboxGroup && !!src;
const displayAlt    = alt ?? label ?? 'Screenshot';

// Determine whether the frame gets a fixed aspect-ratio:
//   - Placeholders always get it (layout stability while image is being prepared)
//   - 'natural' + real image → no frame ratio, image determines height
//   - 'cover' or 'contain'  → frame ratio enforced
//   - mobile + no explicit ratio → skip (mobile portrait logic)
const useFrameRatio = isPlaceholder
  || (fit !== 'natural')
  || (device === 'mobile' && aspectRatio === '16/9');

// Style string for the frame element
const frameStyle = useFrameRatio ? `aspect-ratio: ${aspectRatio}` : '';

// For 'natural' + real image: put aspect-ratio on <img> for CLS prevention
// (browser reserves space before image loads even without width/height attrs)
const imgCLSStyle = (fit === 'natural' && !!src && !width) ? `aspect-ratio: ${aspectRatio}` : '';

// schema.org ImageObject JSON-LD
const SITE_URL = 'https://cryptobonusworld.com';
const schemaData = emitSchema && src ? {
  '@context': 'https://schema.org',
  '@type': 'ImageObject',
  contentUrl: canonicalUrl ?? (src.startsWith('http') ? src : `${SITE_URL}${src}`),
  name: displayAlt,
  description: caption ?? displayAlt,
  ...(capturedAt ? { datePublished: capturedAt + '-01' } : {}),
  ...(width ? { width } : {}),
  ...(height ? { height } : {}),
} : null;
---

{schemaData && (
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
)}
<figure
  class={`sc-wrap ${device === 'mobile' ? 'sc-wrap--portrait' : ''} ${hasLightbox ? 'sc-wrap--clickable' : ''} ${extraClass ?? ''}`}
  data-lightbox-group={lightboxGroup}
  data-lightbox-src={src}
  data-lightbox-alt={displayAlt}
  data-lightbox-caption={caption}
  data-lightbox-category={mediaCategory ?? ''}
  data-lightbox-date={capturedAt ?? ''}
  itemscope={emitSchema && !!src ? '' : undefined}
  itemtype={emitSchema && !!src ? 'https://schema.org/ImageObject' : undefined}
>
  {device === 'desktop' && (
    <div class="sc-chrome sc-chrome--desktop" aria-hidden="true">
      <span class="sc-chrome-dot"></span>
      <span class="sc-chrome-dot"></span>
      <span class="sc-chrome-dot"></span>
      <span class="sc-chrome-bar"></span>
    </div>
  )}
  {device === 'mobile' && (
    <div class="sc-chrome sc-chrome--mobile" aria-hidden="true">
      <span class="sc-chrome-notch"></span>
    </div>
  )}

  <div
    class={`sc-frame sc-frame--${fit} ${device !== 'none' ? 'sc-frame--chrome' : ''} ${isPlaceholder ? 'sc-frame--placeholder' : ''} ${hasLightbox ? 'sc-frame--lightbox' : ''}`}
    style={frameStyle || undefined}
  >
    {src ? (
      <>
        <img
          src={src}
          alt={displayAlt}
          width={width}
          height={height}
          loading={lazy ? 'lazy' : 'eager'}
          decoding="async"
          class="sc-img"
          style={imgCLSStyle || undefined}
        />
        {capturedAt && (
          <span class="sc-date-badge">Updated {fmtMonth(capturedAt)}</span>
        )}
        {hasLightbox && (
          <button class="sc-zoom-btn" aria-label="Enlarge screenshot" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </button>
        )}
      </>
    ) : (
      <div class="sc-placeholder-inner" role="img" aria-label={`${label ?? 'Screenshot'} — image being prepared`}>
        <svg class="sc-ph-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="14" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        {label && <span class="sc-ph-label">{label}</span>}
        <span class="sc-ph-tag">Screenshot in preparation</span>
      </div>
    )}
  </div>

  {(caption || mediaCategory) && (
    <figcaption class="sc-caption">
      {mediaCategory && <span class="sc-cat-tag">{mediaCategory}</span>}
      {caption && <span>{caption}</span>}
      {capturedAt && !caption && <span>Captured {fmtMonth(capturedAt)}</span>}
    </figcaption>
  )}
</figure>

<style>
  .sc-wrap {
    margin: 0;
    width: 100%;
    display: block;
  }

  /* ── Desktop chrome ── */
  .sc-chrome--desktop {
    display: flex;
    align-items: center;
    gap: 5px;
    background: #2a2a2a;
    border: 1px solid #3a3a3a;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    padding: 7px 10px;
  }
  .sc-chrome-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #555;
  }
  .sc-chrome-dot:nth-child(1) { background: #f87171; }
  .sc-chrome-dot:nth-child(2) { background: #fbbf24; }
  .sc-chrome-dot:nth-child(3) { background: #34d399; }
  .sc-chrome-bar {
    flex: 1;
    height: 14px;
    background: #1e1e1e;
    border-radius: 3px;
    margin-left: 4px;
  }

  /* ── Mobile chrome ── */
  .sc-chrome--mobile {
    background: #1a1a1a;
    border: 1px solid #333;
    border-bottom: none;
    border-radius: 20px 20px 0 0;
    display: flex;
    justify-content: center;
    padding: 6px 0 4px;
  }
  .sc-chrome-notch {
    width: 40px; height: 4px;
    background: #444;
    border-radius: 2px;
  }

  /* ── Frame ── */
  .sc-frame {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--color-border, #2a2a2a);
    background: #0f0f0f;
    /* Subtle inner highlight — enterprise polish */
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
  }
  .sc-frame--chrome {
    border-radius: 0 0 8px 8px;
    border-top: none;
  }
  .sc-frame--placeholder {
    border-style: dashed;
    border-color: #333;
    box-shadow: none;
  }
  .sc-frame--lightbox {
    cursor: zoom-in;
  }
  .sc-frame--lightbox:hover .sc-zoom-btn { opacity: 1; }

  /* Entire card is clickable when lightbox is active */
  .sc-wrap--clickable {
    cursor: zoom-in;
  }
  .sc-wrap--clickable .sc-chrome--desktop,
  .sc-wrap--clickable .sc-chrome--mobile {
    cursor: zoom-in;
  }

  /* ── Image: base (cover mode, backward-compat default) ── */
  .sc-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Contain mode: fit within box, dark bars, NO cropping ── */
  .sc-frame--contain .sc-img {
    object-fit: contain;
    /* height stays 100% — image scales down to fit inside the aspect-ratio box */
  }

  /* ── Natural mode: image at true proportions, zero cropping ── */
  .sc-frame--natural {
    /* No forced aspect-ratio on the frame — height follows image */
  }
  .sc-frame--natural .sc-img {
    height: auto;           /* natural height — never cropped */
    /* contain (not unset): when the inline CLS aspect-ratio hint differs from
       the image's true ratio, the mismatch becomes dark letterbox bars instead
       of a stretched/distorted image. With a matching ratio it has no effect. */
    object-fit: contain;
    display: block;
    width: 100%;
    /* aspect-ratio set inline on <img> for CLS prevention when width/height absent */
  }

  /* ── Portrait / mobile layout ── */
  .sc-wrap--portrait {
    max-width: 360px;
    margin: 0 auto;
  }
  .sc-wrap--portrait .sc-chrome--mobile {
    border-radius: 20px 20px 0 0;
  }
  .sc-wrap--portrait .sc-frame {
    aspect-ratio: unset;
    height: auto;
  }
  /* portrait + no ratio = full image (contain) */
  .sc-wrap--portrait .sc-img {
    object-fit: contain;
    height: auto;
    width: 100%;
    display: block;
  }
  /* portrait + explicit ratio = crop to amount area */
  .sc-wrap--portrait .sc-frame[style] .sc-img {
    object-fit: cover;
    object-position: center 45%;
    height: 100%;
  }

  /* ── Date badge ── */
  .sc-date-badge {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.65);
    color: #bbb;
    font-size: 0.62rem;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.02em;
    pointer-events: none;
  }

  /* ── Zoom button ── */
  .sc-zoom-btn {
    position: absolute;
    top: 6px;
    right: 6px;
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    color: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px; height: 26px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .sc-zoom-btn:hover { background: rgba(0,0,0,0.85); }

  /* ── Placeholder ── */
  .sc-placeholder-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1.5rem;
    text-align: center;
    background: linear-gradient(135deg, rgba(245,197,66,0.03) 0%, rgba(0,0,0,0) 100%);
  }
  .sc-ph-icon { color: #444; flex-shrink: 0; }
  .sc-ph-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary, #888);
    line-height: 1.3;
    max-width: 200px;
  }
  .sc-ph-tag {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #444;
    border: 1px solid #333;
    border-radius: 3px;
    padding: 2px 6px;
  }

  /* ── Caption ── */
  .sc-caption {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.35rem;
    font-size: 0.72rem;
    color: var(--color-text-muted, #666);
    text-align: center;
    line-height: 1.4;
    font-style: italic;
  }
  .sc-cat-tag {
    font-style: normal;
    font-weight: 700;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent, #f5c542);
    background: rgba(245,197,66,0.08);
    border: 1px solid rgba(245,197,66,0.2);
    border-radius: 3px;
    padding: 1px 5px;
  }
</style>
