---
interface Props {
  required: boolean;
}
const { required } = Astro.props;
---

<span class:list={['kyc-badge', required ? 'kyc-badge--required' : 'kyc-badge--none']}>
  {required ? 'KYC Required' : 'No KYC'}
</span>

<style>
  .kyc-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill, 100px);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    line-height: 1;
  }
  .kyc-badge--required {
    background: rgba(248, 113, 113, 0.1);
    color: #f87171;
    border: 1px solid rgba(248, 113, 113, 0.22);
  }
  .kyc-badge--none {
    background: rgba(74, 222, 128, 0.1);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.22);
  }
</style>
