---
/**
 * OfferRealism.astro
 * ============================================================
 * Displays transparent, trust-building signals about a bonus offer.
 * Uses the validation fields added in Phase 6:
 *   offerConfidenceScore, realisticUserExpectation, verificationLastChecked,
 *   bonusConditionSummary, bonusDisplayMode
 *
 * Design intent:
 *  - Replace "up to 30,000 USDT!" hype with honest user-first framing
 *  - Show confidence score as a visual meter (not a scary number)
 *  - Surface what typical users actually earn (not the maximum edge case)
 *  - Show when the offer was last verified
 *  - Link to official terms
 *
 * Usage:
 *   <OfferRealism
 *     exchangeName="Bybit"
 *     offerConfidenceScore={72}
 *     realisticUserExpectation="Most users earn 200–600 USDT completing deposit + trading tasks"
 *     verificationLastChecked="2026-05-25"
 *     bonusConditionSummary="KYC + deposit + trading volume within 30 days"
 *     bonusDisplayMode="up-to"
 *     termsUrl="https://www.bybit.com/en/bonus"
 *   />
 */

interface Props {
  exchangeName: string;
  offerConfidenceScore?: number | null;
  realisticUserExpectation?: string | null;
  verificationLastChecked?: string | null;
  bonusConditionSummary?: string | null;
  bonusDisplayMode?: 'up-to' | 'fixed' | 'campaign' | 'range' | 'regional';
  termsUrl?: string | null;
  /** Compact single-row variant (for sidebar or inline use) */
  compact?: boolean;
}

const {
  exchangeName,
  offerConfidenceScore,
  realisticUserExpectation,
  verificationLastChecked,
  bonusConditionSummary,
  bonusDisplayMode = 'up-to',
  termsUrl,
  compact = false,
} = Astro.props;

// ── Confidence level labelling ──────────────────────────────────────────────
function confidenceLabel(score: number): { label: string; color: string; emoji: string } {
  if (score >= 90) return { label: 'Very High Confidence', color: '#4ade80', emoji: '✅' };
  if (score >= 80) return { label: 'High Confidence',      color: '#86efac', emoji: '✓' };
  if (score >= 70) return { label: 'Moderate Confidence',  color: '#fbbf24', emoji: '~' };
  if (score >= 60) return { label: 'Variable Offer',       color: '#f97316', emoji: '⚡' };
  return               { label: 'Campaign-Based',          color: '#f87171', emoji: '📋' };
}

const conf = offerConfidenceScore != null ? confidenceLabel(offerConfidenceScore) : null;

// ── Format verification date ─────────────────────────────────────────────────
function fmtDate(iso: string): string {
  try {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  } catch { return iso; }
}

const isCampaign = bonusDisplayMode === 'campaign';
---

{compact ? (
  <!-- Compact single-row variant -->
  <div class="or-compact">
    {conf && (
      <span class="or-compact-conf" style={`color: ${conf.color}`}>
        {conf.emoji} {conf.label}
      </span>
    )}
    {verificationLastChecked && (
      <span class="or-compact-date">
        Verified {fmtDate(verificationLastChecked)}
      </span>
    )}
    {isCampaign && (
      <span class="or-compact-campaign">
        Verify current offer on official site
      </span>
    )}
  </div>
) : (
  <!-- Full block variant -->
  <div class="or-block">
    <div class="or-header">
      <span class="or-header-icon">🔍</span>
      <span class="or-header-title">Offer Transparency</span>
      {verificationLastChecked && (
        <span class="or-verified-date">Verified {fmtDate(verificationLastChecked)}</span>
      )}
    </div>

    {conf && offerConfidenceScore != null && (
      <div class="or-confidence">
        <div class="or-conf-row">
          <span class="or-conf-label">Offer Reliability</span>
          <span class="or-conf-badge" style={`color: ${conf.color}; border-color: ${conf.color}33`}>
            {conf.emoji} {conf.label}
          </span>
        </div>
        <div class="or-conf-bar-wrap" aria-label={`Confidence score: ${offerConfidenceScore} out of 100`}>
          <div
            class="or-conf-bar-fill"
            style={`width: ${offerConfidenceScore}%; background: ${conf.color}`}
          />
        </div>
      </div>
    )}

    {realisticUserExpectation && (
      <div class="or-realistic">
        <div class="or-realistic-label">What typical users earn</div>
        <p class="or-realistic-text">{realisticUserExpectation}</p>
      </div>
    )}

    {bonusConditionSummary && (
      <div class="or-conditions">
        <div class="or-conditions-label">Key conditions</div>
        <p class="or-conditions-text">{bonusConditionSummary}</p>
      </div>
    )}

    {isCampaign && (
      <div class="or-campaign-warning">
        <span class="or-campaign-icon">📋</span>
        <span>This is a campaign-based offer. Terms, amounts and availability change regularly. Always verify the current bonus on the {exchangeName} official website before registering.</span>
      </div>
    )}

    <div class="or-footer">
      <span class="or-footer-note">Conditions verified by CryptoBonusWorld editorial team.</span>
      {termsUrl && (
        <a href={termsUrl} target="_blank" rel="noopener noreferrer nofollow" class="or-terms-link">
          View official terms ↗
        </a>
      )}
    </div>
  </div>
)}

<style>
  /* ── Full block ── */
  .or-block {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.82rem;
  }

  .or-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .or-header-icon { font-size: 0.9rem; }
  .or-header-title {
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-secondary);
    flex: 1;
  }
  .or-verified-date {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    background: rgba(74,222,128,0.08);
    border: 1px solid rgba(74,222,128,0.15);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }

  /* Confidence meter */
  .or-confidence { display: flex; flex-direction: column; gap: 0.4rem; }
  .or-conf-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .or-conf-label {
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }
  .or-conf-badge {
    font-size: 0.68rem;
    font-weight: 700;
    border: 1px solid;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }
  .or-conf-bar-wrap {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }
  .or-conf-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.4s;
  }

  /* Realistic expectation */
  .or-realistic { display: flex; flex-direction: column; gap: 0.2rem; }
  .or-realistic-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }
  .or-realistic-text {
    margin: 0;
    color: var(--color-text-primary);
    font-size: 0.825rem;
    line-height: 1.5;
  }

  /* Conditions */
  .or-conditions { display: flex; flex-direction: column; gap: 0.2rem; }
  .or-conditions-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }
  .or-conditions-text {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  /* Campaign warning */
  .or-campaign-warning {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    background: rgba(248,113,113,0.06);
    border: 1px solid rgba(248,113,113,0.15);
    border-radius: 6px;
    padding: 0.6rem 0.75rem;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .or-campaign-icon { flex-shrink: 0; }

  /* Footer */
  .or-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    padding-top: 0.5rem;
    margin-top: -0.25rem;
  }
  .or-footer-note {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .or-terms-link {
    font-size: 0.7rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }
  .or-terms-link:hover { text-decoration: underline; }

  /* ── Compact variant ── */
  .or-compact {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    padding: 0.35rem 0;
    font-size: 0.72rem;
  }
  .or-compact-conf {
    font-weight: 700;
  }
  .or-compact-date {
    color: var(--color-text-muted);
  }
  .or-compact-campaign {
    color: #f97316;
    font-style: italic;
  }
</style>
