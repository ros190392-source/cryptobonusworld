        navigator.clipboard.writeText(promoCode).then(function () {
          var row = btn.closest('.bh-promo-row');
          var codeSpan = row ? row.querySelector('.bh-promo-code') : null;
          btn.textContent = 'Copied ✓';
          btn.classList.add('copy-success');
          if (row) row.classList.add('copy-success');
          if (codeSpan) codeSpan.classList.add('copy-success');
          setTimeout(function () {
            btn.textContent = 'Copy';
            btn.classList.remove('copy-success');
            if (row) row.classList.remove('copy-success');
            if (codeSpan) codeSpan.classList.remove('copy-success');
          }, 1800);
        });
      });
    }

    var DEAL_PREFIX = 'cbw_deal_activated_';
    document.querySelectorAll('.p2-rel-btn').forEach(function(relBtn) {
      var slug = relBtn.getAttribute('data-exchange');
      if (!slug) return;
      try {
        if (localStorage.getItem(DEAL_PREFIX + slug)) {
          relBtn.textContent = 'Deal Activated';
          relBtn.classList.add('is-activated');
        }
      } catch(e) {}
      relBtn.addEventListener('click', function() {
        try { localStorage.setItem(DEAL_PREFIX + slug, '1'); } catch(e) {}
        relBtn.textContent = 'Deal Activated';
        relBtn.classList.add('is-activated');
      });
    });

    // ── Real voting — aggregated via /api/exchange-votes ──
    var VOTES_API = '/api/exchange-votes';
    var voteUpBtn   = document.getElementById('vote-up');
    var voteDownBtn = document.getElementById('vote-down');
    var voteStatus  = document.getElementById('vote-status');
    var starBtns    = [].slice.call(document.querySelectorAll('.p2-star-btn'));
    var ratingSummary = document.getElementById('rating-summary');
    var VOTES_UNAVAILABLE = 'Voting is temporarily unavailable. Please try again later.';

    function makeUserKey() {
      if (self.crypto && crypto.randomUUID) return crypto.randomUUID();
      var s = ''; while (s.length < 32) s += Math.floor(Math.random() * 16).toString(16);
      return s;
    }
    var userKey = null;
    try {
      userKey = localStorage.getItem('cbw_user_key');
      if (!userKey) { userKey = makeUserKey(); localStorage.setItem('cbw_user_key', userKey); }
    } catch (e) { userKey = makeUserKey(); }

    function votesApi(method, body) {
      var headers = { 'X-CBW-User': userKey };
      if (method === 'POST') headers['Content-Type'] = 'application/json';
      return fetch(VOTES_API + (method === 'GET' ? '?exchange=' + encodeURIComponent(exchangeSlug) : ''), {
        method: method, headers: headers,
        body: method === 'POST' ? JSON.stringify(body) : undefined,
      }).then(function (r) { if (!r.ok) throw new Error('http ' + r.status); return r.json(); });
    }

    function renderVotes(agg) {
      var fill = agg.userRating || Math.round(agg.averageRating || 0);
      starBtns.forEach(function (b) {
        var n = +b.getAttribute('data-star');
        b.classList.toggle('is-filled', n <= fill);
        b.setAttribute('aria-checked', agg.userRating === n ? 'true' : 'false');
      });
      if (ratingSummary) {
        ratingSummary.textContent = agg.ratingCount > 0
          ? 'Rated ' + agg.averageRating + '/5 from ' + agg.ratingCount + ' user vote' + (agg.ratingCount === 1 ? '' : 's') + '.'
          : 'No ratings yet — be the first to rate this code.';
      }
      if (voteUpBtn && voteDownBtn) {
        voteUpBtn.classList.toggle('is-selected-up', agg.userHelpfulVote === 'works');
        voteDownBtn.classList.toggle('is-selected-down', agg.userHelpfulVote === 'didnt_work');
      }
      if (voteStatus) {
        var total = agg.worksCount + agg.didntWorkCount;
        voteStatus.textContent = total > 0
          ? Math.round(agg.worksCount / total * 100) + '% of ' + total + ' voter' + (total === 1 ? '' : 's') + ' said this code worked.'
          : 'No votes yet — be the first to rate this code.';
      }
    }

    votesApi('GET').then(renderVotes).catch(function () { /* keep honest default text */ });

    starBtns.forEach(function (b) {
      b.addEventListener('click', function () {
        var n = +b.getAttribute('data-star');
        votesApi('POST', { exchange: exchangeSlug, type: 'rating', rating: n })
          .then(function (agg) { renderVotes(agg); if (ratingSummary) ratingSummary.textContent += ' Thanks — your rating was recorded.'; })
          .catch(function () { if (ratingSummary) ratingSummary.textContent = VOTES_UNAVAILABLE; });
      });
    });
    function sendHelpful(value) {
      votesApi('POST', { exchange: exchangeSlug, type: 'helpful', helpful: value })
        .then(function (agg) { renderVotes(agg); if (voteStatus) voteStatus.textContent += ' Thanks — your vote was recorded.'; })
        .catch(function () { if (voteStatus) voteStatus.textContent = VOTES_UNAVAILABLE; });
    }
    if (voteUpBtn)   voteUpBtn.addEventListener('click',   function () { sendHelpful('works'); });
    if (voteDownBtn) voteDownBtn.addEventListener('click', function () { sendHelpful('didnt_work'); });

    var couponBtn = document.getElementById('copy-btn-coupon');
    if (couponBtn) {
      couponBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(promoCode).then(function () {
          var row = couponBtn.closest('.bh-promo-row');
          var codeSpan = row ? row.querySelector('.bh-promo-code') : null;
          couponBtn.textContent = 'Copied ✓';
          couponBtn.classList.add('copy-success');
          if (row) row.classList.add('copy-success');
          if (codeSpan) codeSpan.classList.add('copy-success');
          setTimeout(function () {
            couponBtn.textContent = 'Copy';
            couponBtn.classList.remove('copy-success');
            if (row) row.classList.remove('copy-success');
            if (codeSpan) codeSpan.classList.remove('copy-success');
          }, 1800);
        });
      });
    }
  })();
</script>

