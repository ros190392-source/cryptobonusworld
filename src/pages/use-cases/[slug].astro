---
/**
 * /use-cases/[slug]/ — Exchange use-case comparison pages.
 *
 * Architecture:
 *  - Static paths from USE_CASES data (src/data/use-cases.ts)
 *  - rankExchangesForUseCase() scores + filters exchanges per use-case weights
 *  - Renders: answer box, quick facts, AI summary, ranked table, FAQ
 *  - Full structured data: ItemList + FAQPage
 *
 * Target intents:
 *  "best exchange for [use case]"
 *  "crypto exchange for [beginners/scalping/futures/etc]"
 */

import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AiSummaryBlock from '../../components/AiSummaryBlock.astro';
import QuickFactsBlock from '../../components/QuickFactsBlock.astro';
import BonusTable from '../../components/BonusTable.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RiskDisclaimer from '../../components/RiskDisclaimer.astro';
import RelatedGuidesBlock from '../../components/RelatedGuidesBlock.astro';
import CTAButton from '../../components/CTAButton.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import HowWeEvaluate from '../../components/HowWeEvaluate.astro';

import { USE_CASES } from '../../data/use-cases';
import exchanges from '../../data/exchanges.json';
import guides from '../../data/guides.json';
import categories from '../../data/categories.json';
import AuthorCard from '../../components/AuthorCard.astro';

import {
  rankExchangesForUseCase,
  buildItemListSchema,
  YEAR,
  SITE_URL,
} from '../../utils/seo';
import type { PageContext } from '../../utils/analytics';

export async function getStaticPaths() {
  return USE_CASES.map(uc => ({
    params: { slug: uc.slug },
    props: { useCase: uc },
  }));
}

const { useCase } = Astro.props;

// ── Rank exchanges for this use case ────────────────────────────────────────
const ranked = rankExchangesForUseCase(exchanges as any, useCase.scoring);
const topPick = ranked[0];
const noKycRanked = ranked.filter(ex => !ex.kycRequired);

// ── AI summary items ─────────────────────────────────────────────────────────
const aiItems = ranked.slice(0, 5).map(ex => ({
  label: ex.name,
  value: `Up to ${ex.bonusAmount.toLocaleString('en-US')} ${ex.bonusCurrency} — ${ex.shortDescription.split('.')[0]}`,
  note: `${ex.kycRequired ? 'KYC required' : 'No KYC'} · ${!ex.depositRequired ? 'No min deposit' : `Min $${(ex.minDeposit as any)?.amount ?? '—'}`}`,
}));

// ── Related guides ───────────────────────────────────────────────────────────
const relatedGuides = guides.filter(g =>
  g.slug === useCase.relatedGuideSlug ||
  (useCase.relatedCategorySlugs ?? []).some(cs =>
    g.tags?.includes(cs.replace('-bonuses', '').replace('-', ''))
  )
).slice(0, 3);

// ── Related categories ───────────────────────────────────────────────────────
const relatedCats = (categories as any[]).filter(c =>
  (useCase.relatedCategorySlugs ?? []).includes(c.slug)
);

// ── Related use cases ────────────────────────────────────────────────────────
const relatedUseCases = USE_CASES.filter(uc =>
  (useCase.relatedUseCaseSlugs ?? []).includes(uc.slug)
).slice(0, 4);

// ── Structured data ──────────────────────────────────────────────────────────
const itemListSchema = buildItemListSchema(
  ranked.map(ex => ({
    name: `${ex.name} — Best for ${useCase.label}`,
    url: `/exchanges/${ex.slug}/`,
    description: ex.shortDescription,
  })),
  `${useCase.heading} ${YEAR}`
);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: useCase.faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const analyticsContext: PageContext = { pageType: 'category' };

// ── Thin content guard ────────────────────────────────────────────────────────
// If the ranking engine returns 0 exchanges for a use-case (e.g. a newly added
// use-case with an unsatisfied requireFeatureBadge filter), block indexation.
// Normal use-cases should always rank ≥3 exchanges.
const ucRobotsDirective = ranked.length === 0 ? 'noindex, nofollow' : undefined;

const ogImage = `${SITE_URL}/og/use-case-${useCase.slug}.png`;
---

<Layout
  title={useCase.seoTitle}
  description={useCase.metaDesc}
  canonical={`/use-cases/${useCase.slug}/`}
  schema={[itemListSchema, faqSchema]}
  analyticsContext={analyticsContext}
  robots={ucRobotsDirective}
  ogImage={ogImage}
  ogType="article"
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Exchange Use Cases', href: '/use-cases/' },
      { label: useCase.label },
    ]} />

    <div class="page-header">
      <div class="uc-meta-tag">{useCase.label}</div>
      <h1>{useCase.heading}</h1>
      <p class="lead">{useCase.intro}</p>
    </div>

    <AffiliateDisclosure compact />

    <AuthorCard
      compact
      verb="Reviewed by"
      reviewedAt={new Date().toISOString().slice(0, 10)}
      profileUrl="/reviewers/editorial-team/"
    />

    <!-- Answer box — AI search target (50–100 word concise answer) -->
    <AnswerBox
      question={`What is the best crypto exchange for ${useCase.label.toLowerCase()}?`}
      answer={useCase.answerBox}
      updatedDate={`May ${YEAR}`}
    />

    <QuickFactsBlock
      heading={`${useCase.label} — Key Facts`}
      facts={useCase.quickFacts}
    />

    <AiSummaryBlock
      title={`${useCase.heading} — Quick Summary`}
      intro={`These exchanges are ranked for ${useCase.label.toLowerCase()} based on relevant features, fees and bonus value. Verified May ${YEAR}.`}
      updatedDate={`May ${YEAR}`}
      items={aiItems}
    />

    <!-- Why it matters -->
    <div class="why-matters">
      <p>{useCase.whyMatters}</p>
    </div>

    <!-- Main ranked table -->
    <section class="section">
      <h2 class="section-title">
        {ranked.length} Best Exchange{ranked.length !== 1 ? 's' : ''} for {useCase.label}
      </h2>
      <BonusTable exchanges={ranked} suppressSchema={true} />
    </section>

    <!-- No-KYC sub-section (only if use case doesn't require it — avoid duplication) -->
    {!useCase.scoring.requireNoKyc && noKycRanked.length > 0 && (
      <section class="section nokyc-note">
        <h3 class="section-sub-title">🔓 No-KYC Options for {useCase.label}</h3>
        <p class="section-sub">
          {noKycRanked.length} of the above exchanges support {useCase.label.toLowerCase()} without requiring identity verification:
          {noKycRanked.map((ex, i) => (
            <span>
              <a href={`/exchanges/${ex.slug}/`} class="inline-link">{ex.name}</a>
              {i < noKycRanked.length - 1 ? ', ' : ''}
            </span>
          ))}
        </p>
      </section>
    )}

    <!-- Related categories -->
    {relatedCats.length > 0 && (
      <section class="section related-cats">
        <h3 class="section-sub-title">Related Bonus Categories</h3>
        <div class="cats-row">
          {relatedCats.map(cat => (
            <a href={`/categories/${cat.slug}/`} class="cat-chip">
              {cat.name} →
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related use cases -->
    {relatedUseCases.length > 0 && (
      <section class="section">
        <h3 class="section-sub-title">Related Use Cases</h3>
        <div class="uc-related-grid">
          {relatedUseCases.map(uc => (
            <a href={`/use-cases/${uc.slug}/`} class="uc-related-card">
              <span class="uc-related-name">{uc.label}</span>
              <span class="uc-related-desc">{uc.heading}</span>
              <span class="uc-related-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- How we evaluate — E-E-A-T methodology reference -->
    <HowWeEvaluate variant="compact" />

    <!-- FAQ -->
    <FAQBlock items={useCase.faq} suppressSchema={true} />

    <!-- Related guides -->
    {relatedGuides.length > 0 && (
      <RelatedGuidesBlock guides={relatedGuides} heading={`Guides: ${useCase.label}`} />
    )}

    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }

  .uc-meta-tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-accent);
    background: rgba(245,197,66,0.1);
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
    margin-bottom: 0.625rem;
  }

  .why-matters {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    padding: 1rem 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  .section { margin: 1.75rem 0; }
  .section-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .section-sub-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }
  .section-sub {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .nokyc-note {
    padding: 1rem 1.25rem;
    background: rgba(74,222,128,0.03);
    border: 1px solid rgba(74,222,128,0.12);
    border-radius: 10px;
  }

  .inline-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }
  .inline-link:hover { text-decoration: underline; }

  /* Category chips */
  .cats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cat-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .cat-chip:hover {
    border-color: rgba(245,197,66,0.3);
    color: var(--color-accent);
  }

  /* Related use cases grid */
  .uc-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.625rem;
  }
  .uc-related-card {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    position: relative;
    transition: border-color 0.15s;
  }
  .uc-related-card:hover { border-color: rgba(245,197,66,0.3); }
  .uc-related-name {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .uc-related-desc {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  .uc-related-arrow {
    position: absolute;
    top: 0.75rem;
    right: 0.875rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    transition: transform 0.15s;
  }
  .uc-related-card:hover .uc-related-arrow { transform: translateX(2px); }

  @media (max-width: 640px) {
    .uc-related-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
