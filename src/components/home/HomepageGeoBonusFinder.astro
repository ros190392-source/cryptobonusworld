---
/**
 * HomepageGeoBonusFinder v2 — simplified, conversion-focused GEO bonus finder.
 *
 * The homepage IS this finder: detect country → show the best promo codes for
 * it immediately. One static panel per supported country is rendered
 * server-side; a small inline script toggles panels and swaps the H1 based on
 * (1) the user's manual choice (localStorage cbw_gf_country), (2) the site's
 * existing cbw_geo signal set by Analytics.astro, (3) Global fallback.
 * No geolocation permission prompts, no blocking, no new detection mechanisms.
 *
 * Data: geoRankings.ts (evidence-backed country rows + global ranking),
 * exchanges.ts (rich page URLs, /go/ routes), offers.ts (codes, bonus text),
 * exchanges.json (CBW rating only). Nothing invented — see do-not-invent
 * rules in src/data/geoRankings.ts and src/data/geoBonusEvidence.ts.
 * EU is never a selectable country (regulatory overlay only).
 */
import ExchangeLogo from '../ExchangeLogo.astro';
import PromoCodeCopy from '../promo/PromoCodeCopy.astro';

interface Props {
  /**
   * true when the homepage site hero above owns the H1 + country selector
   * (2026-07 site hero system): the finder then renders only the country
   * panels. The hero writes the same cbw_gf_country key and toggles the
   * same .gf-panel elements, so behavior stays in sync.
   */
  embedded?: boolean;
}
const { embedded = false } = Astro.props as Props;
import { getExchange } from '../../data/exchanges';
import { getOffer } from '../../data/offers';
import exchangesJson from '../../data/exchanges.json';
import {
  getGlobalPromoRanking,
  getCountryPromoRanking,
  type PromoCountrySlug,
} from '../../data/geoRankings';

type Availability = 'available' | 'restricted' | 'unknown';
type BonusAvailability = 'available' | 'not_available' | 'unknown';
type Confidence = 'verified' | 'partial' | 'unknown';

interface FinderRow {
  slug: string;
  name: string;
  rating: number | null;
  pageUrl: string;
  goUrl: string;
  promoCode: string;
  bonusHeadline: string;
  offerStatus: string;
  availability: Availability;
  bonusAvailability: BonusAvailability;
  confidence: Confidence;
  evidenceDate: string | null;
  isGlobalFallback: boolean;
  regulatorCautionNote: string | null;
}

// Country meta moved verbatim to src/data/homepageCountryMeta.ts so the site
// hero GEO panel and this finder share one source (2026-07 site hero system).
// European Union is a regulatory overlay only (geoRankings.ts) — never a country here.
import { HOMEPAGE_COUNTRY_META as COUNTRY_META } from '../../data/homepageCountryMeta';

// CBW editorial rating (existing approved data from exchanges.json — same value
// shown on exchange detail pages). Never invented; null when absent.
const ratingBySlug: Record<string, number> = Object.fromEntries(
  (exchangesJson as any[]).filter(e => typeof e.rating === 'number').map(e => [e.slug, e.rating]),
);

const AVAIL_WEIGHT: Record<Availability, number> = { available: 0, unknown: 1, restricted: 2 };
const CONF_WEIGHT: Record<Confidence, number> = { verified: 0, partial: 1, unknown: 2 };
const MAX_ROWS = 6;

function buildRowsFor(countrySlug: PromoCountrySlug): FinderRow[] {
  if (countrySlug === 'global') {
    return getGlobalPromoRanking()
      .slice(0, MAX_ROWS)
      .map(entry => ({
        slug: entry.exchangeSlug,
        name: entry.exchangeName,
        rating: ratingBySlug[entry.exchangeSlug] ?? null,
        pageUrl: entry.reviewUrl,
        goUrl: entry.claimUrl,
        promoCode: entry.promoCode,
        bonusHeadline: entry.bonusSnapshot,
        offerStatus: entry.offerStatus,
        availability: 'available' as const,
        bonusAvailability: 'available' as const,
        confidence: entry.offerStatus === 'verified' ? 'verified' as const : 'partial' as const,
        evidenceDate: getOffer(entry.exchangeSlug)?.lastChecked ?? null,
        isGlobalFallback: false,
        regulatorCautionNote: null,
      }));
  }
  return getCountryPromoRanking(countrySlug)
    .map(row => {
      const ex = getExchange(row.exchangeSlug);
      const offer = getOffer(row.exchangeSlug);
      if (!ex || !offer) return null;
      return {
        slug: row.exchangeSlug,
        name: ex.name,
        rating: ratingBySlug[row.exchangeSlug] ?? null,
        pageUrl: ex.pageUrl ?? `/exchanges/${ex.slug}/`,
        goUrl: ex.affiliateUrl,
        promoCode: offer.promoCode,
        bonusHeadline: offer.bonusHeadline,
        offerStatus: offer.status,
        availability: row.availability,
        bonusAvailability: row.bonusAvailability,
        confidence: row.confidence,
        evidenceDate: row.evidenceDate,
        // No dedicated evidence captured for this exchange×country — catalog default.
        isGlobalFallback: row.evidenceUrl === null,
        regulatorCautionNote: row.regulatorCautionNote,
      } satisfies FinderRow;
    })
    .filter((r): r is FinderRow => r !== null)
    .sort((a, b) =>
      AVAIL_WEIGHT[a.availability] - AVAIL_WEIGHT[b.availability]
      || CONF_WEIGHT[a.confidence] - CONF_WEIGHT[b.confidence],
    )
    .slice(0, MAX_ROWS);
}

function badgeFor(countrySlug: PromoCountrySlug, row: FinderRow): { text: string; tone: string } {
  if (row.availability === 'restricted') return { text: 'Restricted in this country', tone: 'restricted' };
  // Local regulator publicly flagged the platform for this country (evidence-
  // backed, see geoRankings.ts) — never presented as verified or recommended.
  if (row.regulatorCautionNote) return { text: 'Regulatory status under review', tone: 'partial' };
  if (countrySlug === 'global') return { text: 'Global offer', tone: 'progress' };
  if (row.isGlobalFallback) return { text: 'Global offer · country evidence in progress', tone: 'progress' };
  if (row.availability === 'available' && row.confidence === 'verified') return { text: 'Country evidence: checked', tone: 'verified' };
  if (row.availability === 'available' && row.confidence === 'partial') return { text: 'Early evidence · partially checked', tone: 'partial' };
  return { text: 'Availability evidence in progress', tone: 'progress' };
}

function ctaFor(row: FinderRow): { label: string; href: string; primary: boolean } {
  if (row.availability === 'restricted') {
    return { label: 'View details', href: row.pageUrl, primary: false };
  }
  // Regulator-flagged for this country: prefer Review/Details over any
  // affiliate CTA until the conflict is resolved (owner decision).
  if (row.regulatorCautionNote) {
    return { label: 'View details', href: row.pageUrl, primary: false };
  }
  if (row.bonusAvailability === 'not_available') {
    return { label: `Visit ${row.name}`, href: row.goUrl, primary: false };
  }
  // Researched but unresolved availability — softer CTA (see Sprint 8E note).
  if (row.availability === 'unknown' && !row.isGlobalFallback) {
    return { label: 'Check offer', href: row.goUrl, primary: false };
  }
  return { label: 'Claim Bonus', href: row.goUrl, primary: true };
}

const panels = COUNTRY_META.map(meta => ({ ...meta, rows: buildRowsFor(meta.slug) }));
const countryMetaJson = JSON.stringify(COUNTRY_META.map(({ slug, label, flag, headline }) => ({ slug, label, flag, headline })));
---

<section class="gf" id="finder" aria-label="Best crypto bonus codes by country">
  <div class="gf-wrap">

    {!embedded && (
      <div class="gf-head">
        <div class="gf-selector-row">
          <span class="gf-flag" id="gf-current-flag" aria-hidden="true">🌍</span>
          <label class="gf-select-wrap">
            <span class="gf-select-label">Your country</span>
            <select id="gf-country-select" aria-label="Select your country">
              {COUNTRY_META.map(c => (
                <option value={c.slug}>{c.flag} {c.label}</option>
              ))}
            </select>
          </label>
        </div>
        <h1 class="gf-h1" id="gf-h1">Best Crypto Bonus Codes Worldwide</h1>
        <p class="gf-trust">Crypto bonus codes checked by country. Terms and KYC may apply.</p>
      </div>
    )}

    {panels.map(panel => (
      <div class="gf-panel" data-country={panel.slug} hidden={panel.slug !== 'global'}>
        <div class="gf-rows">
          {panel.rows.map(row => {
            const badge = badgeFor(panel.slug, row);
            const cta = ctaFor(row);
            return (
              <div class="gf-row">
                <div class="gf-row-id">
                  <ExchangeLogo slug={row.slug} name={row.name} size={40} variant="square" lazy={false} />
                  <div class="gf-row-idtext">
                    <span class="gf-row-name">{row.name}</span>
                    {row.rating !== null && (
                      <span class="gf-row-rating" title="CryptoBonusWorld editorial score">★ {row.rating.toFixed(1)}/10</span>
                    )}
                  </div>
                  <span class={`gf-badge gf-badge-${badge.tone}`}>{badge.text}</span>
                </div>
                <div class="gf-row-bonus">{row.bonusHeadline}</div>
                {row.bonusAvailability === 'not_available' && (
                  <p class="gf-row-note">Tracked bonus not confirmed for this country.</p>
                )}
                {panel.slug !== 'global' && row.availability === 'available' && row.bonusAvailability === 'unknown' && (
                  <p class="gf-row-note">Bonus terms for this country not fully verified yet — final eligibility may depend on local terms.</p>
                )}
                {row.regulatorCautionNote && (
                  <p class="gf-row-note gf-row-note-caution">{row.regulatorCautionNote}</p>
                )}
                <div class="gf-row-actions">
                  {row.availability !== 'restricted' && (
                    <PromoCodeCopy code={row.promoCode} exchange={row.name} />
                  )}
                  <div class="gf-row-btns">
                    <a href={cta.href} class={cta.primary ? 'gf-cta gf-cta-primary' : 'gf-cta gf-cta-secondary'} target="_blank" rel="noopener noreferrer sponsored">
                      {cta.label} →
                    </a>
                    <a href={row.pageUrl} class="gf-review">Review</a>
                  </div>
                </div>
                {row.evidenceDate && <p class="gf-row-checked">Last checked {row.evidenceDate}</p>}
              </div>
            );
          })}
        </div>
        <a href="/promo-codes/" class="gf-view-all">View full comparison →</a>
      </div>
    ))}
  </div>
</section>

<script define:vars={{ __countryMeta: JSON.parse(countryMetaJson) }} is:inline>
(function () {
  'use strict';

  var META = __countryMeta;
  var SLUGS = META.map(function (m) { return m.slug; });
  var STORAGE_KEY = 'cbw_gf_country';

  // Existing site-wide 2-letter geo signal (cbw_geo, set by Analytics.astro)
  // mapped to supported country slugs. Exact allowlist only — anything
  // unmapped falls back to 'global', never guessed. No permission prompts.
  var GEO_CODE_MAP = {
    pl: 'poland', de: 'germany', kz: 'kazakhstan', tr: 'turkey',
    gb: 'united-kingdom', uk: 'united-kingdom', us: 'united-states',
  };

  function detectInitialCountry() {
    try {
      var stored = localStorage.getItem(STORAGE_KEY);
      if (stored && SLUGS.indexOf(stored) !== -1) return stored;
    } catch (_) {}
    try {
      var geo = (localStorage.getItem('cbw_geo') || '').toLowerCase();
      if (GEO_CODE_MAP[geo]) return GEO_CODE_MAP[geo];
    } catch (_) {}
    return 'global';
  }

  function applyCountry(slug) {
    if (SLUGS.indexOf(slug) === -1) slug = 'global';
    var panels = document.querySelectorAll('.gf-panel');
    for (var i = 0; i < panels.length; i++) {
      panels[i].hidden = panels[i].getAttribute('data-country') !== slug;
    }
    var meta = META.find(function (m) { return m.slug === slug; });
    if (meta) {
      var flagEl = document.getElementById('gf-current-flag');
      if (flagEl) flagEl.textContent = meta.flag;
      var h1 = document.getElementById('gf-h1');
      if (h1) h1.textContent = meta.headline;
    }
    var select = document.getElementById('gf-country-select');
    if (select && select.value !== slug) select.value = slug;
  }

  applyCountry(detectInitialCountry());

  var selectEl = document.getElementById('gf-country-select');
  if (selectEl) {
    selectEl.addEventListener('change', function () {
      var slug = selectEl.value;
      applyCountry(slug);
      try { localStorage.setItem(STORAGE_KEY, slug); } catch (_) {}
    });
  }

  // Copy-to-clipboard is handled by the shared PromoCodeCopy component.
})();
</script>

<style>
  .gf {
    background: linear-gradient(180deg, #FAFAF7 0%, #FFFFFF 100%);
    border-bottom: 1px solid #E5E7EB;
    padding: 18px 0 28px;
  }
  .gf-wrap {
    /* Section aligns with the wide directory standard; the interactive rows
       below are capped separately (stacked row cards stretch past ~960px). */
    max-width: var(--cbw-wide-max, 1120px);
    margin: 0 auto;
    padding: 0 16px;
    box-sizing: border-box;
  }
  @media (min-width: 820px) { .gf-wrap { padding: 0 32px; } .gf { padding: 24px 0 36px; } }

  /* ── Head: selector + headline + trust ───────────────────────── */
  .gf-head { text-align: center; margin-bottom: 14px; }

  .gf-selector-row {
    display: inline-flex; align-items: center; gap: 12px;
    background: #fff; border: 1px solid #E5E7EB; border-radius: 12px;
    padding: 8px 16px 8px 12px; margin-bottom: 12px;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
  }
  .gf-flag { font-size: 34px; line-height: 1; flex-shrink: 0; }
  .gf-select-wrap { display: flex; flex-direction: column; gap: 1px; text-align: left; }
  .gf-select-label { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: #9CA3AF; font-weight: 600; }
  #gf-country-select {
    font-size: 15px; font-weight: 700; color: #111827;
    border: none; background: transparent; padding: 1px 0; cursor: pointer;
  }
  #gf-country-select:focus-visible { outline: 2px solid #16A34A; outline-offset: 2px; border-radius: 4px; }

  .gf-h1 {
    font-size: clamp(22px, 4vw, 30px); font-weight: 800; line-height: 1.16;
    letter-spacing: -.02em; color: #111827; margin: 0 0 6px;
  }
  .gf-trust { font-size: 12.5px; line-height: 1.5; color: #6B7280; margin: 0; }

  /* ── Rows ─────────────────────────────────────────────────────── */
  .gf-rows {
    display: flex; flex-direction: column; gap: 10px;
    /* Balanced cap: at the full 1120px the stacked row cards look stretched */
    max-width: 960px; margin: 0 auto;
  }

  .gf-row {
    background: #fff; border: 1px solid #E5E7EB; border-radius: 12px;
    padding: 12px 14px;
    box-shadow: 0 1px 3px rgba(0,0,0,.03);
  }

  .gf-row-id { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
  .gf-row-idtext { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .gf-row-name { font-size: 15px; font-weight: 800; color: #111827; letter-spacing: -.01em; }
  .gf-row-rating { font-size: 11.5px; font-weight: 700; color: #B45309; }
  .gf-badge {
    margin-left: auto;
    font-size: 10.5px; font-weight: 700; padding: 3px 9px; border-radius: 20px;
    white-space: nowrap;
  }
  .gf-badge-verified   { background: #F0FDF4; color: #15803D; border: 1px solid #BBF7D0; }
  .gf-badge-partial    { background: #FFFBEB; color: #B45309; border: 1px solid #FDE68A; }
  .gf-badge-progress   { background: #F3F4F6; color: #4B5563; border: 1px solid #E5E7EB; }
  .gf-badge-restricted { background: #FEF2F2; color: #B91C1C; border: 1px solid #FECACA; }

  .gf-row-bonus { font-size: 13px; color: #374151; line-height: 1.4; margin-bottom: 8px; }
  .gf-row-note { font-size: 11.5px; color: #9CA3AF; margin: -4px 0 8px; }
  .gf-row-note-caution { color: #B45309; }

  .gf-row-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

  /* Promo-code field is the shared canonical PromoCodeCopy component */

  .gf-row-btns { display: flex; align-items: center; gap: 8px; margin-left: auto; }
  .gf-cta {
    text-decoration: none; font-size: 13.5px; font-weight: 700;
    padding: 9px 16px; border-radius: 8px; white-space: nowrap;
  }
  .gf-cta-primary { background: #16A34A; color: #fff; }
  .gf-cta-primary:hover { background: #15803D; }
  .gf-cta-secondary { background: #fff; color: #374151; border: 1.5px solid #D1D5DB; }
  .gf-cta-secondary:hover { border-color: #9CA3AF; }
  .gf-review {
    font-size: 12.5px; font-weight: 600; color: #6B7280;
    text-decoration: underline; text-underline-offset: 2px; white-space: nowrap;
  }
  .gf-review:hover { color: #111827; }

  .gf-row-checked { font-size: 10.5px; color: #9CA3AF; margin: 6px 0 0; }

  .gf-view-all {
    display: inline-block; margin-top: 12px; font-size: 12.5px; font-weight: 700;
    color: #15803D; text-decoration: underline; text-underline-offset: 2px;
  }
  .gf-view-all:hover { color: #166534; }

  @media (max-width: 480px) {
    .gf-row-actions { flex-direction: column; align-items: stretch; }
    .gf-row-btns { margin-left: 0; }
    .gf-cta { flex: 1; text-align: center; }
    .gf-badge { margin-left: 0; width: fit-content; }
  }
</style>
