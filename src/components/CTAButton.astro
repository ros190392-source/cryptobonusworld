---
interface Props {
  href: string;
  /** Full label override — takes precedence over `exchange`-derived label */
  label?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  /** Exchange name — used to build default "Claim {name} Bonus" label */
  exchange?: string;
  rel?: string;

  // ── Tracking (affiliate click analytics) ──────────────────────────────
  /** Where on the page this button sits: hero | sidebar | table | card | compare | sticky | alternatives */
  trackPlacement?: string;
  /** Bonus amount for tracking (passed as data-bonus) */
  trackBonus?: number;

  // ── GEO-aware affiliate link ──────────────────────────────────────────
  /**
   * Map of geo code → affiliate URL.
   * Serialised as data-geo-href JSON. Client script swaps href on page load
   * when user timezone matches a known GEO. Only non-placeholder URLs are used.
   * e.g. { tr: "https://bybit.com/?ref=tr", in: "https://bybit.com/?ref=in" }
   */
  geoHrefs?: Record<string, string>;

  // ── A/B experiment text opt-in ─────────────────────────────────────────
  /**
   * Opt this button's label text into an experiment transform.
   * Format: "{expId}:{variantId}:{text}|{expId}:{variantId}:{text}|..."
   * Passed directly to data-exp-text on the label span.
   * ExperimentProvider.astro handles the swap client-side.
   *
   * Example:
   *   experimentText="cta-copy-v1:get-started:Get Started|cta-copy-v1:view-offer:View Offer"
   */
  experimentText?: string;
}

const {
  href,
  label,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  exchange,
  rel = 'noopener noreferrer nofollow sponsored',
  trackPlacement,
  trackBonus,
  geoHrefs,
  experimentText,
} = Astro.props;

const isExternal = href.startsWith('http') || href === '#';
const target = isExternal ? '_blank' : undefined;
const displayLabel = label ?? (exchange ? `View ${exchange} Offer` : 'View offer');

// Tracking data attributes — only for external affiliate links
const isAffiliate = isExternal;
const exchangeKey = exchange?.toLowerCase().replace(/\s+/g, '-') ?? null;

// GEO href — filter out placeholders (#) before serialising
const filteredGeoHrefs = geoHrefs
  ? Object.fromEntries(Object.entries(geoHrefs).filter(([, v]) => v && v !== '#'))
  : null;
const hasGeoHrefs = filteredGeoHrefs && Object.keys(filteredGeoHrefs).length > 0;
---

<a
  href={href}
  class:list={['cta-btn', `cta-btn--${variant}`, `cta-btn--${size}`, fullWidth && 'cta-btn--full']}
  target={target}
  rel={isExternal ? rel : undefined}
  aria-label={displayLabel}
  data-track={isAffiliate ? 'affiliate-cta' : undefined}
  data-exchange={isAffiliate && exchangeKey ? exchangeKey : undefined}
  data-placement={isAffiliate && trackPlacement ? trackPlacement : undefined}
  data-bonus={isAffiliate && trackBonus !== undefined ? String(trackBonus) : undefined}
  data-geo-href={hasGeoHrefs ? JSON.stringify(filteredGeoHrefs) : undefined}
>
  <span class="cta-label" data-exp-text={experimentText ?? undefined}>{displayLabel}</span>
  {isExternal && <span class="cta-arrow" aria-hidden="true">→</span>}
</a>

<style>
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md, 10px);
    transition:
      background var(--duration-base, 200ms) var(--ease-standard, ease),
      box-shadow var(--duration-base, 200ms) var(--ease-standard, ease),
      transform var(--duration-fast, 120ms) var(--ease-spring, ease),
      opacity var(--duration-fast, 120ms) var(--ease-standard, ease);
    cursor: pointer;
    border: 2px solid transparent;
    white-space: nowrap;
    /* Minimum touch target */
    min-height: 44px;
    position: relative;
    isolation: isolate;
  }

  .cta-btn:active {
    transform: scale(0.96) !important;
    transition-duration: 80ms !important;
  }

  /* ── Primary ── */
  .cta-btn--primary {
    background: var(--gradient-gold, var(--color-accent));
    color: #000;
    border-color: var(--color-accent);
    font-weight: 800;
    letter-spacing: -0.01em;
    animation: cta-pulse 8s ease-in-out infinite;
  }
  .cta-btn--primary:hover {
    box-shadow: var(--glow-cta, 0 4px 20px rgba(245,197,66,0.35)), 0 8px 32px rgba(245,197,66,0.2);
    transform: translateY(-3px);
    background: var(--color-accent-warm, #fbbf24);
    border-color: var(--color-accent-warm, #fbbf24);
    animation: none;
  }
  .cta-btn--primary:focus-visible {
    animation: none;
    box-shadow: 0 0 0 3px rgba(245,197,66,0.5);
  }

  /* Subtle periodic glow pulse — attention signal without fake urgency */
  @keyframes cta-pulse {
    0%, 82%, 100% {
      box-shadow: none;
    }
    88% {
      box-shadow: 0 0 0 3px rgba(245,197,66,0.2), 0 4px 20px rgba(245,197,66,0.28);
    }
    94% {
      box-shadow: 0 0 0 5px rgba(245,197,66,0.1), 0 6px 28px rgba(245,197,66,0.38);
    }
  }

  /* Respect reduced-motion: disable pulse */
  @media (prefers-reduced-motion: reduce) {
    .cta-btn--primary { animation: none; }
  }

  /* ── Secondary ── */
  .cta-btn--secondary {
    background: var(--surface-overlay, #1a1a1a);
    color: var(--color-text-primary);
    border-color: var(--color-border, #252525);
  }
  .cta-btn--secondary:hover {
    background: var(--surface-elevated, #151515);
    border-color: var(--color-accent-dim, rgba(245,197,66,0.15));
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ── Outline ── */
  .cta-btn--outline {
    background: transparent;
    color: var(--color-accent);
    border-color: var(--color-accent-dim, rgba(245,197,66,0.35));
  }
  .cta-btn--outline:hover {
    background: var(--color-accent);
    color: #000;
    border-color: var(--color-accent);
    box-shadow: var(--glow-gold-sm, 0 0 12px rgba(245,197,66,0.2));
    transform: translateY(-1px);
  }

  /* ── Sizes ── */
  .cta-btn--sm {
    font-size: var(--text-sm, 0.875rem);
    padding: 0.4rem 1rem;
    min-height: 40px;
    border-radius: var(--radius-sm, 6px);
  }
  .cta-btn--md {
    font-size: var(--text-sm, 0.875rem);
    padding: 0.6rem 1.375rem;
  }
  .cta-btn--lg {
    font-size: var(--text-base, 1rem);
    padding: 0.8rem 1.875rem;
    letter-spacing: -0.01em;
  }
  .cta-btn--full { width: 100%; }

  /* label wrapper — purely for experiment targeting, no visual impact */
  .cta-label { display: contents; }

  .cta-arrow {
    font-size: 0.875em;
    display: inline-block;
    transition: transform var(--duration-base, 200ms) var(--ease-spring, cubic-bezier(0.34,1.56,0.64,1));
    will-change: transform;
  }
  .cta-btn:hover .cta-arrow {
    transform: translateX(4px);
  }

  /* Mobile: lg primary buttons go full-width for easier tap */
  @media (max-width: 640px) {
    .cta-btn--lg.cta-btn--primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
