---
/**
 * ScreenshotPlaceholder.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * Structured placeholder for screenshots that are pending capture, outdated,
 * or regionally unavailable. Replaces the old "suppress-and-hide" approach.
 *
 * Renders nothing for status='not_applicable'.
 * Renders nothing for status='available' (caller should use a real <img>).
 *
 * Public-facing copy is intentionally non-technical:
 *   - No "needs_manual_capture" / "outdated" jargon visible to users
 *   - Context-appropriate message based on device/geo/status combination
 *
 * data-* attributes are written for audit tooling (screenshot-checklist,
 * audit-exchange-screenshots) and for capture-queue prioritisation.
 */

import type { ScreenshotStatus, ScreenshotCategory } from '../../data/evidence/_schema';

interface Props {
  /** Current status of the screenshot — drives which visual state to render */
  status: ScreenshotStatus;
  /** Exchange slug — e.g. "bybit", "binance" — used for audit data attributes */
  exchange?: string;
  /** Screenshot category — determines icon and tint colour */
  category?: ScreenshotCategory;
  /** Geographic variant — non-GLOBAL triggers "Regional interface may differ" copy */
  geo?: string;
  /** Locale code — reserved for future multi-language use */
  locale?: string;
  /** Device this placeholder represents — 'mobile' gets a distinct message */
  device?: 'desktop' | 'mobile';
  /** ISO YYYY-MM when the last screenshot was captured — shown for outdated entries */
  lastVerified?: string | null;
  /** Capture priority band — written to data attribute for audit tooling */
  capturePriority?: 'P1' | 'P2' | 'P3' | 'P4';
  /** Override the auto-derived public label */
  label?: string;
  /** CSS aspect-ratio value for the placeholder frame — default 16/9 */
  aspectRatio?: string;
  /** Extra CSS class(es) to apply to the outer wrapper */
  class?: string;
}

const {
  status,
  exchange,
  category,
  geo = 'GLOBAL',
  locale = 'en',
  device = 'desktop',
  lastVerified,
  capturePriority,
  label: labelProp,
  aspectRatio = '16/9',
  class: className,
} = Astro.props;

// ── Render guard ──────────────────────────────────────────────────────────────

// not_applicable → nothing to show
// available → caller must use a real <img>, not a placeholder
const shouldRender = status !== 'not_applicable' && status !== 'available';

// ── Category metadata ─────────────────────────────────────────────────────────

const CATEGORY_META: Record<ScreenshotCategory, { icon: string; tint: string; label: string }> = {
  registration:     { icon: '🖥️',  tint: 'rgba(96,165,250,0.08)',  label: 'Registration screen' },
  kyc:              { icon: '🪪',  tint: 'rgba(167,139,250,0.08)', label: 'KYC verification' },
  bonus:            { icon: '🎁',  tint: 'rgba(245,197,66,0.08)',  label: 'Bonus & rewards' },
  deposit:          { icon: '💳',  tint: 'rgba(74,222,128,0.07)', label: 'Deposit screen' },
  p2p:              { icon: '🔄',  tint: 'rgba(56,189,248,0.07)', label: 'P2P trading' },
  spot:             { icon: '📊',  tint: 'rgba(251,146,60,0.07)', label: 'Spot trading' },
  futures:          { icon: '⚡',  tint: 'rgba(250,204,21,0.07)', label: 'Futures trading' },
  fees:             { icon: '📋',  tint: 'rgba(148,163,184,0.07)',label: 'Fee schedule' },
  mobile_app:       { icon: '📱',  tint: 'rgba(52,211,153,0.07)', label: 'Mobile app' },
  proof_of_reserves:{ icon: '🔒',  tint: 'rgba(99,102,241,0.08)', label: 'Proof of Reserves' },
};

const meta = category ? CATEGORY_META[category] : null;
const tint = meta?.tint ?? 'rgba(255,255,255,0.04)';

// ── Public-facing copy ────────────────────────────────────────────────────────

let publicMessage: string;
let statusBadge: string;

if (device === 'mobile') {
  publicMessage = 'Mobile interface capture pending';
  statusBadge = 'Coming soon';
} else if (geo !== 'GLOBAL' && geo !== '') {
  publicMessage = 'Regional interface may differ';
  statusBadge = 'Regional variant';
} else if (status === 'outdated' && lastVerified) {
  publicMessage = `Screenshot update in progress`;
  statusBadge = 'Updating';
} else {
  publicMessage = 'Screenshot update in progress';
  statusBadge = status === 'archived' ? 'Archived' : 'Coming soon';
}

// Apply caller override
const displayLabel = labelProp ?? (meta?.label ?? 'Screenshot');

// ── Data attributes for audit tooling ────────────────────────────────────────

const dataAttrs: Record<string, string> = {};
if (exchange) dataAttrs['data-screenshot-exchange'] = exchange;
if (category) dataAttrs['data-screenshot-category'] = category;
if (capturePriority) dataAttrs['data-screenshot-priority'] = capturePriority;
dataAttrs['data-screenshot-status'] = status;
if (geo && geo !== 'GLOBAL') dataAttrs['data-screenshot-geo'] = geo;
if (device === 'mobile') dataAttrs['data-screenshot-device'] = 'mobile';
---

{shouldRender && (
  <div
    class:list={['sp-wrap', className]}
    style={`--sp-tint:${tint};--sp-ratio:${aspectRatio};`}
    {...dataAttrs}
    aria-label={`${displayLabel} — ${publicMessage}`}
  >
    <div class="sp-frame">
      {meta?.icon && (
        <span class="sp-icon" aria-hidden="true">{meta.icon}</span>
      )}
      <p class="sp-message">{publicMessage}</p>
      {status === 'outdated' && lastVerified && (
        <p class="sp-sub">Last verified: {lastVerified}</p>
      )}
    </div>
    <div class="sp-badge">{statusBadge}</div>
  </div>
)}

<style>
  .sp-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: var(--sp-ratio, 16/9);
    background: var(--sp-tint, rgba(255,255,255,0.04));
    border: 1.5px dashed var(--color-border, #2a2a2a);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Prevent aspect-ratio from collapsing on very old browsers */
    min-height: 120px;
  }

  .sp-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1rem;
    text-align: center;
    max-width: 260px;
  }

  .sp-icon {
    font-size: 2rem;
    line-height: 1;
    filter: grayscale(0.3) opacity(0.75);
    margin-bottom: 0.25rem;
  }

  .sp-message {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted, #6b7280);
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  .sp-sub {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-text-muted, #6b7280);
    opacity: 0.7;
  }

  /* Status badge — bottom-right corner */
  .sp-badge {
    position: absolute;
    bottom: 0.5rem;
    right: 0.625rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted, #6b7280);
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.06);
    line-height: 1.4;
    pointer-events: none;
    user-select: none;
  }

  /* Animated shimmer for updating state */
  @keyframes sp-shimmer {
    0%   { opacity: 0.5; }
    50%  { opacity: 1; }
    100% { opacity: 0.5; }
  }

  .sp-message {
    animation: sp-shimmer 2.8s ease-in-out infinite;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .sp-wrap {
      min-height: 90px;
    }
    .sp-icon {
      font-size: 1.6rem;
    }
    .sp-message {
      font-size: 0.77rem;
    }
    .sp-badge {
      font-size: 0.6rem;
      padding: 0.15rem 0.35rem;
    }
  }
</style>
