---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import guides from '../../data/guides.json';
import { dataUpdatedLabel, EXCHANGE_COUNT } from '../../utils/seo';

const categoryColors: Record<string, string> = {
  'Basics':          '#f5c542',
  'Exchange Guides': '#60a5fa',
  'How-To Guides':   '#34d399',
  'Bonus Guides':    '#f59e0b',
  'Earning Guides':  '#a78bfa',
};

const categoryIcons: Record<string, string> = {
  'Basics':          '📚',
  'Exchange Guides': '🏦',
  'How-To Guides':   '🛠️',
  'Bonus Guides':    '🎁',
  'Earning Guides':  '💰',
};

const grouped = guides.reduce((acc: Record<string, typeof guides>, g) => {
  (acc[g.category] ??= []).push(g);
  return acc;
}, {});

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Crypto Exchange Guides — CryptoBonusWorld',
  description: 'In-depth guides to crypto exchange bonuses, no-KYC trading, P2P platforms, staking and more.',
  url: 'https://cryptobonusworld.com/guides/',
  publisher: { '@type': 'Organization', name: 'CryptoBonusWorld', url: 'https://cryptobonusworld.com' },
};
---

<Layout
  title="Crypto Exchange Guides 2026 — CryptoBonusWorld"
  description="In-depth guides to crypto bonuses, no-KYC exchanges, P2P trading, copy trading, staking and more. Learn how crypto exchange promotions really work."
  canonical="/guides/"
  schema={schema}
>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Guides' },
    ]} />

    <header class="guides-header">
      <h1 class="guides-title">Crypto Exchange Guides</h1>
      <p class="guides-subtitle">
        In-depth resources for navigating crypto exchanges, bonuses, and passive income strategies.
        Updated {dataUpdatedLabel()} by the CryptoBonusWorld editorial team.
      </p>
      <div class="guides-meta">
        <span class="guides-count">{guides.length} guides</span>
        <span class="guides-dot">·</span>
        <span>Updated regularly</span>
        <span class="guides-dot">·</span>
        <a href="/methodology/">Editorial methodology →</a>
      </div>
    </header>

    {Object.entries(grouped).map(([category, items]) => (
      <section class="guides-category">
        <div class="guides-cat-header">
          <span class="guides-cat-icon">{categoryIcons[category] ?? '📄'}</span>
          <h2 class="guides-cat-title">{category}</h2>
          <span class="guides-cat-count">{items.length} guides</span>
        </div>
        <div class="guides-grid">
          {items.map(guide => (
            <a href={`/guides/${guide.slug}/`} class="guide-card">
              <div class="guide-card-top">
                <span class="guide-card-category" style={`color: ${categoryColors[guide.category] ?? '#f5c542'}`}>
                  {guide.category}
                </span>
                <span class="guide-card-read">{guide.readTime} read</span>
              </div>
              <h3 class="guide-card-title">{guide.title}</h3>
              <p class="guide-card-desc">{guide.quickAnswer.substring(0, 120)}…</p>
              <div class="guide-card-footer">
                <span class="guide-card-updated">Updated {guide.lastUpdated}</span>
                <span class="guide-card-arrow">Read guide →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- CTA strip -->
    <section class="guides-cta-strip">
      <div class="guides-cta-text">
        <h2>Ready to claim a bonus?</h2>
        <p>Compare all {EXCHANGE_COUNT} exchange bonuses and find the best offer for your country and trading goals.</p>
      </div>
      <CTAButton href="/bonuses/" label="Compare All Bonuses →" size="lg" />
    </section>
  </div>
</Layout>

<style>
  .guides-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }
  .guides-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }
  .guides-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 1rem;
    max-width: 600px;
  }
  .guides-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .guides-meta a { color: var(--color-accent); text-decoration: none; }
  .guides-meta a:hover { text-decoration: underline; }
  .guides-count { font-weight: 700; color: var(--color-text-secondary); }
  .guides-dot { color: var(--color-border); }

  .guides-category { margin-bottom: 2.5rem; }
  .guides-cat-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1rem;
  }
  .guides-cat-icon { font-size: 1.1rem; }
  .guides-cat-title {
    font-size: 1.1rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .guides-cat-count {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.15rem 0.6rem;
    margin-left: 0.25rem;
  }

  .guides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .guide-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .guide-card:hover {
    border-color: rgba(245,197,66,0.35);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.2);
  }
  .guide-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .guide-card-category {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .guide-card-read {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .guide-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.4;
  }
  .guide-card-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .guide-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }
  .guide-card-updated {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .guide-card-arrow {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    opacity: 0.7;
    transition: opacity 0.15s;
  }
  .guide-card:hover .guide-card-arrow { opacity: 1; }

  .guides-cta-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: linear-gradient(135deg, rgba(245,197,66,0.06) 0%, var(--color-bg-secondary) 100%);
    border: 1px solid rgba(245,197,66,0.25);
    border-radius: 16px;
    padding: 2rem;
    margin: 2rem 0 3rem;
    flex-wrap: wrap;
  }
  .guides-cta-text h2 {
    font-size: 1.25rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
  }
  .guides-cta-text p {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 480px;
  }

  @media (max-width: 640px) {
    .guides-grid { grid-template-columns: 1fr; }
    .guides-cta-strip { flex-direction: column; text-align: center; }
  }
</style>
