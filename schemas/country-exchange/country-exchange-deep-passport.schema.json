{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CBW Country Exchange Deep Passport",
  "type": "object",
  "required": [
    "exchangeId",
    "countryCode",
    "languageCode",
    "availability",
    "checkedDate",
    "confidence",
    "globalPassportRef",
    "countryExchangeCell",
    "evidenceRefs",
    "pageState"
  ],
  "properties": {
    "exchangeId": {
      "type": "string"
    },
    "countryCode": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2
    },
    "languageCode": {
      "type": "string"
    },
    "availability": {
      "enum": [
        "AVAILABLE",
        "AVAILABLE_WITH_LIMITS",
        "RESTRICTED",
        "UNAVAILABLE",
        "UNDER_REVIEW",
        "CONFLICTING",
        "UNKNOWN",
        "STALE"
      ]
    },
    "checkedDate": {
      "type": "string",
      "format": "date"
    },
    "confidence": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "globalPassportRef": {
      "type": "string"
    },
    "countryProfileRef": {
      "type": "string"
    },
    "offerRecordRef": {
      "type": "string"
    },
    "countryExchangeCell": {
      "type": "object",
      "required": [
        "registration",
        "kyc",
        "spot",
        "derivatives",
        "p2p"
      ],
      "properties": {
        "registration": {
          "type": "string"
        },
        "kyc": {
          "type": "string"
        },
        "spot": {
          "type": "string"
        },
        "derivatives": {
          "type": "string"
        },
        "p2p": {
          "type": "string"
        },
        "localCurrency": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paymentMethods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "restrictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "localOfferEligibility": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "languageLayerRef": {
      "type": "string"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claimIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pageState": {
      "enum": [
        "RESEARCHING",
        "EVIDENCE_COMPLETE",
        "CONFLICTING",
        "DESIGN_READY",
        "NOINDEX_PREVIEW",
        "OWNER_REVIEW",
        "PUBLISHABLE",
        "PUBLISHED",
        "STALE",
        "RECHECK_REQUIRED",
        "ARCHIVED"
      ]
    }
  },
  "additionalProperties": true
}
