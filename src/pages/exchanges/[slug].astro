            <h2 class="ex-section-title">Step-by-Step Walkthroughs</h2>
            <p class="ex-prose" style="margin-bottom: 1rem">
              Every walkthrough below was completed on the live {ex.name} platform using a real account. Each screenshot was captured manually — no stock images or placeholder UI. The flows cover the complete path from account creation through KYC, depositing funds, buying via P2P, and placing a leveraged futures trade.
            </p>

            <!-- Walkthrough TOC — jump navigation -->
            <nav class="wt-toc" aria-label="Walkthrough sections">
              {walkthroughFlows.map(flow => (
                <a href={`#${flow.id}`} class="wt-toc-link">
                  {getFlowShortTitle(flow.id)}
                </a>
              ))}
            </nav>

            {walkthroughFlows.map((flow, flowIndex) => (
              <Fragment>
                {flow.id.includes('kyc') && _kycScreenshot && (
                  <ContextualEvidenceScreenshot
                    src={_kycScreenshot.src}
                    alt={`${ex.name} identity verification page screenshot`}
                    caption={`${ex.name} Verification Center screenshot showing the account verification area. Owner-approved authenticated capture, with private data excluded.`}
                    device={_kycScreenshot.device === 'none' ? 'desktop' : _kycScreenshot.device}
                    capturedAt={_kycScreenshot.capturedAt}
                    {..._imgDims(_kycScreenshot.src)}
                  />
                )}
                {flow.id.includes('p2p') && _p2pScreenshot && (
                  <ContextualEvidenceScreenshot
                    src={_p2pScreenshot.src}
                    alt={`${ex.name} P2P trading page screenshot`}
                    caption={`${ex.name} P2P page screenshot used as supporting evidence for the P2P section.`}
                    device={_p2pScreenshot.device === 'none' ? 'desktop' : _p2pScreenshot.device}
                    capturedAt={_p2pScreenshot.capturedAt}
                    {..._imgDims(_p2pScreenshot.src)}
                  />
                )}
              <WalkthroughFlow
                id={flow.id}
                title={flow.title}
                description={flow.description}
                introHtml={(flow as any).introHtml}
                stepCount={flow.stepCount}
                lastVerified={flow.lastVerified}
                exchangeName={ex.name}
                exchangeSlug={ex.slug}
                affiliateUrl={ex.affiliateUrl}
                ctaLabel={flow.cta?.label}
                ctaBody={flow.cta?.body}
                showCTA={true}
                totalTime={FLOW_TIMES[flow.id]}
                schemaSteps={flowIndex === 0 ? flow.steps.map((s, i) => ({
                  position: i + 1,
                  name: s.title,
                  text: stripHtml(s.description ?? s.title).slice(0, 300),
                  image: s.src ? `${SITE_URL}${s.src}` : undefined,
                })) : undefined}
              >
                {flow.steps.map((step, i) => (
                  <Fragment>
                    <WalkthroughStepImage
                      step={i + 1}
                      title={step.title}
                      description={step.description}
                      src={step.src}
                      alt={step.alt}
                      caption={step.caption}
                      capturedAt={step.capturedAt ?? flow.lastVerified}
                      device={step.device ?? 'desktop'}
                      aspectRatio={step.aspectRatio ?? '16/9'}
                      width={step.width ?? (step.device === 'mobile' ? 390 : 1280)}
                      height={step.height ?? (step.device === 'mobile' ? 844 : 720)}
                      warning={step.warning}
                      tip={step.tip}
                      region={step.region}
                      whatHappensNext={step.whatHappensNext}
                      lightboxGroup={flow.id}
                      label={step.screenshotLabel}
                      tableContent={(step as any).tableContent}
                    />
                    {(flow as any).midCtaAfterStep === i + 1 && (
                      <div class="wt-mid-cta">
                        <span class="wt-mid-cta-icon" aria-hidden="true">🔗</span>
                        <span class="wt-mid-cta-text">Following this guide on {ex.name}? Open your account in a new tab to complete steps as you read.</span>
                        <a
                          href={ex.affiliateUrl}
                          class="wt-mid-cta-btn"
                          rel="noopener noreferrer sponsored"
                          target="_blank"
                        >
                          Open {ex.name} ↗
                        </a>
                      </div>
                    )}
                  </Fragment>
                ))}
              </WalkthroughFlow>
              </Fragment>
            ))}
          </section>
        )}

        {_sectionsAt('after-walkthroughs').map((s: any) => (
          <section class="ex-section" id={s.id}>
            <h2 class="ex-section-title">{s.heading}</h2>
            <div class="flagship-html" set:html={s.html} />
          </section>
        ))}

        {_p2pDirectionScreenshot && (
          <ContextualEvidenceScreenshot
            src={_p2pDirectionScreenshot.src}
            alt="Binance P2P interface with Buy selected, USDT active, USD selected, filters visible, and seller names masked."
            caption="Binance P2P public interface showing the Buy flow for USDT with USD selected. Rates and payment methods vary by country, seller, and time."
            device={_p2pDirectionScreenshot.device === 'none' ? 'desktop' : _p2pDirectionScreenshot.device}
            capturedAt={_p2pDirectionScreenshot.capturedAt}
            {..._imgDims(_p2pDirectionScreenshot.src)}
          />
        )}

        <!-- About exchange -->
        <section class="ex-section" id="exchange-review">
          <h2 class="ex-section-title">{ex.name} Review: Is It Worth It in 2026?</h2>

          {/* Snippet-ready trust paragraph — targets "is [exchange] safe/legit" queries */}
          {((ex as any).licences?.length > 0 || (ex as any).founded || (ex as any).users) && (
            <p class="ex-prose ex-prose--snippet" id="is-safe">
              <strong>{ex.name} is a legitimate{(ex as any).licences?.length > 0 ? ' and regulated' : ''} cryptocurrency exchange</strong>
              {(ex as any).founded ? `, founded in ${(ex as any).founded}` : ''}
              {(ex as any).licences?.length > 0
                ? ` and licensed by ${getLicenceText((ex as any).licences)}`
                : ''}.
              {(ex as any).users ? ` It serves over ${(ex as any).users} registered users worldwide` : ''}
              {(ex as any).headquarters ? ` and is headquartered in ${(ex as any).headquarters}` : ''}.
              {' '}It supports {getExchangeTypeDesc(ex)}.
              {(ex as any).proofOfReserves
                ? ` ${ex.name} publishes regular proof-of-reserves audits, with user funds held primarily in cold storage.`
                : ' User funds are held in cold storage with multi-signature security.'}
              {ex.countries?.includes('us') === false
                ? ` ${ex.name} is not available to residents of the United States.`
                : ''}
            </p>
          )}

          {_proofOfReservesScreenshot && (
            <ContextualEvidenceScreenshot
              src={_proofOfReservesScreenshot.src}
              alt={`${ex.name} proof-of-reserves page showing assets backed at or above 100%`}
              caption={_proofOfReservesScreenshot.caption ?? `${ex.name} Proof of Reserves page — published reserve ratios for major assets. Page captured June 2026; figures reflect the latest audit snapshot shown on it.`}
              device={_proofOfReservesScreenshot.device === 'none' ? 'desktop' : _proofOfReservesScreenshot.device}
              capturedAt={_proofOfReservesScreenshot.capturedAt}
              {..._imgDims(_proofOfReservesScreenshot.src)}
              zoomable
            />
          )}

          {/* Exchange quick-facts table — snippet extraction + AI Overview clarity */}
          {((ex as any).founded || (ex as any).licences?.length > 0 || (ex as any).spotMakerFee !== undefined) && (
            <div class="ex-fact-box" aria-label={`${ex.name} key facts`}>
              <div class="ex-fact-box-title">{ex.name} — Key Facts</div>
              <table class="ex-fact-table">
                <tbody>
                  {(ex as any).founded && (
                    <tr><th scope="row">Founded</th><td>{(ex as any).founded}</td></tr>
                  )}
                  {(ex as any).headquarters && (
                    <tr><th scope="row">Headquarters</th><td>{(ex as any).headquarters}</td></tr>
                  )}
                  {(ex as any).licences?.length > 0 && (
                    <tr>
                      <th scope="row">Regulator</th>
                      <td>{getLicenceShort((ex as any).licences)}</td>
                    </tr>
                  )}
                  {(ex as any).users && (
                    <tr><th scope="row">Users</th><td>{(ex as any).users} registered</td></tr>
                  )}
                  {(ex as any).tradingPairsCount && (
                    <tr><th scope="row">Trading Pairs</th><td>{((ex as any).tradingPairsCount as number).toLocaleString()}+</td></tr>
                  )}
                  {(ex as any).spotMakerFee !== undefined && (
                    <tr>
                      <th scope="row">Spot Fees</th>
                      <td>{(ex as any).spotMakerFee}% maker / {(ex as any).spotTakerFee}% taker</td>
                    </tr>
                  )}
                  {(ex as any).futuresMakerFee !== undefined && (
                    <tr>
                      <th scope="row">Futures Fees</th>
                      <td>{(ex as any).futuresMakerFee}% maker / {(ex as any).futuresTakerFee}% taker</td>
                    </tr>
                  )}
                  {(ex as any).p2pAvailable && (
                    <tr><th scope="row">P2P Trading</th><td>Public P2P marketplace; terms vary by seller and region</td></tr>
                  )}
                  {(ex as any).maxFuturesLeverage && (
                    <tr><th scope="row">Max Leverage</th><td>Up to {(ex as any).maxFuturesLeverage}× (BTCUSDT: 125×)</td></tr>
                  )}
                  <tr>
                    <th scope="row">KYC Required</th>
                    <td>{ex.kycRequired ? 'Yes — Standard KYC (Level 1)' : _kycClaimSafe ? 'No' : 'Check official terms'}</td>
                  </tr>
                  <tr><th scope="row">Mobile App</th><td>iOS &amp; Android</td></tr>
                  {(ex as any).proofOfReserves && (
                    <tr><th scope="row">Proof of Reserves</th><td>Yes — publicly verifiable</td></tr>
                  )}
                </tbody>
              </table>
            </div>
          )}

          {/* Comparison mini-table — comparative-intent capture (featured snippet
              + AI extraction). Rendered only when the editorial override names
              competitor slugs; all numbers come from exchanges.json. */}
          {_compareMini.length > 0 && (
            <div class="ex-fact-box" aria-label={`${ex.name} vs alternatives comparison`}>
              <h3 class="ex-fact-box-title" style="margin:0">{ex.name} vs {_compareMini.map(c => c.name).join(' vs ')} — Bonus Comparison</h3>
              <table class="ex-fact-table ex-compare-mini">
                <thead>
                  <tr>
                    <th scope="col"></th>
                    <th scope="col">{ex.name}</th>
                    {_compareMini.map(c => <th scope="col"><a href={`/exchanges/${c.slug}/`}>{c.name}</a></th>)}
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row">Max bonus</th>
                    <td><strong>{ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}</strong></td>
                    {_compareMini.map(c => <td>{c.bonusAmount.toLocaleString()} {c.bonusCurrency}</td>)}
                  </tr>
                  <tr>
                    <th scope="row">KYC required</th>
                    <td>{ex.kycRequired ? 'Yes' : 'No'}</td>
                    {_compareMini.map(c => <td>{c.kycRequired ? 'Yes' : 'No'}</td>)}
                  </tr>
                  <tr>
                    <th scope="row">Min deposit</th>
                    <td>{(ex as any).minDeposit?.amount ? `${(ex as any).minDeposit.amount} ${(ex as any).minDeposit.currency}` : 'None'}</td>
                    {_compareMini.map(c => <td>{c.minDeposit?.amount ? `${c.minDeposit.amount} ${c.minDeposit.currency}` : 'None'}</td>)}
                  </tr>
                  <tr>
                    <th scope="row">Typical real earnings</th>
                    <td>{(ex as any).bonusRange?.typicalMin ? `${(ex as any).bonusRange.typicalMin}–${(ex as any).bonusRange.typicalMax} ${(ex as any).bonusRange.currency}` : '—'}</td>
                    {_compareMini.map(c => <td>{c.bonusRange?.typicalMin ? `${c.bonusRange.typicalMin}–${c.bonusRange.typicalMax} ${c.bonusRange.currency}` : '—'}</td>)}
                  </tr>
                </tbody>
              </table>
            </div>
          )}


          <p class="ex-prose">{(_faqOverride?.longDescription?.length > 20 ? _faqOverride.longDescription : null) ?? ex.longDescription}</p>
          {((ex as any).editorNote?.length > 30 || (_faqOverride?.editorNote?.length > 30)) && (
            <EditorialNote
              note={(_faqOverride?.editorNote?.length > 30 ? _faqOverride.editorNote : null) ?? (ex as any).editorNote}
              reviewedAt={(ex as any).lastVerified ?? ex.updatedAt}
            />
          )}

          {/* People Also Compare — behavioral SEO + internal linking widget */}
          {myComparePairs.length > 0 && (
            <PeopleAlsoCompare
              pairs={myComparePairs}
              exchanges={exMap as any}
              currentSlug={ex.slug}
              limit={5}
            />
          )}
        </section>

        <!-- Pros & Cons -->
        <section class="ex-section">
          <h2 class="ex-section-title">Pros & Cons</h2>
          <ProsConsBlock pros={ex.pros} cons={ex.cons} />
        </section>

        <!-- Country availability + cross-links -->
        <section class="ex-section">
          <h2 class="ex-section-title">Country Availability</h2>
          <CountryAvailability countries={ex.countries} excludedCountries={ex.excludedCountries} />

          <!-- Geo-aware regulatory note (shown for visitor's country) -->
          <GeoRegulatoryNote exchange={ex as any} />

          {countryCrossLinks.length > 0 && (
            <CountryCrossLinksBlock
              countries={countryCrossLinks as any}
              heading="Explore Country-Specific Bonus Guides"
            />
          )}
        </section>

        <!-- Related bonus categories (internal linking) -->
        {relatedCats.length > 0 && (
          <section class="ex-section">
            <h2 class="ex-section-title">Compare by Bonus Type</h2>
            <p class="ex-prose" style="margin-bottom: 0.75rem">
              {ex.name} qualifies across multiple bonus categories. Browse the full comparison for each type:
            </p>
            <RelatedCategoriesBlock
              categories={relatedCats as any}
              heading="Bonus Categories"
            />
          </section>
        )}

        <!-- Related Guides (internal linking) -->
        {relatedGuides.length > 0 && (
          <section class="ex-section">
            <RelatedGuidesBlock
              guides={relatedGuides}
              heading="Related Guides"
              variant="full"
            />
          </section>
        )}

        <!-- Use-case cross-links -->
        {relatedUseCases.length > 0 && (
          <section class="ex-section ex-use-case-links">
            <h2 class="ex-section-title" style="margin-bottom: 0.5rem">{ex.name} is recommended for:</h2>
            <div class="ex-uc-chips">
              {relatedUseCases.map(uc => (
                <a href={`/use-cases/${uc.slug}/`} class="ex-uc-chip">
                  {uc.label}
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Related Next Reads — internal distribution, dead-end elimination -->
        {rnrItems.length > 0 && (
          <RelatedNextReads
            heading="Explore next"
            items={rnrItems}
            compact
          />
        )}

        <!-- Bonus landing page link + bonus code cross-link -->
        <section class="ex-section">
          <div class="bonus-page-link-strip">
            <div>
              <div class="bonus-page-link-label">Step-by-step bonus guide</div>
              <div class="bonus-page-link-title">How to Claim the {ex.name} Bonus</div>
            </div>
            <a href={`/bonuses/${ex.slug}-bonus/`} class="bonus-page-link-cta">Claim Guide →</a>
          </div>
          {hasBonusCode && (
            <div class="bonus-code-strip">
              <span class="bonus-code-strip-label">🔑 Working promo codes</span>
              <a href={`/bonus-codes/${ex.slug}/`} class="bonus-code-strip-link">{ex.name} Bonus Code {new Date().getFullYear()} →</a>
            </div>
          )}
        </section>

        <!-- Coins available on this exchange — internal linking to /coins/ -->
        {relatedCoins.length > 0 && (
          <section class="ex-section">
            <h3 class="ex-section-title" style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.07em;color:var(--color-text-muted)">Buy Crypto on {ex.name}</h3>
            <div class="ex-coin-chips">
              {relatedCoins.map(coin => (
                <a href={`/coins/${coin.slug}/`} class="ex-coin-chip">
                  {(coin as any).symbol ?? coin.slug.toUpperCase()}
                </a>
              ))}
              <a href="/coins/" class="ex-coin-chip ex-coin-chip--all">All Coins →</a>
            </div>
          </section>
        )}

        <!-- How we evaluate — compact E-E-A-T methodology reference -->
        <HowWeEvaluate variant="compact" />

        <!-- FAQ -->
        <FAQBlock items={faqItems} title={`${ex.name} Bonus — FAQ`} exchangeSlug={ex.slug} suppressSchema={!!faqSchema} />

        {_sectionsAt('after-faq').map((s: any) => (
          <section class="ex-section" id={s.id}>
            <h2 class="ex-section-title">{s.heading}</h2>
            <div class="flagship-html" set:html={s.html} />
          </section>
        ))}

      </div>

      <!-- ── STICKY SIDEBAR ── -->
      <aside class="ex-sidebar">
        <div class="sidebar-card">
          <div class="sidebar-label">Bonus Summary</div>
          <div class="sidebar-amount">
            Up to {ex.bonusAmount.toLocaleString()} {ex.bonusCurrency}
          </div>
          <div class="sidebar-title">{ex.bonusTitle}</div>

          <div class="sidebar-stats">
            <div class:list={['sidebar-stat', !ex.kycRequired && _kycClaimSafe && 'sidebar-stat--ok']}>
              <span class="sidebar-stat-icon">{ex.kycRequired ? '🪪' : _kycClaimSafe ? '✓' : '⚠️'}</span>
              <span>{ex.kycRequired ? 'KYC Required' : _kycClaimSafe ? 'No KYC' : 'Verify KYC terms'}</span>
            </div>
            <div class:list={['sidebar-stat', !ex.depositRequired && 'sidebar-stat--ok']}>
              <span class="sidebar-stat-icon">{ex.depositRequired ? '💰' : '✓'}</span>
              <span>
                {minDeposit && minDeposit.amount > 0
                  ? `Min deposit: ${minDeposit.amount} ${minDeposit.currency}`
                  : ex.depositRequired ? 'Deposit Required' : 'No Deposit'}
              </span>
            </div>
            <div class="sidebar-stat">
              <span class="sidebar-stat-icon">⭐</span>
              <span>Rating: {ex.rating}/10</span>
            </div>
            {bonusExpiry && (
              <div class="sidebar-stat">
                <span class="sidebar-stat-icon">⏳</span>
                <span>Expires in {bonusExpiry.days} days</span>
              </div>
            )}
          </div>
          {((ex as any).founded || (ex as any).users || (ex as any).headquarters) && (
            <div class="sidebar-meta">
              {(ex as any).founded && (
                <div class="sidebar-meta-row">
                  <span class="sidebar-meta-label">Founded</span>
                  <span class="sidebar-meta-val">{(ex as any).founded}</span>
                </div>
              )}
              {(ex as any).users && (
                <div class="sidebar-meta-row">
                  <span class="sidebar-meta-label">Users</span>
                  <span class="sidebar-meta-val">{(ex as any).users}</span>
                </div>
              )}
              {(ex as any).headquarters && (
                <div class="sidebar-meta-row">
                  <span class="sidebar-meta-label">HQ</span>
                  <span class="sidebar-meta-val">{(ex as any).headquarters}</span>
                </div>
              )}
            </div>
          )}

          {ex.promoCode && (
            <div class="sidebar-promo">
              <div class="sidebar-promo-label">Promo code</div>
              <div class="sidebar-promo-val">{ex.promoCode}</div>
            </div>
          )}

          <div class="sidebar-cta">
            <CTAButton
              href={ex.affiliateUrl}
              label={!ex.kycRequired && _kycClaimSafe && !ex.depositRequired
                ? `Get ${ex.name} Bonus`
                : !ex.kycRequired && _kycClaimSafe
                  ? `Claim — No KYC`
                  : `Claim ${ex.name} Bonus`}
              exchange={ex.name}
              size="lg"
              fullWidth
              trackPlacement="sidebar"
              trackBonus={ex.bonusAmount}
              geoHrefs={(ex as any).affiliateLinks?.geo ?? undefined}
            />
          </div>

          {ex.termsUrl && (
            <a href={ex.termsUrl} target="_blank" rel="noopener noreferrer nofollow" class="sidebar-terms">
              View official terms ↗
            </a>
          )}

          <p class="sidebar-risk">{ex.riskNotes}</p>
        </div>

        <!-- Trust block -->
        <div class="sidebar-trust">
          {(ex as any).topChoice && (
            <div class="sidebar-top-choice">⭐ Editor's Top Pick</div>
          )}
          <div class="sidebar-trust-title">Why we list this exchange</div>
          <ul class="sidebar-trust-list">
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {(ex as any).founded
                ? `Established ${(ex as any).founded} — ${new Date().getFullYear() - (ex as any).founded}+ years operating`
                : 'Established platform with track record'}
            </li>
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {(ex as any).users ? `${(ex as any).users} registered users` : 'Cold storage asset protection'}
            </li>
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Verified bonus conditions
            </li>
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Available in {ex.countries.length}+ regions
            </li>
            {(ex as any).licences?.length > 0 && (
              <li>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Licensed: {(ex as any).licences.join(', ')}
              </li>
            )}
          </ul>
        </div>
      </aside>

    </div>

    <!-- Full-width sections below two-column -->
    <AlternativesBlock currentSlug={ex.slug} exchanges={exchanges} />

    <!-- Compare vs. section -->
    {myComparePairs.length > 0 && (
      <section class="compare-vs-section">
        <h2 class="section-heading">Compare {ex.name} vs Alternatives</h2>
        <div class="compare-vs-grid">
          {myComparePairs.map(p => {
            const otherSlug = p.a === ex.slug ? p.b : p.a;
            const other = exMap[otherSlug] as any;
            if (!other) return null;
            return (
              <a href={`/compare/${p.pair}/`} class="compare-vs-card">
                <div class="compare-vs-logos">
                  <ExchangeLogo slug={ex.slug} name={ex.name} size={44} variant="square" lazy={false} />
                  <span class="compare-vs-divider">vs</span>
                  <ExchangeLogo slug={otherSlug} name={other.name} size={44} variant="square" lazy={false} />
                </div>
                <span class="compare-vs-label">{ex.name} vs {other.name}</span>
                <span class="compare-vs-arrow">→</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <RiskDisclaimer />
  </div>
</Layout>

<style>
  .ex-page {
    padding-bottom: 2rem;
  }

  /* ── Freshness row ── */
  .ex-freshness-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0 0.875rem;
  }

  /* ── "Why trust this review?" details block ── */
  .trust-details {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }
  .trust-details-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.15s;
  }
  .trust-details-summary::-webkit-details-marker { display: none; }
  .trust-details-summary:hover { background: rgba(255,255,255,0.03); }
  .trust-details-summary svg:first-child { color: #4ade80; flex-shrink: 0; }
  .trust-details-chevron {
    margin-left: auto;
    flex-shrink: 0;
    transition: transform 0.2s;
    color: var(--color-text-muted);
  }
  .trust-details[open] .trust-details-chevron { transform: rotate(180deg); }
  .trust-details[open] .trust-details-summary { border-bottom: 1px solid var(--color-border); }

  .trust-details-list {
    list-style: none;
    padding: 0.75rem 1rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .trust-details-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }
  .trust-details-list li svg {
    flex-shrink: 0;
    color: #4ade80;
    margin-top: 3px;
  }
  .trust-details-list li strong { color: var(--color-text-primary); }
  .trust-details-footer {
    padding: 0.5rem 1rem 0.75rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .trust-details-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.75rem;
  }
  .trust-details-link:hover { text-decoration: underline; }

  /* ── Exchange fact box (entity/snippet table) ── */
  .ex-fact-box {
    margin: 1rem 0 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }
  .ex-fact-box-title {
    padding: 0.55rem 0.875rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    background: rgba(245,197,66,0.05);
    border-bottom: 1px solid var(--color-border);
  }
  /* Answer capsule — AI-extractable datestamped quick answer below hero */
  .answer-capsule {
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 4%, var(--color-bg-secondary));
    border: 1px solid color-mix(in srgb, var(--color-accent) 22%, var(--color-border));
    border-radius: 12px;
  }
  .answer-capsule-text {
    margin: 0 0 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-primary);
  }
  .answer-capsule-text :global(strong) { color: var(--color-accent); }
  .answer-capsule-meta {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #4ade80;
  }

  /* Flagship HTML sections — content injected via set:html lacks Astro scope
     attributes, so style descendants through :global() */
  .flagship-html :global(p) {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 1rem;
  }
  .flagship-html :global(strong) { color: var(--color-text-primary); }
  .flagship-html :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .flagship-html :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }
  .flagship-html :global(th),
  .flagship-html :global(td) {
    padding: 0.55rem 0.75rem;
    font-size: 0.82rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }
  .flagship-html :global(thead th) {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }
  .flagship-html :global(tbody th) {
    color: var(--color-text-primary);
    font-weight: 600;
  }
  .flagship-html :global(tr:last-child th),
  .flagship-html :global(tr:last-child td) { border-bottom: none; }
  .flagship-html :global(figure.fh-mobile-shot) {
    margin: 1.25rem auto;
    max-width: 320px;
  }
  .flagship-html :global(figure.fh-mobile-shot img) {
    width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    display: block;
  }
  .flagship-html :global(figure.fh-mobile-shot figcaption) {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    line-height: 1.5;
  }
  .flagship-html :global(.fh-tour-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.25rem 0;
  }
  .flagship-html :global(.fh-tour-grid figure),
  .flagship-html :global(figure.fh-wide-shot) {
    margin: 0;
  }
  .flagship-html :global(figure.fh-wide-shot) { margin-top: 1.25rem; }
  .flagship-html :global(.fh-tour-grid img),
  .flagship-html :global(figure.fh-wide-shot img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    display: block;
  }
  .flagship-html :global(.fh-tour-grid figcaption),
  .flagship-html :global(figure.fh-wide-shot figcaption) {
    margin-top: 0.4rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.45;
  }
  @media (max-width: 720px) {
    .flagship-html :global(.fh-tour-grid) { grid-template-columns: minmax(0, 1fr); }
  }

  /* Side-by-side proof pair inside flagship html (e.g. withdrawal both-ends) */
  .flagship-html :global(.fh-pair) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: start;
    margin-top: 1.25rem;
  }
  .flagship-html :global(.fh-pair figure) {
    margin: 0;
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface, #13131f);
  }
  .flagship-html :global(.fh-pair figure img) {
    display: block;
    width: 100%;
    height: auto;
    max-width: 320px;
    margin: 0 auto;
  }
  .flagship-html :global(.fh-pair figcaption) {
    padding: 0.5rem 0.875rem 0.625rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.45;
  }
  @media (max-width: 720px) {
    .flagship-html :global(.fh-pair) { grid-template-columns: minmax(0, 1fr); }
  }
  /* Any flagship figure wired to the lightbox is visibly clickable */
  .flagship-html :global(figure[data-lightbox-group]) { cursor: zoom-in; }

  /* Tier table section (flagship §4.3) */
  .tier-stage-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 1.5rem 0 0.75rem;
  }
  .tier-note {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0.5rem 0 0;
  }
  .ex-tier-table thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .ex-tier-table td.tier-reward {
    color: var(--color-accent);
    font-weight: 700;
  }
  /* Tier numbers are single digits — don't inherit the wide label-column
     width from the key-facts table (it left a large empty gap).
     table.-prefixed selector outranks the later .ex-fact-table base rule. */
  table.ex-tier-table th[scope="row"],
  table.ex-tier-table thead th:first-child {
    width: 3.5rem;
    white-space: nowrap;
    text-align: center;
  }
  .tier-footnotes {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .tier-footnotes li { margin-bottom: 0.35rem; }

  /* Paired evidence shots (fee schedules, tier proofs) — two columns on
     desktop so dense captures don't stack as unreadable full-width walls */
  .shots-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: start;
    margin-top: 1rem;
  }
  .shots-pair :global(.ce-shot) { margin: 0; }
  .shots-pair :global(.ce-shot__img) {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top center;
  }
  @media (max-width: 860px) {
    .shots-pair { grid-template-columns: minmax(0, 1fr); }
  }

  .ex-compare-mini thead th {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .ex-compare-mini thead th a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ex-compare-mini thead th a:hover { color: var(--color-accent); }
  .ex-compare-mini td strong { color: var(--color-accent); }

  .ex-fact-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .ex-fact-table th[scope="row"] {
    text-align: left;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 0.45rem 0.875rem;
    width: 42%;
    vertical-align: top;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    white-space: nowrap;
  }
  .ex-fact-table td {
    color: var(--color-text-primary);
    padding: 0.45rem 0.875rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: top;
  }
  .ex-fact-table tr:last-child th,
  .ex-fact-table tr:last-child td { border-bottom: none; }
  @media (max-width: 480px) {
    .ex-fact-table th[scope="row"] { width: 45%; font-size: 0.78rem; white-space: normal; }
    .ex-fact-table td { font-size: 0.78rem; }
  }

  /* ── Comparison context paragraph ── */
  .ex-prose--comparison {
    padding: 0.875rem 1rem;
    background: rgba(96,165,250,0.04);
    border: 1px solid rgba(96,165,250,0.12);
    border-left: 3px solid rgba(96,165,250,0.35);
    border-radius: 0 8px 8px 0;
    font-size: 0.875rem;
    line-height: 1.7;
    margin-top: 1rem !important;
  }
  .ex-prose-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }
  .ex-prose-link:hover { text-decoration: underline; }

  /* Compare vs section */
  .compare-vs-section { margin: 2rem 0; }
  .compare-vs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .compare-vs-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: border-color var(--duration-base), box-shadow var(--duration-base), transform var(--duration-base);
  }
  .compare-vs-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-card);
    transform: translateY(-1px);
  }
  .compare-vs-logos {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  /* ExchangeLogo handles its own sizing — no img override needed */
  .compare-vs-divider { font-size: 0.65rem; color: var(--color-text-muted); font-weight: 400; }
  .compare-vs-label { flex: 1; font-size: var(--text-sm); }
  .compare-vs-arrow { color: var(--color-accent); font-weight: 700; flex-shrink: 0; }

  /* Two-column layout */
  .ex-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
    margin-top: 0.5rem;
  }

  /* Sidebar */
  .ex-sidebar {
    position: sticky;
    top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .sidebar-amount {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-accent);
    line-height: 1;
  }

  .sidebar-title {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: -0.5rem;
  }

  .sidebar-stats {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.875rem;
    background: var(--color-bg-tertiary);
    border-radius: 10px;
    border: 1px solid var(--color-border);
  }

  .sidebar-stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .sidebar-stat--ok { color: #4ade80; }

  .sidebar-stat-icon { font-size: 0.875rem; }

  .sidebar-promo {
    background: rgba(245, 197, 66, 0.06);
    border: 1px dashed var(--color-accent-dim);
    border-radius: 8px;
    padding: 0.75rem;
    text-align: center;
  }

  .sidebar-promo-label {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .sidebar-promo-val {
    font-family: monospace;
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .sidebar-cta { margin-top: 0.25rem; }

  .sidebar-terms {
    display: block;
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
    margin-top: -0.25rem;
  }

  .sidebar-terms:hover { color: var(--color-accent); }

  .sidebar-risk {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
    padding-top: 0.625rem;
    border-top: 1px solid var(--color-border);
  }

  .sidebar-trust {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.25rem;
  }

  .sidebar-trust-title {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .sidebar-trust-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-trust-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
  }

  .sidebar-trust-list svg { color: #4ade80; flex-shrink: 0; }

  .sidebar-top-choice {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: rgba(245, 197, 66, 0.1);
    border: 1px solid rgba(245, 197, 66, 0.25);
    border-radius: var(--radius-pill, 100px);
    padding: 0.25rem 0.65rem;
    margin-bottom: 0.25rem;
  }

  .sidebar-meta {
    padding: 0.75rem;
    background: var(--color-bg-tertiary);
    border-radius: 8px;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: -0.25rem;
  }

  .sidebar-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .sidebar-meta-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .sidebar-meta-val {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: right;
  }

  /* Section styles */
  .ex-section { margin-bottom: 2rem; }

  .ex-section-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
  }

  .ex-prose {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
  }

  /* Bonus tiers */
  .bonus-tiers {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.875rem;
  }

  .bonus-tier {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: border-color 0.15s;
  }

  .bonus-tier:hover { border-color: var(--color-accent-dim); }

  .bonus-tier-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .bonus-tier-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .bonus-tier-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Rich tier card layout when using structured bonusTiers data */
  .bonus-tier--data { align-items: flex-start; }

  .bonus-tier-content { flex: 1; min-width: 0; }

  .bonus-tier-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }

  .bonus-tier-amount {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--color-accent);
    background: rgba(245, 197, 66, 0.1);
    border: 1px solid rgba(245, 197, 66, 0.2);
    border-radius: var(--radius-pill, 100px);
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .bonus-tier-note {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin-top: 0.3rem;
    font-style: italic;
    line-height: 1.4;
  }

  /* Conditions grid */
  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .cond-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .cond-card--highlight {
    border-color: var(--color-accent-dim);
    background: rgba(245, 197, 66, 0.04);
  }

  .cond-card--ok {
    border-color: rgba(74, 222, 128, 0.25);
  }

  .cond-card--warn {
    border-color: rgba(248, 113, 113, 0.2);
  }

  .cond-icon { font-size: 1.1rem; margin-top: 1px; }

  .cond-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.2rem;
  }

  .cond-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .cond-card--ok .cond-value { color: #4ade80; }
  .cond-card--warn .cond-value { color: #f87171; }
  .cond-card--highlight .cond-value { color: var(--color-accent); }

  .cond-bonus-types {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .cond-types-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  /* ReviewerBlock compact is rendered by the component itself */

  /* Mobile: stack layout, pad bottom for sticky CTA */
  @media (max-width: 960px) {
    .ex-layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .ex-main {
      min-width: 0;
      overflow-x: clip;
    }

    .ex-sidebar {
      position: static;
      order: -1;
    }

    .sidebar-card {
      border-left: 3px solid var(--color-accent);
    }
  }

  /* Sticky CTA shows at ≤768px — need matching padding */
  @media (max-width: 768px) {
    .ex-page { padding-bottom: 80px; }
  }

  @media (max-width: 640px) {
    .bonus-tiers { grid-template-columns: minmax(0, 1fr); }
    .conditions-grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); }
  }

  @media (max-width: 400px) {
    .conditions-grid { grid-template-columns: 1fr; }
  }

  /* Bonus page link strip */
  .bonus-page-link-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
