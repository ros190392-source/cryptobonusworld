---
/**
 * /go/[exchange]/ — Safe Affiliate Redirect Page
 *
 * Static HTML redirect page for affiliate links. Handles:
 *  1. Analytics logging (cbw_affiliate_click) before redirect
 *  2. GEO-aware URL resolution (reads localStorage cbw_geo)
 *  3. Client-side redirect via window.location.replace() — no history entry
 *     (equivalent to HTTP 302 from the browser's perspective)
 *  4. <meta http-equiv="refresh"> fallback for JS-disabled environments
 *  5. <link rel="canonical"> pointing to the exchange detail page (SEO-safe)
 *
 * SEO: noindex + nofollow on all outbound links.
 *      Canonical → /exchanges/{slug}/ (exchange detail page).
 *      These pages are excluded from the sitemap.
 *
 * Note on HTTP 302: This is a static site (output: 'static'). A true
 * server-side 302 requires a server adapter or nginx rewrite rules.
 * JS location.replace() is the functional equivalent:
 *  - no browser history entry created
 *  - same user experience as server 302
 *  - affiliate programs accept JS redirects
 * If migrating to SSR, replace this page with a server endpoint that
 * returns Response.redirect(url, 302).
 */

import exchanges from '../../data/exchanges.json';

export function getStaticPaths() {
  return exchanges.map(ex => ({
    params: { exchange: ex.slug },
    props: { exchange: ex },
  }));
}

const { exchange: ex } = Astro.props;

// Fallback redirect target (exchange detail page) — used when:
//  - JS is disabled
//  - All affiliate URLs are placeholders
//  - 0-second redirect before JS fires
// bybit has a dedicated /bybit/ route; all others fall back to /exchanges/[slug]/
const fallbackUrl = ex.slug === 'bybit' ? '/bybit/' : `/exchanges/${ex.slug}/`;

// Server-rendered href for the visible "Continue" fallback button (works even
// with JS disabled). Uses the default affiliate URL when it's a real https
// link; placeholder/retired exchanges fall back to the safe internal page.
// The client script upgrades this to the fully resolved GEO/tracked URL.
const rawDefault = ex.affiliateLinks?.default ?? ex.affiliateUrl ?? '#';
const continueHref = /^https?:\/\//.test(rawDefault) ? rawDefault : fallbackUrl;

// Serialise affiliate link data for client-side resolution
const linkData = {
  slug:    ex.slug,
  name:    ex.name,
  default: ex.affiliateLinks?.default ?? ex.affiliateUrl ?? '#',
  geo:     ex.affiliateLinks?.geo ?? {},
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Opening {ex.name} — CryptoBonusWorld</title>

  <!-- SEO: noindex this redirect page; canonical → content page -->
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={ex.slug === 'bybit' ? 'https://cryptobonusworld.com/bybit/' : `https://cryptobonusworld.com/exchanges/${ex.slug}/`} />

  <!--
    Fallback meta-refresh: redirects to exchange detail page if JS fails.
    We redirect to the detail page (not affiliate URL) so the fallback is
    always safe regardless of URL placeholder state.
  -->
  <meta http-equiv="refresh" content={`8;url=${fallbackUrl}`} />

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      background: #0B1220;
      color: #94A3B8;
      font-family: Inter, system-ui, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 1.25rem;
    }
    .card {
      background: #13233E; /* header navy */
      border: 1px solid #27405F;
      border-radius: 16px;
      padding: 2rem 1.75rem 1.75rem;
      text-align: center;
      max-width: 400px;
      width: 100%;
    }
    .brand {
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #F8FAFC;
      margin: 0 0 1.25rem;
    }
    .brand .accent { color: #F5A623; }
    .ex-logo {
      height: 44px;
      max-width: 200px;
      object-fit: contain;
      margin: 0 auto 0.9rem;
      display: block;
    }
    h1 {
      font-size: 1.15rem;
      font-weight: 800;
      color: #FFFFFF;
      margin: 0 0 0.6rem;
    }
    p {
      font-size: 0.85rem;
      color: #94A3B8;
      margin: 0 0 0.6rem;
      line-height: 1.55;
    }
    .progress {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin: 1rem 0 1.1rem;
      font-size: 0.8rem;
      color: #CBD5E1;
    }
    .spinner {
      width: 18px;
      height: 18px;
      border: 2px solid #27405F;
      border-top-color: #F5A623;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      flex: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .continue-btn {
      display: block;
      width: 100%;
      padding: 0.85rem 1rem;
      border-radius: 10px;
      background: #15803D;
      color: #FFFFFF;
      font-size: 0.9rem;
      font-weight: 800;
      text-decoration: none;
      line-height: 1.2;
    }
    .continue-btn:hover { background: #166534; }
    .disclaimer {
      font-size: 0.68rem;
      color: #64748B;
      margin: 1.1rem 0 0;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <div class="card">
    <p class="brand">Crypto<span class="accent">Bonus</span>World</p>
    <img
      class="ex-logo"
      src={`/logos/${ex.slug}.png`}
      alt={`${ex.name} logo`}
      onerror="this.style.display='none'"
    />
    <h1>Opening {ex.name}</h1>
    <p>You’re being redirected to the official {ex.name} registration page.</p>
    <p>Your referral code and available bonus will be applied where supported.</p>
    <div class="progress">
      <span class="spinner" aria-hidden="true"></span>
      <span>Redirecting securely…</span>
    </div>
    <a
      id="cbw-continue"
      href={continueHref}
      class="continue-btn"
      rel="noopener noreferrer sponsored"
    >
      Continue to {ex.name}
    </a>
    <p class="disclaimer">
      Conditions apply. Always verify bonus terms on the official exchange website before registering.
    </p>
  </div>

  <!--
    Affiliate redirect script.
    Runs immediately — define:vars inlines the link data so no fetch needed.
    Reads localStorage cbw_geo (set by Analytics.astro) for GEO-aware routing.
    Fires cbw_affiliate_click before redirect.
    Uses window.location.replace() — equivalent to HTTP 302 (no history entry).
  -->
  <script define:vars={{ __linkData: linkData, __exchangeSlug: ex.slug, __fallbackUrl: fallbackUrl }} is:inline>
  (function () {
    'use strict';

    var PLACEHOLDER = '#';
    var SITE_BASE   = 'https://cryptobonusworld.com';

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isPlaceholder(url) {
      return !url || url === PLACEHOLDER || url.trim() === '' || url === 'null';
    }
    function isValidUrl(url) {
      try { var u = new URL(url); return u.protocol === 'https:' || u.protocol === 'http:'; }
      catch(_) { return false; }
    }

    // ── Read visitor context ──────────────────────────────────────────────────
    var geo = 'unknown', device = 'unknown', sid = 'unknown', abVariant = 'control', sessionPageCount = 0;
    try {
      geo    = localStorage.getItem('cbw_geo')    || 'unknown';
      device = localStorage.getItem('cbw_device') || 'unknown';
    } catch(_) {}
    try {
      sid              = sessionStorage.getItem('cbw_sid')    || 'unknown';
      sessionPageCount = parseInt(sessionStorage.getItem('cbw_pcount') || '0', 10);
    } catch(_) {}
    try { abVariant = localStorage.getItem('cbw_ab') || 'control'; } catch(_) {}

    // Read URL params (placement, pageType, comparePair passed from referring page)
    var searchParams = new URLSearchParams(location.search);
    var placement    = searchParams.get('pl')   || 'go-redirect';
    var pageType     = searchParams.get('pt')   || 'unknown';
    var comparePair  = searchParams.get('cp')   || null;
    var ctxRank      = searchParams.get('rank') ? parseInt(searchParams.get('rank'), 10) : null;
    var geoOverride  = searchParams.get('geo');
    if (geoOverride) geo = geoOverride;

    // ── Resolve affiliate URL ─────────────────────────────────────────────────
    var resolvedUrl  = null;
    var linkSource   = 'fallback-page';

    // 1. GEO URL
    if (geo !== 'unknown' && __linkData.geo && __linkData.geo[geo]) {
      var geoUrl = __linkData.geo[geo];
      if (!isPlaceholder(geoUrl) && isValidUrl(geoUrl)) {
        resolvedUrl = geoUrl;
        linkSource  = 'geo';
      }
    }

    // 2. Default URL
    if (!resolvedUrl && !isPlaceholder(__linkData.default) && isValidUrl(__linkData.default)) {
      resolvedUrl = __linkData.default;
      linkSource  = 'default';
    }

    // 3. Safe internal fallback
    if (!resolvedUrl) {
      resolvedUrl = SITE_BASE + '/exchanges/' + __exchangeSlug + '/';
      linkSource  = 'fallback-page';
    }

    // ── Build SubID and tracked URL ───────────────────────────────────────────
    function buildSubId() {
      var parts = ['cbw', __exchangeSlug, placement];
      if (geo !== 'unknown')    parts.push(geo);
      if (device !== 'unknown') parts.push(device);
      return parts.join('_').replace(/[^a-z0-9_-]/gi, '-');
    }

    function appendTracking(url) {
      if (linkSource === 'fallback-page') return url; // don't append to internal URLs
      try {
        var u = new URL(url);
        u.searchParams.set('subid', buildSubId());
        if (!u.searchParams.has('utm_source'))   u.searchParams.set('utm_source',   'cbw');
        if (!u.searchParams.has('utm_medium'))   u.searchParams.set('utm_medium',   'affiliate');
        if (!u.searchParams.has('utm_campaign')) u.searchParams.set('utm_campaign', __exchangeSlug + '-bonus');
        return u.toString();
      } catch(_) { return url; }
    }

    var finalUrl = appendTracking(resolvedUrl);

    // ── Fire analytics ────────────────────────────────────────────────────────
    var clickEvent = {
      schema_version:  1,
      event:           'cbw_affiliate_click',
      timestamp:       new Date().toISOString(),
      ts:              Date.now(),
      exchange:        __exchangeSlug,
      placement:       placement,
      page_type:       pageType,
      path:            document.referrer ? new URL(document.referrer).pathname : '/',
      geo_code:        geo,
      device_type:     device,
      session_id:      sid,
      ab_variant:      abVariant,
      link_source:     linkSource,
      href:            finalUrl,
      is_go_redirect:  true,
      contextual_rank: ctxRank,
      compare_pair:    comparePair,
    };

    // Internal event log (window.cbw may not exist here — it's set by Analytics.astro on referrer page)
    try {
      if (window.cbw && Array.isArray(window.cbw.events)) window.cbw.events.push(clickEvent);
    } catch(_) {}

    // GTM dataLayer
    try {
      if (window.dataLayer && Array.isArray(window.dataLayer)) {
        window.dataLayer.push(Object.assign({ event: clickEvent.event }, clickEvent));
      }
    } catch(_) {}

    // Plausible
    try {
      if (typeof window.plausible === 'function') {
        window.plausible('cbw_affiliate_click', { props: {
          exchange:        String(clickEvent.exchange),
          placement:       String(clickEvent.placement),
          page_type:       String(clickEvent.page_type),
          geo_code:        String(clickEvent.geo_code),
          device_type:     String(clickEvent.device_type),
          link_source:     String(clickEvent.link_source),
        }});
      }
    } catch(_) {}

    // Custom event (BI listeners)
    try {
      document.dispatchEvent(new CustomEvent('cbw:click', { detail: clickEvent, bubbles: true }));
    } catch(_) {}

    // PostHog
    try {
      if (typeof window.posthog !== 'undefined' && typeof window.posthog.capture === 'function') {
        window.posthog.capture('cbw_affiliate_click', clickEvent);
      }
    } catch(_) {}

    // ─ Dev console ────────────────────────────────────────────────────────────
    if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') {
      console.info('[CBW /go/] Resolved:', { slug: __exchangeSlug, linkSource, finalUrl, geo, device });
    }

    // ── Fallback button: upgrade to the fully resolved GEO/tracked URL ────────
    try {
      var btn = document.getElementById('cbw-continue');
      if (btn) btn.setAttribute('href', finalUrl);
    } catch(_) {}

    // ── Redirect ──────────────────────────────────────────────────────────────
    // Branded screen stays visible for ~1000 ms (owner spec), then this tab
    // navigates to the resolved destination. location.replace() keeps /go/ out
    // of browser history (302 semantics). The referring CBW page stays open in
    // its own tab because CTAs open /go/ with target="_blank".
    setTimeout(function () {
      window.location.replace(finalUrl);
    }, 1000);

  })();
  </script>
</body>
</html>
