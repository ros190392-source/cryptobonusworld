{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cryptobonusworld.com/schemas/geo/claim.schema.json",
  "title": "GEO Claim Object",
  "description": "A publishable factual statement. Nothing reaches a page except through a Claim Object with status verified/verified_with_limits. Spec §6.",
  "type": "object",
  "required": ["claim_id", "country", "exchange", "category", "claim", "status", "confidence", "evidence_ids"],
  "additionalProperties": false,
  "properties": {
    "claim_id": { "type": "string", "pattern": "^[a-z]{2}-[a-z-]+-[a-z0-9-]+-[0-9]{3}$", "description": "e.g. kz-bybit-p2p-kzt-001" },
    "country": { "type": "string" },
    "exchange": { "type": "string", "enum": ["bybit", "mexc", "okx", "bitget", "kucoin", "bingx"] },
    "category": { "type": "string" },
    "claim": { "type": "string" },
    "value": { "type": ["boolean", "string", "number", "null"] },
    "status": { "type": "string", "enum": ["verified", "verified_with_limits", "unknown", "conflicted", "stale", "failed"], "description": "Only verified / verified_with_limits are publishable as confirmed fact." },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "conflict_ids": { "type": "array", "items": { "type": "string" } },
    "first_verified_at": { "type": ["string", "null"] },
    "last_verified_at": { "type": ["string", "null"] },
    "next_check_at": { "type": ["string", "null"], "description": "Derived from config/geo/freshness.json windows" },
    "owner_review_required": { "type": "boolean", "default": false }
  }
}
