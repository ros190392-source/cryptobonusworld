---
import BonusBadge from './BonusBadge.astro';
import KycBadge from './KycBadge.astro';
import CTAButton from './CTAButton.astro';
import ExchangeLogo from './ExchangeLogo.astro';
import TrustVerificationBlock from './TrustVerificationBlock.astro';

import { getCtaLabel, getBonusExpiryNote } from '../utils/affiliateUtils';
import { type PartnerStatus, isLimited } from '../utils/partnerStatus';
import { BONUS_TYPE_DEFS } from '../utils/contentEngine';

interface Props {
  name: string;
  slug: string;
  rating: number;
  pageTitle: string;
  bonusTitle: string;
  bonusAmount: number;
  bonusCurrency: string;
  bonusTypes: string[];
  kycRequired: boolean;
  depositRequired: boolean;
  affiliateUrl: string;
  promoCode: string;
  updatedAt: string;
  countries: string[];
  paymentMethods: string[];
  // Trust row data — optional, progressive enhancement
  licences?: string[];
  founded?: number;
  users?: string;
  // Conversion optimisation
  bonusExpiry?: { days: number; note?: string } | null;
  geoHrefs?: Record<string, string>;
  // Trust verification signals (from exchanges.json)
  verificationStatus?: 'verified' | 'needs-review' | 'outdated' | 'unverified';
  lastVerified?: string | null;
  bonusNote?: string | null;
  bonusSourceUrl?: string | null;
  excludedCountries?: string[] | null;
  bonusDisplayMode?: 'up-to' | 'range' | 'fixed' | 'regional' | 'campaign';
  // Partner relationship tier
  partnerStatus?: PartnerStatus;
  // Hero left-column "how the bonus unlocks" block (structured tiers only)
  bonusTiers?: { type: string; title: string; amount: number; currency: string; condition: string }[];
  bonusRange?: { typicalMin?: number; typicalMax?: number; currency?: string; typicalNote?: string } | null;
  proofShot?: { src: string; capturedAt?: string } | null;
}

const props = Astro.props;
const limited = isLimited({ partner_status: props.partnerStatus });

// Contextual CTA label — highlights most compelling differentiator
const ctaLabel = getCtaLabel({
  name: props.name,
  slug: props.slug,
  kycRequired: props.kycRequired,
  depositRequired: props.depositRequired,
  bonusAmount: props.bonusAmount,
  bonusCurrency: props.bonusCurrency,
  bonusTypes: props.bonusTypes,
  rating: props.rating,
});

// Factual urgency note from real bonusExpiry data (null = don't show)
// Suppressed for limited partners — no bonus to claim
const expiryNote = !limited ? getBonusExpiryNote(props.bonusExpiry) : null;

// Build dynamic trust row from available data
const trustItems: { icon: string; text: string; green?: boolean }[] = [];
if (props.licences && props.licences.length > 0) {
  trustItems.push({ icon: '🏛️', text: `${props.licences[0]} Licensed`, green: true });
} else {
  trustItems.push({ icon: '✓', text: 'Established Exchange', green: true });
}
if (props.users) {
  trustItems.push({ icon: '👥', text: `${props.users} Registered Users`, green: true });
} else {
  trustItems.push({ icon: '✓', text: 'Cold Storage Security', green: true });
}
if (props.founded) {
  const age = new Date().getFullYear() - props.founded;
  trustItems.push({ icon: '📅', text: `Est. ${props.founded} · ${age}+ yrs`, green: true });
} else {
  trustItems.push({ icon: '✓', text: '24/7 Customer Support', green: true });
}

import { getBrandColor } from '../utils/logoConfig';
const brand = getBrandColor(props.slug);

// ── "How the bonus unlocks" left-column block ─────────────────────────────
// Fills the desktop void below the trust chips. Data comes verbatim from
// fact-checked exchanges.json fields — no synthetic claims here.
const unlockSteps = !limited && props.bonusTiers?.length ? props.bonusTiers.slice(0, 3) : [];
const campaignMode = props.bonusDisplayMode === 'campaign';
const fmtUnlockAmount = (a: number) =>
  a >= 1000 ? `${(a / 1000).toFixed(1).replace(/\.0$/, '')}K` : String(a);
const typicalLine =
  props.bonusRange?.typicalNote ??
  (props.bonusRange?.typicalMin && props.bonusRange?.typicalMax
    ? `Most users earn ${props.bonusRange.typicalMin}–${props.bonusRange.typicalMax} ${props.bonusRange.currency ?? props.bonusCurrency}`
    : null);
const proofDate = props.proofShot?.capturedAt
  ? new Date(props.proofShot.capturedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : null;

const ratingFull = Math.floor(props.rating / 2);
const ratingHalf = (props.rating / 2) % 1 >= 0.5;

const quickFacts = [
  {
    icon: '🌍',
    val: `${props.countries.length} region${props.countries.length !== 1 ? 's' : ''}`,
    sub: 'Available in',
  },
  {
    icon: props.kycRequired ? '🪪' : '✓',
    val: props.kycRequired ? 'KYC Required' : 'No KYC',
    sub: 'Identity',
    highlight: !props.kycRequired,
  },
  {
    icon: props.depositRequired ? '💰' : '✓',
    val: props.depositRequired ? 'Deposit Needed' : 'No Deposit',
    sub: 'Funding',
    highlight: !props.depositRequired,
  },
  {
    icon: '💳',
    val: props.paymentMethods.slice(0, 2).map(m => m.toUpperCase()).join(' · '),
    sub: 'Payment',
  },
];
---

<div class="exhero" style={`--brand: ${brand};`}>
  <div class="exhero-glow" aria-hidden="true"></div>

  <div class="exhero-inner">
    <h1 class="exhero-page-title">{props.pageTitle}</h1>

    <div class="exhero-grid">
      <!-- Left: identity -->
      <div class="exhero-left">
        <div class="exhero-identity">
          <ExchangeLogo slug={props.slug} name={props.name} size={120} variant="square" lazy={false} class="exhero-logomark" />
          <div class="exhero-id-text">
            <div class="exhero-name">{props.name}</div>
            <div class="exhero-rating-row">
              <div class="exhero-stars" aria-label={`Rating ${props.rating} out of 10`}>
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg width="13" height="13" viewBox="0 0 24 24"
                    fill={i < ratingFull ? 'currentColor' : 'none'}
                    stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                ))}
              </div>
              <span class="exhero-rating-num">{props.rating}/10</span>
            </div>
            <div class="exhero-badges">
              {props.bonusTypes.map(t => <BonusBadge type={t} />)}
              <KycBadge required={props.kycRequired} />
            </div>
          </div>
        </div>

        <div class="exhero-trust-row">
          {trustItems.map(item => (
            <span class="exhero-trust-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {item.text}
            </span>
          ))}
        </div>

        {unlockSteps.length > 0 && (
          <div class="exhero-unlock">
            <div class="exhero-unlock-eyebrow">How the bonus unlocks</div>
            <ol class="exhero-unlock-steps" aria-label="Bonus unlock steps">
              {unlockSteps.map(step => (
                <li class="exhero-unlock-step">
                  <span class="exhero-unlock-icon" aria-hidden="true">{BONUS_TYPE_DEFS[step.type]?.icon ?? '🎁'}</span>
                  <span class="exhero-unlock-body">
                    <span class="exhero-unlock-head">
                      <span class="exhero-unlock-title">{step.title}</span>
                      {!campaignMode && step.amount > 0 && (
                        <span class="exhero-unlock-amount">{fmtUnlockAmount(step.amount)} {step.currency}</span>
                      )}
                    </span>
                    <span class="exhero-unlock-cond">{step.condition}</span>
                  </span>
                </li>
              ))}
            </ol>
            {campaignMode ? (
              <p class="exhero-unlock-typical">Verify current campaign terms on the official site</p>
            ) : typicalLine && (
              <p class="exhero-unlock-typical">{typicalLine} · <a href="#bonus-breakdown">full breakdown ↓</a></p>
            )}
            {props.proofShot && (
              <a href="#bonus-proof" class="exhero-unlock-proof">
                <img
                  src={props.proofShot.src}
                  width="88" height="50"
                  loading="lazy" decoding="async"
                  alt={`${props.name} sign-up page showing the live new-user offer${proofDate ? ` — captured ${proofDate}` : ''}`}
                />
                <span class="exhero-unlock-proof-text">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Offer verified on live {props.name} sign-up page{proofDate && ` · ${proofDate}`}
                </span>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Right: bonus display + CTA -->
      <div class="exhero-right">
        {limited ? (
          /* ── Limited partner: neutral info block, no bonus CTA ── */
          <div class="exhero-bonus-display exhero-bonus-display--neutral">
            <div class="exhero-bonus-eyebrow">Exchange Info</div>
            <div class="exhero-bonus-amount exhero-bonus-amount--neutral">
              {props.name}
            </div>
            <div class="exhero-bonus-sub">Visit the official site for current offers</div>
          </div>
        ) : (
          /* ── Full partner: standard bonus display ── */
          <div class="exhero-bonus-display">
            <div class="exhero-bonus-eyebrow">
              {props.bonusDisplayMode === 'fixed'
                ? 'New User Reward'
                : props.bonusDisplayMode === 'campaign'
                  ? 'Current Campaign'
                  : 'Welcome Bonus'}
            </div>
            {props.bonusDisplayMode === 'campaign' ? (
              <div class="exhero-bonus-campaign">
                <span class="exhero-campaign-label">Active Offer</span>
                <span class="exhero-campaign-hint">Verify on official site</span>
              </div>
            ) : (
              <div class="exhero-bonus-amount">
                {props.bonusDisplayMode !== 'fixed' && <span class="exhero-bonus-prefix">Up to</span>}
                {props.bonusAmount.toLocaleString()} {props.bonusCurrency}
              </div>
            )}
            <div class="exhero-bonus-sub">{props.bonusTitle}</div>
          </div>
        )}

        {!limited && props.promoCode && (
          <div class="exhero-promo">
            <span class="exhero-promo-label">Promo code</span>
            <button
              class="exhero-promo-code"
              data-code={props.promoCode}
              data-exchange={props.slug}
              data-track="bonus_copy"
              aria-label={`Copy promo code ${props.promoCode}`}
            >
              <span class="exhero-promo-val">{props.promoCode}</span>
              <span class="exhero-promo-copy">copy</span>
            </button>
          </div>
        )}

        <div class="exhero-ctas" id="exhero-ctas">
          {limited ? (
            /* Neutral visit button — no tracking redirect, no bonus framing */
            <CTAButton
              href={props.affiliateUrl}
              label={`Visit ${props.name} →`}
              variant="secondary"
              size="lg"
              fullWidth
              rel="noopener noreferrer nofollow"
              exchange={props.name}
              trackPlacement="hero"
            />
          ) : (
            <CTAButton
              href={props.affiliateUrl}
              label={ctaLabel}
              size="lg"
              fullWidth
              trackPlacement="hero"
              trackBonus={props.bonusAmount}
              exchange={props.name}
              geoHrefs={props.geoHrefs}
            />
          )}
          {expiryNote && (
            <p class="exhero-expiry-note">{expiryNote}</p>
          )}
          <a href="/bonuses/" class="exhero-compare-link">↗ Compare all bonuses</a>
        </div>

        <TrustVerificationBlock
          verificationStatus={props.verificationStatus ?? (props as any).verificationStatus}
          verifiedAt={props.lastVerified ?? props.updatedAt}
          offerLastChecked={props.lastVerified ?? props.updatedAt}
          termsUrl={props.bonusSourceUrl ?? undefined}
          bonusNote={props.bonusNote ?? null}
          regionRestrictions={props.excludedCountries ?? null}
          compact={true}
        />
        <p class="exhero-disc-line"><a href="/affiliate-disclosure/" class="exhero-disc-link">Affiliate disclosure</a></p>
      </div>
    </div>
  </div>

  <!-- Quick facts bar -->
  <div class="exhero-facts">
    {quickFacts.map(f => (
      <div class:list={['exhero-fact', f.highlight && 'exhero-fact--highlight']}>
        <span class="exhero-fact-icon">{f.icon}</span>
        <div>
          <div class="exhero-fact-val">{f.val}</div>
          <div class="exhero-fact-sub">{f.sub}</div>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- Mobile sticky CTA bar — hidden by default, shown via IntersectionObserver -->
<div class="exhero-sticky" id="exhero-sticky" aria-hidden="true">
  <ExchangeLogo slug={props.slug} name={props.name} size={36} variant="square" class="exhero-sticky-logo" />
  <div class="exhero-sticky-info">
    <span class="exhero-sticky-name">{props.name}</span>
    <span class="exhero-sticky-bonus">Up to {props.bonusAmount.toLocaleString('en-US')} {props.bonusCurrency}</span>
  </div>
  <CTAButton
    href={props.affiliateUrl}
    label="Claim Bonus"
    exchange={props.name}
    size="md"
    trackPlacement="sticky"
    trackBonus={props.bonusAmount}
    geoHrefs={props.geoHrefs}
  />
</div>

<script>
  // ── Promo code copy ─────────────────────────────────────────────────────
  import { analytics } from '../lib/analytics';

  document.querySelectorAll<HTMLButtonElement>('[data-track="bonus_copy"].exhero-promo-code').forEach(btn => {
    btn.addEventListener('click', async () => {
      const code     = btn.dataset.code     ?? '';
      const exchange = btn.dataset.exchange ?? '';
      await navigator.clipboard.writeText(code).catch(() => {});
      const val  = btn.querySelector('.exhero-promo-val');
      const copy = btn.querySelector('.exhero-promo-copy');
      if (val)  val.textContent  = '✓ Copied!';
      if (copy) copy.textContent = '';
      setTimeout(() => {
        if (val)  val.textContent  = code;
        if (copy) copy.textContent = 'copy';
      }, 2000);
      // Track: bonus_copy goal
      analytics.trackBonusCopy({ exchange, code });
    });
  });

  // ── Sticky CTA visibility (IntersectionObserver) ─────────────────────
  // Show sticky only after the in-hero CTA block scrolls out of view.
  // This prevents doubling the CTA before the user even starts reading.
  const heroCtas = document.getElementById('exhero-ctas');
  const stickyBar = document.getElementById('exhero-sticky');

  if (heroCtas && stickyBar) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        // When hero CTAs leave viewport → show sticky
        const visible = !entry.isIntersecting;
        stickyBar.classList.toggle('is-visible', visible);
        stickyBar.setAttribute('aria-hidden', String(!visible));
      },
      {
        threshold: 0,
        // Trigger slightly before hero exits viewport for smoother UX
        rootMargin: '0px 0px -48px 0px',
      }
    );
    observer.observe(heroCtas);
  }
</script>

<style>
  .exhero {
    position: relative;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    margin: 1.25rem 0 2rem;
  }

  .exhero-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 440px;
    height: 440px;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--brand) 18%, transparent) 0%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  .exhero-inner {
    position: relative;
    z-index: 1;
    padding: 2rem 2rem 1.5rem;
  }

  .exhero-page-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    line-height: 1.3;
    max-width: 700px;
  }

  .exhero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  /* Left */
  .exhero-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .exhero-identity {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  /* ExchangeLogo component within hero — brand-tinted border + glow */
  :global(.exhero-logomark) {
    flex-shrink: 0;
    border-radius: 16px !important;
    border-color: color-mix(in srgb, var(--brand) 40%, transparent) !important;
    background: color-mix(in srgb, var(--brand) 12%, var(--surface-overlay, #111)) !important;
    box-shadow: 0 4px 24px color-mix(in srgb, var(--brand) 22%, transparent),
                0 1px 6px rgba(0,0,0,0.4) !important;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  :global(.exhero-logomark:hover) {
    box-shadow: 0 6px 32px color-mix(in srgb, var(--brand) 32%, transparent),
                0 2px 8px rgba(0,0,0,0.4) !important;
  }

  .exhero-id-text { flex: 1; }

  .exhero-name {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-text-primary);
    margin-bottom: 0.3rem;
    line-height: 1.1;
  }

  .exhero-rating-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.625rem;
  }

  .exhero-stars {
    display: flex;
    gap: 1px;
    color: var(--color-accent);
  }

  .exhero-rating-num {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .exhero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .exhero-trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .exhero-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.18);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  /* "How the bonus unlocks" — desktop-only filler for the left-column void */
  .exhero-unlock {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .exhero-unlock-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .exhero-unlock-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .exhero-unlock-step {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    min-width: 0;
  }

  .exhero-unlock-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--brand) 10%, var(--color-bg-tertiary));
    border: 1px solid color-mix(in srgb, var(--brand) 25%, var(--color-border));
  }

  .exhero-unlock-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
    flex: 1;
  }

  .exhero-unlock-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    min-width: 0;
  }

  .exhero-unlock-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .exhero-unlock-amount {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--color-accent);
  }

  .exhero-unlock-cond {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .exhero-unlock-typical {
    margin: 0;
    font-size: 0.72rem;
    font-style: italic;
    color: var(--color-text-muted);
  }
  .exhero-unlock-typical a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }
  .exhero-unlock-typical a:hover { color: var(--color-accent); }

  .exhero-unlock-proof {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    min-width: 0;
  }

  .exhero-unlock-proof img {
    width: 88px;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top center;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .exhero-unlock-proof-text {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #4ade80;
    line-height: 1.35;
  }
  .exhero-unlock-proof-text svg { flex-shrink: 0; }
  .exhero-unlock-proof:hover .exhero-unlock-proof-text {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Right */
  .exhero-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .exhero-bonus-display {
    padding: 1.25rem;
    background: color-mix(in srgb, var(--brand) 5%, var(--color-bg-tertiary));
    border: 1px solid color-mix(in srgb, var(--brand) 20%, var(--color-border));
    border-radius: 14px;
  }

  .exhero-bonus-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .exhero-bonus-amount {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.375rem;
    text-shadow: 0 0 28px rgba(245, 197, 66, 0.28);
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .exhero-bonus-prefix {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: none;
    align-self: flex-end;
    padding-bottom: 0.15em;
  }

  .exhero-bonus-sub {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .exhero-bonus-campaign {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.5rem 0;
  }
  .exhero-campaign-label {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }
  .exhero-campaign-hint {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .exhero-promo {
    display: flex;
