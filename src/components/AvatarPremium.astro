---
/**
 * AvatarPremium — Premium circular profile avatar.
 *
 * Designed for reviewer/editor profile pages and any place that needs a
 * high-quality, dark-theme-native portrait display: circular crop,
 * multi-layer gold border, soft glow shadow, retina-ready.
 *
 * Usage:
 *   <AvatarPremium src="/avatars/alexandr-shadurskyi-lg.webp" alt="Oleksandr Shadurskyi" />
 *   <AvatarPremium src="/avatars/..." alt="..." size={200} objectPosition="center 15%" />
 *   <AvatarPremium src="/avatars/..." alt="..." href="/reviewers/alexandr-shadurskyi/" />
 *
 * Sizes (px):
 *   desktop default = 240   |  compact = 120   |  small = 72
 * Responsive: scales to 160px on ≤480px.
 */

interface Props {
  src: string;
  alt: string;
  /** Diameter in px (desktop). Default 240. */
  size?: number;
  /** object-position value. Default "center 15%" — keeps face high. */
  objectPosition?: string;
  /** If provided, wraps the avatar in an <a> link. */
  href?: string;
  /** Reviewer name — shown on hover as tooltip. */
  name?: string;
  /** Small label beneath avatar (e.g. "Editor-in-Chief") */
  title?: string;
  /** Show the name + title caption below the circle. Default true when title set. */
  showCaption?: boolean;
  /** Extra CSS class on the root element. */
  class?: string;
}

const {
  src,
  alt,
  size           = 240,
  objectPosition = 'center 15%',
  href,
  name,
  title,
  showCaption    = !!title,
  class: cls     = '',
} = Astro.props;

const Tag    = href ? 'a' : 'div';
const tagProps = href
  ? { href, 'aria-label': name ?? alt }
  : {};

// Scale for mobile: cap at 160 if desktop size > 160
const mobileSize = Math.min(size, 160);
---

<div
  class={`ap-wrap${cls ? ` ${cls}` : ''}`}
  style={`--ap-size:${size}px; --ap-size-mobile:${mobileSize}px;`}
>
  <Tag class="ap-ring" {...tagProps} title={name ?? undefined}>
    <span class="ap-border-outer" aria-hidden="true"></span>
    <span class="ap-border-inner" aria-hidden="true"></span>
    <img
      src={src}
      alt={alt}
      width={size}
      height={size}
      class="ap-img"
      style={`object-position: ${objectPosition};`}
      loading="eager"
      decoding="async"
    />
    {href && <span class="ap-hover-overlay" aria-hidden="true"></span>}
  </Tag>

  {showCaption && (name || title) && (
    <div class="ap-caption">
      {name && <span class="ap-caption-name">{name}</span>}
      {title && <span class="ap-caption-title">{title}</span>}
    </div>
  )}
</div>

<style>
  /* ── Root wrapper ── */
  .ap-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  /* ── Ring container — holds decorative borders + image ── */
  .ap-ring {
    position: relative;
    display: block;
    width: var(--ap-size);
    height: var(--ap-size);
    border-radius: 50%;
    cursor: default;
    text-decoration: none;

    /* Outer ambient glow — dark bg friendly */
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.55))
            drop-shadow(0 0 18px rgba(185, 151, 74, 0.22));

    transition: filter 0.3s ease, transform 0.3s ease;
    will-change: transform, filter;
  }

  /* Link variant — pointer + hover lift */
  a.ap-ring {
    cursor: pointer;
  }
  a.ap-ring:hover {
    transform: translateY(-3px) scale(1.015);
    filter: drop-shadow(0 12px 40px rgba(0, 0, 0, 0.65))
            drop-shadow(0 0 28px rgba(185, 151, 74, 0.4));
  }

  /* ── Outer border ring — gold gradient ── */
  .ap-border-outer {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    /* Conic gradient gives the "brushed gold" ring effect */
    background: conic-gradient(
      from 120deg,
      #6b4f1a 0deg,
      #c9a64a 60deg,
      #f0d080 120deg,
      #b7974a 180deg,
      #e8c96a 240deg,
      #8a6828 300deg,
      #6b4f1a 360deg
    );
    padding: 3px;          /* ring thickness */
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 2;
  }

  /* ── Inner border — subtle pale ring for depth ── */
  .ap-border-inner {
    position: absolute;
    inset: 4px;            /* sits just inside the outer ring */
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.06);
    pointer-events: none;
    z-index: 2;
  }

  /* ── Image ── */
  .ap-img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    /* object-position set inline from prop */
    background: var(--color-bg-secondary, #1a1a1a);
    position: relative;
    z-index: 1;
  }

  /* ── Hover overlay (link variant only) ── */
  .ap-hover-overlay {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(185,151,74,0.12) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 3;
  }
  a.ap-ring:hover .ap-hover-overlay {
    opacity: 1;
  }

  /* ── Caption ── */
  .ap-caption {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-align: center;
  }
  .ap-caption-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-primary, #f0f0f0);
    letter-spacing: -0.01em;
  }
  .ap-caption-title {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-accent, #c9a64a);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .ap-ring {
      width: var(--ap-size-mobile) !important;
      height: var(--ap-size-mobile) !important;
    }
  }
</style>
